---
// src/components/cart/CartDrawer.astro
import Icons from "../shared/Icons.astro";
import SelectElite from "../shared/SelectElite.astro";
---
<!-- Bloque 1 - Estructura Base Elite -->
<aside id="cart-drawer" class="drawer-panel" aria-labelledby="cart-title">
    
    <!-- Piso 1: Header Fijo -->
    <header class="p-6 border-b border-slate-100 flex items-center justify-between bg-white shrink-0">
        <div class="flex items-center gap-3">
            <div class="text-brand">
                <Icons type="shopping-cart" class="w-7 h-7" strokeWidth={2} />
            </div>
            <div>
                <h2 id="cart-title" class="text-[17px] font-black text-slate-900 tracking-tight">Tu pedido</h2>
                <p class="text-[10px] text-slate-500 font-bold leading-none tracking-wider">Sistema de pedidos WhatsApp</p>
            </div>
        </div>
        
        <div class="flex items-center gap-2">
            <button id="clear-cart" class="text-[10px] font-black text-slate-400 hover:text-red-500 tracking-widest px-2 py-1 transition-colors">
                Vaciar
            </button>
            <button id="close-cart" class="w-8 h-8 flex items-center justify-center rounded-xl hover:bg-slate-100 text-slate-400 hover:text-slate-900 transition-all">
                <Icons type="x" class="w-5 h-5" strokeWidth={2.5} />
            </button>
        </div>
    </header>

     <!-- Piso 2: Contenido Scrolleable (Items + Formulario) -->
    <div class="flex-1 overflow-y-auto custom-scrollbar p-6 space-y-8">
        <!-- Lista de Productos -->
        <div id="cart-items-container">
             <div id="cart-items-list" class="space-y-4"></div>
             
             <div id="cart-empty-state" class="text-center py-20 hidden">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-200">
                    <Icons type="shopping-cart" class="w-8 h-8" />
                </div>
                <h3 class="text-slate-900 font-bold">Tu carrito está vacío</h3>
                <p class="text-slate-400 text-xs mt-1">Explora el catálogo para añadir productos.</p>
                <button onclick="document.dispatchEvent(new CustomEvent('toggleCart'))" class="mt-8 px-8 py-3 bg-slate-900 text-white text-[11px] font-black tracking-widest rounded-xl hover:bg-slate-800 transition-all active:scale-95 shadow-sm">
                    Explorar catálogo
                </button>
             </div>
        </div>

        <!-- Formulario de Pedido -->
        <div id="checkout-form-container" class="hidden space-y-8 pt-8 border-t border-slate-100">
            <div class="space-y-6">
                <h3 class="text-[13px] font-black text-slate-900 tracking-widest flex items-center gap-2.5">
                    <div class="w-6 h-6 bg-brand/10 rounded-lg flex items-center justify-center">
                        <Icons type="truck" class="w-3.5 h-3.5 text-brand" strokeWidth={3} />
                    </div>
                    Datos de entrega
                </h3>
                
                <div class="grid grid-cols-1 gap-5">
                    <div class="space-y-2">
                        <label for="bill-name" class="cart-label">Nombre completo *</label>
                        <input type="text" id="bill-name" class="cart-input" placeholder="Ej: Alejandro Ruiz" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-2">
                            <label for="bill-id" class="cart-label">Cédula o NIT *</label>
                            <input type="text" id="bill-id" class="cart-input" placeholder="Ej: 1.020.300..." />
                        </div>
                        <div class="space-y-2">
                            <label for="bill-whatsapp" class="cart-label">WhatsApp *</label>
                            <input type="tel" id="bill-whatsapp" class="cart-input" placeholder="Ej: 300 123 4567" />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label for="bill-address" class="cart-label">Dirección (Opcional)</label>
                        <input type="text" id="bill-address" class="cart-input" placeholder="Barrio, calle y número" />
                    </div>
                    <div class="space-y-3">
                        <label class="cart-label">Método de pago preferido</label>
                        <SelectElite 
                            id="bill-payment" 
                            placeholder="Selecciona un método..." 
                            options={[
                                { value: "transferencia", label: "Transferencia Bancaria" },
                                { value: "nequi", label: "Nequi / Daviplata" },
                                { value: "efectivo", label: "Efectivo contra entrega" }
                            ]} 
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Piso 3: Footer Fijo (Resumen y Botones) -->
    <footer class="p-6 bg-slate-50/50 border-t border-slate-100 shrink-0 space-y-6">
        <div class="space-y-3 px-2">
            <div class="flex justify-between items-center text-xs">
                <span class="text-slate-500 font-bold">Subtotal</span>
                <span id="cart-subtotal" class="text-slate-900 font-black">$0</span>
            </div>
            <div class="flex justify-between items-center text-xs">
                <span class="text-slate-400 font-bold">Descuento</span>
                <span class="text-brand font-black">-$0</span>
            </div>
            <div class="pt-3 border-t border-slate-200 flex justify-between items-center">
                <span class="text-[13px] font-black text-slate-900 tracking-widest">Total pedido</span>
                <span id="cart-total" class="text-2xl font-black text-slate-900 tracking-tighter">$0</span>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-3">
            <button id="btn-order-medico" class="btn-whatsapp-elite group/btn" data-variant="medico">
                <Icons type="whatsapp" class="w-5 h-5 group-hover/btn:scale-110 transition-transform" />
                <span>Pedido Médico WhatsApp</span>
            </button>
            <button id="btn-order-farmacia" class="btn-whatsapp-elite group/btn" data-variant="farmacia">
                <Icons type="whatsapp" class="w-5 h-5 group-hover/btn:scale-110 transition-transform" />
                <span>Pedido Farmacia WhatsApp</span>
            </button>
        </div>
    </footer>

</aside>

<!-- Fondo Oscuro Overlay -->
<div id="cart-overlay" class="drawer-overlay"></div>

<script>
    import { encryptData, decryptData } from '../../utils/security';
    import { getDistributors } from '../../data/api';

    // --- NAMESPACE PROTEGIDO ELITE ---
    window.__MH_CART__ = window.__MH_CART__ || {
        items: [],
        initialized: false,
        contacts: { medico: '', farmacia: '' }
    };

    const CART_STORAGE_KEY = 'mh_cart_data';

    const saveCartToStorage = () => {
        try {
            const encrypted = encryptData(window.__MH_CART__.items);
            localStorage.setItem(CART_STORAGE_KEY, encrypted);
        } catch (e) {
            console.error('[Elite Cart] Error persistiendo datos.');
        }
    };

    if (!window.__MH_CART__.initialized) {
        const loadInitialCart = () => {
            try {
                const saved = localStorage.getItem(CART_STORAGE_KEY) || localStorage.getItem('cart');
                if (saved) {
                    window.__MH_CART__.items = decryptData(saved) || JSON.parse(saved) || [];
                    if (saved.startsWith('[')) saveCartToStorage(); 
                }
            } catch (e) {
                window.__MH_CART__.items = [];
            }
        };

        loadInitialCart();

        document.addEventListener('addToCart', ((e: CustomEvent) => {
            const { name, price } = e.detail;
            const items = window.__MH_CART__.items;
            const existing = items.find((i: any) => i.name === name);
            
            if (existing) {
                existing.quantity++;
            } else {
                items.push({ name, price: parseInt(price), quantity: 1, hasNote: false, note: '' });
            }
            
            saveCartToStorage();
            document.dispatchEvent(new CustomEvent('renderCartInternal'));
            document.body.classList.add('cart-open');
        }) as EventListener);

        document.addEventListener('toggleCart', () => {
            document.body.classList.toggle('cart-open');
        });

        window.__MH_CART__.initialized = true;
    }

    // --- LÓGICA DE RENDERIZADO Y NEGOCIO ---
    document.addEventListener('astro:page-load', async () => {
        const cartItemsList = document.getElementById('cart-items-list');
        const cartEmptyState = document.getElementById('cart-empty-state');
        const cartTotalEl = document.getElementById('cart-total');
        const cartSubtotalEl = document.getElementById('cart-subtotal');

        // Cargar números de contacto dinámicamente
        try {
            const distributors = await getDistributors();
            const mainBranch = distributors.find(d => (d.nombre || '').toLowerCase().includes('sede principal')) || distributors[0];
            if (mainBranch) {
                window.__MH_CART__.contacts = {
                    medico: mainBranch.whatsapp || '',
                    farmacia: mainBranch.whatsapp_2 || mainBranch.whatsapp || ''
                };
            }
        } catch (e) {
            console.warn('[Elite Cart] Error cargando contactos dinámicos.');
        }

        const ICONS = {
            trash: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>`,
            minus: `<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg>`,
            plus: `<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>`,
            note: `<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15.5 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5L15.5 3z"/><polyline points="15 3 15 9 21 9"/></svg>`
        };

        const renderCart = () => {
            const items = window.__MH_CART__.items;
            if (!cartItemsList || !cartEmptyState) return;

            if (items.length === 0) {
                cartEmptyState.style.display = 'block';
                cartItemsList.innerHTML = '';
                document.getElementById('checkout-form-container')?.classList.add('hidden');
            } else {
                cartEmptyState.style.display = 'none';
                document.getElementById('checkout-form-container')?.classList.remove('hidden');
                cartItemsList.innerHTML = items.map((item: any, index: number) => `
                    <div class="cart-item-card group animate-fade-in" style="animation-delay: ${index * 0.05}s">
                        <button class="absolute top-4 right-4 text-slate-600 hover:text-red-500 transition-all hover:rotate-90 btn-remove-item" data-index="${index}" title="Eliminar preparación">
                            ${ICONS.trash}
                        </button>
                        <div class="pr-6">
                            <h4 class="text-[13px] font-bold text-slate-800 leading-tight">${item.name}</h4>
                            <p class="text-[11px] text-slate-500 mt-1 font-medium">$${item.price.toLocaleString()}</p>
                        </div>
                        <div class="flex items-center justify-between mt-4">
                            <div class="flex items-center gap-1">
                                <button class="w-7 h-7 flex items-center justify-center bg-brand-vibrant hover:bg-brand text-white rounded-md transition-all active:scale-90 btn-qty" data-index="${index}" data-action="minus">
                                    ${ICONS.minus}
                                </button>
                                <span class="text-sm font-bold text-slate-900 min-w-[1.5rem] text-center tabular-nums">${item.quantity}</span>
                                <button class="w-7 h-7 flex items-center justify-center bg-brand-vibrant hover:bg-brand text-white rounded-md transition-all active:scale-90 btn-qty" data-index="${index}" data-action="plus">
                                    ${ICONS.plus}
                                </button>
                            </div>
                            <span class="text-sm font-black text-slate-900">$${(item.price * item.quantity).toLocaleString()}</span>
                        </div>

                        <div class="pt-3 mt-3 border-t border-dashed border-slate-100">
                            <button class="flex items-center gap-2 text-[10px] font-black tracking-wider text-slate-400 ${item.hasNote ? 'hover:text-red-500' : 'hover:text-brand'} transition-colors btn-add-note" data-index="${index}">
                                ${item.hasNote ? ICONS.minus : ICONS.plus}
                                ${item.hasNote ? 'Quitar nota' : 'Añadir especificación'}
                            </button>
                            <textarea class="mt-3 w-full text-[12px] text-slate-700 bg-white border border-slate-200 rounded-xl px-4 py-3 resize-none focus:outline-none focus:ring-2 focus:ring-brand focus:ring-opacity-10 focus:border-brand transition-all cart-item-note ${item.hasNote ? 'block' : 'hidden'}" 
                                data-index="${index}" rows="2" placeholder="Ej: Sin alcohol, presentación 30ml...">${item.note}</textarea>
                        </div>
                    </div>
                `).join('');

                // Listeners (Quantity, Remove, Notes)
                cartItemsList.querySelectorAll('.btn-qty').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const b = e.currentTarget as HTMLElement;
                        const idx = parseInt(b.dataset.index!);
                        if (b.dataset.action === 'plus') items[idx].quantity++;
                        else if (items[idx].quantity > 1) items[idx].quantity--;
                        else items.splice(idx, 1);
                        saveCartToStorage();
                        renderCart();
                    });
                });

                cartItemsList.querySelectorAll('.btn-remove-item').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const b = e.currentTarget as HTMLElement;
                        items.splice(parseInt(b.dataset.index!), 1);
                        saveCartToStorage();
                        renderCart();
                    });
                });

                cartItemsList.querySelectorAll('.btn-add-note').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const b = e.currentTarget as HTMLElement;
                        const idx = parseInt(b.dataset.index!);
                        items[idx].hasNote = !items[idx].hasNote;
                        if (!items[idx].hasNote) items[idx].note = '';
                        saveCartToStorage();
                        renderCart();
                    });
                });

                cartItemsList.querySelectorAll('.cart-item-note').forEach(textarea => {
                    textarea.addEventListener('input', (e) => {
                        const t = e.target as HTMLTextAreaElement;
                        items[parseInt(t.dataset.index!)].note = t.value;
                        saveCartToStorage();
                    });
                });
            }

            const total = items.reduce((acc: number, i: any) => acc + (i.price * i.quantity), 0);
            if (cartSubtotalEl) cartSubtotalEl.innerText = `$${total.toLocaleString()}`;
            if (cartTotalEl) cartTotalEl.innerText = `$${total.toLocaleString()}`;
            
            document.dispatchEvent(new CustomEvent('cartUpdated', { 
                detail: { totalItems: items.reduce((acc: number, i: any) => acc + i.quantity, 0) } 
            }));
        };

        // --- MOTOR DE ENVÍO WHATSAPP ---
        const handleSendOrder = (variant: 'medico' | 'farmacia') => {
            const items = window.__MH_CART__.items;
            const name = (document.getElementById('bill-name') as HTMLInputElement).value.trim();
            const id = (document.getElementById('bill-id') as HTMLInputElement).value.trim();
            const whatsapp = (document.getElementById('bill-whatsapp') as HTMLInputElement).value.trim();
            const address = (document.getElementById('bill-address') as HTMLInputElement).value.trim();
            const payment = (document.getElementById('bill-payment') as HTMLInputElement)?.value || 'No especificado';

            if (!name || !id || !whatsapp) {
                alert('Por favor completa los campos obligatorios (*)');
                return;
            }

            const total = items.reduce((acc: number, i: any) => acc + (i.price * i.quantity), 0);
            const targetPhone = window.__MH_CART__.contacts[variant];

            let message = `*PEDIDO MUNDO HOMEOPÁTICO*\n`;
            message += `--------------------------------\n`;
            message += `*DATOS DEL CLIENTE:*\n`;
            message += `👤 Nombre: ${name}\n`;
            message += `🆔 Cédula/NIT: ${id}\n`;
            message += `📱 WhatsApp: ${whatsapp}\n`;
            if (address) message += `🏠 Dirección: ${address}\n`;
            message += `💳 Pago: ${payment}\n\n`;

            message += `*PRODUCTOS:*\n`;
            items.forEach((item: any) => {
                message += `- ${item.name} x${item.quantity} ($${(item.price * item.quantity).toLocaleString()})\n`;
                if (item.hasNote && item.note) message += `  📝 Nota: ${item.note}\n`;
            });

            message += `\n*RESUMEN:* \n`;
            message += `Total a pagar: *$${total.toLocaleString()}*\n`;
            message += `--------------------------------`;

            const encodedMessage = encodeURIComponent(message);
            window.open(`https://wa.me/${targetPhone}?text=${encodedMessage}`, '_blank');
        };

        document.getElementById('btn-order-medico')?.addEventListener('click', () => handleSendOrder('medico'));
        document.getElementById('btn-order-farmacia')?.addEventListener('click', () => handleSendOrder('farmacia'));

        // Eventos UI
        document.getElementById('close-cart')?.addEventListener('click', () => document.body.classList.remove('cart-open'));
        document.getElementById('cart-overlay')?.addEventListener('click', () => document.body.classList.remove('cart-open'));
        document.getElementById('clear-cart')?.addEventListener('click', () => {
            if (confirm('¿Vaciar pedido?')) {
                window.__MH_CART__.items = [];
                saveCartToStorage();
                renderCart();
            }
        });

        document.removeEventListener('renderCartInternal', renderCart);
        document.addEventListener('renderCartInternal', renderCart);
        renderCart();
    });
</script>

<style is:global>
    /* --- ESTRUCTURA DEL DRAWER --- */
    .drawer-panel {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        width: 100%;
        max-width: 450px;
        background: white;
        z-index: 1000;
        transform: translateX(100%);
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        box-shadow: -10px 0 50px rgba(0, 0, 0, 0.1);
    }

    body.cart-open {
        overflow: hidden;
    }

    body.cart-open .drawer-panel {
        transform: translateX(0);
    }

    body.cart-open .drawer-overlay {
        opacity: 1;
        visibility: visible;
    }

    .drawer-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(8px);
        opacity: 0;
        visibility: hidden;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 900;
    }

    /* --- COMPONENTES ELITE --- */
    .cart-item-card {
        @apply relative bg-white border border-slate-100 p-5 rounded-2xl shadow-sm hover:shadow-md transition-all duration-300;
    }

    .cart-label {
        @apply text-[10px] font-black text-slate-400 tracking-widest block ml-1;
    }

    .cart-input {
        @apply w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-brand focus:ring-opacity-10 focus:border-brand transition-all font-medium;
    }

    .btn-whatsapp-elite {
        @apply w-full flex items-center justify-center gap-3 py-4 rounded-2xl font-bold text-sm transition-all active:scale-[0.98] shadow-sm hover:shadow-lg;
    }

    .btn-whatsapp-elite[data-variant="medico"] {
        @apply bg-[#25D366] text-white hover:bg-[#20bd5a];
    }

    .btn-whatsapp-elite[data-variant="farmacia"] {
        @apply bg-slate-900 text-white hover:bg-slate-800;
    }

    /* --- UTILIDADES Y ANIMACIONES --- */
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        @apply bg-slate-200 rounded-full hover:bg-slate-300 transition-colors;
    }

    @keyframes fadeInSlide {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .animate-fade-in {
        animation: fadeInSlide 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
</style>
