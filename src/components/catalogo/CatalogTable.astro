---
// src/components/catalogo/CatalogTable.astro
import Icons from "../shared/Icons.astro";
import ProductRowElite from "./ProductRowElite.astro";

interface Product {
    name: string;
    badges: { label: string; variant?: any }[];
    farmaciaPrice: string;
    publicoPrice: string;
    cartData?: { name: string; price: string };
}

interface Props {
    id: string;
    title: string;
    subtitle?: string;
    breadcrumb: string[];
    products: Product[];
}

const { id, title, subtitle, breadcrumb, products } = Astro.props;
---

<section id={id} class="scroll-mt-16">
    <!-- Encabezado de la Sección -->
    <header class="sticky top-0 md:static z-30 bg-surface-muted -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col auto-animate-header">
        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-slate-500 tracking-wider mb-2">
            {breadcrumb.map((item, index) => (
                <>
                    <span class="hover:text-slate-800 transition-colors cursor-pointer">{item}</span>
                    {index < breadcrumb.length - 1 && (
                        <Icons type="chevron-right" class="w-2.5 h-2.5 text-slate-400" strokeWidth={3} />
                    )}
                </>
            ))}
        </nav>
        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-slate-900 tracking-tight mb-2">{title}</h2>
        {subtitle && <p class="text-slate-700 text-[15px] font-medium leading-snug">{subtitle}</p>}
    </header>

    <!-- Shell de la Tabla -->
    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden">
        <!-- Encabezado de Tabla (Solo Desktop) -->
        <div class="hidden sm:grid grid-cols-[1fr_120px_120px_70px] md:grid-cols-[1fr_130px_130px_100px] gap-4 items-center bg-surface-muted/50 border-b border-subtle py-3.5 px-6 text-[12px] font-bold text-slate-700 tracking-wide">
            <div class="invisible">Producto</div>
            <div class="text-right">Precio farmacia</div>
            <div class="text-right">Precio público</div>
            <div class="flex justify-center">
                <Icons type="cart" class="w-4 h-4 text-slate-700" strokeWidth={2.3} />
            </div>
        </div>

        <!-- Filas de Productos -->
        {products.map((product) => (
            <ProductRowElite {...product} />
        ))}
    </div>
</section>
