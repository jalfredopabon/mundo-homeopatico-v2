---
// src/components/catalogo/CatalogTable.astro
import Icons from "../shared/Icons.astro";
import ProductRowElite from "./ProductRowElite.astro";

interface Product {
    name: string;
    description?: string;
    requiresPreparation?: boolean;
    badges: { label: string; variant?: any }[];
    farmaciaPrice: string;
    publicoPrice: string;
    cartData?: { name: string; price: string };
}

interface Props {
    id: string;
    title: string;
    subtitle?: string;
    description?: string;
    breadcrumb: string[];
    products: Product[];
}

const { id, title, subtitle, description, breadcrumb, products } = Astro.props;
---

<section id={id} class="scroll-mt-0 pt-12">
    <!-- Encabezado de la Sección -->
    <header class="catalog-section-header auto-animate-header">
        <nav aria-label="Breadcrumb" class="catalog-breadcrumb">
            {breadcrumb.map((item, index) => (
                <>
                    <span class="hover:text-slate-800 transition-colors cursor-pointer">{item}</span>
                    {index < breadcrumb.length - 1 && (
                        <Icons type="chevron-right" class="w-2.5 h-2.5 text-slate-400" strokeWidth={3} />
                    )}
                </>
            ))}
        </nav>
        <h2 class="catalog-title">{title}</h2>
        {subtitle && <p class="text-slate-700 text-[15px] font-medium leading-snug">{subtitle}</p>}
        {description && (
            <p class="catalog-description text-dynamic-content">
                {description}
            </p>
        )}
    </header>

    <!-- Shell de la Tabla -->
    <div class="catalog-table-shell">
        <!-- Encabezado de Tabla (Solo Desktop) -->
        <div class="catalog-table-header">
            <div class="invisible">Producto</div>
            <div class="text-right">Precio farmacia</div>
            <div class="text-right">Precio público</div>
            <div class="flex justify-center">
                <Icons type="cart" class="w-4 h-4 text-slate-700" strokeWidth={2.3} />
            </div>
        </div>

        <!-- Filas de Productos -->
        {products.map((product) => (
            <ProductRowElite {...product} />
        ))}
    </div>
</section>
