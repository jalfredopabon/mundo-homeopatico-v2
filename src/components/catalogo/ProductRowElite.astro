---
// src/components/catalogo/ProductRowElite.astro
import BadgeElite from "../shared/BadgeElite.astro";
import ButtonElite from "../shared/ButtonElite.astro";
import Icons from "../shared/Icons.astro";

interface Badge {
  label: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
}

interface Props {
  name: string;
  description?: string;
  requiresPreparation?: boolean;
  badges: Badge[];
  farmaciaPrice: string;
  publicoPrice: string;
  cartData?: {
    name: string;
    price: string;
  };
}

const { 
  name,
  description,
  requiresPreparation,
  badges, 
  farmaciaPrice, 
  publicoPrice, 
  cartData 
} = Astro.props;

// Fase 1: Lógica de Truncado Automático (Revelación Progresiva)
const maxBadges = 10;
const visibleBadges = (badges && badges.length > 0) ? badges.slice(0, maxBadges) : [];
const hiddenBadges = badges && badges.length > maxBadges ? badges.slice(maxBadges) : [];
const extraCount = hiddenBadges.length;

// ID Único para evitar colisiones quirúrgicas entre filas
const extraId = `badges-${Math.random().toString(36).substring(2, 9)}`;
---

<div class="catalog-row group/row">
    <!-- Información del Producto (Nivel 3 Lego) -->
    <div class="flex flex-col w-full min-w-0 pl-0 transition-transform duration-500 group-hover/row:translate-x-1">
        <!-- Línea 1: Nombre + Estado (Flujo Dinámico) -->
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5">
            <h3 class="text-slate-900 font-bold leading-tight text-dynamic-content">
                {name}
                <!-- Fase 2: Keywords ocultos para permitir búsqueda por badges invisibles -->
                <span style="display: none !important;" aria-hidden="true">
                    {badges && badges.map(b => b.label).join(' ')}
                </span>
            </h3>
            
            {requiresPreparation && (
              <div class="badge-status-alert">
                  <Icons type="clock" class="w-[11px] h-[11px]" strokeWidth={3} />
                  <span>Requiere elaboración</span>
              </div>
            )}
        </div>

        <!-- Línea 2: Descripción (Si existe) -->
        {description && (
            <p class="catalog-description text-slate-700 mt-1">
                {description}
            </p>
        )}

        <!-- Línea 3: Badges de Atributos (Revelación Progresiva) -->
        {badges && badges.length > 0 && (
            <div class="flex flex-wrap items-center gap-2 mt-2">
                {/* Badges Visibles */}
                {visibleBadges.map((badge) => (
                    <BadgeElite 
                      label={badge.label} 
                      variant={badge.variant || 'outline'} 
                      size="xs"
                      class="text-dynamic-badge" 
                    />
                ))}

                {/* Contenedor Fantasma (Invisible para el diseño, real para el DOM) */}
                <span id={extraId} style="display: none;">
                    {hiddenBadges.map((badge) => (
                        <span class="inline-flex m-1">
                          <BadgeElite 
                            label={badge.label} 
                            variant={badge.variant || 'outline'} 
                            size="xs"
                            class="text-dynamic-badge" 
                          />
                        </span>
                    ))}
                </span>

                {/* Botón Contador (Interruptor Inteligente- Fase 1) */}
                {extraCount > 0 && (
                  <button 
                    id={`${extraId}-btn`}
                    data-expanded="false"
                    class="badge-elite badge-elite--emerald px-2 py-0.5 text-[9px] font-bold flex items-center gap-1 cursor-pointer hover:bg-emerald-100 transition-all group/extra ml-0.5"
                    onclick={`const container = document.getElementById('${extraId}'); const label = this.querySelector('.js-label'); const isExpanded = this.getAttribute('data-expanded') === 'true'; if (isExpanded) { container.style.display = 'none'; label.textContent = '+${extraCount} más'; this.setAttribute('data-expanded', 'false'); } else { container.style.display = 'contents'; label.textContent = 'Ver menos'; this.setAttribute('data-expanded', 'true'); }`}
                    aria-label="Alternar visualización de badges"
                  >
                    <span class="js-label">+{extraCount} más</span>
                    <Icons 
                      type="chevron-down" 
                      class="w-2.5 h-2.5 transition-transform duration-300 group-data-[expanded=true]/extra:rotate-180" 
                      strokeWidth={3} 
                    />
                  </button>
                )}
            </div>
        )}
    </div>

    <!-- Precios y Acción (Estructura responsiva Elite) -->
    <div class="sm:contents">
        <!-- Farmacia -->
        <div class="flex flex-col sm:block text-left sm:text-right mt-3 sm:mt-0 pt-3 sm:pt-0 border-t border-subtle/30 sm:border-0">
            <span class="sm:hidden text-[10px] text-slate-500 font-bold uppercase tracking-wider mb-0.5">Farmacia</span>
            <span class="catalog-cell-price">
                {farmaciaPrice}
            </span>
        </div>
        
        <!-- Público (Desktop) -->
        <div class="hidden sm:block text-right mt-1 sm:mt-0">
            <span class="catalog-cell-price">
                {publicoPrice}
            </span>
        </div>

        <!-- Botón de Acción (Uso de ButtonElite) -->
        <div class="flex justify-end sm:justify-center mt-3 sm:mt-0">
            <button 
                class="catalog-btn-add btn-add-cart" 
                data-name={cartData?.name || name} 
                data-price={cartData?.price || farmaciaPrice.replace(/[^0-9]/g, '')}
                aria-label={`Añadir ${name}`}
                id={cartData ? `btn-${cartData.price}` : undefined}
            >
                <div class="flex items-center justify-center mt-[-1px]">
                    <Icons type="plus" class="w-[18px] h-[18px] transition-colors" strokeWidth={3} />
                    <span class="sm:hidden ml-2 font-bold text-sm leading-none">Añadir al pedido</span>
                </div>
            </button>
        </div>
    </div>
</div>
