                <a href="#homeopaticos-especiales" class="sidebar-link group relative flex items-center h-9 rounded-lg transition-all text-slate-700 hover:bg-surface-muted hover:text-slate-800 mx-4 focus:outline-none focus-visible:ring-1 focus-visible:ring-brand/30">
                  <div class="w-8 flex-shrink-0"></div>
                  <span class="text-[13px] font-normal group-[.is-active]:font-bold leading-none mt-[-0.5px] transition-transform">Homeopáticos especiales</span>
