            </div>
            
            <div class="flex flex-col">
              <a href="#cbd" class="sidebar-link group relative flex items-center h-9 rounded-lg transition-all text-slate-700 hover:bg-slate-100 hover:text-slate-800 mx-4 focus:outline-none focus-visible:ring-1 focus-visible:ring-brand/30">
                <div class="w-8 flex-shrink-0 flex items-center justify-start pl-[6px] transition-colors">
