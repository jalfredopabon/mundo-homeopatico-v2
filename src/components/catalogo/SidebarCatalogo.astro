---
// src/components/catalogo/SidebarCatalogo.astro
import { CATALOGO_DATA } from "../../data/catalogo";
import Icons from "./Icons.astro";
---

<aside class="hidden md:flex flex-col w-64 border-r border-subtle bg-surface-white h-[calc(100vh-64px)] sticky top-[64px] overflow-y-auto scrollbar-premium">
  
  <!-- BUSCADOR STICKY -->
  <div class="sticky top-0 z-30 bg-surface-white px-4 py-4 border-b border-subtle">
    <div class="relative group">
      <div class="absolute left-[6px] top-0 h-full w-4 flex items-center justify-center text-slate-700 group-focus-within:text-brand transition-colors">
        <div class="relative w-4 h-4 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
            <path d="M17 17L21 21" />
            <path d="M19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19C15.4183 19 19 15.4183 19 11Z" />
          </svg>
        </div>
      </div>
        <input 
        type="search" 
        id="catalogo-search"
        placeholder="Buscar productos..." 
        class="w-full h-10 pl-8 pr-4 bg-slate-50/70 border border-subtle rounded-lg text-[14px] text-slate-800 focus:outline-none focus:bg-white focus:ring-1 focus:ring-brand focus:border-brand transition-all placeholder:text-slate-700"
      />
    </div>
  </div>

  <nav class="pb-20 mt-4 space-y-6" id="catalogo-scrollspy">
    {CATALOGO_DATA.map((section) => (
      <div class="space-y-2">
        {/* Nivel 1: Título de Sección - Alineado al borde del buscador (pl-5) */}
        <span class="block text-[12px] font-semibold text-slate-900 px-4 tracking-tight">{section.title}</span>
        
        <div class="flex flex-col gap-4">
          {section.subsections.map((sub) => (
            <div class="flex flex-col gap-0">
              {/* Nivel 2: Título de Subsección - Alineado al borde del buscador (pl-5) */}
                <span class="block text-[12px] font-medium text-slate-600 px-4">{sub.title}</span>
              
              <div class="flex flex-col gap-0.5">
                {sub.groups.map((group) => {
                  const hasSubLinks = group.links && group.links.length > 0;
                  
                  return (
                    <div class="flex flex-col">
                      {/* Nivel 3: Agrupador o Link Directo - Alineación Centralizada */}
                      {hasSubLinks ? (
                        <button 
                          class="accordion-trigger group relative flex items-center w-[calc(100%-2rem)] ml-4 pr-4 h-9 mt-1 text-slate-700 transition-colors rounded-lg hover:bg-slate-50 focus:outline-none focus-visible:ring-1 focus-visible:ring-brand/30"
                          data-target={group.name.toLowerCase().replace(/\s+/g, '-')}
                        >
                          <div class="w-8 flex-shrink-0 flex items-center justify-start pl-[6px] transition-colors">
                            <div class="w-[18px] h-[18px] flex items-center justify-center">
                              <Icons type={group.iconType} />
                            </div>
                          </div>
                          <span class="text-[14px] font-normal leading-none mt-[-1px] transition-transform">{group.name}</span>
                          
                          {/* Chevron Down (Hugeicons) - Alineado con el fin del buscador */}
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-auto transition-all duration-300 accordion-icon">
                            <path d="M18 9L12 15L6 9" />
                          </svg>
                        </button>
                      ) : (
                        <a href={group.href} class="sidebar-link group relative flex items-center h-9 rounded-lg transition-all text-slate-700 hover:bg-slate-100 hover:text-slate-800 [&.is-active]:bg-slate-200 mx-4 focus:outline-none focus-visible:ring-1 focus-visible:ring-brand/30">
                          <div class="w-8 flex-shrink-0 flex items-center justify-start pl-[6px] transition-colors">
                            <div class="w-[18px] h-[18px] flex items-center justify-center">
                              <Icons type={group.iconType} />
                            </div>
                          </div>
                          <span class="text-[14px] font-normal group-[.is-active]:font-bold leading-none mt-[-1px] transition-transform">{group.name}</span>
                        </a>
                      )}

                      {/* Nivel 4: Sub-links (Acordeón) */}
                      {hasSubLinks && (
                        <div class="accordion-content overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0;">
                          {group.links.map((link) => (
                            <a href={link.href} class="sidebar-link group relative flex items-center h-9 rounded-lg transition-all text-slate-700 hover:bg-slate-100 hover:text-slate-800 [&.is-active]:bg-slate-200 mx-4 focus:outline-none focus-visible:ring-1 focus-visible:ring-brand/30">
                              <div class="w-8 flex-shrink-0"></div>
                              <span class="text-[13px] font-normal group-[.is-active]:font-bold leading-none mt-[-0.5px] transition-transform">{link.name}</span>
                            </a>
                          ))}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </nav>

  <!-- FIRMA DE AUTOR (Crédito de Autor persistente) -->
  <div class="mt-auto px-4 pb-8 pt-4 border-t border-slate-50 bg-slate-50/30">
    <a 
      href="https://www.linkedin.com/in/jalfredopabon/" 
      target="_blank" 
      rel="noopener noreferrer" 
      class="group flex items-center gap-3 p-2 rounded-xl transition-all hover:bg-white hover:shadow-sm ring-1 ring-transparent hover:ring-slate-200"
    >
      <!-- Avatar / Iniciales AP -->
      <div class="w-8 h-8 rounded-lg bg-slate-900 flex items-center justify-center text-[10px] font-bold text-white transition-transform group-hover:scale-110">
        AP
      </div>
      <div class="flex flex-col">
        <span class="text-[10px] text-slate-500 font-bold leading-none mb-1">Creado por</span>
        <span class="text-[12px] font-bold text-slate-900 leading-none group-hover:text-brand transition-colors">Alfredo Pabón</span>
      </div>
      <!-- Icono de salida externa sutil -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 ml-auto text-slate-300 group-hover:text-brand transition-colors opacity-0 group-hover:opacity-100 translate-x-1 group-hover:translate-x-0 transition-all">
        <path d="M7 17L17 7M17 7H7M17 7V17" />
      </svg>
    </a>
  </div>

</aside>

<style>


  /* Scrollbar Invisible Premium */
  .scrollbar-premium::-webkit-scrollbar {
    width: 4px;
    background: transparent;
  }
  
  .scrollbar-premium::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 20px;
    transition: background 0.3s;
  }

  .scrollbar-premium:hover::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.1);
  }

  /* Separación de profundidad Flat */
  aside {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Sistema de Líneas de Jerarquía (Tree-Guide) - Fase 3 */
  .accordion-content {
    position: relative;
  }

  /* Sistema de Línea Maestra (Tronco Único) */
  .accordion-content {
    position: relative;
  }

  /* El Tronco: Línea recta continua centrada con los iconos */
  .accordion-content::before {
    content: "";
    position: absolute;
    left: 31px; /* Eje central del icono (6px padding + 9px medio icono) + 16px margen ext */
    top: -8px;
    bottom: 16px;
    border-left: 1.5px solid #64748b;
    z-index: 0;
  }

  /* Las Ramas: Eliminadas por petición del usuario */
  .accordion-content .sidebar-link::before {
    display: none;
  }

  /* Limpieza de pseudo-elementos antiguos fragmentados */
  .accordion-content .sidebar-link::after {
    display: none;
  }

  /* El último hijo no debe continuar el tronco hacia abajo */
  .accordion-content .sidebar-link:last-child::after {
    display: none;
  }

  /* Ajuste óptico Flush: Alineación perfecta con el texto de nivel 3 */
  .accordion-content .sidebar-link span {
    position: relative;
    z-index: 1;
    margin-left: 0; /* Eliminado indentación redundante (ya está en el HTML) */
  }

  /* Rotación del Chevron */
  .accordion-trigger.is-expanded .accordion-icon {
    transform: rotate(180deg);
    color: var(--brand);
    opacity: 1;
  }

  /* Estilos para el estado activo unificado - Cápsula Sombreada (Estilo Vademécum) */
  .sidebar-link.is-active,
  .sidebar-link:focus,
  .accordion-trigger:focus {
    outline: none !important;
  }
  
  .sidebar-link.is-active {
    background-color: #e2e8f0; /* Color un poco más oscuro (slate-200) para mayor contraste */
    color: #0f172a !important; /* slate-900 para máxima legibilidad */
    font-weight: 700 !important;
    border: none !important;
    box-shadow: none !important;
  }

  /* Ajuste de margin para consistencia */
  .sidebar-link.is-active {
    margin-left: 1rem;
    margin-right: 1rem;
  }

  .sidebar-link.is-active .icon-container {
    color: var(--primary);
  }

  .sidebar-link:hover:not(.is-active) {
    background-color: rgba(0, 0, 0, 0.02);
  }

  /* Animación de escala para ítems activos */
  .sidebar-link {
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Ajuste de scroll */
  nav {
    scroll-behavior: smooth;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // LÓGICA DE SCROLLSPY
    const scrollContainer = document.getElementById('catalogo-main-scroll');
    const sections = scrollContainer ? scrollContainer.querySelectorAll('section[id]') : [];
    
    if (scrollContainer && sections.length > 0) {
      const observerOptions = {
        root: scrollContainer,
        rootMargin: '-20% 0px -60% 0px',
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            document.querySelectorAll('#catalogo-scrollspy .sidebar-link').forEach(link => {
              const href = link.getAttribute('href');
              if (href === `#${id}`) {
                link.classList.add('is-active');
              } else {
                link.classList.remove('is-active');
              }
            });
          }
        });
      }, observerOptions);

      sections.forEach(section => observer.observe(section));
    }

    // LÓGICA DE ACORDEONES INTELIGENTES (Fase 2)
    const triggers = document.querySelectorAll('.accordion-trigger');
    
    const closeAllAccordions = (except = null) => {
      document.querySelectorAll('.accordion-content').forEach(content => {
        if (content !== except) {
          content.style.maxHeight = '0';
          const trigger = content.previousElementSibling;
          if (trigger) trigger.classList.remove('is-expanded');
        }
      });
    };

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const content = trigger.nextElementSibling as HTMLElement;
        if (!content) return;
        
        const isExpanded = trigger.classList.contains('is-expanded');
        closeAllAccordions(content);

        if (isExpanded) {
          content.style.maxHeight = '0';
          trigger.classList.remove('is-expanded');
        } else {
          content.style.maxHeight = content.scrollHeight + 'px';
          trigger.classList.add('is-expanded');
        }
        
        // Evitar el foco persistente del botón al hacer clic
        setTimeout(() => { trigger.blur(); }, 50);
      });
    });

    // Auto-apertura si hay un link activo dentro
    const activeChild = document.querySelector('.sidebar-link.is-active');
    if (activeChild) {
      const parentAccordion = activeChild.closest('.accordion-content') as HTMLElement;
      if (parentAccordion) {
        parentAccordion.style.maxHeight = parentAccordion.scrollHeight + 'px';
        const trigger = parentAccordion.previousElementSibling;
        if (trigger) trigger.classList.add('is-expanded');
      }
    }

    // Cerrar acordeones al hacer clic en un link que NO sea de cuarto nivel
    document.querySelectorAll('.sidebar-link').forEach(link => {
      link.addEventListener('click', () => {
        const isFourthLevel = link.closest('.accordion-content');
        if (!isFourthLevel) {
          closeAllAccordions();
        }
      });
    });
  });
</script>
