---
// src/components/catalogo/SidebarCatalogo.astro
import Icons from "../shared/Icons.astro";
---

<aside class="hidden md:flex flex-col w-64 border-r border-subtle bg-surface-white h-[calc(100dvh-64px)] sticky top-[64px] overflow-y-auto scrollbar-premium shrink-0">
  
  <!-- BUSCADOR STICKY (Se mantiene estático para evitar parpadeo) -->
  <div class="sidebar-search-header">
    <div class="relative group">
      <div class="absolute left-[7px] top-0 h-full w-4 flex items-center justify-center text-slate-700 group-focus-within:text-brand transition-colors">
        <div class="relative w-4 h-4 flex items-center justify-center">
          <Icons type="search" class="w-full h-full" />
        </div>
      </div>
      <input type="search" id="catalogo-search" placeholder="Buscar productos..." class="input-elite-field pl-8 pr-4 mt-[-2.5px]">
    </div>
  </div>

  <!-- CONTENEDOR DE NAVEGACIÓN (Se hidratará en cliente) -->
  <nav class="pb-6 mt-0 space-y-6" id="catalogo-scrollspy">
    <!-- Skeleton/Loader opcional aquí si se desea -->
    <div class="p-8 space-y-8 animate-pulse">
        <div class="h-4 bg-slate-50 rounded w-1/2"></div>
        <div class="space-y-3">
            <div class="h-8 bg-slate-50 rounded-lg w-full"></div>
            <div class="h-8 bg-slate-50 rounded-lg w-full"></div>
            <div class="h-8 bg-slate-50 rounded-lg w-full"></div>
        </div>
    </div>
  </nav>

</aside>

<style>
    /* VARIABLES DE ALINEACIÓN ELITE (PLOMADAS) */
    :root {
        --sidebar-gap-x: 1rem; /* 16px (Plomada 1: Borde) */
        --sidebar-icon-w: 32px;
        --sidebar-plumb-line: 31px; /* Eje de la línea guía */
        --sidebar-l4-indent: 38px; /* Offset para cápsula Nivel 4 */
    }

    /* Estilos base para elementos inyectados dinámicamente */
    .accordion-trigger.is-expanded {
        @apply bg-slate-50 text-slate-900 font-bold;
    }

    .accordion-content {
        position: relative;
    }

    .accordion-content::before {
        content: "";
        position: absolute;
        left: var(--sidebar-plumb-line);
        top: 0;
        bottom: 0;
        width: 1px;
        @apply bg-slate-200;
        z-index: 10;
        pointer-events: none;
    }

    .sidebar-link {
        position: relative;
        z-index: 5;
    }

    .sidebar-label--sub {
        @apply transition-all duration-300;
        font-size: 13px;
        color: #475569; /* slate-600 */
    }

    .sidebar-link.is-active .sidebar-label--sub {
        @apply text-slate-900;
    }
</style>
