---
// src/components/catalogo/ProductRowElite.astro
import BadgeElite from "../shared/BadgeElite.astro";
import Icons from "../shared/Icons.astro";

interface Badge {
  label: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
}

interface Props {
  id?: string;
  name: string;
  description?: string;
  requiresPreparation?: boolean;
  badges: Badge[];
  farmaciaPrice: string;
  publicoPrice: string;
  cartData?: {
    name: string;
    price: string;
  };
}

const { 
  id,
  name,
  description,
  requiresPreparation,
  badges, 
  farmaciaPrice, 
  publicoPrice, 
  cartData 
} = Astro.props;

// Fase 1: Lógica de Truncado Automático (Revelación Progresiva)
const maxBadges = 10;
const visibleBadges = (badges && badges.length > 0) ? badges.slice(0, maxBadges) : [];
const hiddenBadges = badges && badges.length > maxBadges ? badges.slice(maxBadges) : [];
const extraCount = hiddenBadges.length;

// ID Único basado en el producto para estabilidad del DOM
const safeId = id ? id.replace(/[^a-z0-9]/gi, '-') : name.toLowerCase().replace(/[^a-z0-9]/gi, '-');
const extraId = `badges-${safeId}`;
---

<div class="catalog-row group/row">
    <!-- Información del Producto (Nivel 3 Lego) -->
    <div class="flex flex-col w-full min-w-0 pl-0 transition-transform duration-500 group-hover/row:translate-x-1">
        <!-- Línea 1: Nombre + Estado (Flujo Dinámico) -->
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5">
            <h3 class="text-slate-900 font-bold leading-tight text-dynamic-content">
                {name}
                <!-- Fase 2: Keywords ocultos para permitir búsqueda por badges invisibles -->
                <span style="display: none !important;" aria-hidden="true">
                    {badges && badges.map(b => b.label).join(' ')}
                </span>
            </h3>
            
            {requiresPreparation && (
              <div class="badge-status-alert">
                  <Icons type="clock" class="w-[11px] h-[11px]" strokeWidth={3} />
                  <span>Requiere elaboración</span>
              </div>
            )}
        </div>

        <!-- Línea 2: Descripción (Si existe) -->
        {description && (
            <p class="catalog-description text-slate-700 mt-1">
                {description}
            </p>
        )}

        <!-- Línea 3: Badges de Atributos (Revelación Progresiva) -->
        {badges && badges.length > 0 && (
            <div class="flex flex-wrap items-center gap-2 mt-2">
                {/* Badges Visibles */}
                {visibleBadges.map((badge) => (
                    <BadgeElite 
                      label={badge.label} 
                      variant={badge.variant || 'outline'} 
                      size="xs"
                      class="text-dynamic-badge" 
                    />
                ))}

                {/* Contenedor Fantasma (Invisible para el diseño, real para el DOM) */}
                <span id={extraId} style="display: none;">
                    {hiddenBadges.map((badge) => (
                        <span class="inline-flex m-1">
                          <BadgeElite 
                            label={badge.label} 
                            variant={badge.variant || 'outline'} 
                            size="xs"
                            class="text-dynamic-badge" 
                          />
                        </span>
                    ))}
                </span>

                {/* Botón Contador (Interruptor Inteligente- Fase 1) */}
                {extraCount > 0 && (
                  <button 
                    id={`${extraId}-btn`}
                    data-expanded="false"
                    data-extra-toggle={extraId}
                    data-extra-count={extraCount}
                    class="badge-elite badge-elite--emerald px-2 py-0.5 text-[9px] font-bold flex items-center gap-1 cursor-pointer hover:bg-emerald-100 transition-all group/extra ml-0.5 js-badge-toggle"
                    aria-label="Alternar visualización de badges"
                  >
                    <span class="js-label">+{extraCount} más</span>
                    <Icons 
                      type="chevron-down" 
                      class="w-2.5 h-2.5 transition-transform duration-300 group-data-[expanded=true]/extra:rotate-180" 
                      strokeWidth={3} 
                    />
                  </button>
                )}
            </div>
        )}
    </div>

    <!-- Precios y Acción (Estructura responsiva Elite - Hito 39) -->
    <div class="catalog-price-hub">
        <!-- Grupo de Precios (Horizontal Master Layout) -->
        <div class="flex flex-row flex-wrap items-center gap-x-4 gap-y-1.5 sm:contents">
            <!-- Farmacia -->
            <div class="flex items-center gap-1.5 sm:block text-left sm:text-right">
                <span class="sm:hidden text-[10px] text-slate-400 font-medium">Farmacia:</span>
                <span class="catalog-cell-price">
                    {farmaciaPrice || '$0.00'}
                </span>
            </div>
            
            <!-- Público -->
            <div class="flex items-center gap-1.5 sm:block text-left sm:text-right">
                <span class="sm:hidden text-[10px] text-slate-400">Público:</span>
                <span class="catalog-cell-price">
                    {publicoPrice || '$0.00'}
                </span>
            </div>
        </div>

        <!-- Botón de Acción (Compacto en Móvil) -->
        <div class="flex justify-end sm:justify-center">
            <button 
                class="catalog-btn-add btn-add-cart !w-10 sm:!w-10" 
                data-name={cartData?.name || name} 
                data-price={cartData?.price || String(farmaciaPrice || '0').replace(/[^0-9]/g, '')}
                aria-label={`Añadir ${name}`}
            >
                <div class="flex items-center justify-center">
                    <Icons type="plus" class="w-[18px] h-[18px] transition-colors" strokeWidth={3} />
                </div>
            </button>
        </div>
    </div>
</div>

<script>
    /**
     * Lógica de expansión de badges (Revelación Progresiva)
     * Implementada vía delegación de eventos para cumplir con CSP "Fort Knox".
     */
    const initBadgeToggles = () => {
        const toggleBadges = (e: Event) => {
            const btn = (e.target as HTMLElement).closest('.js-badge-toggle') as HTMLButtonElement;
            if (!btn) return;

            const targetId = btn.getAttribute('data-extra-toggle');
            const extraCount = btn.getAttribute('data-extra-count');
            const container = document.getElementById(targetId || '');
            const label = btn.querySelector('.js-label');
            const isExpanded = btn.getAttribute('data-expanded') === 'true';

            if (!container || !label) return;

            if (isExpanded) {
                container.style.display = 'none';
                label.textContent = `+${extraCount} más`;
                btn.setAttribute('data-expanded', 'false');
            } else {
                container.style.display = 'contents';
                label.textContent = 'Ver menos';
                btn.setAttribute('data-expanded', 'true');
            }
        };

        // Escuchador global en el documento para manejar todas las filas dinámicas
        document.removeEventListener('click', toggleBadges);
        document.addEventListener('click', toggleBadges);
    };

    document.addEventListener('astro:page-load', initBadgeToggles);
</script>
