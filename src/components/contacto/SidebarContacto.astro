---
// src/components/contacto/SidebarContacto.astro
import Icons from "../shared/Icons.astro";
/**
 * SidebarContacto: Navegación lateral para la página de Sedes y Contacto.
 * - Versión Optimizada para Paridad Visual y Funcional.
 * - Color Verdoso Sage Oscurecido (#D9E8E4) para estado activo.
 * - Script robusto de ScrollSpy con soporte para ViewTransitions.
 */
---

<aside class="hidden md:flex w-full md:w-64 bg-surface-white border-b md:border-b-0 md:border-r border-subtle flex-col z-20 sticky top-0 md:static shrink-0 overflow-y-auto h-[calc(100vh-64px)] md:h-[calc(100vh-64px)]">
    
    <!-- Header del Sidebar (Card de Acción Rápida - Reemplaza al buscador) -->
    <div class="sticky top-0 z-30 bg-surface-white px-4 py-4">
        <a href="https://instagram.com/mundohomeopatico" target="_blank" class="relative group block w-full">
            <div class="absolute left-[6px] top-0 h-full w-4 flex items-center justify-center text-slate-700 group-hover:text-brand transition-colors pointer-events-none">
                <div class="relative w-4 h-4 flex items-center justify-center">
                    <Icons type="instagram" class="w-full h-full" strokeWidth={1.5} />
                </div>
            </div>
            <div class="h-10 flex items-center pl-8 pr-4 bg-surface-muted/70 border border-subtle rounded-lg text-[14px] text-slate-800 group-hover:bg-white group-hover:border-brand transition-all focus-visible:outline-none">
                <span class="mt-[-2.5px]">Síguenos en Instagram</span>
            </div>
        </a>
    </div>

    <!-- Navegación ScrollSpy: Índice de la página -->
    <nav class="flex-1 flex flex-col pb-4 mt-0 space-y-1 overflow-y-auto scrollbar-premium" id="contacto-scrollspy">
        <a href="#excelencia" class="sidebar-link group relative flex items-center h-9 rounded-lg transition-all text-slate-700 hover:bg-slate-50 hover:text-slate-800 mx-4 is-active">
            <div class="w-8 flex-shrink-0 flex items-center justify-start pl-[6px] transition-colors">
                <div class="w-[18px] h-[18px] flex items-center justify-center">
                    <Icons type="award" class="w-full h-full text-slate-700 transition-colors" strokeWidth={2.2} />
                </div>
            </div>
            <span class="text-[14px] font-normal group-[.is-active]:font-bold text-slate-700 group-hover:text-slate-800 leading-none mt-[-1px] transition-colors">Excelencia homeopática</span>
        </a>

        <a href="#sedes" class="sidebar-link group relative flex items-center h-9 rounded-lg transition-all text-slate-700 hover:bg-slate-50 hover:text-slate-800 mx-4">
            <div class="w-8 flex-shrink-0 flex items-center justify-start pl-[6px] transition-colors">
                <div class="w-[18px] h-[18px] flex items-center justify-center">
                    <Icons type="map-pin" class="w-full h-full text-slate-700 transition-colors" strokeWidth={2.2} />
                </div>
            </div>
            <span class="text-[14px] font-normal group-[.is-active]:font-bold text-slate-700 group-hover:text-slate-800 leading-none mt-[-1px] transition-colors">Sedes y distribuciones</span>
        </a>

        <a href="#faq" class="sidebar-link group relative flex items-center h-9 rounded-lg transition-all text-slate-700 hover:bg-slate-50 hover:text-slate-800 mx-4">
            <div class="w-8 flex-shrink-0 flex items-center justify-start pl-[6px] transition-colors">
                <div class="w-[18px] h-[18px] flex items-center justify-center">
                    <Icons type="help-circle" class="w-full h-full text-slate-700 transition-colors" strokeWidth={2.2} />
                </div>
            </div>
            <span class="text-[14px] font-normal group-[.is-active]:font-bold text-slate-700 group-hover:text-slate-800 leading-none mt-[-1px] transition-colors">Preguntas frecuentes</span>
        </a>
    </nav>

    <!-- Contenedor Inferior: Información estática de soporte -->
    <div class="px-4 py-4 mt-auto bg-surface-muted/50 border-t border-subtle hidden md:block">
        <div class="flex flex-col gap-2">
            <h4 class="text-[12px] font-bold text-slate-700">Atención al cliente</h4>
            <div class="flex items-start">
                <div class="w-8 flex-shrink-0 flex items-center justify-start pl-[6px] mt-0.5">
                    <Icons type="clock" class="w-4 h-4 text-slate-700 shrink-0" strokeWidth={2.2} />
                </div>
                <div>
                    <p class="text-[13px] font-medium text-body leading-tight">Lunes a sábado</p>
                    <p class="text-[11px] text-slate-700">8:00 AM - 6:00 PM</p>
                </div>
            </div>
        </div>
    </div>
</aside>

<style>
    /* Estabilidad de Layout */
    aside {
        scrollbar-gutter: stable;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    /* Limpieza de foco */
    .sidebar-link:focus {
        outline: none !important;
    }

    /* Estado Activo: Cápsula Verde Sage Oscurecido (#D9E8E4) */
    /* Este color es ideal para paridad de oscuridad con slate-100 pero con matiz verde */
    .sidebar-link.is-active {
        background-color: #D9E8E4 !important;
        color: inherit !important;
        font-weight: 700 !important;
        box-shadow: none !important;
        border: none !important;
    }

    /* Estado Hover: Solo negrita, mantiene color original */
    .sidebar-link:hover:not(.is-active) {
        background-color: rgba(0, 0, 0, 0.02);
        font-weight: 700;
    }
</style>

<script>
    /**
     * Lógica de Auto-Anclaje y Resaltado Dinámico (ScrollSpy)
     * Optimizada para precisión quirúrgica y soporte de clics.
     */
    const initScrollSpy = () => {
        const scrollContainer = document.getElementById('contacto-main-scroll');
        const sections = document.querySelectorAll('section[id]');
        const sidebarLinks = document.querySelectorAll('#contacto-scrollspy .sidebar-link');
        
        if (!scrollContainer || !sections.length || !sidebarLinks.length) return;

        const clearActiveStates = () => {
            sidebarLinks.forEach(link => link.classList.remove('is-active'));
        };

        // 1. Manejo de clics para respuesta inmediata
        sidebarLinks.forEach(link => {
            link.addEventListener('click', () => {
                clearActiveStates();
                link.classList.add('is-active');
            });
        });

        // 2. Observer para seguimiento del scroll
        const observerOptions = {
            root: scrollContainer,
            rootMargin: '-30% 0px -60% 0px',
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                // Solo activamos si el elemento está entrando en la zona focal del viewport
                if (entry.isIntersecting) {
                    const currentId = entry.target.getAttribute('id');
                    const activeLink = document.querySelector(`#contacto-scrollspy a[href="#${currentId}"]`);
                    
                    if (activeLink) {
                        clearActiveStates();
                        activeLink.classList.add('is-active');
                    }
                }
            });
        }, observerOptions);

        sections.forEach(section => observer.observe(section));
    };

    // Inicializar en carga inicial y navegaciones
    document.addEventListener('astro:page-load', initScrollSpy);
</script>
