---
// src/components/contacto/SidebarContacto.astro
import Icons from "../shared/Icons.astro";
import { getConfigData } from "../../data/api";

let linkInstagram = "https://instagram.com/mundohomeopatico";
try {
    const config = await getConfigData();
    if (config.link_instagram) {
        linkInstagram = config.link_instagram;
    }
} catch (e) {
    console.warn("No se pudo cargar la configuracion del sidebar de contacto.");
}
---

<aside class="hidden md:flex w-full md:w-64 bg-surface-white border-b md:border-b-0 md:border-r border-subtle flex-col z-20 sticky top-0 md:static shrink-0 overflow-y-auto h-[calc(100dvh-64px)] md:h-[calc(100dvh-64px)]">
    
    <!-- Header del Sidebar (Card de Acción Rápida - Reemplaza al buscador) -->
    <div class="sidebar-search-header">
        <a href={linkInstagram} target="_blank" class="relative group block w-full">
            <div class="absolute left-[7px] top-0 h-full w-4 flex items-center justify-center text-slate-700 group-hover:text-brand transition-colors pointer-events-none">
                <div class="relative w-4 h-4 flex items-center justify-center">
                    <Icons type="instagram" class="w-full h-full" strokeWidth={1.5} />
                </div>
            </div>
            <div class="input-elite-field flex items-center pl-8 pr-4">
                <span class="mt-[-2.5px]">Síguenos en Instagram</span>
            </div>
        </a>
    </div>

    <!-- Navegación ScrollSpy: Índice de la página -->
    <nav class="flex-1 flex flex-col pb-4 mt-0 space-y-1 overflow-y-auto scrollbar-premium" id="contacto-scrollspy">
        <a href="#excelencia" class="sidebar-link sidebar-capsule group is-active">
            <div class="sidebar-icon-slot">
                <div><Icons type="award" class="w-full h-full" strokeWidth={1.5} /></div>
            </div>
            <span class="sidebar-label group-[.is-active]:font-bold">Excelencia homeopática</span>
        </a>

        <a href="#sedes" class="sidebar-link sidebar-capsule group">
            <div class="sidebar-icon-slot">
                <div><Icons type="map-pin" class="w-full h-full" strokeWidth={1.5} /></div>
            </div>
            <span class="sidebar-label group-[.is-active]:font-bold">Sedes y distribuciones</span>
        </a>

        <a href="#faq" class="sidebar-link sidebar-capsule group">
            <div class="sidebar-icon-slot">
                <div><Icons type="help-circle" class="w-full h-full" strokeWidth={1.5} /></div>
            </div>
            <span class="sidebar-label group-[.is-active]:font-bold">Preguntas frecuentes</span>
        </a>
    </nav>

    <!-- Contenedor Inferior: Información estática de soporte -->
    <div class="px-4 py-4 mt-auto bg-surface-muted/50 border-t border-subtle hidden md:block">
        <div class="flex flex-col gap-2">
            <h4 class="text-[12px] font-bold text-slate-700 pl-8">Atención al cliente</h4>
            <div class="flex items-start">
                <div class="sidebar-icon-slot mt-0.5">
                    <div><Icons type="clock" class="w-full h-full text-slate-700" strokeWidth={1.5} /></div>
                </div>
                <div id="sidebar-hours-container" class="flex-1">
                    <p class="text-[13px] font-medium text-body leading-tight">Lunes a sábado</p>
                    <p class="text-[11px] text-slate-700">8:00 AM - 6:00 PM</p>
                </div>
            </div>
        </div>
    </div>
</aside>

<style>
    aside {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
</style>

<script>
    import { getConfigData } from "../../data/api";

    /**
     * Lógica de Auto-Anclaje y Resaltado Dinámico (ScrollSpy)
     * Optimizada para precisión quirúrgica y soporte de clics.
     */
    const initScrollSpy = () => {
        const scrollContainer = document.getElementById('contacto-main-scroll');
        const sections = document.querySelectorAll('section[id]');
        const sidebarLinks = document.querySelectorAll('#contacto-scrollspy .sidebar-link');
        
        if (!scrollContainer || !sections.length || !sidebarLinks.length) return;

        const clearActiveStates = () => {
            sidebarLinks.forEach(link => link.classList.remove('is-active'));
        };

        // 1. Manejo de clics para respuesta inmediata
        sidebarLinks.forEach(link => {
            link.addEventListener('click', () => {
                clearActiveStates();
                link.classList.add('is-active');
            });
        });

        // 2. Observer para seguimiento del scroll
        const observerOptions = {
            root: scrollContainer,
            rootMargin: '-30% 0px -60% 0px',
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const currentId = entry.target.getAttribute('id');
                    const activeLink = document.querySelector(`#contacto-scrollspy a[href="#${currentId}"]`);
                    
                    if (activeLink) {
                        clearActiveStates();
                        activeLink.classList.add('is-active');
                    }
                }
            });
        }, observerOptions);

        sections.forEach(section => observer.observe(section));
    };

    /**
     * Carga y renderiza dinámicamente los horarios de atención desde el Google Sheet (Config).
     */
    const loadSidebarHours = async () => {
        const hoursContainer = document.getElementById('sidebar-hours-container');
        if (!hoursContainer) return;

        try {
            const config = await getConfigData();
            const rawHours = config['horario_atencion'];
            if (rawHours) {
                const blocks = rawHours.split('^').map(b => b.trim());
                let html = '';
                
                blocks.forEach((block, index) => {
                    const colonIndex = block.indexOf(':');
                    const isLast = index === blocks.length - 1;
                    const marginBottomClass = isLast ? '' : 'mb-1.5';
                    
                    if (colonIndex !== -1) {
                        const title = block.substring(0, colonIndex).trim();
                        const details = block.substring(colonIndex + 1).trim();
                        html += `
                            <p class="text-[13px] font-medium text-body leading-tight">${title}</p>
                            <p class="text-[11px] text-slate-700 ${marginBottomClass}">${details}</p>
                        `;
                    } else {
                        html += `
                            <p class="text-[13px] font-medium text-body leading-tight ${marginBottomClass}">${block}</p>
                        `;
                    }
                });
                
                hoursContainer.innerHTML = html;
            }
        } catch (e) {
            console.error("Error al cargar los horarios del sidebar:", e);
        }
    };

    // Inicializar en carga inicial y navegaciones
    document.addEventListener('astro:page-load', () => {
        initScrollSpy();
        loadSidebarHours();
    });
</script>
