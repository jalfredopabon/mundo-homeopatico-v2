---
/**
 * FAQ: Sección de preguntas frecuentes con soporte para acordeones
 * Arquitectura Elite: Datos centralizados y lógica modular.
 */
import Icons from "../shared/Icons.astro";

const faqs = [
    {
        id: "faq-1",
        question: "¿Realizan envíos a nivel nacional para distribuidores B2B?",
        paragraphs: [
            "Sí, cubrimos logísticamente todas las ciudades principales e intermedias de Colombia utilizando flotas refrigeradas y especializadas según la cadena de frío necesaria de cada lote homeopático."
        ],
        isOpen: false
    },
    {
        id: "faq-2",
        question: "¿Cuáles son los requisitos para ser distribuidor autorizado?",
        paragraphs: [
            "Para garantizar la integridad y trazabilidad de nuestros productos, los requisitos mínimos normativos son:"
        ],
        list: [
            "Registro mercantil vigente (cámara de comercio).",
            "Resolución de funcionamiento de la secretaría de salud.",
            "Certificación de estándares de almacenamiento técnico."
        ],
        isOpen: true
    }
];
---

<section id="faq" class="scroll-mt-10">
    <header class="faq-section-header">
        <h2 class="faq-main-title">Preguntas frecuentes</h2>
        <p class="faq-main-sub">Respondemos a las inquietudes más comunes.</p>
    </header>
    <div class="faq-container">
            {faqs.map((faq) => (
                <div class={`faq-item ${faq.isOpen ? 'is-open' : ''}`}>
                <button class="faq-header">
                    <span class="faq-title">{faq.question}</span>
                    <div class="faq-icon-box">
                        <Icons type="chevron-down" class="icon-closed" strokeWidth={2} />
                        <Icons type="chevron-up" class="icon-opened" strokeWidth={2} />
                    </div>
                </button>
                <div class="faq-content-wrapper">
                    <div class="overflow-hidden">
                        <div class="faq-content-inner">
                            {faq.paragraphs && faq.paragraphs.map(p => (
                                <p class={faq.list ? "mb-4" : ""}>{p}</p>
                            ))}
                            {faq.list && (
                                <ul class="faq-list">
                                    {faq.list.map(item => (
                                        <li class="faq-list-item">
                                            <div class="faq-check-box">
                                                <Icons type="check" class="w-3.5 h-3.5" strokeWidth={3} />
                                            </div>
                                            <span class="faq-list-text">{item}</span>
                                        </li>
                                    ))}
                                </ul>
                            )}
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>
</section>

<style>
    .faq-section-header {
        @apply mb-10 flex flex-col gap-1.5;
    }
    .faq-main-title {
        @apply text-[2.25rem] leading-tight font-extrabold text-secondary tracking-tight;
    }
    .faq-main-sub {
        @apply text-slate-700 text-base font-medium;
    }
    .faq-container {
        @apply w-full border-t border-slate-600 mt-4;
    }
    /* Estado Cerrado (Default) */
    .faq-item {
        @apply bg-transparent transition-all duration-300 overflow-hidden border-b border-slate-600;
    }
    .faq-title {
        @apply text-[17px] font-bold text-secondary transition-colors pr-8;
    }
    .faq-header {
        @apply flex w-full items-center justify-between py-6 sm:py-7 pr-2 text-left focus:outline-none transition-colors cursor-pointer;
    }
    .faq-icon-box {
        @apply text-slate-700 transition-all duration-300 flex items-center justify-center shrink-0 w-[22px] h-[22px];
    }
    :global(.icon-opened) {
        display: none;
    }
    .faq-content-wrapper {
        @apply overflow-hidden transition-all duration-500 ease-in-out opacity-0;
        max-height: 0;
    }
    .faq-content-inner {
        @apply pb-6 sm:pb-7 text-body leading-relaxed text-[15px] pr-8 sm:pr-12;
    }
    .faq-list {
        @apply space-y-3.5 mt-2;
    }
    .faq-list-item {
        @apply flex items-start gap-3;
    }
    .faq-check-box {
        @apply p-1 rounded-full text-brand mt-0.5 shrink-0;
        background-color: rgba(10, 92, 78, 0.05);
    }
    .faq-list-text {
        @apply text-[14.5px] font-medium text-body;
    }

    /* Estado Abierto */
    .faq-item.is-open .faq-title {
        @apply text-brand-dark;
    }
    :global(.faq-item.is-open .icon-closed) {
        display: none;
    }
    :global(.faq-item.is-open .icon-opened) {
        display: block;
    }
    .faq-item.is-open .faq-content-wrapper {
        @apply opacity-100;
        max-height: 1000px;
    }
    .faq-item.is-open .faq-content-inner {
        @apply opacity-100 visible;
    }
</style>

<script>
    /**
     * Lógica interactiva minimalista para FAQ (Arquitectura Elite)
     * Implementa comportamiento exclusivo (abre uno, cierra los demás).
     */
    document.addEventListener('astro:page-load', () => {
        const faqItems = document.querySelectorAll('.faq-item');
        
        faqItems.forEach(item => {
            const header = item.querySelector('.faq-header');
            
            header?.addEventListener('click', () => {
                const isCurrentlyOpen = item.classList.contains('is-open');
                
                // Comportamiento Exclusivo: Ocultar los demás suavemente
                faqItems.forEach(i => i.classList.remove('is-open'));
                
                // Abrir solo si no estaba abierto antes (Toggle inteligente)
                if (!isCurrentlyOpen) {
                    item.classList.add('is-open');
                }
            });
        });
    });
</script>
