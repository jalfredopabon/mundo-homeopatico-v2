---
/**
 * FAQ: Sección de preguntas frecuentes con soporte para acordeones
 * Arquitectura Elite: Datos centralizados y lógica modular.
 */
import Icons from "../shared/Icons.astro";
---

<section id="faq" class="scroll-mt-10">
    <header class="section-header">
        <h2 class="section-title">Preguntas frecuentes</h2>
        <p class="section-subtitle">Respondemos a las inquietudes más comunes.</p>
    </header>
    
    <div id="faq-container" class="faq-container">
        <!-- Skeleton Loading -->
        {[1, 2, 3, 4].map(() => (
            <div class="animate-pulse mb-4 border border-slate-100 rounded-xl p-6">
                <div class="h-5 bg-slate-100 rounded w-3/4 mb-4"></div>
                <div class="h-3 bg-slate-50 rounded w-1/2"></div>
            </div>
        ))}
    </div>
</section>

<script>
    import { getFAQData } from "../../data/api";
    import { renderFAQList } from "../../utils/faq-renderer";

    document.addEventListener('astro:page-load', async () => {
        const container = document.getElementById('faq-container');
        if (!container) return;

        try {
            const faqs = await getFAQData();
            container.innerHTML = renderFAQList(faqs);
            initAccordionLogic();
        } catch (e) {
            console.error("Error al cargar FAQs:", e);
            container.innerHTML = '<p class="text-center py-8 text-slate-500">Error al cargar la información.</p>';
        }

        function initAccordionLogic() {
            const faqItems = container.querySelectorAll('.faq-item');
            
            faqItems.forEach(item => {
                const header = item.querySelector('.faq-header');
                const contentWrapper = item.querySelector('.faq-content-wrapper') as HTMLElement;
                
                header?.addEventListener('click', () => {
                    const isCurrentlyOpen = item.classList.contains('is-open');
                    
                    // Cerrar todos los demás
                    faqItems.forEach(i => {
                        const otherWrapper = i.querySelector('.faq-content-wrapper') as HTMLElement;
                        i.classList.remove('is-open');
                        if (otherWrapper) otherWrapper.style.height = '0px';
                        
                        // Switch icons
                        const closedIcon = i.querySelector('.icon-closed');
                        const openedIcon = i.querySelector('.icon-opened');
                        closedIcon?.classList.remove('hidden');
                        openedIcon?.classList.add('hidden');
                    });
                    
                    // Abrir este si no estaba abierto
                    if (!isCurrentlyOpen) {
                        item.classList.add('is-open');
                        const inner = item.querySelector('.faq-content-inner');
                        if (inner && contentWrapper) {
                            contentWrapper.style.height = `${inner.scrollHeight}px`;
                        }
                        
                        // Switch icons
                        const closedIcon = item.querySelector('.icon-closed');
                        const openedIcon = item.querySelector('.icon-opened');
                        closedIcon?.classList.add('hidden');
                        openedIcon?.classList.remove('hidden');
                    }
                });
            });
        }
    });
</script>
