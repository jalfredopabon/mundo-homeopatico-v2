---
/**
 * Locations: Sección de sedes principales y distribuidores autorizados
 * Clonación Estricta: Se respeta el diseño visual idéntico al online.
 */
import Icons from "../shared/Icons.astro";
import ButtonElite from "../shared/ButtonElite.astro";

// TODO: migrar a data layer / CMS
---

<section id="sedes" class="scroll-mt-10">
    <header class="section-header">
        <h2 class="section-title">Sedes y distribuciones</h2>
        <p class="section-subtitle">Encuentra nuestra sede clínica y puntos autorizados.</p>
    </header>

    <div class="flex flex-col gap-8">
        <!-- Tarjeta Sede Principal -->
        <div class="location-card group flex flex-col lg:flex-row overflow-hidden">
            <div class="flex flex-1 flex-col justify-between p-8 lg:p-12">
                <div class="flex items-center gap-6 mb-10">
                        <div class="h-10 w-10 rounded-xl bg-surface-muted border border-subtle flex items-center justify-center text-brand group-hover:bg-brand group-hover:text-surface-white transition-all duration-500 shrink-0">
                        <Icons type="building" class="w-5 h-5" strokeWidth={2} />
                    </div>
                    <div>
                        <h3 class="text-[17px] font-bold text-secondary leading-snug">Sede principal y laboratorio</h3>
                        <p class="text-slate-700 text-[12px] font-bold mt-0.5">Bogotá D.C.</p>
                    </div>
                </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-3">
                            <div class="flex items-center gap-2.5 text-brand">
                                <Icons type="map-pin" class="w-5 h-5" strokeWidth={2} />
                                <span class="text-[11px] font-bold text-slate-700">Dirección</span>
                            </div>
                            <p id="main-branch-address" class="text-body leading-relaxed font-semibold text-[15px]">Cargando dirección...</p>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-center gap-2.5 text-brand">
                                <Icons type="clock" class="w-5 h-5" strokeWidth={2} />
                                <span class="text-[11px] font-bold text-slate-700">Horarios</span>
                            </div>
                            <p id="main-branch-hours" class="text-body leading-relaxed text-[15px]">Cargando horarios...</p>
                        </div>
                    </div>
                <div class="flex flex-col sm:flex-row gap-4 mt-10">
                    <ButtonElite id="main-branch-whatsapp" variant="primary" size="lg" icon="whatsapp" label="WhatsApp" />
                    <ButtonElite id="main-branch-phone" variant="outline" size="lg" icon="phone" label="Llamar" />
                </div>
            </div>
            <div class="relative w-full lg:w-[40%] min-h-[300px] lg:min-h-0 bg-surface-muted overflow-hidden border-l border-subtle/50">
                <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center grayscale contrast-125 opacity-20 filter blur-[1px]"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="relative z-10 flex flex-col items-center group-hover:-translate-y-1 transition-transform duration-500">
                        <div class="bg-surface-white px-4 py-2 rounded-lg border border-subtle whitespace-nowrap mb-2 relative">
                            <p class="text-[13px] font-bold text-secondary">Sede principal MH</p>
                            <div class="absolute -bottom-1.5 left-1/2 -translate-x-1/2 w-3 h-3 bg-surface-white border-r border-b border-subtle rotate-45"></div>
                        </div>
                        <div class="relative flex items-center justify-center h-12 w-12 bg-brand rounded-xl text-surface-white border-4 border-surface-white">
                            <Icons type="map-pin" class="w-6 h-6" strokeWidth={2.2} />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grilla de Distribuidores -->
        <div id="distributors-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Skeletons -->
            {[1, 2, 3].map(() => (
                <div class="animate-pulse bg-slate-50/50 rounded-2xl h-[220px] border border-slate-100 p-6">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-10 h-10 bg-slate-100 rounded-xl"></div>
                        <div class="flex-1">
                            <div class="h-4 bg-slate-100 rounded w-3/4 mb-2"></div>
                            <div class="h-3 bg-slate-50 rounded w-1/4"></div>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <div class="h-3 bg-slate-50 rounded w-full"></div>
                        <div class="h-3 bg-slate-50 rounded w-2/3"></div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    import { getConfigData, getDistributors } from "../../data/api";
    import { renderDistributorGrid, updateMainBranchUI } from "../../utils/locations-renderer";

    document.addEventListener('astro:page-load', async () => {
        const gridContainer = document.getElementById('distributors-grid');
        
        // Cargar Configuración y Distribuidores en paralelo
        try {
            const [config, distributors] = await Promise.all([
                getConfigData(),
                getDistributors()
            ]);

            // Actualizar Sede Principal
            updateMainBranchUI(config, distributors);

            // Actualizar Grilla de Distribuidores
            if (gridContainer) {
                gridContainer.innerHTML = renderDistributorGrid(distributors);
            }
        } catch (e) {
            console.error("Error al cargar sedes y distribuidores:", e);
        }
    });
</script>
