---
/**
 * Locations: Sección de sedes principales y distribuidores autorizados
 */
---

<section id="sedes" class="scroll-mt-10">
    <header class="mb-8 flex flex-col gap-1.5">
        <h2 class="text-[2.25rem] leading-tight font-extrabold text-secondary tracking-tight">Sedes y distribuciones</h2>
        <p class="text-slate-700 text-base font-medium">Encuentra nuestra sede clínica y puntos autorizados.</p>
    </header>
    <div class="flex flex-col gap-8">
        <!-- Tarjeta Sede Principal -->
        <div class="w-full bg-surface-white rounded-2xl border border-subtle/80 overflow-hidden flex flex-col lg:flex-row group hover:border-strong transition-all duration-500">
            <div class="flex flex-1 flex-col justify-between p-8 lg:p-12">
                <div>
                    <div class="inline-flex items-center gap-2 rounded-lg bg-brand/5 px-3 py-1 text-[11px] font-bold text-brand mb-6 border border-brand/20">
                        <!-- Icono Edificios (Hugeicons) -->
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5">
                            <path d="M15 2H9C5.69067 2 5 2.69067 5 6V22H19V6C19 2.69067 18.3093 2 15 2Z" />
                            <path d="M3 22H21" />
                            <path d="M15 22V19C15 17.3453 14.6547 17 13 17H11C9.34533 17 9 17.3453 9 19V22" />
                            <path d="M13.5 6H10.5M13.5 9.5H10.5M13.5 13H10.5" />
                        </svg>
                        Sede principal y laboratorio
                    </div>
                    <h3 class="text-secondary text-2xl font-extrabold mb-8 tracking-tight">Mundo homeopático Bogotá</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-3">
                            <div class="flex items-center gap-2.5 text-brand">
                                <!-- Icono Dirección/Ubicación (Hugeicons) -->
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                                    <path d="M13.6177 21.367C13.1841 21.773 12.6044 22 12.0011 22C11.3978 22 10.8182 21.773 10.3845 21.367C6.41302 17.626 1.09076 13.4469 3.68627 7.37966C5.08963 4.09916 8.45834 2 12.0011 2C15.5439 2 18.9126 4.09916 20.316 7.37966C22.9082 13.4393 17.599 17.6389 13.6177 21.367Z" />
                                    <path d="M15.5 11C15.5 12.933 13.933 14.5 12 14.5C10.067 14.5 8.5 12.933 8.5 11C8.5 9.067 10.067 7.5 12 7.5C13.933 7.5 15.5 9.067 15.5 11Z" />
                                </svg>
                                <span class="text-[11px] font-bold text-slate-700">Dirección</span>
                            </div>
                            <p class="text-body leading-relaxed font-semibold text-[15px]">Calle de la Salud 123<br/>Edificio San Lucas, Piso 4<br/>Bogotá D.C.</p>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-center gap-2.5 text-brand">
                                <!-- Icono Horarios (Hugeicons) -->
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                                    <circle cx="12" cy="12" r="10" />
                                    <path d="M12 8V12L14 14" />
                                </svg>
                                <span class="text-[11px] font-bold text-slate-700">Horarios</span>
                            </div>
                            <p class="text-body leading-relaxed text-[15px]">
                                <span class="font-bold">Lunes a viernes:</span> 8:00 AM - 6:00 PM<br/>
                                <span class="font-bold">Sábados:</span> 9:00 AM - 1:00 PM
                            </p>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col sm:flex-row gap-4 mt-10">
