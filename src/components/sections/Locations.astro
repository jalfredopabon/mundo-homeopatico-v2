---
/**
 * Locations: Sección de sedes principales y distribuidores autorizados
 * Clonación Estricta: Se respeta el diseño visual idéntico al online.
 */
import Icons from "../shared/Icons.astro";
import ButtonElite from "../shared/ButtonElite.astro";

// TODO: migrar a data layer / CMS
---

<section id="sedes" class="scroll-mt-10">
    <header class="section-header">
        <h2 class="section-title">Sedes y distribuciones</h2>
        <p class="section-subtitle">Encuentra nuestra sede clínica y puntos autorizados.</p>
    </header>

    <div class="flex flex-col gap-8">
        <!-- Tarjeta Sede Principal -->
        <div class="location-card group flex flex-col lg:flex-row overflow-hidden">
            <div class="flex flex-1 flex-col justify-between p-8 lg:p-12">
                    <div class="flex items-center gap-6 mb-10">
                        <div class="h-20 w-20 flex items-center justify-center shrink-0">
                            <img id="main-branch-logo" src="/img/logo-mundo-homeopatico.webp" alt="Logo MH" class="w-full h-full object-contain" />
                        </div>
                        <div>
                            <h3 class="text-[20px] font-bold text-secondary leading-tight">Sede principal y laboratorio</h3>
                            <p id="main-branch-city" class="text-brand text-[12px] font-bold mt-1">Cargando...</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-3">
                            <div class="flex items-center gap-2.5 text-brand">
                                <Icons type="map-pin" class="w-5 h-5" strokeWidth={2.5} />
                                <span class="text-[11px] font-bold text-slate-700">Dirección</span>
                            </div>
                            <p id="main-branch-address" class="text-body leading-relaxed font-semibold text-[15px]">Cargando dirección...</p>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-center gap-2.5 text-brand">
                                <Icons type="clock" class="w-5 h-5" strokeWidth={2.5} />
                                <span class="text-[11px] font-bold text-slate-700">Horarios</span>
                            </div>
                            <p id="main-branch-hours" class="text-body leading-relaxed text-[15px]">Cargando horarios...</p>
                        </div>
                    </div>
                <div id="main-branch-contacts" class="flex flex-wrap gap-4 mt-10">
                    <!-- Botones de contacto inyectados dinámicamente -->
                </div>
            </div>
            <a id="main-branch-map-image-link" href="#" target="_blank" class="relative w-full lg:w-[45%] min-h-[350px] lg:min-h-0 bg-surface-muted overflow-hidden group/map">
                <img id="main-branch-map-static" src="https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?q=80&w=800&auto=format&fit=crop" alt="Mapa de ubicación" class="absolute inset-0 w-full h-full object-cover grayscale contrast-125 opacity-30 group-hover/map:grayscale-0 group-hover/map:opacity-100 transition-all duration-700" />
                
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="bg-surface-white/95 backdrop-blur-sm px-6 py-4 rounded-2xl border border-subtle shadow-xl flex items-center gap-3 transform group-hover/map:scale-105 transition-all duration-500">
                        <div class="h-10 w-10 bg-brand/10 rounded-xl flex items-center justify-center text-brand">
                            <Icons type="map" class="w-5 h-5" strokeWidth={2.5} />
                        </div>
                        <span class="text-sm font-bold text-secondary">Click para ver mapa interactivo</span>
                    </div>
                </div>

                <!-- Botón Flotante 'Cómo Llegar' -->
                <div class="absolute bottom-6 left-6 right-auto">
                    <div class="bg-white/90 backdrop-blur-md border border-subtle shadow-lg text-secondary px-5 py-2.5 rounded-full text-xs font-bold flex items-center gap-2.5 transition-all duration-300 hover:scale-105 hover:border-brand hover:text-brand">
                        <span>Cómo llegar</span>
                        <Icons type="external-link" class="w-3.5 h-3.5" />
                    </div>
                </div>
            </a>
        </div>

        <!-- Grilla de Distribuidores -->
        <div id="distributors-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
            <!-- Skeletons -->
            {[1, 2, 3, 4].map(() => (
                <div class="animate-pulse bg-slate-50/50 rounded-2xl h-[220px] border border-slate-100 p-6">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-10 h-10 bg-slate-100 rounded-xl"></div>
                        <div class="flex-1">
                            <div class="h-4 bg-slate-100 rounded w-3/4 mb-2"></div>
                            <div class="h-3 bg-slate-50 rounded w-1/4"></div>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <div class="h-3 bg-slate-50 rounded w-full"></div>
                        <div class="h-3 bg-slate-50 rounded w-2/3"></div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    import { getConfigData, getDistributors } from "../../data/api";
    import { renderDistributorGrid, updateMainBranchUI } from "../../utils/locations-renderer";

    document.addEventListener('astro:page-load', async () => {
        const gridContainer = document.getElementById('distributors-grid');
        
        // Cargar Configuración y Distribuidores en paralelo
        try {
            const [config, distributors] = await Promise.all([
                getConfigData(),
                getDistributors()
            ]);

            // Actualizar Sede Principal
            updateMainBranchUI(config, distributors);

            // Actualizar Grilla de Distribuidores (Filtrando la Sede Principal para no duplicar)
            if (gridContainer) {
                const authorizedDistributors = distributors.filter(d => 
                    !(d.nombre || '').toLowerCase().includes('sede principal')
                );
                gridContainer.innerHTML = renderDistributorGrid(authorizedDistributors);
            }
        } catch (e) {
            console.error("Error al cargar sedes y distribuidores:", e);
        }
    });
</script>
