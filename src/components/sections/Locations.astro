                </div>
            </div>
            <div class="relative w-full lg:w-[40%] min-h-[300px] lg:min-h-0 bg-surface-muted overflow-hidden border-l border-subtle/50">
                <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center grayscale contrast-125 opacity-20 filter blur-[1px]"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="relative z-10 flex flex-col items-center group-hover:-translate-y-1 transition-transform duration-500">
                        <div class="bg-surface-white px-4 py-2 rounded-lg border border-subtle whitespace-nowrap mb-2 relative">
                            <p class="text-[13px] font-bold text-secondary">Sede principal MH</p>
                            <div class="absolute -bottom-1.5 left-1/2 -translate-x-1/2 w-3 h-3 bg-surface-white border-r border-b border-subtle rotate-45"></div>
                        </div>
                        <div class="relative flex items-center justify-center h-12 w-12 bg-brand rounded-full text-surface-white border-4 border-surface-white">
                            <!-- Icono Ubicación/Pin (Hugeicons) -->
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                                <path d="M13.6177 21.367C13.1841 21.773 12.6044 22 12.0011 22C11.3978 22 10.8182 21.773 10.3845 21.367C6.41302 17.626 1.09076 13.4469 3.68627 7.37966C5.08963 4.09916 8.45834 2 12.0011 2C15.5439 2 18.9126 4.09916 20.316 7.37966C22.9082 13.4393 17.599 17.6389 13.6177 21.367Z" />
