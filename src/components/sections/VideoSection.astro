---
// src/components/sections/VideoSection.astro
import { Image } from 'astro:assets';
import Icons from "../shared/Icons.astro";
/**
 * VideoSection: Sección de excelencia homeopática con video institucional
 * Clonación Estricta: Se respeta el diseño visual idéntico al online.
 */
---

<section id="excelencia" class="scroll-mt-10">
    <header class="section-header">
        <nav aria-label="Breadcrumb" class="catalog-breadcrumb mb-2">
            <span class="hover:text-slate-800 transition-colors cursor-pointer">Mundo Homeopático</span>
            <Icons type="chevron-right" class="w-[10px] h-[10px] text-slate-400" strokeWidth={3} />
            <span class="hover:text-slate-800 transition-colors cursor-pointer">Institucional</span>
        </nav>
        <h2 class="section-title mb-2">Excelencia homeopática</h2>
        <p class="section-subtitle">Nuestra promesa de calidad y procesos de manufactura.</p>
    </header>

    <!-- Contenedor de Video/Imagen a un player institucional -->
    <div id="video-container" class="relative group aspect-video sm:aspect-[16/9] w-full overflow-hidden rounded-2xl bg-secondary border border-strong/60 transition-all">
        <!-- Iframe oculto por defecto -->
        <div id="youtube-overlay" class="absolute inset-0 z-50 hidden bg-black">
            <iframe 
                id="youtube-iframe"
                width="100%" 
                height="100%" 
                src="" 
                title="YouTube video player" 
                frameborder="0" 
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                referrerpolicy="strict-origin-when-cross-origin" 
                allowfullscreen 
                class="w-full h-full"
            ></iframe>
            <button id="close-video" class="absolute top-4 right-4 z-[60] p-2 bg-black/50 text-white rounded-full hover:bg-black/80 transition-all opacity-0 group-hover:opacity-100">
                <Icons type="close-x" class="w-6 h-6" />
            </button>
        </div>

        <div id="video-preview-elements">
            <Image 
                src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=1200&auto=format&fit=crop" 
                alt="Laboratorio farmacéutico clínico moderno" 
                width={1200}
                height={675}
                class="h-full w-full object-cover opacity-60 group-hover:scale-105 group-hover:opacity-70 transition-all duration-[2000ms]"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-secondary/90 via-transparent to-transparent pointer-events-none"></div>
            <div class="absolute inset-0 flex items-center justify-center z-20">
                <button id="play-video-btn" class="flex h-20 w-20 items-center justify-center rounded-xl bg-surface-white/10 backdrop-blur-md text-surface-white border border-surface-white/20 hover:bg-surface-white hover:text-brand transition-all duration-300 scale-95 hover:scale-105 active:scale-95 group/play" aria-label="Reproducir video">
                    <Icons type="play" class="w-[36px] h-[36px]" />
                </button>
            </div>
            <div class="absolute bottom-0 left-0 w-full p-6 sm:p-8 pointer-events-none">
                <div class="bg-black/30 backdrop-blur-md border border-surface-white/10 rounded-xl p-5 flex flex-col md:flex-row md:items-center justify-between gap-6 pointer-events-auto">
                    <div class="flex flex-col gap-1.5">
                        <p class="text-sm font-bold text-surface-white tracking-widest opacity-90 uppercase">Procesos de calidad premium</p>
                        <p class="text-surface-white/80 text-xs sm:text-sm max-w-md">Descubra cómo transformamos la materia prima en soluciones homeopáticas de alta fidelidad clínica.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('astro:page-load', () => {
        const videoSection = document.getElementById('excelencia');
        
        // --- HIDRATACIÓN INTELIGENTE: Solo inicializar cuando sea visible ---
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    initVideoLogic();
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        if (videoSection) observer.observe(videoSection);

        function initVideoLogic() {
            const playBtn = document.getElementById('play-video-btn');
            const closeBtn = document.getElementById('close-video');
            const overlay = document.getElementById('youtube-overlay');
            const iframe = document.getElementById('youtube-iframe') as HTMLIFrameElement;
            const videoId = "ZCkVmauoVVo";

            if (playBtn && overlay && iframe) {
                playBtn.addEventListener('click', () => {
                    iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&rel=0`;
                    overlay.classList.remove('hidden');
                    overlay.classList.add('flex');
                });
            }

            if (closeBtn && overlay && iframe) {
                closeBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    iframe.src = "";
                    overlay.classList.add('hidden');
                    overlay.classList.remove('flex');
                });
            }
        }
    });
</script>
