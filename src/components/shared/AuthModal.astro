---
import Icons from './Icons.astro';
---

<!-- Modal de Autenticación (Capa sobre el Dashboard, respeta TabNav en móvil) -->
<div id="auth-modal-overlay" class="fixed top-0 left-0 right-0 bottom-16 md:bottom-0 z-[70] md:z-[100] bg-slate-900/40 backdrop-blur-sm flex items-center justify-center overflow-y-auto transition-all duration-500 ease-in-out">
    
    <!-- Enlace invisible que cubre el fondo para cerrar el modal al hacer clic fuera -->
    <a href="/" class="absolute inset-0 z-0" aria-label="Cerrar y volver al inicio"></a>

    <div id="auth-modal" class="w-full max-w-[440px] mx-4 relative z-10">
        
        <!-- Tarjeta Principal del Modal -->
        <div class="bg-surface-muted rounded-3xl overflow-hidden relative border border-white/60">
            
            <!-- Botón de Cerrar (X) Superior Derecha -->
            <a href="/" class="absolute top-6 right-6 p-2 rounded-xl text-secondary hover:text-body hover:bg-surface-muted transition-colors focus:outline-none focus:ring-1 focus:ring-brand z-20" aria-label="Cerrar modal">
                <Icons type="close-x" class="w-5 h-5" />
            </a>

            <!-- Encabezado del Modal -->
            <div class="px-8 pt-10 pb-4 text-left">
                <h2 class="text-body text-[26px] font-extrabold tracking-tight mb-2 font-display">Acceso</h2>
            </div>

            <!-- Cuerpo del Formulario -->
            <div class="px-8 pb-10">
                <form id="auth-form" class="space-y-4" novalidate>
                    
                    <!-- Campo NIT / Cédula -->
                    <div class="space-y-1.5">
                        <label for="auth-nit" class="text-[13px] font-bold text-body">
                            Cédula o NIT
                        </label>
                        <div class="relative">
                            <input 
                                type="text" 
                                id="auth-nit" 
                                placeholder="Ej: 1234567890"
                                autocomplete="username"
                                class="w-full px-4 py-3 bg-surface-white border border-subtle focus:border-brand rounded-xl text-[15px] text-body placeholder:text-muted focus:outline-none focus:ring-1 focus:ring-brand shadow-sm hover:border-strong transition-all focus:placeholder:text-transparent"
                            />
                        </div>
                    </div>

                    <!-- Campo Contraseña -->
                    <div class="space-y-1.5">
                        <label for="auth-password" class="text-[13px] font-bold text-body">
                            Contraseña
                        </label>
                        <div class="relative">
                            <input 
                                type="password" 
                                id="auth-password"
                                placeholder="••••••••••"
                                autocomplete="current-password"
                                class="w-full px-4 py-3 bg-surface-white border border-subtle focus:border-brand rounded-xl text-[15px] text-body placeholder:text-muted focus:outline-none focus:ring-1 focus:ring-brand shadow-sm hover:border-strong transition-all pr-12 tracking-widest font-mono focus:placeholder:text-transparent"
                            />
                            <!-- Botón para mostrar/ocultar contraseña -->
                             <button type="button" id="toggle-password" class="absolute right-3 top-1/2 -translate-y-1/2 p-2 rounded-lg text-secondary hover:text-body hover:bg-surface-muted transition-all" aria-label="Mostrar contraseña">
                                <Icons type="eye" id="icon-eye-open" class="w-[18px] h-[18px]" />
                                <Icons type="eye-off" id="icon-eye-closed" class="w-[18px] h-[18px] hidden" />
                            </button>
                        </div>
                        <!-- Vía de escape -->
                        <div class="flex justify-end pt-1">
                            <a 
                                href="https://wa.me/573000000000?text=Hola,%20Soy%20profesional%20m%C3%A9dico%20y%20olvid%C3%A9%20mis%20credenciales." 
                                target="_blank" 
                                rel="noopener noreferrer"
                                class="text-[12px] font-medium text-secondary hover:text-brand hover:underline transition-all cursor-pointer"
                            >
                                ¿Olvidó su contraseña?
                            </a>
                        </div>
                    </div>

                    <!-- Checkbox "Mantener sesión" -->
                    <div class="flex items-center pt-2 pb-1">
                        <label class="flex items-center gap-2.5 text-[13px] text-secondary cursor-pointer hover:text-body transition-colors">
                            <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Mantener sesión iniciada
                        </label>
                    </div>

                    <!-- Mensaje de Error -->
                    <div id="auth-error" class="hidden items-center gap-2.5 px-4 py-3 bg-red-50 border border-red-100 rounded-xl text-red-600 text-[13px] font-medium animate-shake">
                        <Icons type="alert-triangle" class="w-4 h-4 shrink-0" />
                        <span id="auth-error-text">Credenciales incorrectas</span>
                    </div>

                    <!-- Botón de Ingreso -->
                    <button 
                        type="submit" 
                        id="auth-submit"
                        class="w-full flex items-center justify-center bg-brand-vibrant hover:bg-brand text-white font-bold py-3.5 rounded-xl transition-all duration-200 hover:-translate-y-[1px] active:scale-[0.98] focus:ring-2 focus:ring-brand focus:ring-offset-2 text-[15px]"
                    >
                        Ingresar
                    </button>
                    
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    import { validateAccess } from '../../data/api';

    function getInitials(name: string): string {
        const cleanName = name.replace(/^(Dr\.|Dra\.|Esp\.|Lic\.)\s+/i, '');
        const parts = cleanName.split(' ').filter(p => p.length > 0);
        if (parts.length >= 2) {
            return (parts[0][0] + parts[1][0]).toUpperCase();
        } else if (parts.length === 1) {
            return parts[0].substring(0, 2).toUpperCase();
        }
        return 'IN';
    }

    function initAuth() {
        const overlay = document.getElementById('auth-modal-overlay');
        const form = document.getElementById('auth-form') as HTMLFormElement | null;
        const inputNit = document.getElementById('auth-nit') as HTMLInputElement | null;
        const inputPass = document.getElementById('auth-password') as HTMLInputElement | null;
        const inputKeep = form?.querySelector('input[type="checkbox"]') as HTMLInputElement | null;
        const errorBox = document.getElementById('auth-error');
        const errorText = document.getElementById('auth-error-text');
        const toggleBtn = document.getElementById('toggle-password');
        const iconOpen = document.getElementById('icon-eye-open');
        const iconClosed = document.getElementById('icon-eye-closed');
        const submitBtn = document.getElementById('auth-submit');

        if (!form || !overlay) return;

        // Bloqueo de scroll al detectar el modal activo
        if (!overlay.classList.contains('hidden')) {
            document.body.style.overflow = 'hidden';
            setTimeout(() => inputNit?.focus(), 500);
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const user = inputNit?.value.trim(); 
            const pass = inputPass?.value.trim();

            console.log('[Elite Auth] Intentando ingreso con usuario:', user);

            if (!user || !pass) {
                errorBox?.classList.remove('hidden');
                errorBox?.classList.add('flex');
                if (errorText) errorText.textContent = 'Ingresa usuario y contraseña.';
                return;
            }

            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Verificando...';
            }
            errorBox?.classList.add('hidden');

            try {
                const result = await validateAccess(user, pass);
                console.log('[Elite Auth] Respuesta de Google Script:', result);

                if (result && result.ok) {
                    const sessionData = {
                        nombre_usuario: result.nombre_usuario || user,
                        iniciales: getInitials(result.nombre_usuario || user),
                        timestamp: Date.now()
                    };

                    const storage = inputKeep?.checked ? localStorage : sessionStorage;
                    storage.setItem('mh_session', JSON.stringify(sessionData));

                    // Notificar a otros componentes (como el Sidebar)
                    document.dispatchEvent(new CustomEvent('mhSessionUpdated'));

                    if (submitBtn) submitBtn.textContent = '¡Bienvenido!';
                    overlay.classList.add('opacity-0');
                    
                    setTimeout(() => {
                        overlay.classList.add('hidden');
                        document.body.style.overflow = '';
                    }, 400);
                } else {
                    const msg = result?.error || 'Credenciales incorrectas';
                    throw new Error(msg);
                }
            } catch (err: any) {
                console.error('[Elite Auth] Error en validación:', err);
                errorBox?.classList.remove('hidden');
                errorBox?.classList.add('flex');
                if (errorText) errorText.textContent = err.message || 'Error de conexión con el servidor.';
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Ingresar';
                }
                inputPass?.focus();
            }
        });

        toggleBtn?.addEventListener('click', () => {
            if (!inputPass) return;
            const isPassword = inputPass.type === 'password';
            inputPass.type = isPassword ? 'text' : 'password';
            iconOpen?.classList.toggle('hidden');
            iconClosed?.classList.toggle('hidden');
        });
    }

    // --- HIDRATACIÓN INTELIGENTE (Paso 2.1) ---
    // Usamos requestIdleCallback para que el modal se inicialice cuando el navegador esté libre.
    document.addEventListener('astro:page-load', () => {
        if ('requestIdleCallback' in window) {
            window.requestIdleCallback(() => initAuth());
        } else {
            setTimeout(() => initAuth(), 200);
        }
    });
</script>

<style>
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-4px); }
        75% { transform: translateX(4px); }
    }
    .animate-shake {
        animation: shake 0.4s ease-in-out;
    }
</style>
