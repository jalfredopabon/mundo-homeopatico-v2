---
// src/components/shared/BadgeElite.astro
interface Props {
  label: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'success' | 'warning';
  size?: 'xs' | 'sm' | 'md';
  class?: string;
}

const { 
  label, 
  variant = 'primary', 
  size = 'sm',
  class: className = '' 
} = Astro.props;

// Diccionario de Estrictos Estilos Elite
const variants = {
  primary: "bg-brand/10 text-brand border-brand/20",
  secondary: "bg-slate-100 text-slate-600 border-slate-200",
  outline: "bg-transparent text-slate-500 border-subtle",
  ghost: "bg-slate-50/50 text-slate-400 border-transparent",
  success: "bg-emerald-50 text-emerald-700 border-emerald-100",
  warning: "bg-amber-50 text-amber-700 border-amber-100"
};

const sizes = {
  xs: "px-1.5 py-0.5 text-[10px] font-bold tracking-tight",
  sm: "px-2.5 py-1 text-[11px] font-semibold tracking-normal",
  md: "px-3 py-1.5 text-[12px] font-semibold"
};
---

<span class:list={[
  "inline-flex items-center justify-center rounded-full border transition-all select-none",
  variants[variant],
  sizes[size],
  className
]}>
  {label}
</span>
