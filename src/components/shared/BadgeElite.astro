---
// src/components/shared/BadgeElite.astro
interface Props {
  label: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'success' | 'warning';
  size?: 'xs' | 'sm' | 'md';
  class?: string;
}

const { 
  label, 
  variant = 'primary', 
  size = 'sm',
  class: className = '' 
} = Astro.props;

// Diccionario de Estrictos Estilos Elite (Sincronizados con global.css)
const variants = {
  primary: "badge-elite--brand",
  secondary: "badge-elite--slate",
  outline: "badge-elite--neutral", // Para el catálogo (Gris/Gris)
  ghost: "badge-elite--slate opacity-50",
  success: "badge-elite--emerald",
  warning: "badge-elite--amber",
  info: "badge-elite--indigo",
  neutral: "badge-elite--neutral",
  rose: "badge-elite--rose"
};

const sizes = {
  xs: "px-1.5 py-0.5 text-[9px] font-medium tracking-tight",
  sm: "px-2 py-0.5 text-[10px] font-medium tracking-normal",
  md: "px-2.5 py-1 text-[11px] font-medium"
};
---

<span class:list={[
  "badge-elite",
  variants[variant],
  sizes[size],
  className
]}>
  {label}
</span>
