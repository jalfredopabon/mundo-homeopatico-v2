---
// src/components/shared/BadgeElite.astro
interface Props {
  label: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'slate' | 'ghost' | 'success' | 'warning' | 'info' | 'indigo' | 'neutral' | 'rose' | 'violet' | 'sky' | 'cyan' | 'bronze';
  size?: 'xs' | 'sm' | 'md';
  class?: string;
}

const { 
  label, 
  variant = 'primary', 
  size = 'sm',
  class: className = '' 
} = Astro.props;

// Diccionario de Estrictos Estilos Elite (Sincronizados con global.css)
const variants = {
  primary: "badge-elite--brand",
  secondary: "badge-elite--slate",
  slate: "badge-elite--slate",
  outline: "badge-elite--neutral",
  ghost: "badge-elite--slate opacity-50",
  success: "badge-elite--emerald",
  warning: "badge-elite--amber",
  info: "badge-elite--indigo",
  indigo: "badge-elite--indigo",
  neutral: "badge-elite--neutral",
  rose: "badge-elite--rose",
  violet: "badge-elite--violet",
  sky: "badge-elite--sky",
  cyan: "badge-elite--cyan",
  bronze: "badge-elite--bronze"
};

const sizes = {
  xs: "px-1.5 py-0.5 text-[9px] font-medium tracking-tight",
  sm: "px-2 py-0.5 text-[10px] font-medium tracking-normal",
  md: "px-2.5 py-1 text-[11px] font-medium"
};
---

<span class:list={[
  "badge-elite",
  variants[variant],
  sizes[size],
  className
]}>
  {label}
</span>
