---
// src/components/shared/Footer.astro
const year = new Date().getFullYear();
---

<footer class="bg-slate-900 py-12 px-8 md:px-16 mt-auto border-t border-slate-800">
  <div class="max-w-full mx-auto flex flex-col md:flex-row gap-10 md:gap-8 items-start justify-between">
    
    <!-- Branding & Descripción (Columna Izquierda) -->
    <div class="space-y-4 md:w-1/3">
      <div class="flex items-center gap-3">
        <!-- Logo Icon MH -->
        <div class="w-10 h-10 bg-white/5 border border-white/10 flex items-center justify-center rounded text-white font-bold tracking-widest shadow-sm">
          MH
        </div>
        <h2 class="text-[1.3rem] font-bold text-white tracking-tight">
          Mundo homeopático
        </h2>
      </div>
      <p class="text-[13px] text-slate-400 leading-relaxed font-light md:pr-4">
        Más de 20 años formulando soluciones magistrales con absoluta precisión y los más altos estándares de calidad internacional.
      </p>
    </div>

    <!-- Redes Sociales y Links (Columna Central) -->
    <div class="space-y-4 flex flex-col md:items-center md:text-center md:w-1/3">
      <div class="h-10 flex items-center">
        <h3 class="text-[13px] font-bold text-slate-300 tracking-[0.1em] uppercase">Síguenos</h3>
      </div>
      <div class="flex items-center justify-start md:justify-center gap-4">
        <!-- Instagram -->
        <a href="#/" class="w-9 h-9 flex items-center justify-center rounded-full bg-slate-800 text-slate-400 hover:bg-pink-500 hover:text-white transition-all duration-300 group" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
        </a>
        <!-- WhatsApp -->
        <a href="#/" class="w-9 h-9 flex items-center justify-center rounded-full bg-slate-800 text-slate-400 hover:bg-emerald-500 hover:text-white transition-all duration-300 group" aria-label="WhatsApp">
           <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        </a>
        <!-- Web Principal -->
        <a href="https://mhmundohomeopatico.com" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-full bg-slate-800 text-slate-400 hover:bg-slate-700 hover:text-white transition-all duration-300 group" aria-label="Sitio web principal">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path><path d="M2 12h20"></path></svg>
        </a>
      </div>
    </div>

    <!-- Copyright & Créditos (Columna Derecha) -->
    <div class="space-y-3 flex flex-col h-full md:items-end md:text-right md:w-1/3">
      <div class="h-10 flex items-center">
        <p class="text-[13px] font-semibold text-slate-300">
          &copy; {year} Mundo Homeopático.
        </p>
      </div>
      <div class="mt-1 space-y-1">
        <p class="text-[12px] font-medium text-slate-500">
          Todos los derechos reservados.
        </p>
        <p class="text-[12px] text-slate-500 font-medium">
          Medellín, Colombia · Creado por A.P.
        </p>
      </div>
    </div>
  </div>

  <!-- Botón Back To Top (Se comporta fijo en pantalla cuando se hace scroll) -->
  <button id="back-to-top" class="fixed bottom-8 right-8 w-11 h-11 bg-white text-slate-800 rounded-full shadow-[0_8px_30px_rgba(0,0,0,0.12)] flex items-center justify-center translate-y-20 opacity-0 invisible hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(0,0,0,0.2)] hover:text-brand transition-all duration-500 z-50 ring-1 ring-slate-100 focus:outline-none focus:ring-2 focus:ring-brand" aria-label="Volver arriba">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5"></path><polyline points="5 12 12 5 19 12"></polyline></svg>
  </button>
</footer>

<script>
  // Lógica para mostrar/ocultar el botón "Back to Top"
  document.addEventListener('DOMContentLoaded', () => {
    const backToTopBtn = document.getElementById('back-to-top');
    // Escuchamos el scroll de la columna derecha, que es donde ocurre si estamos en Dashboard mode
    // (O el scroll del body si estamos en página normal)
    const scrollContainer = document.querySelector('.overflow-y-auto') || window;
    
    scrollContainer.addEventListener('scroll', () => {
      // Necesitamos verificar cuánto se ha bajado en Y
      const scrollTop = (scrollContainer as HTMLElement).scrollTop || window.scrollY;
      
      if (scrollTop > 300) {
        // Mostrar botón flotante si se hace scroll más de 300px
        backToTopBtn?.classList.remove('translate-y-20', 'opacity-0', 'invisible');
        backToTopBtn?.classList.add('translate-y-0', 'opacity-100', 'visible');
      } else {
        // Ocultar botón flotante
        backToTopBtn?.classList.add('translate-y-20', 'opacity-0', 'invisible');
        backToTopBtn?.classList.remove('translate-y-0', 'opacity-100', 'visible');
      }
    });

    // Acción para subir al hacer click
    backToTopBtn?.addEventListener('click', () => {
      scrollContainer.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  });
</script>
