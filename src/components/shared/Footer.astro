---
// src/components/shared/Footer.astro
import Icons from "./Icons.astro";
import { getConfigData } from "../../data/api";

const year = new Date().getFullYear();

let autorLink = "https://www.linkedin.com/in/jalfredopabon/";
let footerDescripcion = "Más de 20 años formulando soluciones magistrales con absoluta precisión y los más altos estándares de calidad internacional.";
let linkInstagram = "https://instagram.com/mundohomeopatico";
let linkWhatsapp = "https://wa.me/573001234567";
let linkWeb = "https://mhmundohomeopatico.com";

try {
  const config = await getConfigData();
  if (config.link_autor || config.autor_link) {
    autorLink = config.link_autor || config.autor_link;
  }
  if (config.footer_descripcion) {
    footerDescripcion = config.footer_descripcion;
  }
  if (config.link_instagram) {
    linkInstagram = config.link_instagram;
  }
  if (config.link_whatsapp) {
    linkWhatsapp = config.link_whatsapp;
  }
  if (config.link_web) {
    linkWeb = config.link_web;
  }
} catch (e) {
  console.warn("No se pudo cargar la configuracion del footer.");
}
---

<footer class="footer-main">
  <!-- Sección Superior: Grid de Enlaces y Contacto -->
  <div class="max-w-full mx-auto px-8 md:px-[72px] grid grid-cols-1 md:grid-cols-4 gap-12 items-start justify-between relative z-10 w-full pb-16">

    <!-- Columna 1: Logo & Descripción -->
    <div class="space-y-4 group cursor-default">
      <div class="h-12 flex items-end border-b border-slate-100 pb-3 gap-3">
        <div class="footer-logo-box">MH</div>
        <h2 class="text-[1.3rem] font-bold text-slate-900 tracking-tight group-hover:text-brand transition-colors duration-500 font-serif leading-none">Mundo homeopático</h2>
      </div>
      <p class="text-[13px] text-slate-500 leading-relaxed font-normal md:pr-4 group-hover:text-slate-700 transition-colors duration-500">
        {footerDescripcion}
      </p>
    </div>

    <!-- Columna 2: Navegación -->
    <div class="space-y-4 flex flex-col items-start">
      <div class="h-12 flex items-end border-b border-slate-100 w-full pb-3">
        <h3 class="footer-title">Navegación</h3>
      </div>
      <div class="flex flex-col gap-2.5">
        <a href="/" class="text-[12px] font-semibold text-slate-500 hover:text-brand transition-colors">Catálogo de productos</a>
        <a href="/vademecum" class="text-[12px] font-semibold text-slate-500 hover:text-brand transition-colors">Vademécum clínico</a>
        <a href="/contacto" class="text-[12px] font-semibold text-slate-500 hover:text-brand transition-colors">Sedes y contacto</a>
      </div>
    </div>

    <!-- Columna 3: Redes Sociales -->
    <div class="space-y-4 flex flex-col items-start">
      <div class="h-12 flex items-end border-b border-slate-100 w-full pb-3">
        <h3 class="footer-title">Síguenos</h3>
      </div>
      <div class="flex items-center justify-start gap-4">
        <a href={linkInstagram} target="_blank" rel="noopener noreferrer" class="footer-social-link group" data-brand="instagram" aria-label="Instagram">
          <Icons type="instagram" class="w-[18px] h-[18px] group-hover:scale-110 transition-transform" strokeWidth={1.5} />
        </a>
        <a href={linkWhatsapp} target="_blank" rel="noopener noreferrer" class="footer-social-link group" data-brand="whatsapp" aria-label="WhatsApp">
          <Icons type="whatsapp" class="w-[18px] h-[18px] group-hover:scale-110 transition-transform" strokeWidth={2} />
        </a>
        <a href={linkWeb} target="_blank" rel="noopener noreferrer" class="footer-social-link group" data-brand="web" aria-label="Sitio web principal">
          <Icons type="globe" class="w-[18px] h-[18px] group-hover:scale-110 transition-transform" strokeWidth={2} />
        </a>
      </div>
    </div>

    <!-- Columna 4: Ubicación e Info -->
    <div class="space-y-4 flex flex-col md:items-start">
      <div class="h-12 flex items-end border-b border-slate-100 w-full pb-3">
        <h3 class="footer-title">Ubicación</h3>
      </div>
      <div class="space-y-2 text-[12px] text-slate-500 font-medium">
        <p>Medellín, Colombia</p>
        <a href={autorLink} target="_blank" rel="noopener noreferrer" class="inline-block hover:text-brand transition-colors group">
          Creado por <span class="text-slate-800 font-bold group-hover:text-brand transition-colors">Alfredo Pabón</span>
        </a>
      </div>
    </div>

  </div>

  <!-- Sección Inferior: Lienzo Botánico de Acuarela -->
  <div class="w-full h-[260px] md:h-[340px] relative mt-auto flex items-end justify-center overflow-hidden select-none pointer-events-none">
    
    <!-- Imagen de Naturaleza de Fondo -->
    <div class="absolute inset-0 bg-cover bg-center transition-transform duration-[12s] ease-out hover:scale-105" style="background-image: url('/img/img_footer.webp');">
       <!-- Gradiente: Desvanecimiento suave desde el blanco del fondo hacia transparente para fundirse con la cuadrícula de textos -->
       <div class="absolute inset-0 bg-gradient-to-b from-surface-white to-transparent"></div>
    </div>

  </div>

  <button id="back-to-top" class="btn-back-to-top shadow-md border border-slate-100/50" aria-label="Volver arriba">
    <Icons type="arrow-up" class="w-5 h-5" strokeWidth={2.5} />
  </button>
</footer>

<script>
  document.addEventListener('astro:page-load', () => {
    const backToTopBtn = document.getElementById('back-to-top');
    // Detectamos el contenedor de scroll más cercano (importante para arquitecturas tipo dashboard)
    const scrollContainer = backToTopBtn?.closest('.overflow-y-auto') || window;
    
    scrollContainer.addEventListener('scroll', () => {
      const scrollTop = (scrollContainer instanceof HTMLElement) ? scrollContainer.scrollTop : window.scrollY;
      if (scrollTop > 400) {
        backToTopBtn?.classList.remove('translate-y-20', 'opacity-0', 'invisible');
        backToTopBtn?.classList.add('translate-y-0', 'opacity-100', 'visible');
      } else {
        backToTopBtn?.classList.add('translate-y-20', 'opacity-0', 'invisible');
        backToTopBtn?.classList.remove('translate-y-0', 'opacity-100', 'visible');
      }
    });

    backToTopBtn?.addEventListener('click', () => {
      scrollContainer.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
