---
interface Props {
  mostrarZoom?: boolean;
}

const { mostrarZoom = false } = Astro.props;

// Helper para saber qué ruta está activa
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full bg-surface-white border-b border-subtle transition-all duration-300">
  <div class="max-w-full mx-auto h-16 md:h-20 flex items-center justify-between">
    
    <!-- Lado Izquierdo: Identidad de Marca (Alineado con Sidebar w-64) -->
    <div class="w-64 flex-shrink-0 flex justify-start pl-6">
      <a href="/" class="no-underline inline-flex items-center gap-2.5 transition-transform hover:scale-105 active:scale-95 group">
      <!-- Icono provisional (reemplazar por el logo real) -->
      <div class="w-9 h-9 bg-brand flex items-center justify-center rounded text-white text-sm font-bold tracking-widest shadow-md group-hover:shadow-lg transition-all">
        MH
      </div>
      <h1 class="text-lg font-bold text-slate-800 tracking-tight whitespace-nowrap">
        Mundo homeopático
      </h1>
      </a>
    </div>

    <!-- Centro: Navegación Principal -->
    <nav class="hidden md:flex flex-1 items-center justify-center gap-8 px-8">
      <a 
        href="/" 
        class={`no-underline text-sm font-semibold relative py-1 transition-colors group ${
          currentPath === '/' ? 'text-brand' : 'text-slate-800 hover:text-brand'
        }`}
      >
        Lista de precios
        <span class={`absolute -bottom-1 left-1/2 -translate-x-1/2 h-[2px] bg-brand transition-all duration-300 ease-out ${
          currentPath === '/' ? 'w-full' : 'w-0 group-hover:w-full'
        }`}></span>
      </a>
      
      <a 
        href="/contacto" 
        class={`no-underline text-sm font-semibold relative py-1 transition-colors group ${
          currentPath === '/contacto' ? 'text-brand' : 'text-slate-800 hover:text-brand'
        }`}
      >
        Sedes y contacto
        <span class={`absolute -bottom-1 left-1/2 -translate-x-1/2 h-[2px] bg-brand transition-all duration-300 ease-out ${
          currentPath === '/contacto' ? 'w-full' : 'w-0 group-hover:w-full'
        }`}></span>
      </a>
      
      <!-- Botón Soy Médico -->
      <a 
        href="/vademecum" 
        class={`no-underline relative group flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full transition-all shadow-sm hover:shadow-md border ${
          currentPath === '/vademecum' 
            ? 'bg-transparent text-brand border-brand hover:bg-brand/5' 
            : 'bg-brand text-white border-transparent hover:bg-brand-dark'
        }`}
      >
        <span>Soy médico</span>
        <!-- Icono de Candado -->
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-90"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      </a>
    </nav>

    <!-- Lado Derecho: Controles Operativos -->
    <div class="w-64 flex-shrink-0 flex items-center justify-end gap-4 pr-6">
      
      {mostrarZoom && (
        <div class="relative group hidden sm:flex flex-col items-center justify-center cursor-pointer">
          <button class="flex flex-col items-center justify-center p-1.5 min-w-[3rem] text-slate-800 hover:bg-slate-100 rounded-lg transition-colors" aria-label="Cambiar tamaño de texto">
            <span class="h-5 flex items-end justify-center font-bold leading-none tracking-tighter text-slate-800/90 pb-[1px]">
              <span class="text-[17px]">A</span>
              <span class="text-[11px] ml-[1px]">A</span>
            </span>
            <span class="text-[10px] font-medium text-slate-800 mt-[2px]">Zoom</span>
          </button>
          
          <!-- Tooltip Animado (Aparece en hover) -->
          <div class="absolute top-full mt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-1 group-hover:translate-y-0 z-50">
            <div class="bg-slate-800 text-white text-xs font-medium py-1.5 px-3 rounded shadow-xl whitespace-nowrap relative">
              Tamaño normal
              <!-- Triangulito del tooltip -->
              <div class="absolute -top-1 left-1/2 -translate-x-1/2 border-solid border-b-slate-800 border-b-[6px] border-x-transparent border-x-[5px] border-t-0"></div>
            </div>
          </div>
        </div>
      )}

      <!-- Botón Carrito -->
      <button id="header-cart-btn" class="relative flex flex-col items-center justify-center p-1.5 min-w-[3rem] text-slate-800 hover:bg-slate-100 rounded-lg transition-colors group" aria-label="Ver carrito de pedidos">
         <div class="h-5 flex items-center justify-center text-slate-800/90">
           <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-rotate-3 transition-transform"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
         </div>
        <span class="text-[10px] font-medium text-slate-800 mt-[2px]">Pedidos</span>
        
        <!-- Burbuja de notificación con efecto latido (Pulse) -->
        <span class="absolute top-0 right-0 flex h-[18px] w-[18px]">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
          <span class="relative inline-flex items-center justify-center rounded-full h-[18px] w-[18px] bg-red-500 text-white text-[9px] font-bold shadow-sm">3</span>
        </span>
      </button>
    </div>
  </div>

  <!-- Barra de progreso / loading sutil (Obligatoria por UX) -->
  <div class="w-full h-[2px] bg-slate-100 relative overflow-hidden">
    <!-- El width será controlado por JS, aquí hay un estado de ejemplo al 30% -->
    <div class="h-full bg-brand w-[30%] rounded-r-full shadow-[0_0_10px_rgba(37,99,235,0.5)] transition-all duration-500 ease-out" id="global-progress-bar"></div>
  </div>
</header>

<script>
  // Emitir evento global para abrir/cerrar el carrito desde el Header
  document.addEventListener('DOMContentLoaded', () => {
    const cartBtn = document.getElementById('header-cart-btn');
    if (cartBtn) {
      cartBtn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('toggleCart'));
      });
    }
  });
</script>
