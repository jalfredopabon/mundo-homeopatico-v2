---
interface Props {
  mostrarZoom?: boolean;
}

const { mostrarZoom = false } = Astro.props;

// Helper para saber qué ruta está activa
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full bg-surface-white border-b border-subtle transition-all duration-300">
  <div class="max-w-full mx-auto h-16 md:h-20 flex items-center justify-between">
    
    <!-- Lado Izquierdo: Identidad de Marca (Alineado con Sidebar w-64 en Desktop) -->
    <div class="w-auto md:w-64 flex-shrink-0 flex justify-start pl-4 md:pl-4">
      <a href="/" class="no-underline inline-flex items-center gap-2.5 transition-transform hover:scale-105 active:scale-95 group">
      <!-- Icono provisional (reemplazar por el logo real) -->
      <div class="w-11 h-11 bg-brand flex items-center justify-center rounded text-white text-base font-bold tracking-widest transition-all">
        MH
      </div>
      <h1 class="hidden md:block text-lg font-bold text-slate-800 tracking-tight whitespace-nowrap">
        Mundo homeopático
      </h1>
      </a>
    </div>

    <!-- Centro: Navegación Principal -->
    <nav class="hidden md:flex flex-1 self-stretch justify-center gap-8 px-8">
      <a 
        href="/" 
        class={`no-underline text-sm font-semibold relative h-full flex items-center transition-colors group ${
          currentPath === '/' ? 'text-brand' : 'text-slate-800 hover:text-brand'
        }`}
      >
        Lista de precios
        <span class={`absolute bottom-0 left-0 h-[3px] bg-brand transition-all duration-300 ease-out ${
          currentPath === '/' ? 'w-full' : 'w-0 group-hover:w-full'
        }`}></span>
      </a>
      
      <a 
        href="/contacto" 
        class={`no-underline text-sm font-semibold relative h-full flex items-center transition-colors group ${
          currentPath === '/contacto' ? 'text-brand' : 'text-slate-800 hover:text-brand'
        }`}
      >
        Sedes y contacto
        <span class={`absolute bottom-0 left-0 h-[3px] bg-brand transition-all duration-300 ease-out ${
          currentPath === '/contacto' ? 'w-full' : 'w-0 group-hover:w-full'
        }`}></span>
      </a>
      
      <!-- Botón Soy Médico -->
      <div class="flex items-center">
        <a 
          href="/vademecum" 
          class={`no-underline relative group flex items-center gap-2 text-sm font-semibold px-5 h-12 rounded-lg transition-all border ${
            currentPath === '/vademecum' 
              ? 'bg-transparent text-brand border-brand hover:bg-brand/5' 
              : 'bg-brand text-white border-transparent hover:bg-brand-dark shadow-sm hover:shadow-md'
          }`}
        >
          <span class="leading-none mt-[-1.5px]">Soy médico</span>
          <!-- Icono de Candado (Hugeicons) -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 opacity-90">
              <path d="M12 16V14" />
              <path d="M5 15C5 11.134 8.13401 8 12 8C15.866 8 19 11.134 19 15C19 18.866 15.866 22 12 22C8.13401 22 5 18.866 5 15Z" />
              <path d="M16.5 9.5V6.5C16.5 4.01472 14.4853 2 12 2C9.51472 2 7.5 4.01472 7.5 6.5V9.5" />
          </svg>
        </a>
    </nav>

    <!-- Centro: Buscador Móvil (Placeholder inicial para Desktop/Móvil unificado posterior) -->
    <div class="md:hidden flex-1 px-2">
      <div class="h-10 w-full bg-slate-100 rounded-lg flex items-center px-3 border border-transparent focus-within:bg-white focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/20 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        <span class="text-[13px] text-slate-400 font-medium ml-2 select-none">Buscar...</span>
      </div>
    </div>

    <!-- Lado Derecho: Controles Operativos -->
    <div class="w-auto md:w-64 flex-shrink-0 flex items-center justify-end gap-1 sm:gap-4 pr-3 md:pr-6">
      
      {mostrarZoom && (
        <div class="relative group hidden sm:flex flex-col items-center justify-center cursor-pointer">
          <button class="flex flex-col items-center justify-center p-1.5 min-w-[3rem] text-slate-800 hover:bg-slate-100 rounded-lg transition-colors" aria-label="Cambiar tamaño de texto">
            <div class="h-5 flex items-center justify-center text-slate-800/90">
              <!-- Icono AA (Hugeicons) -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]">
                  <path d="M10.5714 18H5.42857M8 3V18M8 3C6.81082 3 5.28326 3.12265 4.06709 3.24346C3.55271 3.29456 3.29552 3.32011 3.06788 3.41021C2.59438 3.59763 2.21271 4.00855 2.06906 4.48556C2 4.71489 2 4.97659 2 5.5M8 3C9.18918 3 10.7167 3.12265 11.9329 3.24346C12.4473 3.29456 12.7045 3.32011 12.9321 3.41021C13.4056 3.59763 13.7873 4.00855 13.9309 4.48556C14 4.71489 14 4.97659 14 5.5" />
                  <path d="M19.7143 21H16.2857M18 12V21M18 12C17.2072 12 16.1888 12.0818 15.3781 12.1623C15.0351 12.1964 14.8637 12.2134 14.7119 12.2735C14.3963 12.3984 14.1418 12.6724 14.046 12.9904C14 13.1433 14 13.3177 14 13.6667M18 12C18.7928 12 19.8112 12.0818 20.6219 12.1623C20.9649 12.1964 21.1363 12.2134 21.2881 12.2735C21.6037 12.3984 21.8582 12.6724 21.954 12.9904C22 13.1433 22 13.3177 22 13.6667" />
              </svg>
            </div>
            <span class="text-[10px] font-medium text-slate-800 mt-[2px]">Texto</span>
          </button>
          
          <!-- Tooltip Animado (Aparece en hover) -->
          <div class="absolute top-full mt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-1 group-hover:translate-y-0 z-50">
            <div class="bg-slate-800 text-white text-xs font-medium py-1.5 px-3 rounded whitespace-nowrap relative">
              Tamaño normal
              <!-- Triangulito del tooltip -->
              <div class="absolute -top-1 left-1/2 -translate-x-1/2 border-solid border-b-slate-800 border-b-[6px] border-x-transparent border-x-[5px] border-t-0"></div>
            </div>
          </div>
        </div>
      )}

      <!-- Botón Carrito -->
      <button id="header-cart-btn" class="relative flex flex-col items-center justify-center p-1.5 min-w-[2.75rem] text-slate-800 hover:bg-slate-100 rounded-lg transition-colors group" aria-label="Ver carrito de pedidos">
         <div class="h-5 flex items-center justify-center text-slate-800/90 relative">
            <!-- Icono Carrito (Hugeicons) -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" class="w-[18px] h-[18px] group-hover:-rotate-3 transition-transform">
                <path d="M8 16L16.7201 15.2733C19.4486 15.046 20.0611 14.45 20.3635 11.7289L21 6" />
                <path d="M6 6H22" />
                <circle cx="6" cy="20" r="2" />
                <circle cx="17" cy="20" r="2" />
                <path d="M8 20L15 20" />
                <path d="M2 2H2.966C3.91068 2 4.73414 2.62459 4.96326 3.51493L7.93852 15.0765C8.08887 15.6608 7.9602 16.2797 7.58824 16.7616L6.63213 18" />
            </svg>
            
            <!-- Burbuja de notificación re-posicionada -->
            <span class="absolute -top-1.5 -right-2 flex h-4 w-4">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
              <span class="relative inline-flex items-center justify-center rounded-full h-4 w-4 bg-red-500 text-white text-[9px] font-bold">3</span>
            </span>
         </div>
         <!-- Texto 'Pedidos' oculto en móvil para ahorrar espacio con el buscador -->
        <span class="hidden sm:block text-[10px] font-medium text-slate-800 mt-[2px]">Pedidos</span>
      </button>

      <!-- Botón Menú (Solo móvil, movido al extremo derecho) -->
      <button id="mobile-menu-btn" class="md:hidden flex flex-col items-center justify-center p-1.5 min-w-[2.75rem] text-slate-800 hover:bg-slate-100 rounded-lg transition-colors group" aria-label="Abrir menú principal">
          <div class="h-5 flex items-center justify-center text-slate-800/90">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
          </div>
      </button>
    </div>
  </div>

  <!-- Barra de progreso / loading sutil (Obligatoria por UX) -->
  <div class="w-full h-[2px] bg-slate-100 relative overflow-hidden">
    <!-- El width será controlado por JS, aquí hay un estado de ejemplo al 30% -->
    <div class="h-full bg-brand w-[30%] rounded-r-full transition-all duration-500 ease-out" id="global-progress-bar"></div>
  </div>
</header>

<script>
  // Emitir evento global para abrir/cerrar el carrito desde el Header
  document.addEventListener('DOMContentLoaded', () => {
    const cartBtn = document.getElementById('header-cart-btn');
    const menuBtn = document.getElementById('mobile-menu-btn');

    if (cartBtn) {
      cartBtn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('toggleCart'));
      });
    }

    if (menuBtn) {
      menuBtn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('toggleMobileMenu'));
      });
    }
  });
</script>
