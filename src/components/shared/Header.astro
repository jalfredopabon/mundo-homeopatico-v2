---
import Icons from "../catalogo/Icons.astro";

interface Props {
  mostrarZoom?: boolean;
}

const { mostrarZoom = false } = Astro.props;

// Helper para saber qué ruta está activa
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full bg-surface-white border-b border-subtle transition-all duration-300">
  <div class="max-w-full mx-auto h-16 flex items-center justify-between">
    
    <!-- Lado Izquierdo: Identidad de Marca (Alineado con Sidebar pl-4) -->
    <div class="w-auto flex-shrink-0 flex justify-start pl-4 md:pl-4">
      <a href="/" class="no-underline inline-flex items-center gap-2.5 transition-transform hover:scale-105 active:scale-95 group">
      <!-- Icono provisional (reemplazar por el logo real) -->
      <div class="w-11 h-11 bg-brand flex items-center justify-center rounded-xl text-white text-base font-bold tracking-widest transition-all">
        MH
      </div>
      <h1 class="hidden md:block text-lg font-bold text-body tracking-tight whitespace-nowrap">
        Mundo homeopático
      </h1>
      </a>
    </div>

    <!-- Espaciador Dinámico 1 (Genera Armonía Rítmica) -->
    <div class="hidden md:block flex-1"></div>

    <!-- Centro: Navegación Principal (Agrupador Central) -->
    <nav class="hidden md:flex flex-shrink-0 self-stretch items-center gap-10">
      <a 
        href="/" 
        class={`no-underline text-sm font-semibold relative h-full flex items-center transition-colors group ${
          currentPath === '/' ? 'text-brand' : 'text-body hover:text-brand'
        }`}
      >
        Lista de precios
        <span class={`absolute bottom-0 left-0 h-[3px] bg-brand rounded-full transition-all duration-300 ease-out ${
          currentPath === '/' ? 'w-full' : 'w-0 group-hover:w-full'
        }`}></span>
      </a>
      
      <a 
        href="/contacto" 
        class={`no-underline text-sm font-semibold relative h-full flex items-center transition-colors group ${
          currentPath === '/contacto' ? 'text-brand' : 'text-body hover:text-brand'
        }`}
      >
        Sedes y contacto
        <span class={`absolute bottom-0 left-0 h-[3px] bg-brand rounded-full transition-all duration-300 ease-out ${
          currentPath === '/contacto' ? 'w-full' : 'w-0 group-hover:w-full'
        }`}></span>
      </a>
      
      <!-- Botón Soy Médico (Parte del bloque central) -->
      <div class="flex items-center">
        <a 
          href="/vademecum" 
          class={`no-underline relative group flex items-center gap-2 text-sm font-semibold px-5 h-12 rounded-xl transition-all border ${
            currentPath === '/vademecum' 
              ? 'bg-transparent text-brand border-brand hover:bg-brand/5' 
              : 'bg-brand text-white border-transparent hover:bg-brand-dark'
          }`}
        >
          <span class="leading-none mt-[-1.5px]">Soy médico</span>
          <!-- Icono de Candado (Hugeicons) -->
          <div class="w-3.5 h-3.5 opacity-90">
            <Icons type="lock" />
          </div>
        </a>
      </div>
    </nav>

    <!-- Espaciador Dinámico 2 (Genera Armonía Rítmica) -->
    <div class="hidden md:block flex-1"></div>

    <!-- Centro: Buscador Móvil (Placeholder inicial para Desktop/Móvil unificado posterior) -->
    <div class="md:hidden flex-1 px-2">
      <div class="h-10 w-full bg-surface-muted rounded-xl flex items-center px-3 border border-transparent focus-within:bg-surface-white focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/20 transition-all">
        <div class="w-4 h-4 text-muted">
          <Icons type="search" />
        </div>
        <span class="text-[13px] text-muted font-medium ml-2 select-none">Buscar...</span>
      </div>
    </div>

    <div class="w-auto flex-shrink-0 flex items-center justify-end gap-2 pr-4 md:pr-4">
      
      {mostrarZoom && (
        <div class="relative group hidden sm:flex flex-col items-center justify-center cursor-pointer">
          <button class="flex flex-col items-center justify-center p-1.5 min-w-[3rem] text-body hover:bg-surface-muted rounded-xl transition-colors" aria-label="Cambiar tamaño de texto">
            <div class="h-5 flex items-center justify-center text-body/90">
              <!-- Icono AA (Hugeicons) -->
              <div class="w-[18px] h-[18px]">
                <Icons type="text-size" />
              </div>
            </div>
            <span class="text-[10px] font-medium text-body mt-[2px]">Texto</span>
          </button>
          
          <!-- Tooltip Animado (Aparece en hover) -->
          <div class="absolute top-full mt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-1 group-hover:translate-y-0 z-50">
            <div class="bg-slate-900 text-white text-xs font-medium py-1.5 px-3 rounded whitespace-nowrap relative">
              Tamaño normal
              <!-- Triangulito del tooltip -->
              <div class="absolute -top-1 left-1/2 -translate-x-1/2 border-solid border-b-slate-900 border-b-[6px] border-x-transparent border-x-[5px] border-t-0"></div>
            </div>
          </div>
        </div>
      )}

      <!-- Botón Carrito -->
      <button id="header-cart-btn" class="relative flex flex-col items-center justify-center p-1.5 min-w-[2.75rem] text-body hover:bg-surface-muted rounded-xl transition-colors group" aria-label="Ver carrito de pedidos">
         <div class="h-5 flex items-center justify-center text-body/90 relative">
            <!-- Icono Carrito (Hugeicons) -->
            <div class="w-[18px] h-[18px] group-hover:-rotate-3 transition-transform">
              <Icons type="cart" />
            </div>
            
            <!-- Burbuja de notificación re-posicionada -->
            <span id="cart-badge" class="absolute -top-1.5 -right-2 flex h-4 w-4 hidden">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
              <span id="cart-counter" class="relative inline-flex items-center justify-center rounded-full h-4 w-4 bg-red-500 text-white text-[9px] font-bold">0</span>
            </span>
          </div>
         <!-- Texto 'Pedidos' oculto en móvil para ahorrar espacio con el buscador -->
        <span class="hidden sm:block text-[10px] font-medium text-body mt-[2px]">Pedidos</span>
      </button>

      <!-- Botón Menú (Solo móvil, movido al extremo derecho) -->
      <button id="mobile-menu-btn" class="md:hidden flex flex-col items-center justify-center p-1.5 min-w-[2.75rem] text-body hover:bg-surface-muted rounded-xl transition-colors group" aria-label="Abrir menú principal">
          <div class="h-5 flex items-center justify-center text-body/90">
              <div class="w-[22px] h-[22px] group-hover:scale-110 transition-transform">
                <Icons type="menu" />
              </div>
          </div>
      </button>
    </div>
  </div>

  <!-- Barra de progreso / loading sutil (Obligatoria por UX) -->
  <div class="w-full h-[2px] bg-surface-muted relative overflow-hidden">
    <!-- El width será controlado por JS, aquí hay un estado de ejemplo al 30% -->
    <div class="h-full bg-brand w-0 rounded-r-full transition-all duration-500 ease-out" id="global-progress-bar"></div>
  </div>
</header>

<script>
  // Emitir evento global para abrir/cerrar el carrito desde el Header
  document.addEventListener('DOMContentLoaded', () => {
    const cartBtn = document.getElementById('header-cart-btn');
    const menuBtn = document.getElementById('mobile-menu-btn');

    if (cartBtn) {
      cartBtn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('toggleCart'));
      });
    }

    if (menuBtn) {
      menuBtn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('toggleMobileMenu'));
      });
    }

    // Escuchar actualizaciones del carrito para el contador
    document.addEventListener('cartUpdated', (e: any) => {
      const badge = document.getElementById('cart-badge');
      const counter = document.getElementById('cart-counter');
      const totalItems = e.detail.totalItems;

      if (badge && counter) {
        if (totalItems > 0) {
          badge.classList.remove('hidden');
          counter.textContent = totalItems;
          
          // Micro-animación al añadir item
          counter.classList.add('scale-125');
          setTimeout(() => counter.classList.remove('scale-125'), 200);
        } else {
          badge.classList.add('hidden');
        }
      }
    });
  });
</script>
