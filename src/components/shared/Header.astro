---
// src/components/shared/Header.astro
import Icons from "./Icons.astro";
/**
 * Header Global: Clonación Estricta 1:1 con lógica de navegación dinámica.
 * - Sincroniza estados activos según la ruta actual.
 * - Botón "Texto" visible únicamente en Catálogo (/) y Vademécum (/vademecum).
 * - Métrica UX: Barra de progreso y transiciones fluidas.
 */

const currentPath = Astro.url.pathname;
const isCatalog = currentPath === '/';
const isContact = currentPath === '/contacto';
const isVademecum = currentPath === '/vademecum';

// El botón de Zoom solo aparece en Catálogo y Vademécum
const showTextSize = isCatalog || isVademecum;
---

<header class="header-main">
  <div class="header-container">
    
    <!-- Lado Izquierdo: Identidad de Marca -->
    <div class="flex-1 flex justify-start pl-4">
      <a href="/" class="no-underline inline-flex items-center gap-3 transition-transform hover:scale-105 active:scale-95 group">
        <div class="logo-box-brand">MH</div>
        <h1 class="hidden md:block text-lg font-bold text-slate-900 tracking-tight whitespace-nowrap">
          Mundo homeopático
        </h1>
      </a>
    </div>

    <!-- Espaciador Dinámico 1 -->
    <div class="hidden md:block flex-1"></div>

    <!-- Centro: Navegación Principal -->
    <nav class="hidden md:flex flex-shrink-0 self-stretch items-center gap-10">
      <a href="/" class={`header-nav-link ${isCatalog ? 'is-active' : ''}`}>
        Lista de precios
      </a>
      
      <a href="/contacto" class={`header-nav-link ${isContact ? 'is-active' : ''}`}>
        Sedes y contacto
      </a>

      <div class="flex items-center">
        <a href="/vademecum" class={`header-cta-btn ${isVademecum ? 'is-active' : ''}`}>
          <span class="leading-none mt-[-1.5px]">Soy médico</span>
          <Icons type="lock" class="w-3.5 h-3.5 opacity-90" strokeWidth={2} />
        </a>
      </div>
    </nav>

    <!-- Espaciador Dinámico 2 -->
    <div class="hidden md:block flex-1"></div>

    <!-- Lado Derecho: Controles Operativos -->
    <div class="flex-1 flex items-center justify-end gap-4 pr-4">
      
      {/* Lupa de Búsqueda (Solo visible en Catálogo y Vademécum) */}
      {!isContact && (
        <button id="mobile-search-trigger" class="md:hidden flex flex-col items-center justify-center p-2 rounded-full hover:bg-slate-100/50 transition-all group" aria-label="Abrir buscador">
          <div class="header-icon-wrap flex items-center justify-center">
            <Icons type="search" class="w-[22px] h-[22px] text-slate-700 group-hover:text-brand group-hover:scale-110 transition-all" strokeWidth={2.5} />
          </div>
        </button>
      )}

      {showTextSize && (
        <div class="relative group hidden sm:flex flex-col items-center justify-center" id="text-size-btn">
          <button class="header-tool-btn min-w-[3.5rem]" aria-label="Cambiar tamaño de texto">
            <div class="header-icon-wrap">
              <Icons type="text-size" class="w-[18px] h-[18px]" strokeWidth={2} />
            </div>
            <span class="text-[10px] font-medium mt-1">Texto</span>
          </button>
          
          <!-- Tooltip "Elite" -->
          <div class="absolute top-full mt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-1 group-hover:translate-y-0 z-50">
            <div class="bg-slate-900 text-white text-[11px] font-bold py-1.5 px-3 rounded whitespace-nowrap relative text-center tracking-tight shadow-xl">
              <span id="text-size-label">Tamaño normal</span>
              <div class="absolute -top-1 left-1/2 -translate-x-1/2 border-solid border-b-slate-900 border-b-[6px] border-x-transparent border-x-[5px] border-t-0"></div>
            </div>
          </div>
        </div>
      )}

      <!-- Botón Carrito -->
      <button id="header-cart-btn" class="header-tool-btn min-w-[3rem] group" aria-label="Ver carrito de pedidos">
          <div class="header-icon-wrap">
            <Icons type="cart" class="w-[18px] h-[18px] group-hover:-rotate-3 transition-transform" strokeWidth={2.3} />
            <span id="cart-badge" class="absolute -top-0.5 -right-1 flex h-4 w-4 hidden transition-all">
              <span id="cart-ping" class="absolute inset-0 rounded-full bg-red-400 opacity-0 pointer-events-none"></span>
              <span id="cart-counter" class="relative inline-flex items-center justify-center rounded-full h-4 w-4 bg-red-500 text-white text-[9px] font-bold">0</span>
            </span>
          </div>
        <span class="hidden sm:block text-[10px] font-medium mt-1">Pedidos</span>
      </button>

      <!-- Botón Menú Móvil (Transformable Hamburguesa -> X) -->
      <button id="mobile-menu-btn" class="md:hidden header-tool-btn min-w-[2.75rem] group relative z-[5] overflow-hidden" aria-label="Abrir menú principal">
          <div class="header-icon-wrap transition-all duration-300 transform" id="menu-icon-container">
              <!-- Hamburguesa (Visible por defecto) -->
              <div class="menu-icon-burger transition-all duration-300">
                <Icons type="menu" class="w-[22px] h-[22px]" strokeWidth={2.5} />
              </div>
              <!-- X (Oculta por defecto) -->
              <div class="menu-icon-close absolute inset-0 flex items-center justify-center opacity-0 scale-50 rotate-90 transition-all duration-300">
                <Icons type="x" class="w-6 h-6 text-brand" strokeWidth={2.5} />
              </div>
          </div>
      </button>
    </div>
  </div>

  <!-- Barra de progreso (Feedback UX) -->
  <div class="header-progress-track">
    <div class="header-progress-bar" id="global-progress-bar"></div>
  </div>

  <!-- Overlay de Búsqueda Móvil (Paso 2) -->
  <div id="mobile-search-overlay" class="search-overlay-mobile">
    <div class="flex-1 relative">
      <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
        <Icons type="search" class="w-5 h-5" strokeWidth={2.5} />
      </div>
      <input 
        type="search" 
        id="mobile-search-input"
        placeholder="¿Qué medicamento buscas?" 
        class="input-elite-field !h-11 pl-10 pr-4 !bg-slate-50 focus:!bg-white"
        autocomplete="off"
      />
    </div>
    <button id="close-search-btn" class="header-tool-btn min-w-[3rem]" aria-label="Cerrar búsqueda">
      <div class="header-icon-wrap">
        <Icons type="x" class="w-6 h-6" strokeWidth={2} />
      </div>
    </button>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const cartBtn = document.getElementById('header-cart-btn');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const searchTrigger = document.getElementById('mobile-search-trigger');
    const textSizeBtn = document.getElementById('text-size-btn');

    // 1. Carrito
    if (cartBtn) {
      cartBtn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('toggleCart'));
      });
    }

    // 2. Menú Móvil
    if (menuBtn) {
      menuBtn.addEventListener('click', (e) => {
        // Evitamos que el clic se propague a otros elementos
        e.preventDefault();
        e.stopPropagation();
        document.dispatchEvent(new CustomEvent('toggleMobileMenu'));
      });
    }

    // 3. Buscador Móvil Trigger (Overlay)
    const searchOverlay = document.getElementById('mobile-search-overlay');
    const searchInput = document.getElementById('mobile-search-input') as HTMLInputElement;
    const closeSearchBtn = document.getElementById('close-search-btn');

    if (searchTrigger && searchOverlay && searchInput) {
      searchTrigger.addEventListener('click', () => {
        searchOverlay.classList.toggle('is-active');
        if (searchOverlay.classList.contains('is-active')) {
          setTimeout(() => searchInput.focus(), 300);
        }
      });
    }

    if (closeSearchBtn && searchOverlay) {
      closeSearchBtn.addEventListener('click', () => {
        searchOverlay.classList.remove('is-active');
      });
    }

    // Sincronizar con el sistema de búsqueda contextual (Catálogo o Vademécum)
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const value = (e.target as HTMLInputElement).value;
        const targetIds = ['catalogo-search', 'vademecum-search'];
        
        targetIds.forEach(id => {
          const targetInput = document.getElementById(id) as HTMLInputElement;
          if (targetInput) {
            targetInput.value = value;
            // Disparamos el evento input para que los filtros de cada página reaccionen
            targetInput.dispatchEvent(new Event('input', { bubbles: true }));
          }
        });
      });
    }

    // 4. Lógica de Tamaño de Texto (Sistema Dinámico Elite con Blindaje)
    if (textSizeBtn) {
      const sizeLabel = document.getElementById('text-size-label');
      const levels = ['sm', 'md', 'lg'];
      const labels: Record<string, string> = {
        'sm': 'Tamaño normal',
        'md': 'Texto grande',
        'lg': 'Texto extra'
      };

      // Función segura para leer el estado inicial
      const getInitialSize = () => {
        try {
          return localStorage.getItem('mh-font-size') || 'sm';
        } catch (e) {
          console.warn('[Elite Storage] LocalStorage bloqueado, usando valor por defecto.');
          return 'sm';
        }
      };

      let currentIdx = levels.indexOf(getInitialSize());
      if (currentIdx === -1) currentIdx = 0;
      
      const updateFontSize = (idx: number) => {
        const size = levels[idx];
        document.body.setAttribute('data-font-size', size);
        
        try {
          localStorage.setItem('mh-font-size', size);
        } catch (e) {
          // Si falla (ej. modo incógnito restrictivo), al menos lo mantenemos en memoria durante la sesión
          console.error('[Elite Storage] No se pudo guardar preferencia de texto.');
        }

        if (sizeLabel) sizeLabel.textContent = labels[size];
        document.dispatchEvent(new CustomEvent('textSizeChanged', { detail: { size } }));
      };

      // Aplicar estado inicial
      updateFontSize(currentIdx);

      textSizeBtn.addEventListener('click', () => {
        currentIdx = (currentIdx + 1) % levels.length;
        updateFontSize(currentIdx);
      });
    }

    // 5. Barra de progreso (Simulada al entrar)
    const progressBar = document.getElementById('global-progress-bar');
    if (progressBar) {
      progressBar.style.width = '100%';
      setTimeout(() => {
        progressBar.style.opacity = '0';
        setTimeout(() => {
          progressBar.style.width = '0';
          progressBar.style.opacity = '1';
        }, 500);
      }, 1000);
    }

    // 6. Listener de Carrito para el Badge
    document.addEventListener('cartUpdated', (e: any) => {
      const badge = document.getElementById('cart-badge');
      const counter = document.getElementById('cart-counter');
      const totalItems = e.detail.totalItems;

      if (badge && counter) {
        if (totalItems > 0) {
          // Si el número cambió, lanzamos el "Pop" y las "3 Palpitaciones"
          if (counter.textContent !== String(totalItems)) {
            // 1. Animación Pop (Badge principal)
            badge.classList.remove('animate-pop');
            void badge.offsetWidth; 
            badge.classList.add('animate-pop');

            // 2. Animación Eco (3 Palpitaciones)
            const ping = document.getElementById('cart-ping');
            if (ping) {
              ping.classList.remove('animate-ping-3', 'opacity-75');
              void ping.offsetWidth;
              ping.classList.add('animate-ping-3', 'opacity-75');
              // Limpiar opacidad después de las 3 palpitaciones (3s aprox)
              setTimeout(() => {
                ping.classList.remove('opacity-75');
              }, 3000);
            }
          }
          
          badge.classList.remove('hidden');
          counter.textContent = totalItems;
        } else {
          badge.classList.add('hidden');
        }
      }
    });
  });
</script>
