---
// src/components/shared/MobileMenuDrawer.astro
import { CATALOGO_DATA } from "../../data/catalogo";
import Icons from "./Icons.astro";

const currentPath = Astro.url.pathname;
const isContacto = currentPath.includes('/contacto');
const isVademecum = currentPath.includes('/vademecum');
const isCatalogo = !isContacto && !isVademecum;

const drawerTitle = isContacto ? 'Sedes y contacto' : (isVademecum ? 'Vademécum' : 'Lista de precios');
---

<!-- Drawer Panel: Pantalla Completa (Estilo Figma) -->
<div id="mobile-menu-drawer" class="fixed inset-0 w-full bg-surface-white z-[70] translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col">
  
  <!-- Header del Drawer -->
  <div class="h-16 flex items-center justify-between px-6 border-b border-subtle shrink-0">
    <span class="text-body font-bold tracking-tight text-[16px]">{drawerTitle}</span>
    <button id="close-mobile-menu" class="p-2 text-muted hover:text-body active:bg-surface-muted rounded-full transition-all" aria-label="Cerrar menú">
      <Icons type="close-x" class="w-6 h-6" />
    </button>
  </div>

  <!-- Body: Navegación -->
  <div class="flex-1 overflow-y-auto px-4 py-6">
    <div class="pt-2">
      
      {isCatalogo && (
        <div class="flex flex-col gap-1">
          {CATALOGO_DATA.map(section => (
            <div class="mb-4">
              {section.subsections.map(sub => (
                <div class="flex flex-col mb-4">
                  {/* Etiqueta Guía Nivel 2 (No clickeable, al ras del borde) */}
                  <span class="block text-[11px] font-bold text-muted tracking-tight mb-2 pl-0">{sub.title}</span>
                  
                  <div class="flex flex-col border-t border-subtle">
                  {sub.groups.map(group => {
                    const hasSubLinks = group.links && group.links.length > 0;
                    return (
                      <div class="flex flex-col border-b border-subtle">
                        {hasSubLinks ? (
                          <button class="drawer-accordion-trigger w-full flex items-center justify-between py-3.5 pl-4 text-body active:opacity-70 transition-opacity group">
                            <span class="text-[15px] font-medium tracking-tight flex-1 text-left">{group.name}</span>
                            <Icons type="chevron-down" class="w-4 h-4 text-body transition-transform duration-300 drawer-chevron" />
                          </button>
                        ) : (
                          <a href={group.href} class="w-full flex items-center justify-between py-3.5 pl-4 text-body active:opacity-70 transition-opacity group">
                            <span class="text-[15px] font-medium tracking-tight">{group.name}</span>
                          </a>
                        )}

                        {hasSubLinks && (
                          <div class="drawer-accordion-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out pl-4 pr-2 flex flex-col pt-0">
                            <div class="pb-3 pt-1 flex flex-col gap-1">
                                {group.links?.map(link => (
                                  <a href={link.href} class="block py-2.5 pl-4 text-[14px] font-medium text-body hover:text-brand transition-colors border-l border-subtle ml-1">{link.name}</a>
                                ))}
                            </div>
                          </div>
                        )}
                      </div>
                    )
                  })}
                  </div>
                </div>
              ))}
            </div>
          ))}
      </div>
      )}

      {isContacto && (
        <div class="flex flex-col mt-4">
          <div class="flex flex-col border-t border-subtle">
            <!-- Item especial de Instagram -->
            <a href="#instagram" class="w-full flex items-center justify-between py-4 border-b border-subtle text-body active:opacity-70 transition-opacity group">
              <span class="text-[15px] font-medium tracking-tight">Síguenos en Instagram</span>
              <Icons type="instagram" class="w-[18px] h-[18px] text-body group-active:text-brand" />
            </a>
            <!-- ScrollSpy en móvil: Mismo comportamiento minimalista -->
            <a href="#excelencia" class="mobile-contacto-scroll w-full flex items-center justify-between py-4 border-b border-subtle text-body active:opacity-70 transition-opacity">
              <span class="text-[15px] font-medium tracking-tight">Excelencia homeopática</span>
            </a>
            <a href="#sedes" class="mobile-contacto-scroll w-full flex items-center justify-between py-4 border-b border-subtle text-body active:opacity-70 transition-opacity">
              <span class="text-[15px] font-medium tracking-tight">Sedes y distribuciones</span>
            </a>
            <a href="#faq" class="mobile-contacto-scroll w-full flex items-center justify-between py-4 border-b border-subtle text-body active:opacity-70 transition-opacity">
              <span class="text-[15px] font-medium tracking-tight">Preguntas frecuentes</span>
            </a>
          </div>
        </div>
      )}

      {isVademecum && (
        <div class="flex flex-col mt-4">
          <div class="flex flex-col gap-6">

            <section class="pt-2">
                <h4 class="text-[13px] font-bold text-body mb-4 flex items-center gap-2.5">
                    <Icons type="droplet" class="w-[18px] h-[18px]" />
                    Tipo de terapia
                </h4>
                <div class="space-y-4 pl-1">
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Homeopatía compleja
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Terapia floral
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Oligoelementos
                    </label>
                </div>
            </section>

            <section class="border-t border-subtle pt-5">
                <h4 class="text-[13px] font-bold text-body mb-4 flex items-center gap-2.5">
                    <Icons type="pulse" class="w-[18px] h-[18px]" />
                    Sistema del cuerpo
                </h4>
                <div class="space-y-4 pl-1">
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Digestivo
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Nervioso
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Cardiovascular
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Respiratorio
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Locomotor
                    </label>
                </div>
            </section>

            <section class="border-t border-subtle pt-5">
                <h4 class="text-[13px] font-bold text-body mb-4 flex items-center gap-2.5">
                    <Icons type="pill" class="w-[18px] h-[18px]" />
                    Forma farmacéutica
                </h4>
                <div class="space-y-4 pl-1 pb-4">
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Gotas
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Tabletas
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Spray
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-body cursor-pointer hover:text-brand has-[:checked]:text-brand transition-colors">
                        <input type="checkbox" class="size-4 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Crema
                    </label>
                </div>
            </section>
          </div>
        </div>
      )}

    </div>

  <!-- Footer del Drawer -->
  <div class="p-6 bg-surface-muted/30">
    <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-brand/10 rounded flex items-center justify-center text-brand font-bold text-xs shrink-0">MH</div>
        <span class="text-xs font-bold text-body">Mundo homeopático</span>
    </div>
  </div>
</div>

<script>
    document.addEventListener('astro:page-load', () => {
        // Seleccionamos los elementos dinámicamente en cada carga
        const drawer = document.getElementById('mobile-menu-drawer');
        const closeBtn = document.getElementById('close-mobile-menu');
        const drawerAccordions = document.querySelectorAll('.drawer-accordion-trigger');
        const mobileContactoLinks = document.querySelectorAll('.mobile-contacto-scroll');

        // Función Maestra de Control
        function toggleMenu(isOpen: boolean) {
            if (!drawer) return;
            
            if (isOpen) {
                drawer.classList.remove('translate-x-full');
                document.body.style.overflow = 'hidden';
                document.body.classList.add('is-menu-open');
            } else {
                drawer.classList.add('translate-x-full');
                document.body.style.overflow = '';
                document.body.classList.remove('is-menu-open');
            }
        }

        // 1. Escuchar Evento desde el Header
        document.addEventListener('toggleMobileMenu', () => {
             toggleMenu(true);
        });

        // 2. Cerrar con el botón interno (X)
        if (closeBtn) {
            closeBtn.addEventListener('click', () => toggleMenu(false));
        }

        // 3. Lógica de Acordeones
        function closeAllAccordions() {
            drawerAccordions.forEach(trigger => {
                const content = trigger.nextElementSibling as HTMLElement;
                const chevron = trigger.querySelector('.drawer-chevron');
                if (content && content.style.maxHeight && content.style.maxHeight !== '0px') {
                    content.style.maxHeight = '0px';
                    chevron?.classList.remove('rotate-180');
                }
            });
        }
        
        drawerAccordions.forEach(trigger => {
            trigger.addEventListener('click', (e) => {
                const content = trigger.nextElementSibling as HTMLElement;
                const chevron = trigger.querySelector('.drawer-chevron');
                if (!content) return;

                const isClosed = content.style.maxHeight === '0px' || !content.style.maxHeight;
                
                if (isClosed) {
                    closeAllAccordions();
                    content.style.maxHeight = content.scrollHeight + 'px';
                    chevron?.classList.add('rotate-180');
                } else {
                    content.style.maxHeight = '0px';
                    chevron?.classList.remove('rotate-180');
                }
            });
        });

        // 4. Cerrar al pulsar enlaces internos (Catálogo, Sedes, Contacto)
        const navigationLinks = drawer.querySelectorAll('a[href^="#"]');
        navigationLinks.forEach(link => {
           link.addEventListener('click', () => {
               // Pequeño retardo para dar fluidez visual al inicio del desplazamiento
               setTimeout(() => toggleMenu(false), 150);
           });
        });

        // 5. Cierre de seguridad al hacer click fuera en el body (si existiera overlay)
        // Por ahora, el botón X es nuestra fuente de verdad.
    });
</script>
