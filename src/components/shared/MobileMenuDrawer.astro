---
// src/components/shared/MobileMenuDrawer.astro
import { CATALOGO_DATA } from "../../data/catalogo";
import Icons from "../catalogo/Icons.astro";

const currentPath = Astro.url.pathname;
const isContacto = currentPath.includes('/contacto');
const isVademecum = currentPath.includes('/vademecum');
const isCatalogo = !isContacto && !isVademecum;

const drawerTitle = isContacto ? 'Sedes y contacto' : (isVademecum ? 'Vademécum' : 'Lista de precios');
---

<!-- Drawer Panel: Pantalla Completa (Estilo Figma) -->
<div id="mobile-menu-drawer" class="fixed inset-0 w-full bg-surface-white z-[70] translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col">
  
  <!-- Header del Drawer -->
  <div class="h-16 flex items-center justify-between px-6 border-b border-subtle shrink-0">
    <span class="text-slate-800 font-bold tracking-tight text-[16px]">{drawerTitle}</span>
    <button id="close-mobile-menu" class="p-2 text-slate-500 hover:text-slate-800 active:bg-slate-100 rounded-full transition-all" aria-label="Cerrar menú">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
    </button>
  </div>

  <!-- Body: Navegación -->
  <div class="flex-1 overflow-y-auto px-4 py-6">
    <div class="pt-2">
      
      {isCatalogo && (
        <div class="flex flex-col gap-1">
          {CATALOGO_DATA.map(section => (
            <div class="mb-4">
              {section.subsections.map(sub => (
                <div class="flex flex-col mb-4">
                  {/* Etiqueta Guía Nivel 2 (No clickeable, al ras del borde) */}
                  <span class="block text-[11px] font-bold text-slate-500 tracking-tight mb-2 pl-0">{sub.title}</span>
                  
                  <div class="flex flex-col border-t border-slate-700">
                  {sub.groups.map(group => {
                    const hasSubLinks = group.links && group.links.length > 0;
                    return (
                      <div class="flex flex-col border-b border-slate-700">
                        {hasSubLinks ? (
                          <button class="drawer-accordion-trigger w-full flex items-center justify-between py-3.5 pl-4 text-slate-900 active:opacity-70 transition-opacity group">
                            <span class="text-[15px] font-medium tracking-tight flex-1 text-left">{group.name}</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 transition-transform duration-300 drawer-chevron"><path d="m6 9 6 6 6-6"/></svg>
                          </button>
                        ) : (
                          <a href={group.href} class="w-full flex items-center justify-between py-3.5 pl-4 text-slate-900 active:opacity-70 transition-opacity group">
                            <span class="text-[15px] font-medium tracking-tight">{group.name}</span>
                          </a>
                        )}

                        {hasSubLinks && (
                          <div class="drawer-accordion-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out pl-4 pr-2 flex flex-col pt-0">
                            <div class="pb-3 pt-1 flex flex-col gap-1">
                                {group.links?.map(link => (
                                  <a href={link.href} class="block py-2.5 pl-4 text-[14px] font-medium text-slate-700 hover:text-brand transition-colors border-l border-slate-700 ml-1">{link.name}</a>
                                ))}
                            </div>
                          </div>
                        )}
                      </div>
                    )
                  })}
                  </div>
                </div>
              ))}
            </div>
          ))}
      </div>
      )}

      {isContacto && (
        <div class="flex flex-col mt-4">
          <div class="flex flex-col border-t border-slate-500">
            <!-- Item especial de Instagram -->
            <a href="#instagram" class="w-full flex items-center justify-between py-4 border-b border-slate-500 text-slate-800 active:opacity-70 transition-opacity group">
              <span class="text-[15px] font-medium tracking-tight">Síguenos en Instagram</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] text-slate-900 group-active:text-brand">
                  <path d="M2.5 12C2.5 7.52166 2.5 5.28249 3.89124 3.89124C5.28249 2.5 7.52166 2.5 12 2.5C16.4783 2.5 18.7175 2.5 20.1088 3.89124C21.5 5.28249 21.5 7.52166 21.5 12C21.5 16.4783 21.5 18.7175 20.1088 20.1088C18.7175 21.5 16.4783 21.5 12 21.5C7.52166 21.5 5.28249 21.5 3.89124 20.1088C2.5 18.7175 2.5 16.4783 2.5 12Z" />
                  <path d="M16.5 12C16.5 14.4853 14.4853 16.5 12 16.5C9.51472 16.5 7.5 14.4853 7.5 12C7.5 9.51472 9.51472 7.5 12 7.5C14.4853 7.5 16.5 9.51472 16.5 12Z" />
                  <path d="M17.5 6.5H17.509" />
              </svg>
            </a>
            <!-- ScrollSpy en móvil: Mismo comportamiento minimalista -->
            <a href="#excelencia" class="mobile-contacto-scroll w-full flex items-center justify-between py-4 border-b border-slate-500 text-slate-800 active:opacity-70 transition-opacity">
              <span class="text-[15px] font-medium tracking-tight">Excelencia homeopática</span>
            </a>
            <a href="#sedes" class="mobile-contacto-scroll w-full flex items-center justify-between py-4 border-b border-slate-500 text-slate-800 active:opacity-70 transition-opacity">
              <span class="text-[15px] font-medium tracking-tight">Sedes y distribuciones</span>
            </a>
            <a href="#faq" class="mobile-contacto-scroll w-full flex items-center justify-between py-4 border-b border-slate-500 text-slate-800 active:opacity-70 transition-opacity">
              <span class="text-[15px] font-medium tracking-tight">Preguntas frecuentes</span>
            </a>
          </div>
        </div>
      )}

      {isVademecum && (
        <div class="flex flex-col mt-4">
          <div class="flex flex-col gap-6">

            <section class="pt-2">
                <h4 class="text-[13px] font-bold text-slate-900 mb-4 flex items-center gap-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] text-slate-900">
                        <path d="M9.06845 2H14.9316C15.8529 2 16.3135 2 16.5997 2.29289C17.1334 2.83907 17.1334 5.16093 16.5997 5.70711C16.3135 6 15.8529 6 14.9316 6H9.06845C8.14715 6 7.6865 6 7.40029 5.70711C6.86657 5.16093 6.86657 2.83907 7.40029 2.29289C7.6865 2 8.14715 2 9.06845 2Z" />
                        <path d="M8 6C8.16493 6.32986 8.24741 6.49481 8.30606 6.6557C8.61211 7.49515 8.52805 8.42732 8.07678 9.19848C7.99029 9.34628 7.87965 9.49381 7.65836 9.78885L7.25493 10.3268C6.80486 10.9269 6.57983 11.2269 6.41674 11.5556C6.252 11.8877 6.13421 12.241 6.06677 12.6055C6 12.9664 6 13.3414 6 14.0915V16C6 18.8284 6 20.2426 6.87868 21.1213C7.75736 22 9.17157 22 12 22C14.8284 22 16.2426 22 17.1213 21.1213C18 20.2426 18 18.8284 18 16V14.0915C18 13.3414 18 12.9664 17.9332 12.6055C17.8658 12.241 17.748 11.8877 17.5833 11.5556C17.4202 11.2269 17.1951 10.9269 16.7451 10.3268L16.3416 9.78885C16.1204 9.49381 16.0097 9.34628 15.9232 9.19848C15.4719 8.42732 15.3879 7.49515 15.6939 6.6557C15.7526 6.49481 15.8351 6.32987 16 6" />
                        <path d="M12 13V18M9.5 15.5L14.5 15.5" />
                    </svg>
                    Tipo de terapia
                </h4>
                <div class="space-y-4 pl-1">
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Homeopatía compleja
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Terapia floral
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Oligoelementos
                    </label>
                </div>
            </section>

            <section class="border-t border-slate-500 pt-5">
                <h4 class="text-[13px] font-bold text-slate-900 mb-4 flex items-center gap-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] text-slate-900">
                        <path d="M2 12H6L7.5 8L9.5 15L13 6L15.5 18L18 12H22" />
                    </svg>
                    Sistema del cuerpo
                </h4>
                <div class="space-y-4 pl-1">
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Digestivo
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Nervioso
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Cardiovascular
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Respiratorio
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Locomotor
                    </label>
                </div>
            </section>

            <section class="border-t border-slate-500 pt-5">
                <h4 class="text-[13px] font-bold text-slate-900 mb-4 flex items-center gap-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] text-slate-900">
                        <path d="M11.4497 19.5503L19.5503 11.4497C20.4785 10.5215 21 9.2625 21 7.94975C21 5.21608 18.7839 3 16.0503 3C14.7375 3 13.4785 3.52149 12.5503 4.44975L4.44975 12.5503C3.52149 13.4785 3 14.7375 3 16.0503C3 18.7839 5.21608 21 7.94975 21C9.2625 21 10.5215 20.4785 11.4497 19.5503Z" />
                        <path d="M8.5 8.5L15.5 15.5" />
                    </svg>
                    Forma farmacéutica
                </h4>
                <div class="space-y-4 pl-1 pb-4">
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Gotas
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Tabletas
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Spray
                    </label>
                    <label class="flex items-center gap-3 text-[14px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        Crema
                    </label>
                </div>
            </section>
          </div>
        </div>
      )}

    </div>

  <!-- Footer del Drawer -->
  <div class="p-6 bg-surface-muted/30">
    <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-brand/10 rounded flex items-center justify-center text-brand font-bold text-xs shrink-0">MH</div>
        <span class="text-xs font-bold text-slate-800">Mundo homeopático</span>
    </div>
  </div>
</div>

<script>
    // Lógica básica de apertura y cierre (Cableado inicial)
    const openBtn = document.getElementById('mobile-menu-btn');
    // Lógica básica de apertura y cierre (Estilo Pantalla Completa Figma)
    const closeBtn = document.getElementById('close-mobile-menu');
    const drawer = document.getElementById('mobile-menu-drawer');

    function toggleMenu(isOpen: boolean) {
        if (isOpen) {
            drawer?.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden';
        } else {
            drawer?.classList.add('translate-x-full');
            document.body.style.overflow = '';
        }
    }

    // Escuchar evento personalizado que vendrá del Header
    document.addEventListener('toggleMobileMenu', () => toggleMenu(true));
    closeBtn?.addEventListener('click', () => toggleMenu(false));

    // Lógica de Acordeones del Catálogo (Acordeón Exclusivo)
    const drawerAccordions = document.querySelectorAll('.drawer-accordion-trigger');
    
    function closeAllAccordions() {
        drawerAccordions.forEach(trigger => {
            const content = trigger.nextElementSibling as HTMLElement;
            const chevron = trigger.querySelector('.drawer-chevron');
            if (content && content.style.maxHeight && content.style.maxHeight !== '0px') {
                content.style.maxHeight = '0px';
                chevron?.classList.remove('rotate-180');
            }
        });
    }
    
    drawerAccordions.forEach(trigger => {
        trigger.addEventListener('click', () => {
            const content = trigger.nextElementSibling as HTMLElement;
            const chevron = trigger.querySelector('.drawer-chevron');
            
            const isClosed = content.style.maxHeight === '0px' || !content.style.maxHeight;
            
            if (isClosed) {
                // Si estaba cerrado, cerramos todos los demás y abrimos este
                closeAllAccordions();
                content.style.maxHeight = content.scrollHeight + 'px';
                chevron?.classList.add('rotate-180');
            } else {
                // Si estab abierto, lo cerramos
                content.style.maxHeight = '0px';
                chevron?.classList.remove('rotate-180');
            }
        });
    });

    // Si hace click fuera de cualquier acordeón, cerrar todos para limpiar la vista
    document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const isTrigger = target.closest('.drawer-accordion-trigger');
        const isContent = target.closest('.drawer-accordion-content');
        
        if (!isTrigger && !isContent) {
            closeAllAccordions();
        }
    });

    // Cerrar el Drawer automáticamente al hacer clic en un enlace interno (ScrollSpy Móvil)
    const mobileContactoLinks = document.querySelectorAll('.mobile-contacto-scroll');
    mobileContactoLinks.forEach(link => {
       link.addEventListener('click', () => {
           toggleMenu(false);
       });
    });
</script>
