---
import Icons from "../catalogo/Icons.astro";
---

<!-- Buscador Móvil (Trigger de búsqueda rápida) -->
<div class="md:hidden flex-1 px-2">
  <div class="h-10 w-full bg-surface-muted rounded-xl flex items-center px-3 border border-transparent focus-within:bg-surface-white focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/20 transition-all cursor-pointer">
    <div class="w-4 h-4 text-muted">
      <Icons type="search" />
    </div>
    <span class="text-[13px] text-muted font-medium ml-2 select-none">Buscar...</span>
  </div>
</div>
