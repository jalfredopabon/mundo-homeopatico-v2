---
// src/components/shared/MobileSplash.astro
---
<!-- Fuente para el Logo de Animación -->
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet">

<div id="mobile-splash" class="fixed inset-0 z-[100] flex items-center justify-center bg-[#158C77] pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] md:hidden opacity-0" style="display: none;">
    
    <div class="relative flex flex-row items-baseline text-white font-serif tracking-tighter">
        <!-- Parte: M [undo] -->
        <div class="flex items-baseline overflow-hidden">
            <span class="text-5xl sm:text-6xl font-bold animate-expand-m">M</span>
            <span class="text-3xl sm:text-4xl opacity-0 animate-reveal-suffix ml-2">undo</span>
        </div>

        <!-- Espacio entre palabras (se expande) -->
        <div class="w-3 sm:w-6"></div>

        <!-- Parte: H [omeopático] -->
        <div class="flex items-baseline overflow-hidden">
            <span class="text-5xl sm:text-6xl font-bold animate-expand-h">H</span>
            <span class="text-3xl sm:text-4xl opacity-0 animate-reveal-suffix ml-2">omeopático</span>
        </div>
    </div>

</div>

<!-- Script de Detección Inmediata (Corre antes que el renderizado completo) -->
<script is:inline>
    (function() {
        // Acceso seguro a sessionStorage
        let hasSeenSplash = false;
        try {
            hasSeenSplash = !!sessionStorage.getItem('hasSeenSplash_v2');
        } catch (e) {
            console.warn('[Elite Splash] SessionStorage bloqueado. El splash aparecerá siempre.');
        }

        const splash = document.getElementById('mobile-splash');
        if (hasSeenSplash && splash) {
            splash.style.display = 'none';
        } else if (splash) {
            splash.style.display = 'flex';
            splash.style.opacity = '1';

            // --- 🧪 FAIL-SAFE TIMER (Fase 2: Robustez Visual) ---
            // Si en 5 segundos Astro no ha terminado la hidratación o el script principal ha fallado, 
            // forzamos la salida del splash para evitar que el usuario se quede atrapado.
            setTimeout(() => {
                if (splash.style.display !== 'none') {
                    console.warn('[Elite Splash] Fail-safe activado: Quitando splash por tiempo límite (5s).');
                    splash.style.transition = 'opacity 1s ease-out, transform 1s ease-out';
                    splash.style.opacity = '0';
                    splash.style.transform = 'translateY(-20px)';
                    setTimeout(() => {
                        splash.style.display = 'none';
                        // Red de seguridad: Forzar visibilidad del contenido principal
                        const mainEl = document.querySelector('main');
                        if (mainEl) {
                            mainEl.style.opacity = '1';
                            mainEl.style.visibility = 'visible';
                        }
                    }, 1000);
                }
            }, 5000); 
        }
    })();
</script>

<script>
    document.addEventListener('astro:page-load', () => {
        const splash = document.getElementById('mobile-splash');
        if (!splash) return;
        
        let hasSeenSplash = false;
        try {
            hasSeenSplash = !!sessionStorage.getItem('hasSeenSplash_v2');
        } catch (e) {
            console.warn('[Elite Splash] Fallo al leer sessionStorage en el script principal.');
        }

        if (!hasSeenSplash) {
            // Tiempo total de la coreografía (3 segundos para visualización ágil y dinámica)
            setTimeout(() => {
                splash.style.opacity = '0';
                splash.style.transform = 'translateY(-10px)'; // Menos salto, más elegancia
                
                try {
                    sessionStorage.setItem('hasSeenSplash_v2', 'true');
                } catch (e) {
                    // Fallo silencioso si no se puede guardar
                }
                
                setTimeout(() => {
                    splash.style.display = 'none';
                    // Garantizar visibilidad tras salida exitosa
                    const mainEl = document.querySelector('main');
                    if (mainEl) {
                        mainEl.style.opacity = '1';
                        mainEl.style.visibility = 'visible';
                    }
                }, 700);
            }, 3000); 
        }
    });
</script>

<style>
    /* 1. La M comienza en el centro y se mueve a su lugar */
    @keyframes expandM {
        0% { transform: translateX(100%); }
        100% { transform: translateX(0); }
    }
    .animate-expand-m {
        animation: expandM 1.2s cubic-bezier(0.65, 0, 0.35, 1) 0.5s forwards;
    }

    /* 2. La H comienza en el centro (traslapada con M) y se mueve a la derecha */
    @keyframes expandH {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(0); }
    }
    .animate-expand-h {
        animation: expandH 1.2s cubic-bezier(0.65, 0, 0.35, 1) 0.5s forwards;
    }

    /* 3. Revelar el resto de las palabras (undo, omeopático) */
    @keyframes revealSuffix {
        0% { opacity: 0; transform: translateY(5px); filter: blur(5px); }
        100% { opacity: 1; transform: translateY(0); filter: blur(0); }
    }
    .animate-reveal-suffix {
        animation: revealSuffix 1.5s ease-out 1.5s forwards;
    }
</style>
