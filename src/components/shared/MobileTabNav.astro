---
// src/components/shared/MobileTabNav.astro
import Icons from "./Icons.astro";
const { pathname } = Astro.url;

// Normalización de rutas para el estado activo
const currentPath = pathname.endsWith('/') && pathname.length > 1 
  ? pathname.slice(0, -1) 
  : pathname;

const tabs = [
  { 
    name: 'Lista', 
    path: '/',
    type: 'grid'
  },
  { 
    name: 'Contacto', 
    path: '/contacto',
    type: 'map-pin'
  },
  { 
    name: 'Médicos', 
    path: '/vademecum',
    type: 'user'
  }
];
---

<!-- Bottom App Bar (Solo móvil) -->
<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 bg-white/95 backdrop-blur-md border-t border-slate-100 pb-safe h-16 shadow-[0_-4px_24px_rgba(0,0,0,0.04)]">
  <div class="flex h-full items-center justify-around px-2">
      {tabs.map(tab => {
        // Lógica de activación: exacto para '/' o inicio de cadena para otros
        const isActive = tab.path === '/' 
          ? currentPath === '/' 
          : currentPath.startsWith(tab.path);
          
        const iconType = isActive ? `${tab.type}-solid` : tab.type;
        
      return (
        <a
          href={tab.path}
          class="flex-1 py-1 flex items-center justify-center no-underline outline-none group"
          aria-label={`Ir a ${tab.name}`}
        >
          <div 
            class={`flex flex-col items-center justify-center gap-1 w-full relative h-full transition-colors duration-300 ${isActive ? 'text-slate-900' : 'text-slate-500 hover:text-slate-700'}`}
          >
            <!-- Icono con transición de tipo (Stroke -> Solid) -->
            <Icons 
              type={iconType as any} 
              class="w-6 h-6 transition-transform duration-200 active:scale-90" 
              strokeWidth={isActive ? 0 : 2}
            />

            <!-- Label con técnica anti-salto (Bold Jump Fix) -->
            <span 
              class={`tab-label ${isActive ? 'is-active' : ''}`}
              data-text={tab.name}
            >
              {tab.name}
            </span>
          </div>
        </a>
      )
    })}
  </div>
</nav>

<style>
  /* Técnica Elite para evitar que el texto "salte" al ponerse en negrita */
  .tab-label {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    letter-spacing: -0.01em;
    font-weight: 500;
    opacity: 0.8;
    transition: color 0.3s ease, font-weight 0.3s ease, opacity 0.3s ease;
    line-height: normal;
  }

  .tab-label.is-active {
    font-weight: 700;
    opacity: 1;
  }

  .tab-label::after {
    display: block;
    content: attr(data-text);
    font-weight: 700;
    height: 0;
    overflow: hidden;
    visibility: hidden;
    /* El pseudo-elemento reserva el espacio del ancho en negrita preventivamente */
  }

  /* Efecto de toque suave */
  .group:active {
    opacity: 0.7;
  }
</style>
