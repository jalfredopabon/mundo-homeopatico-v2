---
// src/components/shared/MobileTabNav.astro
const { pathname } = Astro.url;

// Normalización de rutas para el estado activo
const currentPath = pathname.endsWith('/') && pathname.length > 1 
  ? pathname.slice(0, -1) 
  : pathname;

const tabs = [
  { 
    name: 'Lista', 
    path: '/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>`,
    activeIcon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M4 5h16a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm0 6h16a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1zm0 6h16a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1z"/></svg>` // Simulación de icono relleno, usando el de lista para el ejemplo, pero aquí pondré paths correctos.
  },
  { 
    name: 'Contacto', 
    path: '/contacto',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
    activeIcon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>`
  },
  { 
    name: 'Vademécum', 
    path: '/vademecum',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    activeIcon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 7a4 4 0 0 0-4-4H2v18h7a3 3 0 0 1 3 3 3 3 0 0 1 3-3h7V3h-6a4 4 0 0 0-4 4z"/></svg>`
  }
];

// Reajuste del icono local de Lista para que sea de grid o items (alineado a un catálogo)
tabs[0].icon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>`;
tabs[0].activeIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>`;
---

<!-- Bottom App Bar (Solo móvil) -->
<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 bg-surface-white border-t border-subtle pb-safe shadow-[0_-4px_24px_-8px_rgba(0,0,0,0.05)] h-14">
  <div class="flex h-full items-center justify-center gap-4 sm:gap-8 px-4">
    {tabs.map(tab => {
      // Lógica de activación: exacto para '/' o inicio de cadena para otros
      const isActive = tab.path === '/' 
        ? currentPath === '/' 
        : currentPath.startsWith(tab.path);
        
      return (
        <a 
          href={tab.path}
          class={`flex items-center justify-center transition-all duration-300 ease-out origin-center ${
            isActive 
              ? 'gap-2 bg-slate-100 text-slate-900 px-5 py-2 rounded-full shadow-sm' 
              : 'w-10 h-10 rounded-full text-slate-700 hover:text-slate-900 hover:bg-slate-50'
          }`}
          aria-label={tab.name}
        >
          <div class={`flex items-center justify-center transition-transform duration-300 ${isActive ? 'scale-110' : ''}`}>
            <Fragment set:html={isActive ? tab.activeIcon : tab.icon} />
          </div>
          
          {/* Texto dinámico visible solo en el estado activo */}
          <div class={`overflow-hidden transition-all duration-300 ${isActive ? 'max-w-[100px] opacity-100 ml-1' : 'max-w-0 opacity-0'}`}>
            <span class="text-[13px] tracking-wide font-extrabold whitespace-nowrap">
              {tab.name}
            </span>
          </div>
        </a>
      )
    })}
  </div>
</nav>

<style>
  /* Asegurar que el entorno móvil respete las áreas seguras (ej. la barra de inicio de iOS) */
  .pb-safe {
    padding-bottom: env(safe-area-inset-bottom);
  }
</style>
