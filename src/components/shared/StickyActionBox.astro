---
import Icons from "../catalogo/Icons.astro";

interface Props {
  id?: string;
  placeholder?: string;
}

const { 
  id, 
  placeholder = "Buscar..."
} = Astro.props;
---

<div class="sticky top-0 z-30 bg-surface-white px-4 py-4">
  <div class="relative group flex items-center w-full">
    <slot>
      <!-- Input de Búsqueda por defecto -->
      <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-muted group-focus-within:text-brand transition-colors">
        <div class="w-4 h-4">
          <Icons type="search" />
        </div>
      </div>
      <input 
        type="text" 
        id={id} 
        placeholder={placeholder}
        class="w-full h-11 pl-10 pr-4 bg-surface-muted/70 border border-subtle rounded-xl text-[14px] text-body placeholder:text-muted focus:outline-none focus:bg-surface-white focus:border-brand focus:ring-4 focus:ring-brand/5 transition-all shadow-sm"
      />
    </slot>
  </div>
</div>
