---
import SkeletonItem from './SkeletonItem.astro';
---

<div class="bg-surface-white rounded-xl p-6 border border-subtle animate-pulse-slow">
    <div class="flex items-baseline gap-2.5 mb-2.5">
        <SkeletonItem width="w-32" height="h-5" rounded="rounded-md" />
        <SkeletonItem width="w-8" height="h-3" rounded="rounded-sm" />
    </div>
    
    <div class="space-y-2 mb-4">
        <SkeletonItem width="w-full" height="h-3.5" />
        <SkeletonItem width="w-full" height="h-3.5" />
        <SkeletonItem width="w-[85%]" height="h-3.5" />
    </div>

    <div class="flex items-center gap-3 flex-wrap">
        <SkeletonItem width="w-20" height="h-6" rounded="rounded-md" />
        <SkeletonItem width="w-16" height="h-6" rounded="rounded-md" />
        <SkeletonItem width="w-14" height="h-6" rounded="rounded-md" />
    </div>
</div>


