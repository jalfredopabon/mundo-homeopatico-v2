---
// src/components/vademecum/MedicalCard.astro

interface Props {
    id: string;
    name: string;
    potency: string;
    shortDesc: string;
    tags?: {
        terapia: string;
        sistema: string[];
        forma: string;
    };
}

import BadgeElite from '../shared/BadgeElite.astro';

const { id, name, potency, shortDesc, tags } = Astro.props;
---

<div 
    class="medical-card medical-item-btn" 
    data-med={id}
    data-id={id}
>
    <div class="mb-2">
        <h3 class="font-bold text-slate-900 leading-tight text-dynamic-content">
            {name} {potency}
        </h3>
    </div>
    
    <p class="text-slate-700 leading-relaxed mb-4 text-dynamic-content">
        {shortDesc}
    </p>
    
    <div class="flex items-center gap-2 flex-wrap">
        {tags && (
            <>
                <BadgeElite label={tags.terapia} variant="indigo" size="xs" class="text-dynamic-badge" />
                {tags.sistema.map(s => (
                    <BadgeElite label={s} variant="violet" size="xs" class="text-dynamic-badge" />
                ))}
                <BadgeElite label={tags.forma} variant="bronze" size="xs" class="text-dynamic-badge" />
            </>
        )}
    </div>
</div>
