---
// src/components/vademecum/MedicalCard.astro

interface Props {
    id: string;
    name: string;
    potency: string;
    shortDesc: string;
    tags?: {
        terapia: string;
        sistema: string[];
        forma: string;
    };
}

import BadgeElite from '../shared/BadgeElite.astro';

const { id, name, potency, shortDesc, tags } = Astro.props;
---

<div 
    class="medical-card medical-item-btn" 
    data-med={id}
    data-id={id}
>
    <div class="mb-2">
        <h3 class="text-[16px] font-bold text-slate-900 leading-tight">
            {name} {potency}
        </h3>
    </div>
    
    <p class="text-[13px] text-slate-700 leading-relaxed mb-4">
        {shortDesc}
    </p>
    
    <div class="flex items-center gap-2 flex-wrap">
        {tags && (
            <>
                <BadgeElite label={tags.terapia} variant="info" size="xs" />
                {tags.sistema.map(s => (
                    <BadgeElite label={s} variant="success" size="xs" />
                ))}
                <BadgeElite label={tags.forma} variant="warning" size="xs" />
            </>
        )}
    </div>
</div>
