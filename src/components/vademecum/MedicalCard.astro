---
// src/components/vademecum/MedicalCard.astro

interface Props {
    id: string;
    name: string;
    potency: string;
    shortDesc: string;
    tags?: {
        terapia: string;
        sistema: string[];
        forma: string;
    };
}

const { id, name, potency, shortDesc, tags } = Astro.props;
---

<div 
    class="group bg-surface-white rounded-xl p-6 cursor-pointer transition-colors reveal medical-item-btn border border-subtle hover:border-brand shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]" 
    data-med={id}
    data-id={id}
>
    <div class="flex items-baseline gap-2.5 mb-2">
        <h3 class="text-[16px] font-bold text-slate-900">
            {name}
        </h3>
        <span class="text-slate-700 text-xs font-medium">{potency}</span>
    </div>
    
    <p class="text-[13px] text-slate-700 leading-relaxed mb-4">
        {shortDesc}
    </p>
    
    <div class="flex items-center gap-2 flex-wrap">
        {tags && (
            <>
                <span class="badge-elite badge-elite--indigo">
                    {tags.terapia}
                </span>
                {tags.sistema.map(s => (
                    <span class="badge-elite badge-elite--emerald">
                        {s}
                    </span>
                ))}
                <span class="badge-elite badge-elite--amber">
                    {tags.forma}
                </span>
            </>
        )}
    </div>
</div>
