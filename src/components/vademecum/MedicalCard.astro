---
// src/components/vademecum/MedicalCard.astro

interface Props {
    id: string;
    name: string;
    potency: string;
    shortDesc: string;
}

const { id, name, potency, shortDesc } = Astro.props;
---

<div 
    class="group bg-surface-white rounded-xl p-6 cursor-pointer transition-colors reveal medical-item-btn border border-subtle hover:border-brand shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]" 
    data-med={id}
    data-id={id}
>
    <div class="flex items-baseline gap-2.5 mb-2">
        <h3 class="text-[16px] font-bold text-slate-900">
            {name}
        </h3>
        <span class="text-slate-700 text-xs font-medium">{potency}</span>
    </div>
    
    <p class="text-[13px] text-slate-700 leading-relaxed mb-4">
        {shortDesc}
    </p>
    
    <div class="flex items-center gap-3 flex-wrap">
        <!-- TODO: Hacer dinámicos estos badges en el futuro -->
        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-surface-muted transition-colors px-2.5 py-1 rounded-md border border-subtle">
            Clínica general
        </span>
        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-surface-muted transition-colors px-2.5 py-1 rounded-md border border-subtle">
            Gotas
        </span>
    </div>
</div>
