---
// src/components/vademecum/MedicalDetails.astro
import Icons from '../shared/Icons.astro';

/** 
 * No recibimos props masivas. El componente se hidrata dinámicamente 
 * en el cliente para mantener el DOM ligero.
 */
---

<aside 
    id="vademecum-aside" 
    data-mobile-open="false" 
    class="medical-aside"
>
    <!-- Botón de cierre móvil unificado -->
    <button id="close-mobile-details" class="close-ficha-btn lg:hidden absolute top-4 right-4 z-50 p-2 text-slate-400 hover:text-brand bg-white rounded-full shadow-lg border border-slate-100 transition-all">
        <Icons type="close-x" class="w-5 h-5" />
    </button>

    <!-- Estado Vacío Inicial -->
    <div id="vademecum-empty-state" class="medical-empty-state flex flex-col items-center justify-center h-full text-center p-8">
        <div class="mb-8 flex justify-center text-slate-200 animate-pulse">
            <Icons type="select-card" class="w-16 h-16" strokeWidth={1} />
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-2">Selecciona un elemento</h3>
        <p class="text-sm text-slate-500 max-w-[240px] mb-1 leading-relaxed">
            Explora el catálogo y selecciona un medicamento o protocolo para ver su ficha técnica.
        </p>
    </div>

    <!-- CONTENEDOR DE FICHA DINÁMICA -->
    <div id="vademecum-details-content" class="medical-sheet hidden overflow-y-auto h-full scrollbar-premium">
        <!-- El motor JS inyectará el contenido aquí -->
    </div>
</aside>

<script>
    import { createMedicineDetails, createProtocolDetails } from '../../utils/vademecum-renderer';

    document.addEventListener('astro:page-load', () => {
        const aside = document.getElementById('vademecum-aside');
        const content = document.getElementById('vademecum-details-content');
        const emptyState = document.getElementById('vademecum-empty-state');
        const closeBtn = document.getElementById('close-mobile-details');

        // Escuchar selección desde Vademecum.astro
        window.addEventListener('vademecum:select-item', (e: any) => {
            const { item, type } = e.detail;

            if (content && emptyState) {
                emptyState.classList.add('hidden');
                content.classList.remove('hidden');
                
                if (type === 'medicine') {
                    content.innerHTML = createMedicineDetails(item);
                } else {
                    content.innerHTML = createProtocolDetails(item);
                }

                content.scrollTop = 0;
                abrirDrawerMovil();
            }
        });

        // SALTO MAESTRO: Delegación de eventos para links dentro de protocolos
        content?.addEventListener('click', (e) => {
            const jumpLink = (e.target as HTMLElement).closest('.master-jump-link');
            if (jumpLink) {
                const targetId = jumpLink.getAttribute('data-jump-to');
                // Emitimos evento de búsqueda de producto para que el controlador principal lo encuentre
                window.dispatchEvent(new CustomEvent('vademecum:request-jump', { 
                    detail: { id: targetId } 
                }));
            }
        });

        // Cierre móvil
        closeBtn?.addEventListener('click', cerrarDrawerMovil);

        function abrirDrawerMovil() {
            if (aside && window.innerWidth < 1024) {
                aside.setAttribute('data-mobile-open', 'true');
                document.body.style.overflow = 'hidden';
            }
        }

        function cerrarDrawerMovil() {
            if (aside) {
                aside.setAttribute('data-mobile-open', 'false');
                document.body.style.overflow = '';
            }
        }
    });
</script>


