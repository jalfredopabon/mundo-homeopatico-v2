---
// src/components/vademecum/PosologiaModal.astro
import Icons from "../shared/Icons.astro";
---

<div id="posologia-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-6 animate-fade-in" role="dialog" aria-modal="true">
    <!-- Backdrop de Vidrio -->
    <div id="posologia-modal-backdrop" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity"></div>

    <!-- Contenedor del Modal -->
    <div class="relative w-full max-w-2xl bg-white rounded-2xl shadow-2xl border border-slate-100 flex flex-col max-h-[85vh] overflow-hidden transform scale-95 opacity-0 transition-all duration-300 ease-out" id="posologia-modal-container">
        
        <!-- Cabecera -->
        <header class="p-6 pb-4 border-b border-slate-100 flex items-start justify-between">
            <div class="space-y-1 pr-6">
                <div class="flex items-center gap-2.5 text-[10px] font-bold text-brand uppercase tracking-wider">
                    <Icons type="task-list" class="w-3.5 h-3.5 text-brand" />
                    Guía de referencia rápida
                </div>
                <h3 class="text-xl font-bold text-slate-900">Posologías Estándar</h3>
                <p class="text-xs text-slate-500">Todas las dosificaciones pueden variar según el criterio de cada especialista.</p>
            </div>
            <button id="close-posologia-modal-btn" class="p-2 text-slate-400 hover:text-slate-900 hover:bg-slate-50 rounded-xl border border-transparent hover:border-slate-100 transition-all active:scale-95 cursor-pointer">
                <Icons type="close-x" class="w-4 h-4" />
            </button>
        </header>

        <!-- Barra de Búsqueda Interna -->
        <div class="px-6 py-3 bg-slate-50/50 border-b border-slate-100">
            <div class="relative group">
                <div class="absolute left-3.5 top-0 h-full flex items-center justify-center text-slate-400 group-focus-within:text-brand transition-colors">
                    <Icons type="search" class="w-4 h-4" />
                </div>
                <input 
                    type="text" 
                    id="posologia-modal-search" 
                    placeholder="Filtrar por forma farmacéutica (ej: crema, gotas)..." 
                    class="w-full h-10 pl-10 pr-4 bg-white border border-slate-200 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand/20 transition-all shadow-sm"
                />
            </div>
        </div>

        <!-- Cuerpo / Tabla -->
        <div class="flex-1 overflow-y-auto p-6 scrollbar-premium">
            <div class="overflow-hidden border border-slate-200 rounded-xl bg-white shadow-sm">
                <table class="w-full border-collapse text-left text-sm text-slate-500">
                    <thead class="bg-slate-50 text-[11px] font-bold uppercase tracking-wider text-slate-700 border-b border-slate-200">
                        <tr>
                            <th scope="col" class="px-5 py-3.5 font-bold w-1/3">Forma Farmacéutica</th>
                            <th scope="col" class="px-5 py-3.5 font-bold">Dosificación Estándar</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200" id="posologia-modal-table-body">
                        <!-- Las filas se inyectan dinámicamente -->
                        <tr id="posologia-modal-loading-row">
                            <td colspan="2" class="px-5 py-8 text-center text-slate-400 italic">
                                Cargando información de posología...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <!-- Estado Vacío del Buscador -->
            <div id="posologia-modal-empty" class="hidden py-10 text-center text-slate-400">
                No se encontraron formas farmacéuticas que coincidan con la búsqueda.
            </div>
        </div>
    </div>
</div>

<script>
    let _posologiaData: any[] = [];

    function openModal() {
        const modal = document.getElementById('posologia-modal');
        const container = document.getElementById('posologia-modal-container');
        if (!modal || !container) return;

        modal.classList.remove('hidden');
        modal.classList.add('flex');
        
        // Retrasar ligeramente la animación para que se active correctamente
        requestAnimationFrame(() => {
            container.classList.remove('scale-95', 'opacity-0');
            container.classList.add('scale-100', 'opacity-100');
        });
        
        document.body.style.overflow = 'hidden'; // Evitar scroll de fondo
        
        // Focus en el buscador del modal
        const searchInput = document.getElementById('posologia-modal-search') as HTMLInputElement;
        if (searchInput) {
            searchInput.value = '';
            searchInput.focus();
        }
        renderTable(_posologiaData);
    }

    function closeModal() {
        const modal = document.getElementById('posologia-modal');
        const container = document.getElementById('posologia-modal-container');
        if (!modal || !container) return;

        container.classList.remove('scale-100', 'opacity-100');
        container.classList.add('scale-95', 'opacity-0');

        // Esperar a que termine la animación
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = ''; // Restaurar scroll
        }, 200);
    }

    function renderTable(data: any[], filter: string = '') {
        const tbody = document.getElementById('posologia-modal-table-body');
        const emptyState = document.getElementById('posologia-modal-empty');
        if (!tbody || !emptyState) return;

        const query = filter.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
        const filtered = data.filter(item => {
            const forma = (item.forma_farmaceutica || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
            return !query || forma.includes(query);
        });

        if (filtered.length === 0) {
            tbody.classList.add('hidden');
            emptyState.classList.remove('hidden');
        } else {
            tbody.classList.remove('hidden');
            emptyState.classList.add('hidden');

            tbody.innerHTML = filtered.map(item => `
                <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="px-5 py-3.5 font-bold text-slate-900">${item.forma_farmaceutica}</td>
                    <td class="px-5 py-3.5 text-slate-700 leading-relaxed">${item.posologia}</td>
                </tr>
            `).join('');
        }
    }

    // Inicializar listeners
    document.addEventListener('astro:page-load', () => {
        const closeBtn = document.getElementById('close-posologia-modal-btn');
        const backdrop = document.getElementById('posologia-modal-backdrop');
        const searchInput = document.getElementById('posologia-modal-search') as HTMLInputElement;

        closeBtn?.addEventListener('click', closeModal);
        backdrop?.addEventListener('click', closeModal);

        searchInput?.addEventListener('input', () => {
            renderTable(_posologiaData, searchInput.value);
        });

        // Escuchar el evento global para abrir el modal
        window.addEventListener('vademecum:open-posologia-modal', (e: any) => {
            _posologiaData = e.detail?.posologia || [];
            openModal();
        });

        // Cerrar con Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });
    });
</script>
