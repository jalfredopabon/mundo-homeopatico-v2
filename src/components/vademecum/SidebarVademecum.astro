---
// src/components/vademecum/SidebarVademecum.astro
---

<aside class="hidden md:flex flex-col w-64 border-r border-subtle bg-surface-white h-[calc(100vh-64px)] md:h-[calc(100vh-72px)] sticky top-[64px] md:top-[72px] overflow-y-auto shrink-0 scrollbar-premium">
    <!-- BUSCADOR STICKY (ADN Maestro) -->
    <div class="sticky top-0 z-30 bg-surface-white px-4 py-4">
        <div class="relative group">
            <div class="absolute left-[6px] top-0 h-full w-4 flex items-center justify-center text-slate-700 group-focus-within:text-brand transition-colors">
                <div class="relative w-4 h-4 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
                        <path d="M17 17L21 21"></path>
                        <path d="M19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19C15.4183 19 19 15.4183 19 11Z"></path>
                    </svg>
                </div>
            </div>
            <input 
                type="search" 
                id="vademecum-search" 
                placeholder="Buscar..." 
                class="w-full h-10 pl-8 pr-4 bg-slate-50/70 border border-subtle rounded-lg text-[14px] text-slate-800 focus:outline-none focus:bg-white focus:ring-1 focus:ring-brand focus:border-brand transition-all placeholder:text-slate-700 mt-[-2.5px]"
            >
        </div>
    </div>

    <div class="p-6 pt-0 space-y-7">
        <!-- SECCIÓN 1: TIPO DE TERAPIA -->
        <section class="pl-1">
            <h4 class="text-[11px] font-bold text-slate-900 mb-4 flex items-center gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-slate-900">
                    <path d="M9.06845 2H14.9316C15.8529 2 16.3135 2 16.5997 2.29289C17.1334 2.83907 17.1334 5.16093 16.5997 5.70711C16.3135 6 15.8529 6 14.9316 6H9.06845C8.14715 6 7.6865 6 7.40029 5.70711C6.86657 5.16093 6.86657 2.83907 7.40029 2.29289C7.6865 2 8.14715 2 9.06845 2Z"></path>
                    <path d="M8 6C8.16493 6.32986 8.24741 6.49481 8.30606 6.6557C8.61211 7.49515 8.52805 8.42732 8.07678 9.19848C7.99029 9.34628 7.87965 9.49381 7.65836 9.78885L7.25493 10.3268C6.80486 10.9269 6.57983 11.2269 6.41674 11.5556C6.252 11.8877 6.13421 12.241 6.06677 12.6055C6 12.9664 6 13.3414 6 14.0915V16C6 18.8284 6 20.2426 6.87868 21.1213C7.75736 22 9.17157 22 12 22C14.8284 22 16.2426 22 17.1213 21.1213C18 20.2426 18 18.8284 18 16V14.0915C18 13.3414 18 12.9664 17.9332 12.6055C17.8658 12.241 17.748 11.8877 17.5833 11.5556C17.4202 11.2269 17.1951 10.9269 16.7451 10.3268L16.3416 9.78885C16.1204 9.49381 16.0097 9.34628 15.9232 9.19848C15.4719 8.42732 15.3879 7.49515 15.6939 6.6557C15.7526 6.49481 15.8351 6.32987 16 6"></path>
                    <path d="M12 13V18M9.5 15.5L14.5 15.5"></path>
                </svg>
                Tipo de terapia
            </h4>
            <div class="space-y-3">
                {["Homeopatía compleja", "Terapia floral", "Oligoelementos"].map((filter) => (
                    <label class="flex items-center gap-3 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        {filter}
                    </label>
                ))}
            </div>
        </section>

        <!-- SECCIÓN 2: SISTEMA DEL CUERPO -->
        <section class="pl-1">
            <h4 class="text-[11px] font-bold text-slate-900 mb-4 flex items-center gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-slate-900">
                    <path d="M2 12H6L7.5 8L9.5 15L13 6L15.5 18L18 12H22"></path>
                </svg>
                Sistema del cuerpo
            </h4>
            <div class="space-y-3">
                {["Digestivo", "Nervioso", "Cardiovascular", "Respiratorio", "Locomotor"].map((filter) => (
                    <label class="flex items-center gap-3 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        {filter}
                    </label>
                ))}
            </div>
        </section>

        <!-- SECCIÓN 3: FORMA FARMACÉUTICA -->
        <section class="pl-1">
            <h4 class="text-[11px] font-bold text-slate-900 mb-4 flex items-center gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-slate-900">
                    <path d="M11.4497 19.5503L19.5503 11.4497C20.4785 10.5215 21 9.2625 21 7.94975C21 5.21608 18.7839 3 16.0503 3C14.7375 3 13.4785 3.52149 12.5503 4.44975L4.44975 12.5503C3.52149 13.4785 3 14.7375 3 16.0503C3 18.7839 5.21608 21 7.94975 21C9.2625 21 10.5215 20.4785 11.4497 19.5503Z"></path>
                    <path d="M8.5 8.5L15.5 15.5"></path>
                </svg>
                Forma farmacéutica
            </h4>
            <div class="space-y-3">
                {["Gotas", "Tabletas", "Spray", "Crema"].map((filter) => (
                    <label class="flex items-center gap-3 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                        <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                        {filter}
                    </label>
                ))}
            </div>
        </section>
    </div>
</aside>
