---
// src/components/vademecum/SidebarVademecum.astro
import Icons from "../shared/Icons.astro";

interface Props {
    userName?: string;
    activeView?: 'productos' | 'protocolos';
}

const { 
    userName = "Invitado", 
    activeView = "productos"
} = Astro.props;
---

<aside class="hidden md:flex flex-col w-64 border-r border-subtle bg-surface-white h-[calc(100dvh-64px)] sticky top-[64px] overflow-y-auto scrollbar-premium shrink-0">
    <!-- BUSCADOR STICKY (Clon idéntico a Catálogo) -->
    <div class="sidebar-search-header">
        <div class="relative group">
            <div class="absolute left-[7px] top-0 h-full w-4 flex items-center justify-center text-slate-700 group-focus-within:text-brand transition-colors">
                <div class="relative w-4 h-4 flex items-center justify-center">
                    <Icons type="search" class="w-full h-full" />
                </div>
            </div>
            <input 
                type="search" 
                id="vademecum-search" 
                placeholder="Buscar..." 
                class="input-elite-field pl-8 pr-4 mt-[-2.5px]"
            >
        </div>
    </div>

    <!-- Navegación de Filtros -->
    <div class="flex-1 flex flex-col pb-12" style="gap: var(--sb-section-gap)">
        <!-- Sección 1: Tipo de terapia (Productos) -->
        <section class="sidebar-filter-section" style="padding-left: calc(var(--sb-px) + var(--sb-icon-offset))" data-view-target="products" id="section-terapia">
            <h4 class="text-[12px] font-bold text-slate-900 mb-4 tracking-tight">
                Tipo de terapia
            </h4>
            <div class="flex flex-col" style="gap: var(--sb-item-gap)" id="filter-terapia-list">
                <!-- Skeleton Loader -->
                <div class="space-y-2 animate-pulse pr-4">
                    <div class="h-4 bg-slate-50 rounded w-full"></div>
                    <div class="h-4 bg-slate-50 rounded w-3/4"></div>
                </div>
            </div>
        </section>

        <!-- Sección 2: Sistema del cuerpo (solo Protocolos) -->
        <section class="sidebar-filter-section hidden" style="padding-left: calc(var(--sb-px) + var(--sb-icon-offset))" data-view-target="protocols" id="section-sistema">
            <h4 class="text-[12px] font-bold text-slate-900 mb-4 tracking-tight">
                Sistema del cuerpo
            </h4>
            <div class="flex flex-col" style="gap: var(--sb-item-gap)" id="filter-sistema-list"></div>
        </section>

        <!-- Sección 3: Forma farmacéutica (Productos) -->
        <section class="sidebar-filter-section" style="padding-left: calc(var(--sb-px) + var(--sb-icon-offset))" data-view-target="products" id="section-forma">
            <h4 class="text-[12px] font-bold text-slate-900 mb-4 tracking-tight">
                Forma farmacéutica
            </h4>
            <div class="flex flex-col" style="gap: var(--sb-item-gap)" id="filter-forma-list">
                <p class="text-[10px] text-slate-400 animate-pulse italic">Cargando formas...</p>
            </div>
        </section>
    </div>

    <!-- Contenedor Inferior: Identidad del Profesional (Hito: Reubicación de Saludo) -->
    <div class="px-4 py-4 mt-auto bg-surface-muted/50 border-t border-subtle">
        <div class="flex items-center gap-3 p-2 rounded-xl transition-all hover:bg-white hover:shadow-sm group">
            <div class="w-8 h-8 rounded-lg bg-slate-900 flex items-center justify-center text-white ring-1 ring-white/20 shadow-sm transition-transform group-hover:scale-105 overflow-hidden">
                <span id="sidebar-user-initials" class="text-[12px] font-bold tracking-tighter">IN</span>
            </div>
            <div class="flex flex-col min-w-0 flex-1">
                <span class="text-[10px] text-slate-500 font-bold leading-none mb-1 tracking-tight">Hola</span>
                <span id="sidebar-user-name" class="text-[13px] font-bold text-slate-900 leading-none truncate group-hover:text-brand transition-colors">
                    Invitado
                </span>
            </div>
            <!-- Botón Logout -->
            <button 
                id="sidebar-logout-btn" 
                class="p-2 rounded-lg text-slate-400 hover:text-red-500 hover:bg-red-50 transition-all active:scale-95"
                title="Cerrar sesión"
            >
                <Icons type="log-out" class="w-4 h-4" />
            </button>
        </div>
    </div>
</aside>

<script>
    function updateSidebarSession() {
        const initialsEl = document.getElementById('sidebar-user-initials');
        const nameEl = document.getElementById('sidebar-user-name');
        const logoutBtn = document.getElementById('sidebar-logout-btn');
        
        if (!initialsEl || !nameEl) return;

        // Intentar leer de localStorage o sessionStorage
        const sessionRaw = localStorage.getItem('mh_session') || sessionStorage.getItem('mh_session');
        
        if (sessionRaw) {
            try {
                const session = JSON.parse(sessionRaw);
                initialsEl.textContent = session.iniciales || 'IN';
                nameEl.textContent = session.nombre_usuario || 'Usuario';
                if (logoutBtn) logoutBtn.classList.remove('hidden');
            } catch (e) {
                console.error('[Elite Sidebar] Error al parsear sesión');
            }
        } else {
            initialsEl.textContent = 'IN';
            nameEl.textContent = 'Invitado';
            if (logoutBtn) logoutBtn.classList.add('hidden');
        }
    }

    function initSidebarActions() {
        const logoutBtn = document.getElementById('sidebar-logout-btn');
        logoutBtn?.addEventListener('click', () => {
            if (confirm('¿Desea cerrar su sesión profesional?')) {
                localStorage.removeItem('mh_session');
                sessionStorage.removeItem('mh_session');
                window.location.reload(); // Esto disparará el guardián de acceso
            }
        });

        updateSidebarSession();
    }

    // Inicializar y escuchar cambios
    document.addEventListener('astro:page-load', initSidebarActions);
    document.addEventListener('mhSessionUpdated', updateSidebarSession);
</script>
