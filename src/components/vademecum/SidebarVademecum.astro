---
import Icons from "../catalogo/Icons.astro";
import StickyActionBox from "../shared/StickyActionBox.astro";
---

<aside class="mh-sidebar">
    <!-- BUSCADOR STICKY UNIFICADO -->
    <StickyActionBox 
        id="vademecum-search" 
        placeholder="Buscar..." 
    />

    <div class="p-4 pt-0 space-y-7">

        <section class="pl-[6px]">
            <h4 class="text-[11px] font-bold text-body mb-4 flex items-center gap-3">
                <div class="w-3.5 h-3.5 text-body">
                    <Icons type="test-tube" />
                </div>
                Tipo de terapia
            </h4>
            <div class="space-y-3">
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Homeopatía compleja
                </label>
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Terapia floral
                </label>
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Oligoelementos
                </label>
            </div>
        </section>

        <section class="pl-[6px]">
            <h4 class="text-[11px] font-bold text-body mb-4 flex items-center gap-3">
                <div class="w-3.5 h-3.5 text-body">
                    <Icons type="pulse" />
                </div>
                Sistema del cuerpo
            </h4>
            <div class="space-y-3">
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Digestivo
                </label>
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Nervioso
                </label>
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Cardiovascular
                </label>
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Respiratorio
                </label>
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Locomotor
                </label>
            </div>
        </section>

        <section class="pl-[6px]">
            <h4 class="text-[11px] font-bold text-body mb-4 flex items-center gap-3">
                <div class="w-3.5 h-3.5 text-body">
                    <Icons type="pill" />
                </div>
                Forma farmacéutica
            </h4>
            <div class="space-y-3">
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Gotas
                </label>
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Tabletas
                </label>
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Spray
                </label>
                <label class="flex items-center gap-3 pl-[6px] text-[13px] text-secondary cursor-pointer hover:text-body has-[:checked]:text-body transition-colors">
                    <input type="checkbox" class="size-3.5 rounded border-subtle accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                    Crema
                </label>
            </div>
        </section>

    </div>
</aside>

