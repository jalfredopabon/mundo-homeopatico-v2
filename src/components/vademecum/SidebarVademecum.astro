---
// src/components/vademecum/SidebarVademecum.astro
import Icons from "../shared/Icons.astro";

interface Props {
    userName?: string;
    activeView?: 'productos' | 'protocolos';
}

const { 
    userName = "Invitado", 
    activeView = "productos"
} = Astro.props;
---

<aside class="hidden md:flex flex-col w-64 border-r border-subtle bg-surface-white h-[calc(100dvh-64px)] sticky top-[64px] overflow-y-auto scrollbar-premium shrink-0">
    <!-- Buscador sticky -->
    <div class="sidebar-search-header">
        <div class="relative group">
            <div class="absolute left-[7px] top-0 h-full w-4 flex items-center justify-center text-slate-700 group-focus-within:text-brand transition-colors">
                <Icons type="search" class="w-full h-full" strokeWidth={1.5} />
            </div>
            <input 
                type="search" 
                id="vademecum-search" 
                placeholder="Buscar..." 
                class="input-elite-field pl-8 pr-4 mt-[-2.5px]"
            >
        </div>
    </div>

    <!-- Navegación de Filtros -->
    <div class="flex-1 px-4 pb-6 pt-0 space-y-7">
        <!-- Sección 1: Tipo de terapia (Productos) -->
        <section class="sidebar-filter-section" data-view-target="products" id="section-terapia">
            <h4 class="text-[11px] font-bold text-slate-900 mb-4 flex items-center gap-2.5 uppercase tracking-wider">
                <Icons type="mortero" class="w-4 h-4 text-slate-900" strokeWidth={1.8} />
                Tipo de terapia
            </h4>
            <div class="space-y-4" id="filter-terapia-list">
                <p class="text-[10px] text-slate-400 animate-pulse italic">Cargando terapias...</p>
            </div>
        </section>

        <!-- Sección 2: Sistema del cuerpo (solo Protocolos) -->
        <section class="sidebar-filter-section hidden" data-view-target="protocols" id="section-sistema">
            <h4 class="text-[11px] font-bold text-slate-900 mb-4 flex items-center gap-2.5 uppercase tracking-wider">
                <Icons type="user-circle-alt" class="w-4 h-4 text-slate-900" strokeWidth={1.5} />
                Sistema del cuerpo
            </h4>
            <div class="space-y-4" id="filter-sistema-list">
                <p class="text-[10px] text-slate-400 animate-pulse italic">Cargando sistemas...</p>
            </div>
        </section>

        <!-- Sección 3: Forma farmacéutica (Productos) -->
        <section class="sidebar-filter-section" data-view-target="products" id="section-forma">
            <h4 class="text-[11px] font-bold text-slate-900 mb-4 flex items-center gap-2.5 uppercase tracking-wider">
                <Icons type="pill" class="w-4 h-4 text-slate-900" strokeWidth={1.5} />
                Forma farmacéutica
            </h4>
            <div class="space-y-4" id="filter-forma-list">
                <p class="text-[10px] text-slate-400 animate-pulse italic">Cargando formas...</p>
            </div>
        </section>
    </div>

    <!-- Contenedor Inferior: Identidad del Profesional (Hito: Reubicación de Saludo) -->
    <div class="px-4 py-4 mt-auto bg-surface-muted/50 border-t border-subtle">
        <div class="flex items-center gap-3 p-2 rounded-xl transition-all hover:bg-white hover:shadow-sm group">
            <div class="w-8 h-8 rounded-lg bg-slate-900 flex items-center justify-center text-white ring-1 ring-white/20 shadow-sm transition-transform group-hover:scale-105 overflow-hidden">
                <span class="text-[12px] font-bold tracking-tighter">AL</span>
            </div>
            <div class="flex flex-col min-w-0">
                <span class="text-[10px] text-slate-500 font-bold leading-none mb-1 tracking-tight">Hola</span>
                <span class="text-[13px] font-bold text-slate-900 leading-none truncate group-hover:text-brand transition-colors">
                    Alfredo Pabón
                </span>
            </div>
        </div>
    </div>
</aside>
