---
// src/components/vademecum/SidebarVademecum.astro
import Icons from "../shared/Icons.astro";
---

<aside class="hidden md:flex flex-col w-64 border-r border-subtle bg-surface-white h-[calc(100dvh-64px)] sticky top-[64px] overflow-y-auto scrollbar-premium shrink-0">
    <!-- Buscador sticky -->
    <div class="sticky top-0 z-30 bg-surface-white px-4 py-4">
        <div class="relative group">
            <div class="absolute left-[7px] top-0 h-full w-4 flex items-center justify-center text-slate-700 group-focus-within:text-brand transition-colors">
                <Icons type="search" class="w-full h-full" strokeWidth={1.5} />
            </div>
            <input 
                type="search" 
                id="vademecum-search" 
                placeholder="Buscar..." 
                class="input-elite-field pl-8 pr-4 mt-[-2.5px]"
            >
        </div>
    </div>

    <div class="px-4 pb-6 pt-0 space-y-7">
        <!-- Sección 1: Tipo de terapia -->
        <section class="sidebar-filter-section">
            <h4 class="text-[11px] font-bold text-slate-900 mb-4 flex items-center gap-2.5">
                <Icons type="mortero" class="w-4 h-4 text-slate-900" strokeWidth={1.8} />
                Tipo de terapia
            </h4>
            <div class="space-y-4">
                {["Homeopatía compleja", "Oligoelementos", "Terapia floral"].map((filter) => (
                    <label class="sidebar-filter-label">
                        <input 
                            type="checkbox" 
                            class="vademecum-filter sidebar-filter-checkbox"
                            data-filter-group="terapia"
                            data-filter-value={filter}
                        />
                        {filter}
                    </label>
                ))}
            </div>
        </section>

        <!-- Sección 2: Sistema del cuerpo -->
        <section class="sidebar-filter-section">
            <h4 class="text-[11px] font-bold text-slate-900 mb-4 flex items-center gap-2.5">
                <Icons type="user-circle-alt" class="w-4 h-4 text-slate-900" strokeWidth={1.5} />
                Sistema del cuerpo
            </h4>
            <div class="space-y-4">
                {["Cardiovascular", "Digestivo", "Locomotor", "Nervioso", "Respiratorio"].map((filter) => (
                    <label class="sidebar-filter-label">
                        <input 
                            type="checkbox" 
                            class="vademecum-filter sidebar-filter-checkbox"
                            data-filter-group="sistema"
                            data-filter-value={filter}
                        />
                        {filter}
                    </label>
                ))}
            </div>
        </section>

        <!-- Sección 3: Forma farmacéutica -->
        <section class="sidebar-filter-section">
            <h4 class="text-[11px] font-bold text-slate-900 mb-4 flex items-center gap-2.5">
                <Icons type="pill" class="w-4 h-4 text-slate-900" strokeWidth={1.5} />
                Forma farmacéutica
            </h4>
            <div class="space-y-4">
                {["Crema", "Gotas", "Spray", "Tabletas"].map((filter) => (
                    <label class="sidebar-filter-label">
                        <input 
                            type="checkbox" 
                            class="vademecum-filter sidebar-filter-checkbox"
                            data-filter-group="forma"
                            data-filter-value={filter}
                        />
                        {filter}
                    </label>
                ))}
            </div>
        </section>
    </div>
</aside>
