---
// src/components/vademecum/VademecumSkeleton.astro
---

<div class="vademecum-skeleton-container space-y-4">
    {[1, 2, 3, 4].map(() => (
        <div class="bg-surface-white border border-subtle rounded-xl p-6 shadow-sm relative overflow-hidden h-[160px]">
            <!-- Shimmer Effect -->
            <div class="shimmer-wrapper"></div>
            
            <div class="flex flex-col gap-4">
                <!-- Título -->
                <div class="h-6 w-1/3 bg-slate-100 rounded-md"></div>
                
                <!-- Descripción -->
                <div class="space-y-2">
                    <div class="h-4 w-full bg-slate-100 rounded-md"></div>
                    <div class="h-4 w-5/6 bg-slate-100 rounded-md"></div>
                </div>
                
                <!-- Badges -->
                <div class="flex gap-2 mt-2">
                    <div class="h-6 w-16 bg-slate-50 rounded-full border border-slate-100"></div>
                    <div class="h-6 w-20 bg-slate-50 rounded-full border border-slate-100"></div>
                    <div class="h-6 w-14 bg-slate-50 rounded-full border border-slate-100"></div>
                </div>
            </div>
        </div>
    ))}
</div>

<style>
    .shimmer-wrapper {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            90deg,
            rgba(255, 255, 255, 0) 0%,
            rgba(255, 255, 255, 0.6) 50%,
            rgba(255, 255, 255, 0) 100%
        );
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite linear;
    }

    @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }
</style>
