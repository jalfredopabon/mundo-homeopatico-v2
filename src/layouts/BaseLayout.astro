---
// src/layouts/BaseLayout.astro
const { title = "Mundo Homeopático", description = "Catálogo digital de productos homeopáticos", mostrarZoom = false } = Astro.props;
import '../styles/global.css';
import Header from '../components/shared/Header.astro';
import Footer from '../components/shared/Footer.astro';
import MobileTabNav from '../components/shared/MobileTabNav.astro';
import MobileMenuDrawer from '../components/shared/MobileMenuDrawer.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import MobileSplash from '../components/shared/MobileSplash.astro';
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
        <!-- 🛰️ Cúpula de Hierro: Content Security Policy (Elite Security) -->
        <meta http-equiv="Content-Security-Policy" content="
            default-src 'self'; 
            script-src 'self' 'unsafe-inline' https://www.youtube.com;
            style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
            font-src 'self' https://fonts.gstatic.com;
            img-src 'self' data: https://i.ytimg.com https://s.ytimg.com;
            frame-src 'self' https://www.youtube.com;
            connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://script.google.com https://script.googleusercontent.com;
        " />
		
		<!-- 🖋️ Infraestructura Tipográfica Elite (Hito 51) -->
		<!-- Acelera el handshake con Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<!-- Carga de fuentes críticas con display=swap para evitar texto invisible -->
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

		<ViewTransitions />
		<title>{title}</title>
	</head>
	<body class="bg-surface-white text-body font-sans antialiased flex flex-col min-h-dvh md:h-screen md:overflow-hidden">
        <MobileSplash />
        <Header mostrarZoom={mostrarZoom} />
        <MobileTabNav />
		<main class="flex-1 w-full flex flex-col min-h-0">
			<slot />
		</main>
        <MobileMenuDrawer />
        <CartDrawer />
	</body>
</html>
