---
// src/layouts/BaseLayout.astro
const { title = "Mundo Homeopático", description = "Catálogo digital de productos homeopáticos", mostrarZoom = false } = Astro.props;
import '../styles/global.css';
import Header from '../components/shared/Header.astro';
import Footer from '../components/shared/Footer.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-surface-white text-body font-sans antialiased flex flex-col h-screen overflow-hidden">
        <Header mostrarZoom={mostrarZoom} />
		<main class="flex-1 w-full flex">
			<slot />
		</main>
	</body>
</html>
