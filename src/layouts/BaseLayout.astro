---
// src/layouts/BaseLayout.astro
const { title = "Mundo Homeopático", description = "Catálogo digital de productos homeopáticos", mostrarZoom = false } = Astro.props;
import '../styles/global.css';
import Header from '../components/shared/Header.astro';
import Footer from '../components/shared/Footer.astro';
import MobileTabNav from '../components/shared/MobileTabNav.astro';
import MobileMenuDrawer from '../components/shared/MobileMenuDrawer.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import MobileSplash from '../components/shared/MobileSplash.astro';
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<ViewTransitions />
		<title>{title}</title>
		{/* Eruda Diagnostic Tool - Temporal */}
		<script is:inline src="https://cdn.jsdelivr.net/npm/eruda"></script>
		<script is:inline>eruda.init();</script>
	</head>
	<body class="bg-surface-white text-body font-sans antialiased flex flex-col md:h-screen md:overflow-hidden">
        <MobileSplash />
        <Header mostrarZoom={mostrarZoom} />
        <MobileTabNav />
		<main class="flex-1 w-full flex flex-col min-h-0">
			<slot />
		</main>
        <MobileMenuDrawer />
        <CartDrawer />
	</body>
</html>
