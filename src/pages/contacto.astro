---
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarContacto from '../components/contacto/SidebarContacto.astro';
import Footer from '../components/shared/Footer.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';

// Importación de Secciones Modulares
import VideoSection from '../components/sections/VideoSection.astro';
import Locations from '../components/sections/Locations.astro';
import FAQ from '../components/sections/FAQ.astro';
---

<BaseLayout title="Sedes y contacto | Mundo homeopático" mostrarZoom={false}>
    
    <!-- Carrito Lateral (Drawer) -->
    <CartDrawer />
    
    <!-- Contenedor Principal de 2 columnas (Aísla el scroll) -->
    <div class="flex flex-col md:flex-row w-full flex-1 h-[calc(100vh-4rem)] md:h-[calc(100vh-5rem)]">
        
        <!-- Columna Izquierda: Sidebar de Navegación (Fijo en Desktop) -->
        <SidebarContacto />

        <!-- Columna Derecha: Contenedor Principal Fluid + Footer ancho total relativo -->
        <div class="flex-1 overflow-y-auto w-full relative flex flex-col bg-surface-muted h-[calc(100vh-4rem)] md:h-[calc(100vh-5rem)] scroll-smooth" id="contacto-main-scroll">
            
            <!-- Área de Contenido -->
            <div class="px-8 md:px-16 pt-8 md:pt-10 pb-24 flex-1 flex flex-col">
                <div class="flex flex-col gap-16 md:gap-20 max-w-5xl">
                
                    <!-- Sección 1: Excelencia Homeopática -->
                    <VideoSection />

                    <!-- Sección 2: Sedes y Distribuciones -->
                    <Locations />

                    <!-- Sección 3: Preguntas Frecuentes -->
                    <FAQ />

                </div>
            </div>

            <!-- Footer incrustado al final de la columna derecha -->
            <div class="mt-auto w-full border-t border-strong/60">
                <Footer />
            </div>

        </div>

    </div>

</BaseLayout>
