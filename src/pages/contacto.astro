---
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarContacto from '../components/contacto/SidebarContacto.astro';
import Footer from '../components/shared/Footer.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
---

<BaseLayout title="Sedes y contacto | Mundo homeopático" mostrarZoom={false}>
    
    <!-- Carrito Lateral (Drawer) -->
    <CartDrawer />
    
    <!-- Contenedor Principal de 2 columnas (Aísla el scroll) -->
    <div class="flex flex-col md:flex-row w-full flex-1 h-[calc(100vh-4rem)] md:h-[calc(100vh-5rem)]">
        
        <!-- Columna Izquierda: Sidebar de Navegación (Fijo en Desktop) -->
        <SidebarContacto />

        <!-- Columna Derecha: Contenedor Principal Fluid + Footer ancho total relativo -->
        <div class="flex-1 overflow-y-auto w-full relative flex flex-col bg-surface-muted h-[calc(100vh-4rem)] md:h-[calc(100vh-5rem)] scroll-smooth" id="contacto-main-scroll">
            
            <!-- Área de Contenido -->
            <div class="px-8 md:px-16 pt-8 md:pt-10 pb-24 flex-1 flex flex-col">
                <div class="flex flex-col gap-16 md:gap-20 max-w-5xl">
                
                <!-- Sección 1: Excelencia Homeopática -->
                <section id="excelencia" class="scroll-mt-10">
                    <header class="mb-8 flex flex-col gap-1.5">
                        <h2 class="text-[2.25rem] leading-tight font-extrabold text-secondary tracking-tight">Excelencia homeopática</h2>
                        <p class="text-muted text-base font-medium">Nuestra promesa de calidad y procesos de manufactura.</p>
                    </header>
                    <!-- Contenedor vacío para Video/Imagen -->
                    <div class="relative group aspect-[21/9] sm:aspect-[16/9] w-full overflow-hidden rounded-2xl bg-secondary shadow-xl border border-strong/60 transition-all">
                        <img alt="Laboratorio farmacéutico clínico" class="h-full w-full object-cover opacity-60 group-hover:scale-105 group-hover:opacity-70 transition-all duration-[2000ms]" src="https://images.unsplash.com/photo-1581093458791-9f3c3900df4b?q=80&w=1200&auto=format&fit=crop"/>
                        <div class="absolute inset-0 bg-gradient-to-t from-secondary/90 via-transparent to-transparent"></div>
                        
                        <div class="absolute inset-0 flex items-center justify-center">
                            <button class="flex h-20 w-20 items-center justify-center rounded-full bg-surface-white/10 backdrop-blur-md text-surface-white border border-surface-white/20 hover:bg-surface-white hover:text-brand transition-all duration-300 shadow-2xl scale-95 hover:scale-105 active:scale-95 group/play" aria-label="Reproducir video">
                                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M8 5v14l11-7z"/></svg>
                            </button>
                        </div>

                        <div class="absolute bottom-0 left-0 w-full p-6 sm:p-8">
                            <div class="bg-black/30 backdrop-blur-md border border-surface-white/10 rounded-xl p-5 flex flex-col md:flex-row md:items-center justify-between gap-6">
                                <div class="flex flex-col gap-1.5">
                                    <p class="text-sm font-bold text-surface-white tracking-widest opacity-90">Procesos de calidad premium</p>
                                    <p class="text-surface-white/80 text-sm max-w-md">Descubra cómo transformamos la materia prima en soluciones homeopáticas de alta fidelidad clínica.</p>
                                </div>
                                <div class="flex items-center gap-3 min-w-[200px] w-full md:w-auto">
                                    <div class="h-1.5 flex-1 rounded-full bg-surface-white/20 overflow-hidden">
                                        <div class="h-full w-1/3 rounded-full bg-brand shadow-lg shadow-brand/50"></div>
                                    </div>
                                    <span class="text-[11px] font-bold text-surface-white/90 tabular-nums tracking-wide">01:45 / 04:30</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Sección 2: Sedes y Distribuciones -->
                <section id="sedes" class="scroll-mt-10">
                    <header class="mb-8 flex flex-col gap-1.5">
                        <h2 class="text-[2.25rem] leading-tight font-extrabold text-secondary tracking-tight">Sedes y distribuciones</h2>
                        <p class="text-muted text-base font-medium">Encuentra nuestra sede clínica y puntos autorizados.</p>
                    </header>
                    <div class="flex flex-col gap-8">
                        <!-- Tarjeta Sede Principal -->
                        <div class="w-full bg-surface-white rounded-2xl shadow-sm border border-subtle/80 overflow-hidden flex flex-col lg:flex-row group hover:shadow-lg hover:border-strong transition-all duration-500">
                            <div class="flex flex-1 flex-col justify-between p-8 lg:p-12">
                                <div>
                                    <div class="inline-flex items-center gap-2 rounded-lg bg-brand/5 px-3 py-1 text-[11px] font-bold text-brand mb-6 border border-brand/20">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
                                        Sede principal y laboratorio
                                    </div>
                                    <h3 class="text-secondary text-2xl font-extrabold mb-8 tracking-tight">Mundo homeopático Bogotá</h3>
                                    
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                        <div class="space-y-3">
                                            <div class="flex items-center gap-2.5 text-brand">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                                <span class="text-[11px] font-bold text-muted/80">Dirección</span>
                                            </div>
                                            <p class="text-body leading-relaxed font-semibold text-[15px]">Calle de la Salud 123<br/>Edificio San Lucas, Piso 4<br/>Bogotá D.C.</p>
                                        </div>
                                        <div class="space-y-3">
                                            <div class="flex items-center gap-2.5 text-brand">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                                <span class="text-[11px] font-bold text-muted/80">Horarios</span>
                                            </div>
                                            <p class="text-body leading-relaxed text-[15px]">
                                                <span class="font-bold">Lunes a viernes:</span> 8:00 AM - 6:00 PM<br/>
                                                <span class="font-bold">Sábados:</span> 9:00 AM - 1:00 PM
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex flex-col sm:flex-row gap-4 mt-10">
                                    <button class="flex-1 flex items-center justify-center gap-2.5 rounded-xl bg-brand px-6 py-4 text-surface-white font-bold hover:bg-brand-dark transition-all focus:ring-2 focus:ring-brand focus:ring-offset-1 active:scale-95 shadow-sm hover:shadow-md hover:-translate-y-0.5">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                                        Contactar farmacia
                                    </button>
                                    <button class="flex-1 flex items-center justify-center gap-2.5 rounded-xl bg-surface-white border border-strong px-6 py-4 text-body font-bold hover:border-brand/50 hover:bg-surface-muted transition-all focus:ring-2 focus:ring-strong focus:ring-offset-1 active:scale-95">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                        Ver línea telefónica
                                    </button>
                                </div>
                            </div>
                            <div class="relative w-full lg:w-[40%] min-h-[300px] lg:min-h-0 bg-surface-muted overflow-hidden border-l border-subtle/50">
                                <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center grayscale contrast-125 opacity-20 filter blur-[1px]"></div>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="relative z-10 flex flex-col items-center group-hover:-translate-y-1 transition-transform duration-500">
                                        <div class="bg-surface-white px-4 py-2 rounded-lg shadow-xl border border-subtle whitespace-nowrap mb-2 relative">
                                            <p class="text-[13px] font-bold text-secondary">Sede principal MH</p>
                                            <div class="absolute -bottom-1.5 left-1/2 -translate-x-1/2 w-3 h-3 bg-surface-white border-r border-b border-subtle rotate-45"></div>
                                        </div>
                                        <div class="relative flex items-center justify-center h-12 w-12 bg-brand rounded-full text-surface-white shadow-lg shadow-brand/40 border-4 border-surface-white">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Grilla de Distribuidores -->
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            
                            <!-- Card Distribuidor 1 -->
                            <div class="bg-surface-white rounded-2xl p-6 shadow-sm border border-subtle hover:border-brand/30 hover:shadow-md transition-all group flex flex-col">
                                <div class="flex items-center gap-3.5 mb-5">
                                    <div class="h-10 w-10 rounded-xl bg-surface-muted border border-subtle flex items-center justify-center text-brand group-hover:bg-brand group-hover:text-surface-white transition-colors duration-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M9 8h1"/><path d="M9 12h1"/><path d="M9 16h1"/><path d="M14 8h1"/><path d="M14 12h1"/><path d="M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>
                                    </div>
                                    <div>
                                        <h4 class="text-[15px] font-bold text-secondary leading-tight">Distribuidora occidente</h4>
                                        <p class="text-muted/80 text-[11px] font-bold">Medellín</p>
                                    </div>
                                </div>
                                <div class="mt-auto space-y-3">
                                    <div class="flex items-center gap-2 text-muted">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                                        <span class="text-[13px] font-medium">medellin@mundohomeo.co</span>
                                    </div>
                                    <button class="w-full flex items-center justify-center gap-2 rounded-lg bg-surface-muted border border-strong px-4 py-2.5 text-body font-bold text-[13px] hover:bg-surface-muted transition-colors">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                        Llamar sucursal
                                    </button>
                                </div>
                            </div>

                            <!-- Card Distribuidor 2 -->
                            <div class="bg-surface-white rounded-2xl p-6 shadow-sm border border-subtle hover:border-brand/30 hover:shadow-md transition-all group flex flex-col">
                                <div class="flex items-center gap-3.5 mb-5">
                                    <div class="h-10 w-10 rounded-xl bg-surface-muted border border-subtle flex items-center justify-center text-brand group-hover:bg-brand group-hover:text-surface-white transition-colors duration-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M9 8h1"/><path d="M9 12h1"/><path d="M9 16h1"/><path d="M14 8h1"/><path d="M14 12h1"/><path d="M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>
                                    </div>
                                    <div>
                                        <h4 class="text-[15px] font-bold text-secondary leading-tight">Sede valle del Cauca</h4>
                                        <p class="text-muted/80 text-[11px] font-bold">Cali</p>
                                    </div>
                                </div>
                                <div class="mt-auto space-y-3">
                                    <div class="flex items-center gap-2 text-muted">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                                        <span class="text-[13px] font-medium">cali@mundohomeo.co</span>
                                    </div>
                                    <button class="w-full flex items-center justify-center gap-2 rounded-lg bg-surface-muted border border-strong px-4 py-2.5 text-body font-bold text-[13px] hover:bg-surface-muted transition-colors">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                        Llamar sucursal
                                    </button>
                                </div>
                            </div>

                            <!-- Card Distribuidor 3 -->
                            <div class="bg-surface-white rounded-2xl p-6 shadow-sm border border-subtle hover:border-brand/30 hover:shadow-md transition-all group flex flex-col">
                                <div class="flex items-center gap-3.5 mb-5">
                                    <div class="h-10 w-10 rounded-xl bg-surface-muted border border-subtle flex items-center justify-center text-brand group-hover:bg-brand group-hover:text-surface-white transition-colors duration-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M9 8h1"/><path d="M9 12h1"/><path d="M9 16h1"/><path d="M14 8h1"/><path d="M14 12h1"/><path d="M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>
                                    </div>
                                    <div>
                                        <h4 class="text-[15px] font-bold text-secondary leading-tight">Farma costa norte</h4>
                                        <p class="text-muted/80 text-[11px] font-bold">Barranquilla</p>
                                    </div>
                                </div>
                                <div class="mt-auto space-y-3">
                                    <div class="flex items-center gap-2 text-muted">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                                        <span class="text-[13px] font-medium">barranquilla@mundohomeo.co</span>
                                    </div>
                                    <button class="w-full flex items-center justify-center gap-2 rounded-lg bg-surface-muted border border-strong px-4 py-2.5 text-body font-bold text-[13px] hover:bg-surface-muted transition-colors">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                        Llamar sucursal
                                    </button>
                                </div>
                            </div>

                        </div>
                    </div>
                </section>

                <!-- Sección 3: FAQ -->
                <section id="faq" class="scroll-mt-10">
                    <header class="mb-8 flex flex-col gap-1.5">
                        <h2 class="text-[2.25rem] leading-tight font-extrabold text-secondary tracking-tight">Preguntas frecuentes</h2>
                        <p class="text-muted text-base font-medium">Respondemos a las inquietudes más comunes.</p>
                    </header>
                    <div class="w-full flex flex-col gap-3">
                        
                        <!-- FAQ Item 1 (Cerrado por defecto) -->
                        <div class="group rounded-2xl border border-strong bg-surface-white hover:border-brand/30 transition-all duration-300 shadow-sm overflow-hidden faq-item is-closed">
                            <button class="faq-header flex w-full items-center justify-between p-6 sm:p-7 text-left focus:outline-none focus:bg-surface-muted transition-colors">
                                <span class="text-[17px] font-bold text-secondary transition-colors pr-8">¿Realizan envíos a nivel nacional para distribuidores B2B?</span>
                                <div class="faq-icon-box h-8 w-8 rounded-full bg-surface-muted border border-subtle flex items-center justify-center text-muted/80 transition-all shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="faq-icon-path"><path d="M5 12h14"/><path d="M12 5v14" class="faq-icon-vertical"/></svg>
                                </div>
                            </button>
                            <div class="faq-content overflow-hidden transition-all duration-300 max-h-0 opacity-0 bg-surface-muted/50">
                                <div class="p-6 sm:p-7 pt-2 text-body leading-relaxed text-[15px] border-t border-subtle">
                                    <p>Sí, cubrimos logísticamente todas las ciudades principales e intermedias de Colombia utilizando flotas refrigeradas y especializadas según la cadena de frío necesaria de cada lote homeopático.</p>
                                </div>
                            </div>
                        </div>

                        <!-- FAQ Item 2 (Simulación Estado Abierto) -->
                        <div class="group rounded-2xl border-2 border-brand/20 bg-surface-white shadow-md shadow-brand/10 transition-all duration-300 overflow-hidden faq-item">
                            <button class="faq-header flex w-full items-center justify-between p-6 sm:p-7 text-left focus:outline-none bg-brand/5">
                                <span class="text-[17px] font-bold text-brand pr-8">¿Cuáles son los requisitos para ser distribuidor autorizado?</span>
                                <div class="faq-icon-box h-8 w-8 rounded-full bg-brand text-surface-white flex items-center justify-center shadow-sm shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
                                </div>
                            </button>
                            <div class="faq-content transition-all duration-300 opacity-100 bg-surface-white">
                                <div class="p-6 sm:p-7 pt-2 text-body leading-relaxed text-[15px] border-t border-brand/10">
                                    <p class="mb-4">Para garantizar la integridad y trazabilidad de nuestros productos, los requisitos mínimos normativos son:</p>
                                    <ul class="space-y-3.5 mt-2">
                                        <li class="flex items-start gap-3">
                                            <div class="bg-brand/5 p-1 rounded-full text-brand mt-0.5 shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                                            <span class="text-[14.5px] font-medium text-body">Registro mercantil vigente (cámara de comercio).</span>
                                        </li>
                                        <li class="flex items-start gap-3">
                                            <div class="bg-brand/5 p-1 rounded-full text-brand mt-0.5 shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                                            <span class="text-[14.5px] font-medium text-body">Resolución de funcionamiento de la secretaría de salud.</span>
                                        </li>
                                        <li class="flex items-start gap-3">
                                            <div class="bg-brand/5 p-1 rounded-full text-brand mt-0.5 shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                                            <span class="text-[14.5px] font-medium text-body">Certificación de estándares de almacenamiento técnico.</span>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                    </div>
                </section>

                </div>
            </div>

            <!-- Footer incrustado al final de la columna derecha -->
            <div class="mt-auto w-full border-t border-strong/60">
                <Footer />
            </div>

        </div>

    </div>

</BaseLayout>
