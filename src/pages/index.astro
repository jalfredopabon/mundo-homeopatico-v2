---

<BaseLayout title="Catálogo de Productos | Mundo Homeopático" mostrarZoom={true}>
    
    <!-- Carrito Lateral (Drawer) -->
    <CartDrawer />
    
    <!-- Contenedor Principal de 2 columnas -->
    <div class="flex flex-col md:flex-row w-full flex-1 h-[calc(100vh-64px)]">
        
        <!-- Columna Izquierda: Sidebar de Filtros (Fijo en Desktop) -->
        <SidebarCatalogo />

        <!-- Columna Derecha: Contenedor Master de Data + Footer (Standard Branded Gray) -->
        <div class="flex-1 overflow-y-auto w-full relative flex flex-col bg-surface-muted h-[calc(100vh-64px)] scroll-smooth" id="catalogo-main-scroll">
            
            <!-- Banner Informativo (Cinta de Alerta Frontal) -->
            <div id="info-banner" class="w-full bg-surface-white border-b border-subtle px-4 md:px-16 py-3 sm:py-4 flex items-start justify-between gap-4 transition-all duration-300">
                <div class="flex items-start gap-4">
                    <div class="bg-brand text-white p-2 rounded-lg shrink-0">
                        <Icons type="alert-triangle" class="w-[18px] h-[18px]" strokeWidth={2.5} />
                    </div>
                    <div class="flex flex-col">
                        <span class="text-slate-900 font-bold text-[14px]">Se informa al público</span>
                        <span class="text-slate-700 text-[13px] leading-relaxed mt-0.5">Dispensación limitada a usuarios con receta médica vigente. Validación de stock: identifique si el artículo seleccionado cuenta con entrega inmediata o es de elaboración bajo pedido.</span>
                    </div>
                </div>
                <button id="close-banner" class="text-slate-700 hover:text-body hover:bg-brand/10 p-1.5 rounded-lg transition-colors shrink-0 focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-1" aria-label="Cerrar aviso">
                    <Icons type="close-x" class="w-[18px] h-[18px]" />
                </button>
            </div>

            <div class="px-8 md:px-[72px] pt-8 pb-8 flex-1 flex flex-col">
                <div class="flex flex-col gap-12">
                    {catalogSections.map((section) => (
                        <CatalogTable {...section} />
                    ))}
                </div>
            </div>

            <!-- Footer corporativo unificado -->
            <Footer />
        </div>



    </div>
</BaseLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        // --- 1. Lógica del Carrito con Micro-animaciones ---
        const btnAddCart = document.querySelectorAll('.btn-add-cart');
        
        btnAddCart.forEach(btn => {
            const button = btn as HTMLButtonElement;
            button.addEventListener('click', () => {
                const name = button.getAttribute('data-name');
                const price = button.getAttribute('data-price');

                // Lanzar evento para CartDrawer.astro
                document.dispatchEvent(new CustomEvent('addToCart', {
                    detail: { name, price }
                }));

                // Micro-animación: Mutación del botón (+ → ✓)
                const originalContent = button.innerHTML;
                button.innerHTML = '<div class="flex items-center justify-center shadow-sm"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></div>';
                button.classList.add('bg-brand', 'scale-110');
                
                setTimeout(() => {
                    button.innerHTML = originalContent;
                    button.classList.remove('bg-brand', 'scale-110');
                }, 1200);
            });
        });

        // --- 2. Cierre del Banner ---
        const btnCloseBanner = document.getElementById('close-banner');
        const infoBanner = document.getElementById('info-banner');
        
        if (btnCloseBanner && infoBanner) {
            btnCloseBanner.addEventListener('click', () => {
                infoBanner.style.opacity = '0';
                infoBanner.style.transform = 'translateY(-10px)';
                setTimeout(() => {
                    infoBanner.style.display = 'none';
                }, 300);
            });
        }


    });
</script>
