        </div>

        <!-- Botón Back To Top -->
        <button id="back-to-top" class="fixed bottom-8 right-8 w-11 h-11 bg-white text-slate-800 rounded-full flex items-center justify-center shadow-xl translate-y-20 opacity-0 invisible hover:-translate-y-1 hover:text-brand transition-all duration-500 z-50 ring-1 ring-slate-100 focus:outline-none focus:ring-2 focus:ring-brand" aria-label="Volver arriba">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5"></path><polyline points="5 12 12 5 19 12"></polyline></svg>
        </button>

    </div>
</BaseLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        // --- 1. Lógica del Carrito con Micro-animaciones ---
        const btnAddCart = document.querySelectorAll('.btn-add-cart');
        
        btnAddCart.forEach(btn => {
            const button = btn as HTMLButtonElement;
            button.addEventListener('click', () => {
                const name = button.getAttribute('data-name');
                const price = button.getAttribute('data-price');

                // Lanzar evento para CartDrawer.astro
                document.dispatchEvent(new CustomEvent('addToCart', {
                    detail: { name, price }
                }));

                // Micro-animación: Mutación del botón (+ → ✓)
                const originalContent = button.innerHTML;
                button.innerHTML = '<div class="flex items-center justify-center shadow-sm"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></div>';
                button.classList.add('bg-brand', 'scale-110');
                
                setTimeout(() => {
                    button.innerHTML = originalContent;
                    button.classList.remove('bg-brand', 'scale-110');
                }, 1200);
            });
        });

        // --- 2. Cierre del Banner ---
        const btnCloseBanner = document.getElementById('close-banner');
        const infoBanner = document.getElementById('info-banner');
        
        if (btnCloseBanner && infoBanner) {
            btnCloseBanner.addEventListener('click', () => {
                infoBanner.style.opacity = '0';
                infoBanner.style.transform = 'translateY(-10px)';
                setTimeout(() => {
                    infoBanner.style.display = 'none';
                }, 300);
            });
        }

        // --- 3. Back To Top Dinámico ---
        const btnBackToTop = document.getElementById('back-to-top');
        const scrollContainer = document.getElementById('catalogo-main-scroll');

        if (btnBackToTop && scrollContainer) {
            scrollContainer.addEventListener('scroll', () => {
                if (scrollContainer.scrollTop > 400) {
                    btnBackToTop.classList.remove('opacity-0', 'invisible', 'translate-y-20');
                } else {
                    btnBackToTop.classList.add('opacity-0', 'invisible', 'translate-y-20');
                }
            });

            btnBackToTop.addEventListener('click', () => {
                scrollContainer.scrollTo({ top: 0, behavior: 'smooth' });
            });
        }
    });
</script>
