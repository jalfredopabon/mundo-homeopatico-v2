---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarCatalogo from '../components/catalogo/SidebarCatalogo.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import Footer from '../components/shared/Footer.astro';
import Icons from '../components/shared/Icons.astro';
---

<BaseLayout title="Catálogo de Productos | Mundo Homeopático" mostrarZoom={true}>
    
    <!-- Contenedor Principal de 2 columnas -->
    <div class="flex flex-col md:flex-row w-full flex-1 h-[calc(100dvh-64px)] min-h-0">
        
        <!-- Columna Izquierda: Sidebar (Se hidratará en cliente) -->
        <SidebarCatalogo />

        <!-- Columna Derecha: Contenedor Master de Data + Footer -->
        <div class="main-content-scroll" id="catalogo-main-scroll">
            
            <!-- Banner Informativo (Estático) -->
            <div id="info-banner" class="banner-info">
                <div class="flex items-start gap-4">
                    <div class="banner-info-icon">
                        <Icons type="alert-triangle" class="w-[18px] h-[18px]" strokeWidth={2.5} />
                    </div>
                    <div class="flex flex-col">
                        <span class="text-slate-900 font-bold text-[14px]">Se informa al público</span>
                        <span class="text-slate-700 text-[13px] leading-relaxed mt-0.5">Dispensación limitada a usuarios con receta médica vigente. Validación de stock: identifique si el artículo seleccionado cuenta con entrega inmediata o es de elaboración bajo pedido.</span>
                    </div>
                </div>
                <button id="close-banner" class="banner-info-close" aria-label="Cerrar aviso">
                    <Icons type="close-x" class="w-[18px] h-[18px]" />
                </button>
            </div>

            <div class="page-section">
                <!-- CONTENEDOR DINÁMICO -->
                <div id="catalog-dynamic-container" class="flex flex-col gap-16 min-h-[400px]">
                    <!-- Skeleton de Carga Elite -->
                    <div class="animate-pulse space-y-12">
                        {[1, 2].map(() => (
                            <div class="space-y-4">
                                <div class="h-8 bg-slate-100 rounded-md w-1/3"></div>
                                <div class="space-y-2">
                                    <div class="h-12 bg-slate-50 rounded-lg w-full"></div>
                                    <div class="h-12 bg-slate-50 rounded-lg w-full"></div>
                                    <div class="h-12 bg-slate-50 rounded-lg w-full"></div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Footer corporativo unificado -->
            <Footer />
        </div>
    </div>
</BaseLayout>

<script>
    import { getCatalogNavigation, getCatalogProducts, getConfigData } from '../data/api';
    import { createCatalogTable } from '../utils/catalogo-renderer';
    import { renderSidebar } from '../utils/sidebar-renderer';

    const initCatalog = async () => {
        const container = document.getElementById('catalog-dynamic-container');
        const sidebarNav = document.getElementById('catalogo-scrollspy');
        if (!container || !sidebarNav) return;
        
        try {
            // 1. CARGA DE DATOS (SWR en Cliente = Instantáneo si hay caché)
            const [navigationData, productsData, configData] = await Promise.all([
                getCatalogNavigation(),
                getCatalogProducts(),
                getConfigData()
            ]);

            // Dinamizar banner informativo
            const bannerTitleEl = document.querySelector('#info-banner .flex-col span:first-child');
            const bannerMsgEl = document.querySelector('#info-banner .flex-col span:last-child');
            const infoBannerEl = document.getElementById('info-banner');
            
            if (infoBannerEl) {
                const bannerMsg = configData.banner_mensaje || '';
                const bannerTitle = configData.banner_titulo || '';
                if (bannerMsg.trim()) {
                    if (bannerTitleEl) bannerTitleEl.textContent = bannerTitle;
                    if (bannerMsgEl) bannerMsgEl.textContent = bannerMsg;
                } else {
                    infoBannerEl.style.display = 'none';
                }
            }

            // EXPORTAR VARIABLE DEBUG PARA AUDITORÍA
            (window as any).__DEBUG_CATALOG__ = { navData: navigationData, prodData: productsData };

            // 2. RENDERIZADO DE SIDEBAR
            sidebarNav.innerHTML = renderSidebar(navigationData);

            // 3. MOTOR DE TRANSFORMACIÓN (Hash Map)
            const cleanText = (val: string) => (val || '').replace(/\^|\\n/g, '<br>');

            const productsByTable = productsData.reduce((acc: any, p: any) => {
                const status = (p.estado || '').toLowerCase();
                if (status !== 'activo') return acc;
                if (!acc[p.tabla_id]) acc[p.tabla_id] = [];
                acc[p.tabla_id].push(p);
                return acc;
            }, {});

            const catalogSections = navigationData
                .filter((nav: any) => nav.tabla_id)
                .map((nav: any) => {
                    const rawProducts = productsByTable[nav.tabla_id] || [];
                    const sectionProducts = rawProducts.map((p: any) => {
                        const formatPrice = (val: string) => {
                            const clean = String(val).replace(/[^0-9]/g, '');
                            return clean ? `$${Number(clean).toLocaleString('es-CO')}` : '$0.00';
                        };

                        return {
                            id: `${p.tabla_id}-${p.producto.toLowerCase().replace(/[^a-z0-9]/gi, '-')}`,
                            name: cleanText(p.producto),
                            presentacion: cleanText(p.presentacion),
                            description: cleanText(p.descripcion_producto || p.description_producto),
                            requiresPreparation: ['si', '1', 'bajo pedido', 'requiere elaboración', 'elaboración'].some(term => {
                                const raw = (p.requiere_elaboracion || '').toLowerCase().trim();
                                return (term === '1' || term === 'si') ? raw === term : raw.includes(term);
                            }),
                            permanentStock: ['stock permanente', 'permanente', 'stock'].some(term => (p.requiere_elaboracion || '').toLowerCase().trim().includes(term)),
                            is20Percent: (p.requiere_elaboracion || '').includes('20%') || (p.badges || '').includes('20%'),
                            is100Percent: (p.requiere_elaboracion || '').includes('100%') || (p.badges || '').includes('100%'),
                            badges: (p.badges || '').split(/[|;]/).filter(Boolean).map((label: string) => ({
                                label: label.trim(),
                                variant: 'outline'
                            })),
                            farmaciaPrice: formatPrice(p.precio_farmacia),
                            publicoPrice: formatPrice(p.precio_publico),
                            cartData: {
                                name: p.producto,
                                price: String(p.precio_farmacia).replace(/[^0-9]/g, ''),
                                tableId: p.tabla_id
                            }
                        };
                    });

                    return {
                        id: nav.tabla_id,
                        title: cleanText(nav.titulo_mostrar),
                        description: cleanText(nav.descripcion),
                        breadcrumb: [nav.nivel_1, nav.nivel_2, nav.nivel_3, nav.nivel_4].filter(Boolean),
                        products: sectionProducts,
                        presentacionLabel: nav.titulo_presentacion,
                        farmaciaLabel: nav.titulo_precio_farmacia,
                        publicoLabel: nav.titulo_precio_publico
                    };
                });

            // 4. RENDERIZADO DE TABLAS
            container.innerHTML = catalogSections.map(section => createCatalogTable(section)).join('');

            // 5. RE-INICIALIZAR LISTENERS
            initCatalogListeners(catalogSections);
            initSidebarListeners();

            // 6. AUTO-SCROLL SI HAY HASH
            if (window.location.hash) {
                setTimeout(() => {
                    const target = document.querySelector(window.location.hash);
                    if (target) target.scrollIntoView({ behavior: 'smooth' });
                }, 100);
            }

        } catch (error) {
            console.error("Error hidatrando catálogo:", error);
            container.innerHTML = '<div class="p-8 text-center text-slate-500">Error cargando el catálogo.</div>';
        }
    };

    // Doble gatillo para robustez: DOM estándar + Transiciones Astro
    document.addEventListener('DOMContentLoaded', initCatalog);
    document.addEventListener('astro:page-load', initCatalog);

    function initCatalogListeners(catalogSections: any[]) {
        // --- Lógica del Carrito ---
        const btnAddCart = document.querySelectorAll('.btn-add-cart');
        btnAddCart.forEach(btn => {
            btn.addEventListener('click', () => {
                const button = btn as HTMLButtonElement;
                const originalContent = button.innerHTML; // CAPTURA CRÍTICA
                const name = button.getAttribute('data-name');
                const price = button.getAttribute('data-price');
                const tableId = button.getAttribute('data-table-id');
                document.dispatchEvent(new CustomEvent('addToCart', { detail: { name, price, tableId } }));
                
                const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
                button.innerHTML = `<div class="flex items-center justify-center animate-fade-in">${checkIcon}</div>`;
                button.classList.add('is-success');
                setTimeout(() => {
                    button.innerHTML = originalContent;
                    button.classList.remove('is-success');
                }, 800); // Un poco más de tiempo para feedback visual Elite
            });
        });

        // --- Cierre del Banner ---
        const btnCloseBanner = document.getElementById('close-banner');
        const infoBanner = document.getElementById('info-banner');
        if (btnCloseBanner && infoBanner) {
            btnCloseBanner.addEventListener('click', () => {
                infoBanner.style.opacity = '0';
                infoBanner.style.transform = 'translateY(-10px)';
                setTimeout(() => infoBanner.style.display = 'none', 300);
            });
        }

        // --- Motor de Búsqueda Predictivo ---
        let searchInput = document.getElementById('catalogo-search') as HTMLInputElement;
        const searchDropdown = document.getElementById('catalogo-search-dropdown');

        if (searchInput) {
            // Clonar para limpiar event listeners antiguos (evita duplicados de Astro y HMR)
            const cleanedInput = searchInput.cloneNode(true) as HTMLInputElement;
            searchInput.parentNode?.replaceChild(cleanedInput, searchInput);
            searchInput = cleanedInput;
        }

        // Construir base de datos de búsqueda predictiva directamente de los datos cargados en memoria
        const searchDatabase: any[] = [];
        if (catalogSections) {
            catalogSections.forEach(section => {
                section.products.forEach((p: any) => {
                    const searchName = p.name.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
                    const searchPresentacion = p.presentacion.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
                    const searchBadges = p.badges.map((b: any) => b.label.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase()).join(' ');
                    const searchTerms = `${searchName} ${searchPresentacion} ${searchBadges}`.trim().replace(/\s+/g, ' ');

                    searchDatabase.push({
                        rowId: p.id,
                        name: p.name,
                        searchTerms,
                        categoryName: section.title,
                        badges: p.badges.map((b: any) => b.label)
                    });
                });
            });
        }

        let searchFocusIndex = -1;
        let lastSearchItems: any[] = [];
        let lastSearchQuery = '';
        let isSearchExpanded = false;

        const toggleDropdown = (show: boolean) => {
            if (searchDropdown) {
                if (show) {
                    searchDropdown.classList.remove('hidden');
                } else {
                    searchDropdown.classList.add('hidden');
                }
            }
        };

        const updateSearchFocus = (elements: NodeListOf<Element>) => {
            elements.forEach((el, idx) => {
                if (idx === searchFocusIndex) {
                    el.classList.add('is-focused');
                    el.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                } else {
                    el.classList.remove('is-focused');
                }
            });
        };

        const scrollToElement = (rowId: string) => {
            const targetEl = document.getElementById(rowId);
            if (targetEl) {
                toggleDropdown(false);
                targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                
                // Resaltar con animación de destello
                targetEl.classList.add('highlight-row');
                setTimeout(() => targetEl.classList.remove('highlight-row'), 2500);
            }
        };

        const updateSearchDropdown = (items: any[] | null, query: string | null, forceExpand: boolean | null = null) => {
            if (!searchDropdown) return;

            let finalItems = items;
            let finalQuery = query;

            if (items !== null && query !== null) {
                lastSearchItems = items;
                lastSearchQuery = query;
                if (forceExpand === null) {
                    isSearchExpanded = false;
                    searchFocusIndex = -1;
                }
            } else {
                finalItems = lastSearchItems;
                finalQuery = lastSearchQuery;
            }

            if (forceExpand !== null) isSearchExpanded = forceExpand;

            const initialLimit = 6;
            const limit = isSearchExpanded ? 1000 : initialLimit;
            const shown = (finalItems || []).slice(0, limit);

            if (shown.length === 0 || !finalQuery) {
                toggleDropdown(false);
                return;
            }

            // Sanitización y resaltado
            const escapeHtml = (text: string) => {
                return text
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            };

            let html = `
                <div class="p-2.5 border-b border-slate-100 text-[10px] text-slate-400 font-bold tracking-wider flex justify-between bg-slate-50/80 sticky top-0 z-10 backdrop-blur-sm">
                    <span>RESULTADOS (${(finalItems || []).length})</span>
                    <span class="hidden sm:block">Navega con ↑↓ Enter</span>
                </div>
                <div class="search-results-list">
            `;

            html += shown.map((item, index) => {
                const qNorm = (finalQuery || '').normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
                const iNorm = item.name.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
                
                let highlightedName = escapeHtml(item.name);
                const matchIdx = iNorm.indexOf(qNorm);
                
                if (matchIdx !== -1 && qNorm.length > 0) {
                    const originalText = item.name.substring(matchIdx, matchIdx + (finalQuery || '').length);
                    highlightedName = escapeHtml(item.name.substring(0, matchIdx)) +
                        `<span class="search-highlight">${escapeHtml(originalText)}</span>` +
                        escapeHtml(item.name.substring(matchIdx + (finalQuery || '').length));
                }

                // Detectar badge coincidente para mostrarlo como pista visual
                let matchedBadgeHtml = '';
                if (qNorm.length > 0) {
                    const matchingBadge = (item.badges || []).find((b: string) => {
                        const bNorm = b.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
                        return bNorm.includes(qNorm);
                    });
                    if (matchingBadge) {
                        const bNorm = matchingBadge.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
                        const bIdx = bNorm.indexOf(qNorm);
                        const highlighted = escapeHtml(matchingBadge.substring(0, bIdx)) +
                            `<span class="search-highlight">${escapeHtml(matchingBadge.substring(bIdx, bIdx + (finalQuery || '').length))}</span>` +
                            escapeHtml(matchingBadge.substring(bIdx + (finalQuery || '').length));
                        matchedBadgeHtml = `<div class="text-[10px] text-slate-400 mt-0.5">🏷 ${highlighted}</div>`;
                    }
                }

                const focusClass = (index === searchFocusIndex) ? 'is-focused' : '';

                return `
                    <div class="search-result-item ${focusClass} js-search-item" data-row-id="${item.rowId}" data-index="${index}">
                        <div class="text-[12px] font-bold text-slate-700 leading-tight">${highlightedName}</div>
                        ${matchedBadgeHtml}
                        <div class="text-[10px] text-brand-vibrant font-medium truncate mt-0.5">en ${escapeHtml(item.categoryName)}</div>
                    </div>
                `;
            }).join('');

            html += `</div>`;

            if ((finalItems || []).length > initialLimit) {
                const toggleLabel = isSearchExpanded
                    ? 'Ver menos'
                    : `Ver ${(finalItems || []).length - initialLimit} más...`;
                
                html += `
                    <div class="sticky bottom-0 z-10 p-2.5 text-[11px] text-center text-brand font-bold bg-white cursor-pointer hover:bg-emerald-50 transition-all border-t border-slate-100 js-search-toggle-more">
                        ${toggleLabel}
                    </div>
                `;
            }

            searchDropdown.innerHTML = html;
            toggleDropdown(true);

            // Re-vincular eventos del dropdown inyectado
            const itemsEls = searchDropdown.querySelectorAll('.js-search-item');
            itemsEls.forEach(el => {
                el.addEventListener('click', () => {
                    const rowId = el.getAttribute('data-row-id');
                    if (rowId) scrollToElement(rowId);
                });
            });

            const toggleBtn = searchDropdown.querySelector('.js-search-toggle-more');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    updateSearchDropdown(null, null, !isSearchExpanded);
                });
            }
        };

        if (searchInput) {
            searchInput.addEventListener('input', async (e) => {
                const { sanitizeInput } = await import('../utils/security');
                const raw = sanitizeInput((e.target as HTMLInputElement).value).trim();
                const value = raw.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
                
                if (!value) {
                    toggleDropdown(false);
                    return;
                }

                // Filtrar en memoria
                const matches = searchDatabase.filter(item => item.searchTerms.includes(value));
                updateSearchDropdown(matches, value);
            });

            searchInput.addEventListener('keydown', (e) => {
                if (!searchDropdown || searchDropdown.classList.contains('hidden')) return;

                const itemsEls = searchDropdown.querySelectorAll('.js-search-item');
                if (itemsEls.length === 0) return;

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    searchFocusIndex = (searchFocusIndex + 1) % itemsEls.length;
                    updateSearchFocus(itemsEls);
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    searchFocusIndex = (searchFocusIndex - 1 + itemsEls.length) % itemsEls.length;
                    updateSearchFocus(itemsEls);
                } else if (e.key === 'Enter') {
                    if (searchFocusIndex >= 0) {
                        e.preventDefault();
                        const selectedEl = itemsEls[searchFocusIndex];
                        const rowId = selectedEl.getAttribute('data-row-id');
                        if (rowId) scrollToElement(rowId);
                    }
                } else if (e.key === 'Escape') {
                    toggleDropdown(false);
                }
            });
        }

        // Cerrar dropdown si se hace click fuera
        document.addEventListener('click', (e) => {
            if (searchDropdown && !searchDropdown.classList.contains('hidden')) {
                const target = e.target as HTMLElement;
                if (!target.closest('#catalogo-search') && !target.closest('#catalogo-search-dropdown')) {
                    toggleDropdown(false);
                }
            }
        });

        // --- Lógica de Badges (Revelación Progresiva) ---
        (window as any).toggleBadges = (btn: HTMLButtonElement, targetId: string, extraCount: number) => {
            const container = document.getElementById(targetId);
            const label = btn.querySelector('.js-label');
            const isExpanded = btn.getAttribute('data-expanded') === 'true';

            if (!container || !label) return;

            if (isExpanded) {
                container.style.display = 'none';
                label.textContent = `+${extraCount} más`;
                btn.setAttribute('data-expanded', 'false');
            } else {
                container.style.display = 'contents';
                label.textContent = 'Ver menos';
                btn.setAttribute('data-expanded', 'true');
            }
        };
    }

    function initSidebarListeners() {
        const sidebarLinks = document.querySelectorAll('#catalogo-scrollspy .sidebar-link');
        const triggers = document.querySelectorAll('.accordion-trigger');
        const scrollContainer = document.getElementById('catalogo-main-scroll');
        const sections = document.querySelectorAll('section[id]');

        // Acordeones
        const closeAllAccordions = (except: HTMLElement | null = null) => {
            document.querySelectorAll('.accordion-content').forEach(el => {
                const content = el as HTMLElement;
                if (content !== except) {
                    content.style.maxHeight = '0';
                    const trigger = content.previousElementSibling;
                    if (trigger) trigger.classList.remove('is-expanded');
                }
            });
        };

        triggers.forEach(trigger => {
            trigger.addEventListener('click', () => {
                const content = trigger.nextElementSibling as HTMLElement;
                if (!content) return;
                const isExpanded = trigger.classList.contains('is-expanded');
                closeAllAccordions(content);
                if (isExpanded) {
                    content.style.maxHeight = '0';
                    trigger.classList.remove('is-expanded');
                } else {
                    content.style.maxHeight = content.scrollHeight + 'px';
                    trigger.classList.add('is-expanded');
                }
            });
        });

        // ScrollSpy
        if (scrollContainer && sections.length) {
            const observerOptions = {
                root: scrollContainer,
                rootMargin: '-30% 0px -40% 0px',
                threshold: 0
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const currentId = entry.target.getAttribute('id');
                        const activeLink = document.querySelector(`#catalogo-scrollspy a[href="#${currentId}"]`);
                        if (activeLink) {
                            sidebarLinks.forEach(l => l.classList.remove('is-active'));
                            activeLink.classList.add('is-active');

                            // Abrir acordeón padre si el enlace está dentro de uno
                            const accordionContent = activeLink.closest('.accordion-content') as HTMLElement | null;
                            closeAllAccordions(accordionContent);
                            
                            if (accordionContent) {
                                accordionContent.style.maxHeight = accordionContent.scrollHeight + 'px';
                                const trigger = accordionContent.previousElementSibling;
                                if (trigger) trigger.classList.add('is-expanded');
                            }

                            // Auto-scroll del sidebar hacia el enlace activo
                            activeLink.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    }
                });
            }, observerOptions);

            sections.forEach(section => observer.observe(section));
        }
    }
</script>
