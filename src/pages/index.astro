---
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarCatalogo from '../components/catalogo/SidebarCatalogo.astro';
import Footer from '../components/shared/Footer.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
---

<BaseLayout title="Catálogo de Productos | Mundo Homeopático" mostrarZoom={true}>
    
    <!-- Carrito Lateral (Drawer) -->
    <CartDrawer />
    
    <!-- Contenedor Principal de 2 columnas -->
    <div class="flex flex-col md:flex-row w-full flex-1 h-[calc(100vh-4rem)] md:h-[calc(100vh-5rem)]">
        
        <!-- Columna Izquierda: Sidebar de Filtros (Fijo en Desktop) -->
        <SidebarCatalogo />

        <!-- Columna Derecha: Contenedor Master de Data + Footer -->
        <div class="flex-1 overflow-y-auto w-full relative flex flex-col bg-surface-muted h-[calc(100vh-4rem)] md:h-[calc(100vh-5rem)] scroll-smooth" id="catalogo-main-scroll">
            
            <!-- Banner Informativo (Cinta de Alerta Frontal) -->
            <div id="info-banner" class="w-full bg-surface-white border-b border-subtle px-4 md:px-16 py-3 sm:py-4 flex items-start sm:items-center justify-between gap-4 transition-all duration-300">
                <div class="flex items-start sm:items-center gap-4">
                    <div class="bg-brand text-white p-2 rounded-lg shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-slate-900 font-bold text-[14px]">Se informa al público</span>
                        <span class="text-slate-700 text-[13px] leading-relaxed mt-0.5">Dispensación limitada a usuarios con receta médica vigente. Validación de stock: identifique si el artículo seleccionado cuenta con entrega inmediata o es de elaboración bajo pedido.</span>
                    </div>
                </div>
                <button id="close-banner" class="text-slate-700 hover:text-body hover:bg-brand/10 p-1.5 rounded-lg transition-colors shrink-0 focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-1" aria-label="Cerrar aviso">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
                </button>
            </div>

            <div class="px-8 md:px-[72px] pt-8 pb-24 flex-1 flex flex-col">
                <div class="flex flex-col gap-8">
                    <!-- Sección: Oligoelementos -->
                <section id="oligoelementos" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col auto-animate-header">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">
                            <span class="hover:text-slate-800 transition-colors cursor-pointer">De nuestra farmacia</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><polyline points="9 18 15 12 9 6"></polyline></svg>
                            <span class="hover:text-slate-800 transition-colors cursor-pointer">Según prescripción</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-slate-900 tracking-tight mb-2">Oligoelementos</h2>
                        <p class="text-slate-700 text-[15px] font-medium leading-snug">Elaborados a la D7</p>
                    </header>
                    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden">
                        <!-- Encabezado de Tabla (Solo Desktop) -->
                        <div class="hidden sm:grid grid-cols-[1fr_120px_120px_70px] md:grid-cols-[1fr_130px_130px_100px] gap-4 items-center bg-surface-muted/50 border-b border-subtle py-3.5 px-6 text-[12px] font-bold text-slate-700 tracking-wide">
                            <div>Producto</div>
                            <div class="text-right">Precio farmacia</div>
                            <div class="text-right">Precio público</div>
                            <div class="flex justify-center pr-1 md:pr-4">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" class="w-4 h-4 text-slate-700">
                                    <path d="M8 16L16.7201 15.2733C19.4486 15.046 20.0611 14.45 20.3635 11.7289L21 6" />
                                    <path d="M6 6H22" />
                                    <circle cx="6" cy="20" r="2" />
                                    <circle cx="17" cy="20" r="2" />
                                    <path d="M8 20L15 20" />
                                    <path d="M2 2H2.966C3.91068 2 4.73414 2.62459 4.96326 3.51493L7.93852 15.0765C8.08887 15.6608 7.9602 16.2797 7.58824 16.7616L6.63213 18" />
                                </svg>
                            </div>
                        </div>

                        <!-- Fila de Producto 1 -->
                        <div class="flex flex-col sm:grid sm:grid-cols-[1fr_120px_120px_70px] md:grid-cols-[1fr_130px_130px_100px] gap-2 sm:gap-4 sm:items-center py-5 px-6 border-b border-subtle cursor-pointer hover:bg-slate-50 transition-all relative z-0 hover:z-10 group">
                            <!-- Información del Producto -->
                            <div class="flex flex-col">
                                <h3 class="text-slate-900 font-bold text-base md:text-[1.05rem] leading-tight transition-colors">Oligoelementos individuales</h3>
                                <div class="flex flex-wrap items-center gap-2 mt-2">
                                    <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-surface-white px-2 py-0.5 rounded border border-subtle">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="m8.5 8.5 7 7"/></svg>
                                        Gotas / Spray
                                    </span>
                                    <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-surface-white px-2 py-0.5 rounded border border-subtle">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
                                        Glóbulos x 30g
                                    </span>
                                </div>
                            </div>

                            <!-- Precios y Acción: Estructura responsiva unificada -->
                            <div class="sm:contents">
                                <!-- Columna 2: Precio Farmacia -->
                                <div class="flex flex-col sm:block text-left sm:text-right mt-3 sm:mt-0 pt-3 sm:pt-0 border-t border-subtle/30 sm:border-0">
                                    <span class="sm:hidden text-[10px] text-slate-500 font-bold uppercase tracking-wider mb-0.5">Farmacia</span>
                                    <span class="text-slate-700 font-medium">$19.500</span>
                                </div>
                                
                                <!-- Columna 3: Precio Público (Solo Desktop) -->
                                <div class="hidden sm:block text-right mt-1 sm:mt-0">
                                    <span class="text-brand font-bold tracking-tight text-base md:text-[1.05rem]">$36.000</span>
                                </div>

                                <!-- Columna 4: Botón de Acción -->
                                <div class="flex justify-end sm:justify-center mt-3 sm:mt-0 md:pr-4">
                                    <button class="w-full sm:w-10 h-12 sm:h-10 flex items-center justify-center rounded-lg bg-brand-vibrant hover:bg-brand text-white shadow-lg sm:shadow-none shadow-brand/20 hover:-translate-y-0.5 transition-all focus:ring-2 focus:ring-brand active:scale-95 btn-add-cart" data-name="Oligoelementos Individuales" data-price="19500" aria-label="Añadir Oligoelementos Individuales">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                                        <span class="sm:hidden ml-2 font-bold text-sm">Añadir al pedido</span>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Fila de Producto 2 -->
                        <div class="flex flex-col sm:grid sm:grid-cols-[1fr_120px_120px_70px] md:grid-cols-[1fr_130px_130px_100px] gap-2 sm:gap-4 sm:items-center py-5 px-6 border-b border-subtle cursor-pointer hover:bg-slate-50 transition-all relative z-0 hover:z-10 group">
                            <!-- Información del Producto -->
                            <div class="flex flex-col">
                                <h3 class="text-slate-900 font-bold text-base md:text-[1.05rem] leading-tight transition-colors">Oligoelementos combinados (hasta 6 componentes)</h3>
                                <div class="flex flex-wrap items-center gap-2 mt-2">
                                    <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-surface-white px-2 py-0.5 rounded border border-subtle">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="m8.5 8.5 7 7"/></svg>
                                        Gotas / Spray
                                    </span>
                                    <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-surface-white px-2 py-0.5 rounded border border-subtle">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
                                        Glóbulos x 30g
                                    </span>
                                </div>
                            </div>

                            <!-- Precios y Acción: Estructura responsiva unificada -->
                            <div class="sm:contents">
                                <!-- Columna 2: Precio Farmacia -->
                                <div class="flex flex-col sm:block text-left sm:text-right mt-3 sm:mt-0 pt-3 sm:pt-0 border-t border-subtle/30 sm:border-0">
                                    <span class="sm:hidden text-[10px] text-slate-500 font-bold uppercase tracking-wider mb-0.5">Farmacia</span>
                                    <span class="text-slate-700 font-medium">$25.500</span>
                                </div>
                                
                                <!-- Columna 3: Precio Público (Solo Desktop) -->
                                <div class="hidden sm:block text-right mt-1 sm:mt-0">
                                    <span class="text-brand font-bold tracking-tight text-base md:text-[1.05rem]">$44.000</span>
                                </div>

                                <!-- Columna 4: Botón de Acción -->
                                <div class="flex justify-end sm:justify-center mt-3 sm:mt-0 md:pr-4">
                                    <button class="w-full sm:w-10 h-12 sm:h-10 flex items-center justify-center rounded-lg bg-brand-vibrant hover:bg-brand text-white shadow-lg sm:shadow-none shadow-brand/20 hover:-translate-y-0.5 transition-all focus:ring-2 focus:ring-brand active:scale-95 btn-add-cart" data-name="Oligoelementos Combinados" data-price="25500" aria-label="Añadir Oligoelementos Combinados">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                                        <span class="sm:hidden ml-2 font-bold text-sm">Añadir al pedido</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Sección: Esencias florales -->
                <section id="esencias-florales" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">
                            <span>De nuestra farmacia</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><polyline points="9 18 15 12 9 6"></polyline></svg>
                            <span>Según prescripción</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-slate-900 tracking-tight mb-2">Esencias florales</h2>
                        <p class="text-slate-700 text-[15px] font-medium leading-snug">Flores de Bach y otras esencias</p>
                    </header>
                    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                        <span class="text-slate-700 text-sm font-medium">Tabla de esencias florales (datos reales en Fase 3)</span>
                    </div>
                </section>

                <!-- Sección: Alimentos funcionales -->
                <section id="alimentos-funcionales" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">
                            <span>Productos exclusivos</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-slate-900 tracking-tight mb-2">Alimentos funcionales</h2>
                        <p class="text-slate-700 text-[15px] font-medium leading-snug">Suplementos y alimentos de alta calidad</p>
                    </header>
                    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                        <span class="text-slate-700 text-sm font-medium">Tabla de alimentos funcionales (datos reales en Fase 3)</span>
                    </div>
                </section>

                <!-- Sección: CBD -->
                <section id="cbd" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">
                            <span>Productos exclusivos</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-slate-900 tracking-tight mb-2">CBD</h2>
                        <p class="text-slate-700 text-[15px] font-medium leading-snug">Productos de cannabidiol de grado farmacéutico</p>
                    </header>
                    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                        <span class="text-slate-700 text-sm font-medium">Tabla de CBD (datos reales en Fase 3)</span>
                    </div>
                </section>

                <!-- Sección: Aceites esenciales -->
                <section id="aceites-esenciales" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">
                            <span>Productos exclusivos</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-slate-900 tracking-tight mb-2">Aceites esenciales</h2>
                        <p class="text-slate-700 text-[15px] font-medium leading-snug">Extractos puros de plantas medicinales</p>
                    </header>
                    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                        <span class="text-slate-700 text-sm font-medium">Tabla de aceites esenciales (datos reales en Fase 3)</span>
                    </div>
                </section>

            </div>
        </div>

        <!-- Footer incrustado al final de la columna derecha con mt-auto para anclaje inferior -->
        <div class="mt-auto w-full border-t border-strong/60 pb-[calc(4rem+env(safe-area-inset-bottom))] md:pb-0">
            <Footer />
        </div>

    </div>

</div>

</BaseLayout>

<script>
    // Lógica para capturar clics en la tabla y mandarlos al carrito (Bloque 2)
    const btnAddCart = document.querySelectorAll('.btn-add-cart');

    btnAddCart.forEach(btn => {
        btn.addEventListener('click', () => {
            const name = btn.getAttribute('data-name');
            const price = btn.getAttribute('data-price');

            // Lanzar evento personalizado para CartDrawer.astro
            const event = new CustomEvent('addToCart', {
                detail: { name, price }
            });
            document.dispatchEvent(event);

            // Micro-animación: Mutación del botón (+ → ✓)
            const originalSvg = btn.innerHTML;
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
            btn.classList.add('bg-brand', 'scale-110');
            setTimeout(() => {
                btn.innerHTML = originalSvg;
                btn.classList.remove('bg-brand', 'scale-110');
            }, 1200);

            // Micro-animación: Flash verde sutil en la fila
            const row = btn.closest('[class*="grid"]');
            if (row) {
                row.style.transition = 'background-color 0.15s ease';
                row.style.backgroundColor = 'rgba(16,185,129,0.08)';
                setTimeout(() => { row.style.backgroundColor = ''; }, 600);
            }

            // Micro-animación: Toast "+1" flotante
            const toast = document.createElement('span');
            toast.textContent = '+1';
            toast.className = 'absolute -top-2 -right-2 text-[11px] font-extrabold text-white bg-brand px-1.5 py-0.5 rounded-full pointer-events-none';
            toast.style.transition = 'all 0.6s ease-out';
            btn.style.position = 'relative';
            btn.appendChild(toast);
            requestAnimationFrame(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(-18px) scale(0.8)';
            });
            setTimeout(() => toast.remove(), 700);
        });
    });

    // Lógica para cerrar el banner informativo (Scroll Continuo)
    const btnCloseBanner = document.getElementById('close-banner');
    const infoBanner = document.getElementById('info-banner');
    
    if (btnCloseBanner && infoBanner) {
        btnCloseBanner.addEventListener('click', () => {
            infoBanner.style.opacity = '0';
            infoBanner.style.transform = 'translateY(-10px)';
            setTimeout(() => {
                infoBanner.style.display = 'none';
            }, 300); // Espera que termine la animación de opacidad antes de borrarlo del DOM visual
        });
    }
</script>
