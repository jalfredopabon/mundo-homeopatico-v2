                            <span class="text-slate-700 text-sm font-medium">Tabla de aceites esenciales (datos reales en Fase 3)</span>
                        </div>
                    </section>
                </div>
            </div>

            <!-- Footer Corporativo -->
            <footer class="bg-slate-900 py-12 md:py-[72px] px-8 md:px-[72px] mt-auto border-t border-slate-800">
