---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarCatalogo from '../components/catalogo/SidebarCatalogo.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import Footer from '../components/shared/Footer.astro';
import Icons from '../components/shared/Icons.astro';
---

<BaseLayout title="Catálogo de Productos | Mundo Homeopático" mostrarZoom={true}>
    
    <!-- Contenedor Principal de 2 columnas -->
    <div class="flex flex-col md:flex-row w-full flex-1 h-[calc(100dvh-64px)] min-h-0">
        
        <!-- Columna Izquierda: Sidebar (Se hidratará en cliente) -->
        <SidebarCatalogo />

        <!-- Columna Derecha: Contenedor Master de Data + Footer -->
        <div class="main-content-scroll" id="catalogo-main-scroll">
            
            <!-- Banner Informativo (Estático) -->
            <div id="info-banner" class="banner-info">
                <div class="flex items-start gap-4">
                    <div class="banner-info-icon">
                        <Icons type="alert-triangle" class="w-[18px] h-[18px]" strokeWidth={2.5} />
                    </div>
                    <div class="flex flex-col">
                        <span class="text-slate-900 font-bold text-[14px]">Se informa al público</span>
                        <span class="text-slate-700 text-[13px] leading-relaxed mt-0.5">Dispensación limitada a usuarios con receta médica vigente. Validación de stock: identifique si el artículo seleccionado cuenta con entrega inmediata o es de elaboración bajo pedido.</span>
                    </div>
                </div>
                <button id="close-banner" class="banner-info-close" aria-label="Cerrar aviso">
                    <Icons type="close-x" class="w-[18px] h-[18px]" />
                </button>
            </div>

            <div class="page-section">
                <!-- CONTENEDOR DINÁMICO -->
                <div id="catalog-dynamic-container" class="flex flex-col gap-16 min-h-[400px]">
                    <!-- Skeleton de Carga Elite -->
                    <div class="animate-pulse space-y-12">
                        {[1, 2].map(() => (
                            <div class="space-y-4">
                                <div class="h-8 bg-slate-100 rounded-md w-1/3"></div>
                                <div class="space-y-2">
                                    <div class="h-12 bg-slate-50 rounded-lg w-full"></div>
                                    <div class="h-12 bg-slate-50 rounded-lg w-full"></div>
                                    <div class="h-12 bg-slate-50 rounded-lg w-full"></div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Footer corporativo unificado -->
            <Footer />
        </div>
    </div>
</BaseLayout>

<script>
    import { getCatalogNavigation, getCatalogProducts } from '../data/api';
    import { createCatalogTable } from '../utils/catalogo-renderer';
    import { renderSidebar } from '../utils/sidebar-renderer';

    const initCatalog = async () => {
        const container = document.getElementById('catalog-dynamic-container');
        const sidebarNav = document.getElementById('catalogo-scrollspy');
        if (!container || !sidebarNav) return;
        
        try {
            // 1. CARGA DE DATOS (SWR en Cliente = Instantáneo si hay caché)
            const [navigationData, productsData] = await Promise.all([
                getCatalogNavigation(),
                getCatalogProducts()
            ]);

            // EXPORTAR VARIABLE DEBUG PARA AUDITORÍA
            (window as any).__DEBUG_CATALOG__ = { navData: navigationData, prodData: productsData };

            // 2. RENDERIZADO DE SIDEBAR
            sidebarNav.innerHTML = renderSidebar(navigationData);

            // 3. MOTOR DE TRANSFORMACIÓN (Hash Map)
            const cleanText = (val: string) => (val || '').replace(/\^|\\n/g, '<br>');

            const productsByTable = productsData.reduce((acc: any, p: any) => {
                const status = (p.estado || '').toLowerCase();
                if (status !== 'activo') return acc;
                if (!acc[p.tabla_id]) acc[p.tabla_id] = [];
                acc[p.tabla_id].push(p);
                return acc;
            }, {});

            const catalogSections = navigationData
                .filter((nav: any) => nav.tabla_id)
                .map((nav: any) => {
                    const rawProducts = productsByTable[nav.tabla_id] || [];
                    const sectionProducts = rawProducts.map((p: any) => {
                        const formatPrice = (val: string) => {
                            const clean = String(val).replace(/[^0-9]/g, '');
                            return clean ? `$${Number(clean).toLocaleString('es-CO')}` : '$0.00';
                        };

                        return {
                            id: `${p.tabla_id}-${p.producto.toLowerCase().replace(/[^a-z0-9]/gi, '-')}`,
                            name: cleanText(p.producto),
                            presentacion: cleanText(p.presentacion),
                            description: cleanText(p.descripcion_producto || p.description_producto),
                            requiresPreparation: ['si', '1', 'bajo pedido', 'requiere elaboración', 'elaboración'].some(term => (p.requiere_elaboracion || '').toLowerCase().trim().includes(term)),
                            badges: (p.badges || '').split(/[|;]/).filter(Boolean).map((label: string) => ({
                                label: label.trim(),
                                variant: 'outline'
                            })),
                            farmaciaPrice: formatPrice(p.precio_farmacia),
                            publicoPrice: formatPrice(p.precio_publico),
                            cartData: {
                                name: p.producto,
                                price: String(p.precio_farmacia).replace(/[^0-9]/g, '')
                            }
                        };
                    });

                    return {
                        id: nav.tabla_id,
                        title: cleanText(nav.titulo_mostrar),
                        description: cleanText(nav.descripcion),
                        breadcrumb: [nav.nivel_1, nav.nivel_2, nav.nivel_3, nav.nivel_4].filter(Boolean),
                        products: sectionProducts,
                        presentacionLabel: nav.titulo_presentacion,
                        farmaciaLabel: nav.titulo_precio_farmacia,
                        publicoLabel: nav.titulo_precio_publico
                    };
                });

            // 4. RENDERIZADO DE TABLAS
            container.innerHTML = catalogSections.map(section => createCatalogTable(section)).join('');

            // 5. RE-INICIALIZAR LISTENERS
            initCatalogListeners();
            initSidebarListeners();

            // 6. AUTO-SCROLL SI HAY HASH
            if (window.location.hash) {
                setTimeout(() => {
                    const target = document.querySelector(window.location.hash);
                    if (target) target.scrollIntoView({ behavior: 'smooth' });
                }, 100);
            }

        } catch (error) {
            console.error("Error hidatrando catálogo:", error);
            container.innerHTML = '<div class="p-8 text-center text-slate-500">Error cargando el catálogo.</div>';
        }
    };

    // Doble gatillo para robustez: DOM estándar + Transiciones Astro
    document.addEventListener('DOMContentLoaded', initCatalog);
    document.addEventListener('astro:page-load', initCatalog);

    function initCatalogListeners() {
        // --- Lógica del Carrito ---
        const btnAddCart = document.querySelectorAll('.btn-add-cart');
        btnAddCart.forEach(btn => {
            btn.addEventListener('click', () => {
                const button = btn as HTMLButtonElement;
                const originalContent = button.innerHTML; // CAPTURA CRÍTICA
                const name = button.getAttribute('data-name');
                const price = button.getAttribute('data-price');
                document.dispatchEvent(new CustomEvent('addToCart', { detail: { name, price } }));
                
                const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
                button.innerHTML = `<div class="flex items-center justify-center animate-fade-in">${checkIcon}</div>`;
                button.classList.add('is-success');
                setTimeout(() => {
                    button.innerHTML = originalContent;
                    button.classList.remove('is-success');
                }, 800); // Un poco más de tiempo para feedback visual Elite
            });
        });

        // --- Cierre del Banner ---
        const btnCloseBanner = document.getElementById('close-banner');
        const infoBanner = document.getElementById('info-banner');
        if (btnCloseBanner && infoBanner) {
            btnCloseBanner.addEventListener('click', () => {
                infoBanner.style.opacity = '0';
                infoBanner.style.transform = 'translateY(-10px)';
                setTimeout(() => infoBanner.style.display = 'none', 300);
            });
        }

        // --- Motor de Búsqueda ---
        const searchInput = document.getElementById('catalogo-search') as HTMLInputElement;
        const productRows = document.querySelectorAll('.catalog-row');
        
        productRows.forEach(row => {
            const titleEl = row.querySelector('h3');
            if (titleEl) row.setAttribute('data-original', titleEl.textContent?.trim() || '');
        });

        if (searchInput) {
            searchInput.addEventListener('input', async (e) => {
                const { sanitizeInput } = await import('../utils/security');
                const value = sanitizeInput((e.target as HTMLInputElement).value).toLowerCase().trim();
                
                productRows.forEach(row => {
                    const originalText = row.getAttribute('data-original') || '';
                    const titleEl = row.querySelector('h3');
                    if (!titleEl) return;

                    if (!value) {
                        row.classList.remove('hidden');
                        titleEl.textContent = originalText;
                        const section = row.closest('section');
                        if (section) section.classList.remove('hidden');
                        return;
                    }

                    if (originalText.toLowerCase().includes(value)) {
                        row.classList.remove('hidden');
                        const regex = new RegExp(`(${value})`, 'gi');
                        titleEl.innerHTML = originalText.replace(regex, `<mark class="bg-brand/15 text-brand rounded-sm px-0.5 font-bold">$1</mark>`);
                        const section = row.closest('section');
                        if (section) section.classList.remove('hidden');
                    } else {
                        row.classList.add('hidden');
                        const section = row.closest('section');
                        if (section) {
                            const visibleRows = section.querySelectorAll('.catalog-row:not(.hidden)');
                            if (visibleRows.length === 0) section.classList.add('hidden');
                        }
                    }
                });
            });
        }

        // --- Lógica de Badges (Revelación Progresiva) ---
        (window as any).toggleBadges = (btn: HTMLButtonElement, targetId: string, extraCount: number) => {
            const container = document.getElementById(targetId);
            const label = btn.querySelector('.js-label');
            const isExpanded = btn.getAttribute('data-expanded') === 'true';

            if (!container || !label) return;

            if (isExpanded) {
                container.style.display = 'none';
                label.textContent = `+${extraCount} más`;
                btn.setAttribute('data-expanded', 'false');
            } else {
                container.style.display = 'contents';
                label.textContent = 'Ver menos';
                btn.setAttribute('data-expanded', 'true');
            }
        };
    }

    function initSidebarListeners() {
        const sidebarLinks = document.querySelectorAll('#catalogo-scrollspy .sidebar-link');
        const triggers = document.querySelectorAll('.accordion-trigger');
        const scrollContainer = document.getElementById('catalogo-main-scroll');
        const sections = document.querySelectorAll('section[id]');

        // Acordeones
        const closeAllAccordions = (except: HTMLElement | null = null) => {
            document.querySelectorAll('.accordion-content').forEach(el => {
                const content = el as HTMLElement;
                if (content !== except) {
                    content.style.maxHeight = '0';
                    const trigger = content.previousElementSibling;
                    if (trigger) trigger.classList.remove('is-expanded');
                }
            });
        };

        triggers.forEach(trigger => {
            trigger.addEventListener('click', () => {
                const content = trigger.nextElementSibling as HTMLElement;
                if (!content) return;
                const isExpanded = trigger.classList.contains('is-expanded');
                closeAllAccordions(content);
                if (isExpanded) {
                    content.style.maxHeight = '0';
                    trigger.classList.remove('is-expanded');
                } else {
                    content.style.maxHeight = content.scrollHeight + 'px';
                    trigger.classList.add('is-expanded');
                }
            });
        });

        // ScrollSpy
        if (scrollContainer && sections.length) {
            const observerOptions = {
                root: scrollContainer,
                rootMargin: '-30% 0px -60% 0px',
                threshold: 0
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const currentId = entry.target.getAttribute('id');
                        const activeLink = document.querySelector(`#catalogo-scrollspy a[href="#${currentId}"]`);
                        if (activeLink) {
                            sidebarLinks.forEach(l => l.classList.remove('is-active'));
                            activeLink.classList.add('is-active');
                        }
                    }
                });
            }, observerOptions);

            sections.forEach(section => observer.observe(section));
        }
    }
</script>
