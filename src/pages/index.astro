// c:\Users\Alfredo Pabón\Documents\Proyectos antigravity\mundo_homeopatico_v2\src\pages\index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarCatalogo from '../components/catalogo/SidebarCatalogo.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import Footer from '../components/shared/Footer.astro';
import Icons from '../components/shared/Icons.astro';
import CatalogTable from '../components/catalogo/CatalogTable.astro';
import { getCatalogNavigation, getCatalogProducts } from '../data/api';

/**
 * Página Principal (Catálogo): 
 * Clonación Estricta del panel principal para paridad visual 1:1.
 * Se aplica el estándar "Sage Green Real" (#E7EDE3).
 */

/**
 * HIDRATACIÓN DINÁMICA (API GOOGLE SHEETS)
 */
const navigationData = await getCatalogNavigation();
const productsData = await getCatalogProducts();

/**
 * MOTOR DE TRANSFORMACIÓN RELACIONAL
 * Vincula la estructura jerárquica de 'navegacion' con los ítems de 'lista_precios'
 */
const catalogSections = navigationData
    .filter(nav => nav.tabla_id) // Solo nodos que disparan tablas de productos
    .map(nav => {
        // 1. Filtrado de productos por tabla_id y estado activo
        const sectionProducts = productsData
            .filter(p => p.tabla_id === nav.tabla_id && (p.estado || '').toLowerCase() === 'activo')
            .map(p => {
                // Normalización de precios (Hito Colombia: Pesos con punto de mil)
                const formatPrice = (val: string) => {
                    const clean = String(val).replace(/[^0-9]/g, '');
                    return clean ? `$${Number(clean).toLocaleString('es-CO')}` : '$0.00';
                };

                return {
                    id: `${p.tabla_id}-${p.producto.toLowerCase().replace(/[^a-z0-9]/gi, '-')}`,
                    name: p.producto,
                    description: p.descripcion_producto,
                    requiresPreparation: ['si', '1', 'bajo pedido'].includes((p.requiere_elaboracion || '').toLowerCase()),
                    badges: (p.badges || '').split('|').filter(Boolean).map(label => ({
                        label: label.trim(),
                        variant: 'outline' as const
                    })),
                    farmaciaPrice: formatPrice(p.precio_farmacia),
                    publicoPrice: formatPrice(p.precio_publico),
                    cartData: {
                        name: p.producto,
                        price: String(p.precio_farmacia).replace(/[^0-9]/g, '')
                    }
                };
            });

        return {
            id: nav.tabla_id,
            title: nav.titulo_mostrar,
            description: nav.descripcion,
            breadcrumb: [nav.nivel_1, nav.nivel_2, nav.nivel_3, nav.nivel_4].filter(Boolean),
            products: sectionProducts,
            presentacionLabel: nav.titulo_presentacion,
            farmaciaLabel: nav.titulo_precio_farmacia,
            publicoLabel: nav.titulo_precio_publico
        };
    });
---

<BaseLayout title="Catálogo de Productos | Mundo Homeopático" mostrarZoom={true}>
    
    <!-- Contenedor Principal de 2 columnas -->
    <div class="flex flex-col md:flex-row w-full flex-1 h-[calc(100dvh-64px)] min-h-0">
        
        <!-- Columna Izquierda: Sidebar de Filtros (Fijo en Desktop) -->
        <SidebarCatalogo navigationData={navigationData} />

        <!-- Columna Derecha: Contenedor Master de Data + Footer -->
        <div class="main-content-scroll" id="catalogo-main-scroll">
            
            <!-- Banner Informativo -->
            <div id="info-banner" class="banner-info">
                <div class="flex items-start gap-4">
                    <div class="banner-info-icon">
                        <Icons type="alert-triangle" class="w-[18px] h-[18px]" strokeWidth={2.5} />
                    </div>
                    <div class="flex flex-col">
                        <span class="text-slate-900 font-bold text-[14px]">Se informa al público</span>
                        <span class="text-slate-700 text-[13px] leading-relaxed mt-0.5">Dispensación limitada a usuarios con receta médica vigente. Validación de stock: identifique si el artículo seleccionado cuenta con entrega inmediata o es de elaboración bajo pedido.</span>
                    </div>
                </div>
                <button id="close-banner" class="banner-info-close" aria-label="Cerrar aviso">
                    <Icons type="close-x" class="w-[18px] h-[18px]" />
                </button>
            </div>

            <div class="page-section">
                <div class="flex flex-col gap-12">
                    {catalogSections.map((section) => (
                        <CatalogTable {...section} />
                    ))}
                </div>
            </div>

            <!-- Footer corporativo unificado -->
            <Footer />
        </div>



    </div>
</BaseLayout>

<script>
    document.addEventListener('astro:page-load', async () => {
        // --- 1. Lógica del Carrito con Micro-animaciones ---
        const btnAddCart = document.querySelectorAll('.btn-add-cart');
        
        btnAddCart.forEach(btn => {
            const button = btn as HTMLButtonElement;
            button.addEventListener('click', () => {
                const name = button.getAttribute('data-name');
                const price = button.getAttribute('data-price');

                // Lanzar evento para CartDrawer.astro
                document.dispatchEvent(new CustomEvent('addToCart', {
                    detail: { name, price }
                }));

                // Micro-animación: Mutación del botón (+ → ✓) usando átomos
                const originalContent = button.innerHTML;
                button.innerHTML = '<div class="flex items-center justify-center animate-fade-in"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></div>';
                button.classList.add('is-success');
                
                setTimeout(() => {
                    button.innerHTML = originalContent;
                    button.classList.remove('is-success');
                }, 500);
            });
        });

        // --- 2. Cierre del Banner ---
        const btnCloseBanner = document.getElementById('close-banner');
        const infoBanner = document.getElementById('info-banner');
        
        if (btnCloseBanner && infoBanner) {
            btnCloseBanner.addEventListener('click', () => {
                infoBanner.style.opacity = '0';
                infoBanner.style.transform = 'translateY(-10px)';
                setTimeout(() => {
                    infoBanner.style.display = 'none';
                }, 300);
            });
        }

        // --- 3. Motor de Búsqueda con Resaltado (Highlighter) ---
        const searchInput = document.getElementById('catalogo-search') as HTMLInputElement;
        const productRows = document.querySelectorAll('.catalog-row');

        // Inicializamos los nombres originales para el resaltado
        productRows.forEach(row => {
            const titleEl = row.querySelector('h3');
            if (titleEl && !row.hasAttribute('data-original')) {
                row.setAttribute('data-original', titleEl.textContent?.trim() || '');
            }
        });

        if (searchInput) {
            // Importación dinámica para el motor de búsqueda (Elite Security)
            const { sanitizeInput } = await import('../utils/security');

            searchInput.addEventListener('input', (e) => {
                const rawValue = (e.target as HTMLInputElement).value;
                const value = sanitizeInput(rawValue).toLowerCase().trim();
                
                productRows.forEach(row => {
                    const originalText = row.getAttribute('data-original') || '';
                    const titleEl = row.querySelector('h3');
                    if (!titleEl) return;

                    // Si no hay búsqueda, restauramos todo
                    if (!value) {
                        row.classList.remove('hidden');
                        titleEl.textContent = originalText;
                        
                        // Cerramos secciones que podrían haber quedado vacías
                        const section = row.closest('section');
                        if (section) section.classList.remove('hidden');
                        return;
                    }

                    // Si hay coincidencia
                    if (originalText.toLowerCase().includes(value)) {
                        row.classList.remove('hidden');
                        
                        // Aplicamos el resaltado Elite
                        const regex = new RegExp(`(${value})`, 'gi');
                        titleEl.innerHTML = originalText.replace(regex, `<mark class="bg-brand/15 text-brand rounded-sm px-0.5 font-bold animate-fade-in">$1</mark>`);
                        
                        // Aseguramos que la sección sea visible
                        const section = row.closest('section');
                        if (section) section.classList.remove('hidden');
                    } else {
                        row.classList.add('hidden');
                        
                        // Si todas las filas de una sección están ocultas, ocultamos la sección entera
                        const section = row.closest('section');
                        if (section) {
                            const visibleRows = section.querySelectorAll('.catalog-row:not(.hidden)');
                            if (visibleRows.length === 0) {
                                section.classList.add('hidden');
                            }
                        }
                    }
                });
            });
        }
        // --- 4. Herramientas de Diagnóstico (Elite Debug) ---
        (window as any).__DEBUG_CATALOG__ = async () => {
            console.log("🔍 Iniciando Auditoría de Datos del Catálogo...");
            try {
                const { getCatalogNavigation, getCatalogProducts } = await import('../data/api');
                const nav = await getCatalogNavigation();
                const products = await getCatalogProducts();
                console.log("📍 Navegación:", nav);
                console.log("📦 Productos:", products);
                
                if (nav.length === 0) console.warn("⚠️ Advertencia: La navegación está vacía.");
                if (products.length === 0) console.warn("⚠️ Advertencia: La lista de productos está vacía.");
                
                return { nav, products };
            } catch (err) {
                console.error("❌ Error en el diagnóstico:", err);
            }
        };

        // Auto-ejecución si hay ?debug en la URL
        if (window.location.search.includes('debug')) {
            (window as any).__DEBUG_CATALOG__();
        }
    });
</script>
