                                <span>Productos exclusivos</span>
                            </nav>
                            <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-slate-900 tracking-tight mb-2">Alimentos funcionales</h2>
                            <p class="text-slate-700 text-[15px] font-medium leading-snug">Suplementos y alimentos de alta calidad</p>
                        </header>
                        <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                            <span class="text-slate-700 text-sm font-medium">Tabla de alimentos funcionales (datos reales en Fase 3)</span>
                        </div>
                    </section>

                    <!-- Placeholder: CBD -->
                    <section id="cbd" class="scroll-mt-16">
                        <header class="sticky top-0 md:static z-30 bg-[#EAF3F1]/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                            <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">
                                <span>Productos exclusivos</span>
                            </nav>
                            <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-slate-900 tracking-tight mb-2">CBD</h2>
                            <p class="text-slate-700 text-[15px] font-medium leading-snug">Productos de cannabidiol de grado farmacéutico</p>
                        </header>
                        <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                            <span class="text-slate-700 text-sm font-medium">Tabla de CBD (datos reales en Fase 3)</span>
                        </div>
                    </section>

                    <!-- Placeholder: Aceites esenciales -->
                    <section id="aceites-esenciales" class="scroll-mt-16">
                        <header class="sticky top-0 md:static z-30 bg-[#EAF3F1]/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                            <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">
                                <span>Productos exclusivos</span>
                            </nav>
