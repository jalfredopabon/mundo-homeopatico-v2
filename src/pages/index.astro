---
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarCatalogo from '../components/catalogo/SidebarCatalogo.astro';
import Footer from '../components/shared/Footer.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import Icons from '../components/catalogo/Icons.astro';
import InfoBanner from '../components/shared/InfoBanner.astro';
import ProductRowElite from '../components/catalogo/ProductRowElite.astro';
---

<BaseLayout title="Catálogo de Productos | Mundo Homeopático" mostrarZoom={true}>
    
    <!-- Carrito Lateral (Drawer) -->
    <CartDrawer />
    
    <!-- Contenedor Principal de 2 columnas -->
    <div class="flex flex-col md:flex-row w-full flex-1 h-[calc(100vh-64px)]">
        
        <!-- Columna Izquierda: Sidebar de Filtros (Fijo en Desktop) -->
        <SidebarCatalogo />

        <!-- Columna Derecha: Contenedor Master de Data + Footer -->
        <div class="flex-1 overflow-y-auto w-full relative flex flex-col bg-surface-muted h-[calc(100vh-64px)] scroll-smooth" id="catalogo-main-scroll">
            
            <!-- Banner Informativo Modular -->
            <div class="mh-layout-px pt-4">
                <InfoBanner message="Dispensación limitada a usuarios con receta médica vigente. Validación de stock requerida." />
            </div>

            <div class="mh-layout-px pt-4 pb-24 flex-1 flex flex-col">
                <div class="flex flex-col gap-8">
                    <!-- Sección: Oligoelementos -->
                <section id="oligoelementos" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm mh-layout-px-neg mh-layout-px pt-0 pb-8 flex flex-col auto-animate-header">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-muted tracking-wider mb-2">
                            <span class="hover:text-body transition-colors cursor-pointer">De nuestra farmacia</span>
                            <div class="w-2.5 h-2.5 text-subtle">
                                <Icons type="chevron-right" />
                            </div>
                            <span class="hover:text-body transition-colors cursor-pointer">Según prescripción</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-body tracking-tight mb-2">Oligoelementos</h2>
                        <p class="text-secondary text-[15px] font-medium leading-snug">Elaborados a la D7</p>
                    </header>
                    <div class="mh-table-container">
                        <!-- Encabezado de Tabla (Solo Desktop) -->
                        <div class="mh-table-header mh-table-grid">
                            <div>Producto</div>
                            <div class="text-right">Precio farmacia</div>
                            <div class="text-right">Precio público</div>
                            <div class="mh-table-action-cell">
                                <div class="w-10 flex justify-center text-body">
                                    <div class="w-4 h-4">
                                        <Icons type="cart" />
                                    </div>
                                </div>
                            </div>
                        </div>

                    <div class="flex flex-col">
                        <ProductRowElite 
                            name="Oligoelementos individuales"
                            badges={[
                                { label: 'Gotas / Spray', icon: 'pill' },
                                { label: 'Glóbulos x 30g', icon: 'shield-check' }
                            ]}
                            farmaciaPrice="$19.500"
                            publicoPrice="$36.000"
                            cartData={{ name: 'Oligoelementos individuales', price: '19500' }}
                        />

                        <ProductRowElite 
                            name="Oligoelementos combinados (hasta 6 componentes)"
                            badges={[
                                { label: 'Gotas / Spray', icon: 'pill' },
                                { label: 'Glóbulos x 30g', icon: 'shield-check' }
                            ]}
                            farmaciaPrice="$25.500"
                            publicoPrice="$44.000"
                            cartData={{ name: 'Oligoelementos combinados', price: '25500' }}
                        />
                    </div>
                    </div>
                </section>

                <!-- Sección: Esencias florales -->
                <section id="esencias-florales" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-muted uppercase tracking-wider mb-2">
                            <span>De nuestra farmacia</span>
                            <div class="w-2.5 h-2.5 text-subtle">
                                <Icons type="chevron-right" />
                            </div>
                            <span>Según prescripción</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-body tracking-tight mb-2">Esencias florales</h2>
                        <p class="text-secondary text-[15px] font-medium leading-snug">Flores de Bach y otras esencias</p>
                    </header>
                    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                        <span class="text-secondary text-sm font-medium">Tabla de esencias florales (datos reales en Fase 3)</span>
                    </div>
                </section>

                <!-- Sección: Alimentos funcionales -->
                <section id="alimentos-funcionales" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-muted uppercase tracking-wider mb-2">
                            <span>Productos exclusivos</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-body tracking-tight mb-2">Alimentos funcionales</h2>
                        <p class="text-secondary text-[15px] font-medium leading-snug">Suplementos y alimentos de alta calidad</p>
                    </header>
                    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                        <span class="text-secondary text-sm font-medium">Tabla de alimentos funcionales (datos reales en Fase 3)</span>
                    </div>
                </section>

                <!-- Sección: CBD -->
                <section id="cbd" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-muted uppercase tracking-wider mb-2">
                            <span>Productos exclusivos</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-body tracking-tight mb-2">CBD</h2>
                        <p class="text-secondary text-[15px] font-medium leading-snug">Productos de cannabidiol de grado farmacéutico</p>
                    </header>
                    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                        <span class="text-secondary text-sm font-medium">Tabla de CBD (datos reales en Fase 3)</span>
                    </div>
                </section>

                <!-- Sección: Aceites esenciales -->
                <section id="aceites-esenciales" class="scroll-mt-16">
                    <header class="sticky top-0 md:static z-30 bg-surface-muted/95 backdrop-blur-sm -mx-8 px-8 md:-mx-[72px] md:px-[72px] pt-0 pb-8 flex flex-col">
                        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[11px] font-bold text-muted uppercase tracking-wider mb-2">
                            <span>Productos exclusivos</span>
                        </nav>
                        <h2 class="text-[2.25rem] leading-[0.9] font-extrabold text-body tracking-tight mb-2">Aceites esenciales</h2>
                        <p class="text-secondary text-[15px] font-medium leading-snug">Extractos puros de plantas medicinales</p>
                    </header>
                    <div class="w-full bg-surface-white rounded-2xl border border-subtle overflow-hidden p-8 flex items-center justify-center min-h-[200px]">
                        <span class="text-secondary text-sm font-medium">Tabla de aceites esenciales (datos reales en Fase 3)</span>
                    </div>
                </section>

            </div>
        </div>

        <!-- Footer incrustado al final de la columna derecha con mt-auto para anclaje inferior -->
        <div class="mt-auto w-full border-t border-strong/60 pb-[calc(4rem+env(safe-area-inset-bottom))] md:pb-0">
            <Footer />
        </div>

    </div>

</div>

</BaseLayout>



<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- 1. Sistema de Scroll Reveal ---
        const revealElements = document.querySelectorAll('.reveal');
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, observerOptions);

        revealElements.forEach(el => revealObserver.observe(el));


        // --- 2. Lógica del Carrito con Micro-animaciones ---
        const btnAddCart = document.querySelectorAll('.btn-add-cart');
        
        btnAddCart.forEach(btn => {
            const button = btn as HTMLButtonElement;
            button.addEventListener('click', () => {
                const name = button.getAttribute('data-name');
                const price = button.getAttribute('data-price');

                // Lanzar evento personalizado para CartDrawer.astro
                const event = new CustomEvent('addToCart', {
                    detail: { name, price }
                });
                document.dispatchEvent(event);

                // Micro-animación: Mutación del botón (+ → ✓)
                const originalSvg = button.innerHTML;
                button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                button.classList.add('bg-brand', 'scale-110');
                setTimeout(() => {
                    button.innerHTML = originalSvg;
                    button.classList.remove('bg-brand', 'scale-110');
                }, 1200);

                // Micro-animación: Flash verde sutil en la fila
                const row = button.closest('[class*="grid"]') as HTMLElement | null;
                if (row) {
                    row.style.transition = 'background-color 0.15s ease';
                    row.style.backgroundColor = 'rgba(16,185,129,0.08)';
                    setTimeout(() => { row.style.backgroundColor = ''; }, 600);
                }

                // Micro-animación: Toast "+1" flotante
                const toast = document.createElement('span');
                toast.textContent = '+1';
                toast.className = 'absolute -top-2 -right-2 text-[11px] font-extrabold text-white bg-brand px-1.5 py-0.5 rounded-full pointer-events-none';
                toast.style.transition = 'all 0.6s ease-out';
                button.style.position = 'relative';
                button.appendChild(toast);
                requestAnimationFrame(() => {
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateY(-18px) scale(0.8)';
                });
                setTimeout(() => toast.remove(), 700);
            });
        });

        // --- 3. Lógica para cerrar el banner informativo (Scroll Continuo) ---
        const btnCloseBanner = document.getElementById('close-banner');
        const infoBanner = document.getElementById('info-banner');
        
        if (btnCloseBanner && infoBanner) {
            btnCloseBanner.addEventListener('click', () => {
                infoBanner.style.opacity = '0';
                infoBanner.style.transform = 'translateY(-10px)';
                setTimeout(() => {
                    infoBanner.style.display = 'none';
                }, 300);
            });
        }
    });
</script>
