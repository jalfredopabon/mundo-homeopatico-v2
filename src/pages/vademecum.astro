<script>
    // ⚠️ TEMPORAL: Credenciales hardcodeadas para desarrollo. Reemplazar por autenticación real (GAS) en Fase 3.
    const TEMP_USER = 'alfredo';
    const TEMP_PASS = '1234';

    const overlay = document.getElementById('auth-modal-overlay');
    const form = document.getElementById('auth-form');
    const inputNit = document.getElementById('auth-nit');
    const inputPass = document.getElementById('auth-password');
    const errorBox = document.getElementById('auth-error');
    const errorText = document.getElementById('auth-error-text');
    const toggleBtn = document.getElementById('toggle-password');
    const iconOpen = document.getElementById('icon-eye-open');
    const iconClosed = document.getElementById('icon-eye-closed');

    // Validación del formulario
    form?.addEventListener('submit', (e) => {
        e.preventDefault();
        const user = inputNit?.value.trim();
        const pass = inputPass?.value;

        if (user === TEMP_USER && pass === TEMP_PASS) {
            // Animación de salida del modal
            overlay?.classList.add('opacity-0');
            setTimeout(() => {
                overlay?.classList.add('hidden');
            }, 300);
        } else {
            // Mostrar error
            errorBox?.classList.remove('hidden');
            errorBox?.classList.add('flex');
            if (errorText) errorText.textContent = 'Credenciales incorrectas. Verifique usuario y contraseña.';
            inputPass?.focus();
        }
    });

    // Toggle de visibilidad de contraseña
    toggleBtn?.addEventListener('click', () => {
        const isPassword = inputPass?.type === 'password';
        if (inputPass) inputPass.type = isPassword ? 'text' : 'password';
        iconOpen?.classList.toggle('hidden');
        iconClosed?.classList.toggle('hidden');
    });
</script>
