---
import BaseLayout from '../layouts/BaseLayout.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import SidebarVademecum from '../components/vademecum/SidebarVademecum.astro';
import AuthModal from '../components/shared/AuthModal.astro';
import MedicalDetails from '../components/vademecum/MedicalDetails.astro';

const medicines = [
    {
        id: 'nux-vomica',
        name: 'Nux vomica',
        potency: 'D4',
        scientificName: 'Strychnos nux-vomica',
        origin: 'Origen vegetal',
        isActive: true,
        sections: [
            {
                title: 'Indicaciones clínicas',
                icon: 'list',
                content: 'Coadyuvante en el tratamiento de dispepsias, flatulencia, estreñimiento espasmódico e irritabilidad vinculada al estilo de vida sedentario.'
            },
            {
                title: 'Perfil farmacológico',
                icon: 'test-tube',
                content: '<span class="font-bold text-body">Tropismo principal:</span> Sistema Digestivo y Sistema Nervioso Central (médula espinal).'
            },
            {
                title: 'Protocolo de posología',
                icon: 'book-open',
                content: 'Disolver <span class="font-bold text-body">5 glóbulos bajo la lengua</span>, 3 veces al día. Evitar café y menta durante el tratamiento.'
            }
        ]
    },
    {
        id: 'arnica-montana',
        name: 'Arnica montana',
        potency: 'D6',
        scientificName: 'Arnica montana L.',
        origin: 'Origen vegetal',
        sections: [
            {
                title: 'Indicaciones clínicas',
                icon: 'list',
                content: 'Tratamiento de traumatismos, contusiones y dolores musculares por sobreesfuerzo físico o trauma.'
            },
            {
                title: 'Perfil farmacológico',
                icon: 'test-tube',
                content: '<span class="font-bold text-body">Tropismo principal:</span> Sistema Muscular, Capilares sanguíneos y Tejido Celular.'
            }
        ]
    },
    {
        id: 'ignatia-amara',
        name: 'Ignatia amara',
        potency: 'D12',
        scientificName: 'Strychnos ignatii',
        origin: 'Origen vegetal',
        sections: [
            {
                title: 'Indicaciones clínicas',
                icon: 'list',
                content: 'Trastornos emocionales, ansiedad con espasmos, labilidad afectiva y efectos de duelos recientes.'
            },
            {
                title: 'Perfil farmacológico',
                icon: 'test-tube',
                content: '<span class="font-bold text-body">Tropismo principal:</span> Sistema Nervioso (Eje cerebroespinal). Sensibilidad extrema.'
            }
        ]
    },
    {
        id: 'pulsatilla',
        name: 'Pulsatilla',
        potency: 'D6',
        scientificName: 'Anemone pulsatilla',
        origin: 'Origen vegetal',
        sections: [
            {
                title: 'Indicaciones clínicas',
                icon: 'list',
                content: 'Afecciones de mucosas con secreciones blandas, variabilidad de síntomas y timidez.'
            },
            {
                title: 'Perfil farmacológico',
                icon: 'test-tube',
                content: '<span class="font-bold text-body">Tropismo principal:</span> Mucosas, Sistema Venoso y Órganos genitales femeninos.'
            }
        ]
    }
];
---

<BaseLayout title="Vademécum Clínico | Mundo Homeopático" mostrarZoom={false}>
    
    <!-- Carrito Lateral (Drawer) -->
    <CartDrawer />

    <!-- Modal de Autenticación Modular -->
    <AuthModal />

    <!-- Contenedor Principal Dashboard 3 Columnas -->
    <div class="flex flex-col md:flex-row w-full max-w-full mx-auto flex-1 h-[calc(100vh-66px)] overflow-hidden">
        
        <!-- Columna Izquierda: Sidebar de Filtros (Consistente con Catálogo) -->
        <SidebarVademecum />

        <!-- Columna Central: Listado de Productos (Scroll propio) -->
        <div class="flex-1 bg-surface-muted border-subtle h-full overflow-y-auto scrollbar-premium">
            <div class="px-8 md:px-[72px] pt-12 pb-24 flex-1">
                
                <!-- Encabezado de Sección -->
                <header class="mb-10 reveal">
                   <div class="flex items-center gap-3 mb-2">
                        <span class="w-10 h-[2px] bg-brand"></span>
                        <span class="text-[11px] font-bold uppercase tracking-widest text-slate-500">Acompañamiento clínico</span>
                   </div>
                   <h1 class="text-[2.5rem] font-black text-slate-900 tracking-tighter mb-3">Vademécum clínico</h1>
                   <p class="text-slate-600 text-[15px] font-medium leading-relaxed max-w-2xl">Explore el catálogo de productos con indicaciones terapéuticas detalladas. Información farmacéutica de alta precisión.</p>
                </header>

                <!-- Grilla de Medicamentos (Buscables) -->
                <div class="grid grid-cols-1 xl:grid-cols-2 gap-5 mb-20" id="meds-container">
                    
                    {medicines.map((med, index) => (
                        <div 
                            class={`bg-surface-white rounded-xl p-6 cursor-pointer border transition-all hover:border-brand/30 hover:shadow-md group reveal ${index % 2 === 0 ? 'reveal-delay-100' : 'reveal-delay-200'} ${med.isActive ? 'border-brand' : 'border-subtle'}`} 
                            data-med={med.id}
                        >
                            <div class="flex items-baseline gap-2.5 mb-2">
                                <h3 class={`text-[16px] font-bold group-hover:scale-[1.02] transition-all origin-left ${med.isActive ? 'text-brand' : 'text-slate-900'}`}>
                                    {med.name}
                                </h3>
                                <span class="text-slate-700 text-xs font-medium">{med.potency}</span>
                            </div>
                            <p class="text-[13px] text-slate-700 leading-relaxed mb-4">
                                {med.sections[0].content.substring(0, 120)}...
                            </p>
                            <div class="flex items-center gap-3 flex-wrap">
                                <span class="mh-pill">Homeopatía</span>
                                <span class="mh-pill">Gotas</span>
                            </div>
                        </div>
                    ))}

                </div>
            </div>
        </div>

        <!-- Columna Derecha: Panel de Ficha Técnica Modular -->
        <MedicalDetails products={medicines} />

    </div>

</BaseLayout>




<script>
    document.addEventListener('DOMContentLoaded', () => {
        initReveal();
        initFichasManager();
        initMobileDrawer();
    });

    /**
     * --- 1. SISTEMA DE REVEAL (ANIMACIONES) ---
     * Gestiona la aparición suave de los elementos al hacer scroll.
     */
    function initReveal() {
        const revealElements = document.querySelectorAll('.reveal');
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, observerOptions);

        revealElements.forEach(el => revealObserver.observe(el));
    }

    /**
     * --- 2. GESTIÓN DE FICHAS TÉCNICAS ---
     * Controla la selección de medicamentos y la visualización de su ficha técnica.
     */
    function initFichasManager() {
        const medCards = document.querySelectorAll('[data-med]');
        const vademecumAside = document.getElementById('vademecum-aside');
        const sheets = document.querySelectorAll('.medical-sheet-container');

        medCards.forEach(card => {
            card.addEventListener('click', () => {
                const medId = card.getAttribute('data-med');

                // 2.1 Actualizar estado visual de las tarjetas
                actualizarTarjetasActivas(medCards, card);

                // 2.2 Cambiar contenido de la ficha (ID dinámico)
                cambiarFichaTecnica(sheets, medId);

                // 2.3 Reset de scroll en el Aside (UX)
                if (vademecumAside) {
                    vademecumAside.scrollTo({ top: 0, behavior: 'smooth' });
                }

                // 2.4 Abrir en móvil si estamos en resolución reducida
                abrirDrawerMovil(vademecumAside);
            });
        });
    }

    // Funciones auxiliares para FichasManager
    function actualizarTarjetasActivas(allCards, selectedCard) {
        allCards.forEach(c => {
            c.classList.remove('border-brand');
            c.classList.add('border-subtle');
            const h3 = c.querySelector('h3');
            if (h3) { h3.classList.remove('text-brand'); h3.classList.add('text-slate-900'); }
        });
        
        selectedCard.classList.add('border-brand');
        const selectedH3 = selectedCard.querySelector('h3');
        if (selectedH3) { selectedH3.classList.remove('text-slate-900'); selectedH3.classList.add('text-brand'); }
    }

    function cambiarFichaTecnica(allSheets, id) {
        allSheets.forEach(sheet => {
            if (sheet.getAttribute('data-sheet-id') === id) {
                sheet.classList.remove('hidden');
            } else {
                sheet.classList.add('hidden');
            }
        });
    }

    /**
     * --- 3. INTERFAZ MÓVIL (DRAWER) ---
     * Gestiona la apertura y cierre del panel lateral en resoluciones móviles.
     */
    function initMobileDrawer() {
        const vademecumAside = document.getElementById('vademecum-aside');
        
        document.querySelectorAll('.close-ficha-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                cerrarDrawerMovil(vademecumAside);
            });
        });
    }

    function abrirDrawerMovil(aside) {
        if (aside && window.innerWidth < 1024) {
            aside.setAttribute('data-mobile-open', 'true');
            document.body.style.overflow = 'hidden';
        }
    }

    function cerrarDrawerMovil(aside) {
        if (aside) {
            aside.setAttribute('data-mobile-open', 'false');
            document.body.style.overflow = '';
        }
    }
</script>
