---
import BaseLayout from '../layouts/BaseLayout.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import SidebarVademecum from '../components/vademecum/SidebarVademecum.astro';
import AuthModal from '../components/shared/AuthModal.astro';
import MedicalDetails from '../components/vademecum/MedicalDetails.astro';
import MedicalCard from '../components/vademecum/MedicalCard.astro';
import Icons from '../components/shared/Icons.astro';
import VademecumToggle from '../components/vademecum/VademecumToggle.astro';

import { medicines as staticMeds } from '../data/medicines.ts';
import { getVademecumMaestro, getVademecumProtocolos } from '../data/api';
import ProtocolCard from '../components/vademecum/ProtocolCard.astro';

// Renderizado inicial instantáneo con datos estáticos (SSR Speed)
const medicines = staticMeds;
const protocols = []; // Se cargarán dinámicamente en el cliente

const userName = "Invitado";
---

<BaseLayout title="Vademécum Clínico | Mundo Homeopático" mostrarZoom={false}>
    
    <!-- Modal de Autenticación Modular -->
    <AuthModal />

    <!-- Barra de progreso inteligente (Hito Global) -->
    <div id="vademecum-loader-bar" class="fixed top-[64px] left-0 w-full h-[3px] bg-emerald-500/20 z-50 overflow-hidden hidden">
        <div class="h-full bg-emerald-500 animate-progress-fast shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
    </div>

    <!-- Contenedor Principal Dashboard 3 Columnas -->
    <div class="flex flex-col md:flex-row w-full max-w-full mx-auto flex-1 h-[calc(100dvh-66px)] min-h-0 overflow-hidden" id="vademecum-page-container" data-view="products">
        
        <!-- Columna Izquierda: Sidebar de Filtros (Consistente con Catálogo) -->
        <SidebarVademecum userName={userName} />

        <!-- Columna Central: Listado de Productos (Scroll propio) -->
        <div class="flex-1 overflow-y-auto w-full relative flex flex-col bg-surface-muted h-[calc(100dvh-64px)] md:h-[calc(100dvh-72px)] min-h-0 scroll-smooth scrollbar-premium" id="vademecum-main-scroll">
            <div class="page-section">
                
                <!-- Encabezado del Vademécum (ADN Clon Catálogo Elite) -->
                <header class="catalog-section-header reveal mb-2">
                    <div class="flex flex-col w-full">
                        <!-- Switcher de Vistas (Hito 57) -->
                        <div class="mb-8">
                            <VademecumToggle />
                        </div>

                        <nav aria-label="Breadcrumb" class="catalog-breadcrumb mb-2">
                            <span class="hover:text-slate-800 transition-colors cursor-pointer text-slate-500">Volver a Inicio</span>
                            <Icons type="chevron-right" class="w-2.5 h-2.5 text-slate-400" strokeWidth={3} />
                            <span class="hover:text-slate-800 transition-colors cursor-pointer text-slate-500">Profesionales</span>
                        </nav>
                        
                        <h2 class="catalog-title mb-2">Vademécum clínico</h2>
                        
                        <p class="text-slate-700 text-[15px] font-medium leading-snug">Explore el catálogo de medicamentos homeopáticos de alta dilución.</p>
                    </div>
                </header>


                <!-- Contador de Resultados (Blindado con min-h para CLS) -->
                <div class="mb-4 flex items-center gap-2 px-3 py-1.5 bg-surface-white border border-subtle rounded-md text-[11px] font-bold text-slate-700 w-fit shadow-sm reveal min-h-[32px]">
                    <Icons type="jarabe" class="w-3.5 h-3.5 text-slate-500" strokeWidth={1.5} />
                    <span id="results-counter">{medicines.length} medicamentos en catálogo</span>
                </div>

                <!-- Listado de Tarjetas Clínicas (PRODUCTOS) -->
                <div class="space-y-3 max-w-3xl products-view-content" id="meds-container">
                    
                    {medicines
                        .sort((a, b) => a.name.localeCompare(b.name))
                        .map((med) => (

                        <div 
                            class="med-item reveal" 
                            data-terapia={med.tags.terapia} 
                            data-sistema={med.tags.sistema.join(',')}
                            data-forma={med.tags.forma}
                            data-name={med.name.toLowerCase()}
                        >
                            <MedicalCard 
                                id={med.id}
                                name={med.name}
                                potency={med.potency}
                                shortDesc={med.shortDesc}
                                tags={med.tags}
                            />
                        </div>
                    ))}

                    <!-- Estado Vacío (Hidden by default) -->
                    <div id="empty-state" class="hidden py-20 text-center reveal">
                        <div class="flex flex-col items-center gap-4">
                            <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center text-slate-400">
                                <Icons type="search" class="w-8 h-8" strokeWidth={1.5} />
                            </div>
                            <div class="space-y-1">
                                <h3 class="text-slate-900 font-bold text-lg">Sin resultados</h3>
                                <p class="text-slate-500 text-sm max-w-[280px]">No encontramos medicamentos que coincidan con estos filtros.</p>
                            </div>
                            <button id="clear-filters-btn" class="mt-2 text-brand font-bold text-sm hover:underline cursor-pointer">
                                Limpiar todos los filtros
                            </button>
                        </div>
                    </div>

                </div>

                <!-- Listado de Protocolos (PROTOCOLOS) -->
                <div class="space-y-3 max-w-3xl protocols-view-content hidden" id="protocols-container">
                    <!-- Los protocolos se inyectan dinámicamente -->
                </div>

                <!-- Paginador Elite (Blindado con min-h para CLS) -->
                <nav class="pagination-wrap min-h-[44px]" id="pagination-nav" aria-label="Paginación del vademécum">
                    <span class="pagination-info" id="pagination-info">Mostrando 1–10 de 24</span>
                    <div class="pagination-controls" id="pagination-controls"></div>
                </nav>
            </div>

            <!-- Margen de cortesía inferior (32px / 8) -->
        </div>

        <!-- Columna Derecha: Panel de Ficha Técnica Modular -->
        <MedicalDetails products={medicines} protocols={protocols} />

    </div>

</BaseLayout>

<style>
    @keyframes progress-fast {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }
    .animate-progress-fast {
        animation: progress-fast 1s infinite linear;
    }
</style>

<script>
    document.addEventListener('astro:page-load', async () => {
        // --- HIDRATACIÓN INTELIGENTE: Diferir inicialización para liberar el hilo principal ---
        const initAll = async () => {
            initReveal();
            initFichasManager();
            initMobileDrawer();
            const filterAPI = await initFilters();
            
            // Iniciar carga dinámica desde Google / Caché
            await loadDynamicContent(filterAPI);
        };

        if ('requestIdleCallback' in window) {
            window.requestIdleCallback(initAll);
        } else {
            setTimeout(initAll, 200);
        }
    });

    /**
     * MOTOR DE CARGA DINÁMICA (ELITE HYDRATION)
     */
    async function loadDynamicContent(filterAPI: any) {
        const loader = document.getElementById('vademecum-loader-bar');
        const medsContainer = document.getElementById('meds-container');
        const protocolsContainer = document.getElementById('protocols-container');
        
        try {
            loader?.classList.remove('hidden');
            
            const { getVademecumMaestro, getVademecumProtocolos } = await import('../data/api');
            
            // Cargar datos en paralelo
            const [dynamicMeds, dynamicProtocols] = await Promise.all([
                getVademecumMaestro(),
                getVademecumProtocolos()
            ]);

            if (dynamicMeds.length > 0) {
                renderMedsDynamic(dynamicMeds, medsContainer);
            }

            if (dynamicProtocols.length > 0) {
                renderProtocolsDynamic(dynamicProtocols, protocolsContainer);
            }

            // Actualizar el motor de filtros con los nuevos elementos del DOM
            filterAPI.refresh();
            
            // Re-vincular eventos de fichas técnicas para los nuevos elementos
            window.dispatchEvent(new CustomEvent('vademecum:content-updated'));

        } catch (error) {
            console.warn('Fallback: Usando datos estáticos del servidor.');
        } finally {
            loader?.classList.add('hidden');
        }
    }

    function renderMedsDynamic(meds: any[], container: HTMLElement | null) {
        if (!container) return;
        
        // Conservar el Empty State y otros elementos especiales antes de vaciar
        const emptyState = document.getElementById('empty-state');
        container.innerHTML = '';
        if (emptyState) container.appendChild(emptyState);

        meds.forEach(med => {
            const div = document.createElement('div');
            div.className = 'med-item reveal';
            div.setAttribute('data-terapia', med.tags.terapia);
            div.setAttribute('data-sistema', med.tags.sistema.join(','));
            div.setAttribute('data-forma', med.tags.forma);
            div.setAttribute('data-name', med.name.toLowerCase());
            
            div.innerHTML = `
                <div class="medical-card medical-item-btn" data-med="${med.id}" data-id="${med.id}">
                    <div class="mb-2">
                        <h3 class="font-bold text-slate-900 leading-tight">${med.name} ${med.potency}</h3>
                    </div>
                    <p class="text-slate-700 leading-relaxed mb-4 text-sm">${med.shortDesc}</p>
                    <div class="flex items-center gap-2 flex-wrap">
                        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-violet-100 text-violet-700">${med.tags.terapia}</span>
                        ${med.tags.sistema.map((s: string) => `<span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-100 text-emerald-700">${s}</span>`).join('')}
                        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-100 text-amber-700">${med.tags.forma}</span>
                    </div>
                </div>
            `;
            container.appendChild(div);
        });
    }

    function renderProtocolsDynamic(protocols: any[], container: HTMLElement | null) {
        if (!container) return;
        container.innerHTML = '';
        
        protocols.forEach(prot => {
            const div = document.createElement('div');
            div.className = 'protocol-item reveal';
            div.setAttribute('data-sistema', prot.sistema);
            div.setAttribute('data-name', prot.patologia.toLowerCase());
            
            div.innerHTML = `
                <div class="medical-card medical-item-btn is-protocol" data-protocol="${prot.id_protocolo}">
                    <div class="flex items-start justify-between gap-4 mb-2">
                        <h3 class="font-bold text-slate-900 leading-tight">${prot.patologia}</h3>
                        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-100 text-emerald-700 uppercase tracking-wider">${prot.sistema}</span>
                    </div>
                    <p class="text-slate-500 text-xs leading-relaxed line-clamp-2">${prot.principales}</p>
                </div>
            `;
            container.appendChild(div);
        });
    }

    /**
     * --- 1. SISTEMA DE REVEAL (ANIMACIONES) ---
     */
    function initReveal() {
        const revealElements = document.querySelectorAll('.reveal');
        const observerOptions = {
            root: null,
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, observerOptions);

        revealElements.forEach(el => revealObserver.observe(el));
    }

    /**
     * --- 2. GESTIÓN DE FILTROS Y VISTAS (ADN ELITE) ---
     */
    async function initFilters() {
        const ITEMS_PER_PAGE = 10;
        let currentPage = 1;
        let currentView = (document.getElementById('vademecum-page-container')?.getAttribute('data-view') as 'products' | 'protocols') || 'products';

        const filterInputs  = document.querySelectorAll('.vademecum-filter');
        const searchInput   = document.getElementById('vademecum-search') as HTMLInputElement;
        const medsContainer = document.getElementById('meds-container');
        const protocolsContainer = document.getElementById('protocols-container');
        
        let allMedItems   = Array.from(document.querySelectorAll('.med-item')) as HTMLElement[];
        let allProtItems  = Array.from(document.querySelectorAll('.protocol-item')) as HTMLElement[];
        
        const counter       = document.getElementById('results-counter');
        const emptyState    = document.getElementById('empty-state');
        const clearBtn      = document.getElementById('clear-filters-btn');
        const paginationNav = document.getElementById('pagination-nav');
        const paginationInfo= document.getElementById('pagination-info');
        const paginationCtrl= document.getElementById('pagination-controls');
        const scrollTarget  = document.getElementById('vademecum-main-scroll');

        const { sanitizeInput } = await import('../utils/security');

        function getFilteredItems(): HTMLElement[] {
            const rawSearch = searchInput?.value || '';
            const activeFilters = {
                terapia : Array.from(document.querySelectorAll('.vademecum-filter[data-filter-group="terapia"]:checked')).map(i => i.getAttribute('data-filter-value')),
                sistema : Array.from(document.querySelectorAll('.vademecum-filter[data-filter-group="sistema"]:checked')).map(i => i.getAttribute('data-filter-value')),
                forma   : Array.from(document.querySelectorAll('.vademecum-filter[data-filter-group="forma"]:checked')).map(i => i.getAttribute('data-filter-value')),
                search  : sanitizeInput(rawSearch).toLowerCase().trim()
            };

            const itemsToFilter = currentView === 'products' ? allMedItems : allProtItems;

            return itemsToFilter.filter(item => {
                const t  = item.getAttribute('data-terapia') || '';
                const ss = (item.getAttribute('data-sistema') || '').split(',');
                const f  = item.getAttribute('data-forma') || '';
                const n  = item.getAttribute('data-name') || '';

                const okTerapia = currentView === 'protocols' || (activeFilters.terapia.length === 0 || activeFilters.terapia.includes(t));
                const okSistema = activeFilters.sistema.length === 0 || activeFilters.sistema.some(s => ss.includes(s));
                const okForma   = currentView === 'protocols' || (activeFilters.forma.length === 0   || activeFilters.forma.includes(f));
                const okSearch  = !activeFilters.search || n.includes(activeFilters.search);

                return okTerapia && okSistema && okForma && okSearch;
            });
        }

        function renderPage(filtered: HTMLElement[], page: number) {
            const total      = filtered.length;
            const totalPages = Math.max(1, Math.ceil(total / ITEMS_PER_PAGE));
            currentPage      = Math.min(page, totalPages);
            const start = (currentPage - 1) * ITEMS_PER_PAGE;
            const end   = Math.min(start + ITEMS_PER_PAGE, total);

            allMedItems.forEach(item => { item.classList.add('hidden'); item.classList.remove('page-visible'); });
            allProtItems.forEach(item => { item.classList.add('hidden'); item.classList.remove('page-visible'); });

            filtered.slice(start, end).forEach((item, idx) => {
                item.classList.remove('hidden');
                setTimeout(() => item.classList.add('page-visible'), idx * 30);
            });

            const label = currentView === 'products' ? 'medicamentos' : 'protocolos';
            if (counter) counter.innerText = `${total} ${label} encontrados`;
            if (emptyState) emptyState.classList.toggle('hidden', total > 0);
            if (paginationNav) paginationNav.style.display = total === 0 ? 'none' : '';
            if (paginationInfo) paginationInfo.textContent = `Mostrando ${start + 1}–${end} de ${total}`;

            renderPageButtons(currentPage, totalPages);
        }

        function renderPageButtons(current: number, total: number) {
            if (!paginationCtrl) return;
            paginationCtrl.innerHTML = '';

            const btn = (label: string, page: number | null, active = false, disabled = false) => {
                const el = document.createElement('button');
                el.className = 'pagination-btn' + (active ? ' is-active' : '') + (disabled ? ' is-disabled' : '');
                el.textContent = label;
                if (page !== null && !disabled) {
                    el.addEventListener('click', () => {
                        renderPage(getFilteredItems(), page);
                        if (scrollTarget) scrollTarget.scrollTo({ top: 0, behavior: 'smooth' });
                    });
                }
                paginationCtrl.appendChild(el);
            };

            btn('‹', current - 1, false, current === 1);
            for (let i = 1; i <= total; i++) {
                if (total > 7 && i > 3 && i < total - 2 && Math.abs(i - current) > 1) {
                    if (i === current - 2 || i === current + 2) {
                        const span = document.createElement('span');
                        span.textContent = '...';
                        paginationCtrl.appendChild(span);
                    }
                    continue;
                }
                btn(String(i), i, i === current);
            }
            btn('›', current + 1, false, current === total);
        }

        const applyFilters = () => renderPage(getFilteredItems(), 1);

        filterInputs.forEach(input => input.addEventListener('change', applyFilters));
        searchInput?.addEventListener('input', applyFilters);
        clearBtn?.addEventListener('click', () => {
            (document.querySelectorAll('.vademecum-filter:checked') as NodeListOf<HTMLInputElement>).forEach(i => i.checked = false);
            if (searchInput) searchInput.value = '';
            applyFilters();
        });

        window.addEventListener('vademecum:view-change', (e: any) => {
            currentView = e.detail.view;
            if (medsContainer) medsContainer.classList.toggle('hidden', currentView !== 'products');
            if (protocolsContainer) protocolsContainer.classList.toggle('hidden', currentView !== 'protocols');
            applyFilters();
        });

        applyFilters();

        return {
            refresh: () => {
                allMedItems   = Array.from(document.querySelectorAll('.med-item')) as HTMLElement[];
                allProtItems  = Array.from(document.querySelectorAll('.protocol-item')) as HTMLElement[];
                initReveal(); // Re-aplicar animaciones a nuevos elementos
                applyFilters();
            }
        };
    }

    /**
     * --- 3. GESTIÓN DE FICHAS TÉCNICAS ---
     */
    function initFichasManager() {
        const medsContainer = document.getElementById('meds-container');
        const protocolsContainer = document.getElementById('protocols-container');
        const vademecumAside = document.getElementById('vademecum-aside');
        
        const attachEvents = () => {
            const handleCardClick = (e: MouseEvent, targetAttr: string) => {
                const card = (e.target as HTMLElement).closest(`[${targetAttr}]`);
                if (!card) return;

                const id = card.getAttribute(targetAttr);
                const sheets = document.querySelectorAll('.medical-sheet');
                const emptySheetState = document.getElementById('vademecum-empty-state');
                const allCards = document.querySelectorAll(`[data-med], [data-protocol]`);
                
                allCards.forEach(c => c.classList.remove('is-selected'));
                card.classList.add('is-selected');

                if (id) {
                    sheets.forEach(sheet => {
                        if (sheet.getAttribute('data-sheet-id') === id) sheet.classList.remove('hidden');
                        else sheet.classList.add('hidden');
                    });
                }
                
                if (emptySheetState) emptySheetState.classList.add('hidden');
                if (vademecumAside) {
                    vademecumAside.scrollTo({ top: 0, behavior: 'smooth' });
                    if (window.innerWidth < 1024) {
                        vademecumAside.setAttribute('data-mobile-open', 'true');
                        document.body.style.overflow = 'hidden';
                    }
                }
            };

            medsContainer?.addEventListener('click', (e) => handleCardClick(e, 'data-med'));
            protocolsContainer?.addEventListener('click', (e) => handleCardClick(e, 'data-protocol'));
        };

        attachEvents();
        window.addEventListener('vademecum:content-updated', attachEvents);
    }

    /**
     * --- 4. INTERFAZ MÓVIL (DRAWER) ---
     */
    function initMobileDrawer() {
        const vademecumAside = document.getElementById('vademecum-aside');
        document.querySelectorAll('.close-ficha-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                if (vademecumAside) {
                    vademecumAside.setAttribute('data-mobile-open', 'false');
                    document.body.style.overflow = '';
                }
            });
        });
    }
</script>
