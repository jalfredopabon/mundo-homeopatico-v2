---
// src/pages/vademecum.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarVademecum from '../components/vademecum/SidebarVademecum.astro';
import AuthModal from '../components/shared/AuthModal.astro';
import MedicalDetails from '../components/vademecum/MedicalDetails.astro';
import Icons from '../components/shared/Icons.astro';
import VademecumToggle from '../components/vademecum/VademecumToggle.astro';

// Nota: Ya no renderizamos las tarjetas en el servidor para evitar DOM Bloat.
// La hidratación es 100% cliente vía motor dinámico.
const userName = "Alfredo Pabón";

---

<BaseLayout title="Vademécum Clínico | Mundo Homeopático" mostrarZoom={false}>
    
    <AuthModal />

    <div class="flex flex-col md:flex-row w-full max-w-full mx-auto flex-1 h-[calc(100dvh-66px)] min-h-0 overflow-hidden" id="vademecum-page-container" data-view="products">
        
        <!-- Sidebar: Ahora recibe filtros base, pero el filtrado es cliente puro -->
        <SidebarVademecum 
            userName={userName} 
            activeView="productos"
        />

        <!-- Contenedor Central -->
        <div class="flex-1 overflow-y-auto w-full relative flex flex-col bg-surface-muted h-[calc(100dvh-64px)] md:h-[calc(100dvh-72px)] min-h-0 scroll-smooth scrollbar-premium" id="vademecum-main-scroll">
            <div class="page-section">
                
                <header class="catalog-section-header mb-8 reveal active">
                    <div class="flex flex-col w-full gap-6">
                        <!-- Switcher de Modo (Prioridad UX) -->
                        <div class="w-fit">
                            <VademecumToggle />
                        </div>

                        <!-- Título Principal -->
                        <h1 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight">Vademécum clínico</h1>
                    </div>
                </header>

                <!-- Contador de Resultados (ADN Clon Catálogo Elite) -->
                <div class="mb-6 flex items-center gap-2 px-3 py-1.5 bg-surface-white border border-subtle rounded-md text-[11px] font-bold text-slate-700 w-fit shadow-sm reveal active min-h-[32px]">
                    <Icons type="mortero" class="w-3.5 h-3.5 text-slate-500" />
                    <span id="results-counter">Cargando catálogo profesional...</span>
                </div>

                <!-- LISTADO DINÁMICO (VACÍO AL INICIO) -->
                <div class="space-y-4 max-w-3xl products-view-content" id="meds-container">
                    <!-- El motor JS inyectará las tarjetas aquí -->
                </div>

                <div class="space-y-4 max-w-3xl protocols-view-content hidden" id="protocols-container">
                    <!-- El motor JS inyectará los protocolos aquí -->
                </div>

                <!-- Estado Vacío -->
                <div id="empty-state" class="hidden py-20 text-center animate-fade-in">
                    <div class="flex flex-col items-center gap-4">
                        <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center text-slate-400">
                            <Icons type="search" class="w-8 h-8" strokeWidth={1.5} />
                        </div>
                        <div class="space-y-1">
                            <h3 class="text-slate-900 font-bold text-lg">Sin resultados</h3>
                            <p class="text-slate-500 text-sm max-w-[280px]">No encontramos coincidencias con estos filtros.</p>
                        </div>
                        <button id="clear-filters-btn" class="mt-2 text-brand font-bold text-sm hover:underline cursor-pointer">
                            Limpiar filtros
                        </button>
                    </div>
                </div>

                <!-- Paginación Dinámica -->
                <nav class="pagination-wrap min-h-[44px]" id="pagination-nav" style="display: none;">
                    <span class="pagination-info" id="pagination-info"></span>
                    <div class="pagination-controls" id="pagination-controls"></div>
                </nav>
            </div>
        </div>

        <!-- Columna Derecha: Panel de Ficha Técnica (Ahora requiere hidratación dinámica) -->
        <MedicalDetails />

    </div>

</BaseLayout>

<script>
    import { getVademecumMaestro, getVademecumProtocolos } from '../data/api';
    import { createMedicalCard, createProtocolCard } from '../utils/vademecum-renderer';
    import { sanitizeInput } from '../utils/security';

    // Estado Centralizado de Datos
    let _allMeds: any[] = [];
    let _allProtocols: any[] = [];
    let _currentView: 'products' | 'protocols' = 'products';
    let _currentPage = 1;
    const ITEMS_PER_PAGE = 12;

    // Fase 1: Selección independiente por vista
    let _selectedMed: any | null = null;
    let _selectedProtocol: any | null = null;

    // Fase 2: Memoria de filtros por vista
    let _filtersProducts = { search: '', terapias: [], formas: [] };
    let _filtersProtocols = { search: '' };
    // Fase 3: Filtro compartido
    let _filterSistemas: string[] = [];

    document.addEventListener('astro:page-load', async () => {
        await initVademecum();
    });

    async function initVademecum() {
        const counter = document.getElementById('results-counter');

        try {
            // 1. CARGA MAESTRO (Prioridad Alta + Metadatos)
            const { medicines, metadata } = await getVademecumMaestro();
            
            _allMeds = medicines.sort((a, b) => a.name.localeCompare(b.name));

            // Hidratar filtros de productos (Terapias y Formas)
            renderSidebarFilters(metadata);

            // 1.5. Habilitar Salto Maestro
            import('../utils/vademecum-renderer').then(m => m.setProductJumpMap(_allMeds));

            // 2. INICIALIZAR LISTENERS DE UI (Delegación de eventos)
            initUIListeners();
            
            // 3. PRIMER RENDER (Catálogo Maestro)
            applyFiltersAndRender();

            // 4. CARGA PROTOCOLOS (Segundo plano)
            getVademecumProtocolos().then(protocols => {
                _allProtocols = protocols.sort((a, b) => a.name.localeCompare(b.name));
                
                // Extraer sistemas únicos de los protocolos para el sidebar
                const sistemas = [...new Set(_allProtocols.map(p => p.system))].filter(Boolean).sort();
                renderSidebarFilters({ sistemas });

                if (_currentView === 'protocols') applyFiltersAndRender();
            }).catch(err => console.error("Error cargando protocolos:", err));

        } catch (error) {
            console.error("Vademecum Initialization Error:", error);
            if (counter) counter.innerText = "Error cargando datos profesional.";
        }
    }

    // --- MOTOR DE HIDRATACIÓN DINÁMICA ---

    function renderSidebarFilters(metadata: any) {
        if (metadata.terapias) {
            const container = document.getElementById('filter-terapia-list');
            if (container) container.innerHTML = metadata.terapias.map((t: string) => createFilterMarkup('terapia', t, 'accent-violet-600')).join('');
        }
        if (metadata.formas) {
            const container = document.getElementById('filter-forma-list');
            if (container) container.innerHTML = metadata.formas.map((f: string) => createFilterMarkup('forma', f, 'accent-orange-500')).join('');
        }
        if (metadata.sistemas) {
            const container = document.getElementById('filter-sistema-list');
            if (container) container.innerHTML = metadata.sistemas.map((s: string) => createFilterMarkup('sistema', s, 'accent-violet-600')).join('');
        }
    }

    function createFilterMarkup(group: string, value: string, accentClass: string) {
        return `
            <label class="sidebar-filter-label group">
                <input 
                    type="checkbox" 
                    class="vademecum-filter sidebar-filter-checkbox ${accentClass}"
                    data-filter-group="${group}"
                    data-filter-value="${value}"
                />
                <span class="group-hover:text-slate-900 transition-colors">${value}</span>
            </label>
        `;
    }

    function applyFiltersAndRender() {
        const activeFilters = _currentView === 'products' ? _filtersProducts : _filtersProtocols;
        const searchTerm = activeFilters.search.toLowerCase();
        
        const source = _currentView === 'products' ? _allMeds : _allProtocols;

        const filtered = source.filter(item => {
            const matchesSearch = !searchTerm || item.name.toLowerCase().includes(searchTerm);
            
            if (_currentView === 'products') {
                const f = _filtersProducts as any;
                const matchesTerapia = f.terapias.length === 0 || f.terapias.includes(item.category);
                const matchesForma = f.formas.length === 0 || f.formas.includes(item.type);
                const matchesSistema = _filterSistemas.length === 0 || (item.tags?.sistema || []).some((s: string) => _filterSistemas.includes(s));
                return matchesSearch && matchesTerapia && matchesForma && matchesSistema;
            } else {
                const matchesSistema = _filterSistemas.length === 0 || _filterSistemas.includes(item.system);
                return matchesSearch && matchesSistema;
            }
        });

        renderList(filtered);
    }

    function syncFilterUI() {
        const f = (_currentView === 'products' ? _filtersProducts : _filtersProtocols) as any;
        
        // Sincronizar Buscador
        const searchInput = document.getElementById('vademecum-search') as HTMLInputElement;
        if (searchInput) searchInput.value = f.search || '';

        // Sincronizar Checkboxes
        document.querySelectorAll('.vademecum-filter').forEach(checkbox => {
            const cb = checkbox as HTMLInputElement;
            const group = cb.getAttribute('data-filter-group') as string;
            const value = cb.getAttribute('data-filter-value') as string;
            
            if (group === 'sistema') {
                cb.checked = _filterSistemas.includes(value);
            } else {
                const activeList = (f as any)[group + 's'] || []; // terapias, formas
                cb.checked = activeList.includes(value);
            }
        });
    }

    function renderList(items: any[]) {
        const medsContainer = document.getElementById('meds-container');
        const protocolsContainer = document.getElementById('protocols-container');
        const emptyState = document.getElementById('empty-state');
        const counter = document.getElementById('results-counter');
        const nav = document.getElementById('pagination-nav');

        const totalItems = items.length;
        const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
        _currentPage = Math.min(_currentPage, totalPages || 1);

        const start = (_currentPage - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;
        const pageItems = items.slice(start, end);

        // Limpiar y Renderizar
        if (_currentView === 'products' && medsContainer) {
            medsContainer.innerHTML = pageItems.map(item => createMedicalCard(item)).join('');
            medsContainer.classList.remove('hidden');
            if (protocolsContainer) protocolsContainer.classList.add('hidden');
        } else if (protocolsContainer) {
            protocolsContainer.innerHTML = pageItems.map(item => createProtocolCard(item)).join('');
            protocolsContainer.classList.remove('hidden');
            if (medsContainer) medsContainer.classList.add('hidden');
        }

        // Actualizar UI
        if (counter) counter.innerText = `${totalItems} ${_currentView === 'products' ? 'medicamentos' : 'protocolos'} encontrados`;
        if (emptyState) emptyState.classList.toggle('hidden', totalItems > 0);
        if (nav) nav.style.display = totalItems > 0 ? 'flex' : 'none';

        renderPaginationControls(totalPages);

        // Fase 4: Restaurar clase is-selected visualmente si el ítem seleccionado está en esta página
        const activeSelectionId = _currentView === 'products' ? _selectedMed?.id : _selectedProtocol?.id;
        if (activeSelectionId) {
            const attr = _currentView === 'products' ? 'data-medicine-id' : 'data-protocol-id';
            const selectedCard = document.querySelector(`[${attr}="${activeSelectionId}"] .medical-card`);
            if (selectedCard) selectedCard.classList.add('is-selected');
        }
    }

    function renderPaginationControls(totalPages: number) {
        const ctrl = document.getElementById('pagination-controls');
        const info = document.getElementById('pagination-info');
        if (!ctrl || !info) return;

        info.innerText = `Página ${_currentPage} de ${totalPages}`;
        ctrl.innerHTML = '';

        if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= _currentPage - 1 && i <= _currentPage + 1)) {
                const btn = document.createElement('button');
                btn.className = `px-3 py-1 rounded-md text-sm font-medium transition-all ${_currentPage === i ? 'bg-brand text-white' : 'bg-white text-slate-600 hover:bg-slate-100'}`;
                btn.innerText = i.toString();
                btn.onclick = () => { _currentPage = i; applyFiltersAndRender(); window.scrollTo({top: 0, behavior: 'smooth'}); };
                ctrl.appendChild(btn);
            } else if (i === _currentPage - 2 || i === _currentPage + 2) {
                const dot = document.createElement('span');
                dot.innerText = '...';
                dot.className = 'text-slate-400 px-1';
                ctrl.appendChild(dot);
            }
        }
    }

    function initUIListeners() {
        const searchInput = document.getElementById('vademecum-search') as HTMLInputElement;
        const clearBtn = document.getElementById('clear-filters-btn');
        const sidebar = document.querySelector('aside');

        // Búsqueda
        searchInput?.addEventListener('input', () => { 
            const f = (_currentView === 'products' ? _filtersProducts : _filtersProtocols) as any;
            f.search = sanitizeInput(searchInput.value);
            _currentPage = 1; 
            applyFiltersAndRender(); 
        });

        // Delegación de eventos para filtros dinámicos
        sidebar?.addEventListener('change', (e) => {
            const target = e.target as HTMLInputElement;
            if (target.classList.contains('vademecum-filter')) {
                const groupAttr = target.getAttribute('data-filter-group') as string;
                const value = target.getAttribute('data-filter-value') as string;
                
                if (groupAttr === 'sistema') {
                    // Fase 3: Actualizar filtro compartido
                    if (target.checked) {
                        if (!_filterSistemas.includes(value)) _filterSistemas.push(value);
                    } else {
                        _filterSistemas = _filterSistemas.filter(v => v !== value);
                    }
                } else {
                    // Fase 2: Actualizar filtros por vista
                    const f = (_currentView === 'products' ? _filtersProducts : _filtersProtocols) as any;
                    const group = groupAttr + 's';
                    if (target.checked) {
                        if (!f[group].includes(value)) f[group].push(value);
                    } else {
                        f[group] = f[group].filter((v: string) => v !== value);
                    }
                }

                _currentPage = 1;
                applyFiltersAndRender();
            }
        });

        clearBtn?.addEventListener('click', () => {
            const f = (_currentView === 'products' ? _filtersProducts : _filtersProtocols) as any;
            f.search = '';
            if (f.terapias) f.terapias = [];
            if (f.formas) f.formas = [];
            
            // Fase 3: Limpiar sistemas también
            _filterSistemas = [];

            syncFilterUI();
            _currentPage = 1;
            applyFiltersAndRender();
        });

        // Switcher de Vistas
        window.addEventListener('vademecum:view-change', (e: any) => {
            _currentView = e.detail.view;
            _currentPage = 1;
            
            // Actualizar Sidebar visibility
            document.querySelectorAll('.sidebar-filter-section').forEach(section => {
                const target = section.getAttribute('data-view-target');
                if (target !== 'both') section.classList.toggle('hidden', target !== _currentView);
            });

            // Fase 1 & 4: Restaurar o limpiar la Columna 3 según la selección guardada de esta vista
            const savedSelection = _currentView === 'products' ? _selectedMed : _selectedProtocol;
            if (savedSelection) {
                window.dispatchEvent(new CustomEvent('vademecum:select-item', { 
                    detail: { item: savedSelection, type: _currentView === 'products' ? 'medicine' : 'protocol' } 
                }));
            } else {
                window.dispatchEvent(new CustomEvent('vademecum:clear-sheet'));
            }

            // Fase 2: Sincronizar UI de filtros con el estado de la nueva vista
            syncFilterUI();
            applyFiltersAndRender();
        });

        // Click en Tarjetas (Delegación de eventos)
        document.getElementById('meds-container')?.addEventListener('click', (e) => {
            const item = (e.target as HTMLElement).closest('[data-medicine-id]');
            if (item) {
                document.querySelectorAll('.medical-card').forEach(c => c.classList.remove('is-selected'));
                const card = item.querySelector('.medical-card');
                if (card) card.classList.add('is-selected');

                const id = item.getAttribute('data-medicine-id');
                const medicine = _allMeds.find(m => m.id === id);
                if (medicine) {
                    _selectedMed = medicine; // Fase 1: guardar selección
                    dispatchEvent(new CustomEvent('vademecum:select-item', { detail: { item: medicine, type: 'medicine' } }));
                }
            }
        });

        document.getElementById('protocols-container')?.addEventListener('click', (e) => {
            const item = (e.target as HTMLElement).closest('[data-protocol-id]');
            if (item) {
                document.querySelectorAll('.medical-card').forEach(c => c.classList.remove('is-selected'));
                const card = item.querySelector('.medical-card');
                if (card) card.classList.add('is-selected');

                const id = item.getAttribute('data-protocol-id');
                const protocol = _allProtocols.find(p => p.id === id);
                if (protocol) {
                    _selectedProtocol = protocol; // Fase 1: guardar selección
                    dispatchEvent(new CustomEvent('vademecum:select-item', { detail: { item: protocol, type: 'protocol' } }));
                }
            }
        });

        // MANEJADOR DE SALTO MAESTRO (Solicitud desde detalles)
        window.addEventListener('vademecum:request-jump', (e: any) => {
            const id = e.detail.id;
            const medicine = _allMeds.find(m => m.id === id);
            if (medicine) {
                // Forzar vista de productos si estamos en protocolos
                if (_currentView !== 'products') {
                    _currentView = 'products';
                    applyFiltersAndRender();
                }
                // Disparar selección
                window.dispatchEvent(new CustomEvent('vademecum:select-item', { 
                    detail: { item: medicine, type: 'medicine' } 
                }));
            }
        });
    }
</script>

<style is:global>
    /* Estilos Críticos para el Renderizado Dinámico (JS Inject) */
    .animate-content-in {
        animation: contentIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes contentIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .badge-brand-sm { 
        @apply inline-flex px-2 py-0.5 text-brand text-[10px] font-bold rounded uppercase tracking-wider ring-1 ring-inset;
        background-color: rgba(var(--brand-rgb, 14, 165, 233), 0.1);
        box-shadow: inset 0 0 0 1px rgba(var(--brand-rgb, 14, 165, 233), 0.2);
    }
    .badge-warning-sm { 
        @apply inline-flex px-2 py-0.5 text-amber-700 text-[10px] font-bold rounded uppercase tracking-wider ring-1 ring-amber-100;
        background-color: #fffbeb;
    }
    .badge-success-sm { 
        @apply inline-flex px-2 py-0.5 text-emerald-700 text-[10px] font-bold rounded uppercase tracking-wider ring-1 ring-emerald-100;
        background-color: #ecfdf5;
    }

    .master-jump-link:hover {
        @apply underline decoration-brand;
        text-shadow: 0 0 1px rgba(var(--color-brand), 0.2);
    }

    /* Scrollbar Premium */
    .scrollbar-premium::-webkit-scrollbar { width: 4px; }
    .scrollbar-premium::-webkit-scrollbar-track { background: transparent; }
    .scrollbar-premium::-webkit-scrollbar-thumb { 
        background: #e2e8f0; 
        border-radius: 10px; 
    }
    .scrollbar-premium::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
</style>
