---
// src/pages/vademecum.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarVademecum from '../components/vademecum/SidebarVademecum.astro';
import AuthModal from '../components/shared/AuthModal.astro';
import PosologiaModal from '../components/vademecum/PosologiaModal.astro';
import PrincipiosModal from '../components/vademecum/PrincipiosModal.astro';
import MedicalDetails from '../components/vademecum/MedicalDetails.astro';
import Icons from '../components/shared/Icons.astro';
import VademecumToggle from '../components/vademecum/VademecumToggle.astro';
import ImportadosModal from '../components/vademecum/ImportadosModal.astro';

// Nota: Ya no renderizamos las tarjetas en el servidor para evitar DOM Bloat.
// La hidratación es 100% cliente vía motor dinámico.
// Nota: Ya no renderizamos las tarjetas en el servidor para evitar DOM Bloat.
// La hidratación es 100% cliente vía motor dinámico.
---

<BaseLayout title="Vademécum | Mundo Homeopático" mostrarZoom={false}>
    
    <AuthModal />
    <PosologiaModal />
    <PrincipiosModal />
    <ImportadosModal />

    <div class="flex flex-col md:flex-row w-full max-w-full mx-auto flex-1 h-[calc(100dvh-66px)] min-h-0 overflow-hidden" id="vademecum-page-container" data-view="products">
        
        <!-- Sidebar: Ahora recibe filtros base, pero el filtrado es cliente puro -->
        <SidebarVademecum 
            activeView="productos"
        />

        <!-- Contenedor Central -->
        <div class="flex-1 overflow-y-auto w-full relative flex flex-col bg-surface-muted h-[calc(100dvh-64px)] md:h-[calc(100dvh-72px)] min-h-0 scroll-smooth scrollbar-premium" id="vademecum-main-scroll">
            <div class="page-section">
                
                <header class="catalog-section-header reveal active">
                    <div class="flex flex-col w-full gap-6">
                        <!-- Switcher de Modo y Botón VIP (Prioridad UX) -->
                        <div class="flex flex-wrap items-center justify-between gap-4 w-full">
                            <div class="w-fit">
                                <VademecumToggle />
                            </div>
                            <button 
                                id="vip-importados-btn" 
                                class="hidden items-center gap-2 py-2 px-4 bg-white hover:bg-brand active:scale-95 text-slate-800 hover:text-white border border-brand hover:border-brand font-bold text-xs rounded-xl transition-all cursor-pointer shadow-sm animate-fade-in group"
                            >
                                <Icons type="globe" class="w-3.5 h-3.5 text-brand group-hover:text-white transition-colors" />
                                Productos importados
                            </button>
                        </div>

                        <!-- Título Principal -->
                        <h1 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight">Vademécum</h1>
                    </div>
                </header>

                <!-- Índice Alfabético A-Z -->
                <div id="alphabet-filter-container" class="mb-6 flex flex-wrap gap-1.5 items-center reveal active py-2">
                    <!-- Inyectado dinámicamente -->
                </div>

                <!-- Contador de Resultados (ADN Clon Catálogo Elite) y Quitar filtros -->
                <div class="mb-8 flex flex-wrap items-center gap-3 reveal active">
                    <div class="flex items-center gap-2 px-3 py-1.5 bg-surface-white border border-subtle rounded-md text-[11px] font-bold text-slate-700 w-fit shadow-sm min-h-[32px]">
                        <Icons type="mortero" class="w-3.5 h-3.5 text-slate-500" />
                        <span id="results-counter">Verificando credenciales...</span>
                    </div>
                    
                    <button 
                        id="global-clear-filters-btn" 
                        class="hidden items-center gap-1.5 py-1 px-3 bg-red-50 hover:bg-red-100/80 active:scale-95 text-red-600 border border-red-200 hover:border-red-300 font-bold text-[10px] rounded-lg transition-all cursor-pointer shadow-sm animate-fade-in"
                    >
                        <Icons type="close-x" class="w-3 h-3 text-red-500" />
                        Quitar filtros
                    </button>
                </div>

                <!-- LISTADO DINÁMICO (VACÍO AL INICIO) -->
                <div class="space-y-4 max-w-3xl products-view-content" id="meds-container">
                    <!-- El motor JS inyectará las tarjetas aquí -->
                </div>

                <div class="space-y-4 max-w-3xl protocols-view-content hidden" id="protocols-container">
                    <!-- El motor JS inyectará los protocolos aquí -->
                </div>

                <!-- Estado Vacío -->
                <div id="empty-state" class="hidden py-20 text-center animate-fade-in">
                    <div class="flex flex-col items-center gap-4">
                        <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center text-slate-400">
                            <Icons type="search" class="w-8 h-8" strokeWidth={1.5} />
                        </div>
                        <div class="space-y-1">
                            <h3 class="text-slate-900 font-bold text-lg">Sin resultados</h3>
                            <p class="text-slate-500 text-sm max-w-[280px]">No encontramos coincidencias con estos filtros.</p>
                        </div>
                        <button id="clear-filters-btn" class="mt-2 text-brand font-bold text-sm hover:underline cursor-pointer">
                            Limpiar filtros
                        </button>
                    </div>
                </div>

                <!-- Paginación Dinámica -->
                <nav class="pagination-wrap min-h-[44px]" id="pagination-nav" style="display: none;">
                    <span class="pagination-info" id="pagination-info"></span>
                    <div class="pagination-controls" id="pagination-controls"></div>
                </nav>
            </div>
        </div>

        <!-- Columna Derecha: Panel de Ficha Técnica (Ahora requiere hidratación dinámica) -->
        <MedicalDetails />

    </div>

</BaseLayout>

<script>
    import { getVademecumMaestro, getVademecumProtocolos, getVademecumPosologia, getVademecumPrincipios } from '../data/api';
    import { createMedicalCard, createProtocolCard, setStandardPosologiaMap } from '../utils/vademecum-renderer';
    import { sanitizeInput } from '../utils/security';

    // Estado Centralizado de Datos
    let _allMeds: any[] = [];
    let _allProtocols: any[] = [];
    let _allPosologias: any[] = [];
    let _allPrincipios: any[] = [];
    let _currentView: 'products' | 'protocols' = 'products';
    let _currentPage = 1;
    const ITEMS_PER_PAGE = 12;

    // Fase 1: Selección independiente por vista
    let _selectedMed: any | null = null;
    let _selectedProtocol: any | null = null;

    // Fase 2: Memoria de filtros por vista
    let _filtersProducts = { search: '', terapias: [], formas: [] };
    let _filtersProtocols = { search: '' };
    // Fase 3: Filtro compartido
    let _filterSistemas: string[] = [];
    
    // Estado del Abecedario
    let _selectedLetter: string | null = null;
    const ALPHABET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

    // Estado del Buscador Predictivo
    let searchFocusIndex = -1;
    let lastSearchItems: any[] = [];
    let lastSearchQuery = '';
    let isSearchExpanded = false;

    function checkVIPAccess() {
        const sessionRaw = localStorage.getItem('mh_session') || sessionStorage.getItem('mh_session');
        const vipBtn = document.getElementById('vip-importados-btn');
        if (!vipBtn) return;
        
        if (sessionRaw) {
            try {
                const session = JSON.parse(sessionRaw);
                if (session.productos_importados) {
                    vipBtn.classList.remove('hidden');
                    vipBtn.classList.add('inline-flex');
                    return;
                }
            } catch (e) {
                console.error('Error parsing session for VIP access:', e);
            }
        }
        vipBtn.classList.add('hidden');
        vipBtn.classList.remove('inline-flex');
    }

    document.addEventListener('astro:page-load', async () => {
        const session = localStorage.getItem('mh_session') || sessionStorage.getItem('mh_session');
        const authModal = document.getElementById('auth-modal-overlay');

        checkVIPAccess();

        const vipBtn = document.getElementById('vip-importados-btn');
        vipBtn?.addEventListener('click', () => {
            window.dispatchEvent(new CustomEvent('vademecum:open-importados-modal'));
        });

        if (!session) {
            // Si no hay sesión, asegurar que el modal sea visible y detener carga
            if (authModal) {
                authModal.classList.remove('hidden', 'opacity-0');
                document.body.style.overflow = 'hidden';
            }
            return;
        }

        // Si hay sesión, ocultar modal e inicializar datos
        if (authModal) authModal.classList.add('hidden');
        await initVademecum();
    });

    // Escuchar el evento de login exitoso para arrancar el Vademécum
    document.addEventListener('mhSessionUpdated', () => {
        checkVIPAccess();
        initVademecum();
    });

    async function initVademecum() {
        const counter = document.getElementById('results-counter');

        try {
            // 0. CARGA POSOLOGÍAS (Para inyección contextual)
            try {
                _allPosologias = await getVademecumPosologia();
                setStandardPosologiaMap(_allPosologias);
            } catch (err) {
                console.error("Error al cargar posologías estándar:", err);
            }

            // 0.5. CARGA PRINCIPIOS ACTIVOS
            try {
                _allPrincipios = await getVademecumPrincipios();
            } catch (err) {
                console.error("Error al cargar principios activos:", err);
            }

            // 1. CARGA MAESTRO (Prioridad Alta + Metadatos)
            const { medicines, metadata } = await getVademecumMaestro();
            
            _allMeds = medicines.sort((a, b) => a.name.localeCompare(b.name));

            // Renderizar la barra del abecedario
            renderAlphabetBar();

            // Hidratar filtros de productos (Terapias y Formas)
            renderSidebarFilters(metadata);

            // 1.5. Habilitar Salto Maestro
            import('../utils/vademecum-renderer').then(m => {
                m.setProductJumpMap(_allMeds);
                m.setStandardPosologiaMap(_allPosologias);
            });

            // 2. INICIALIZAR LISTENERS DE UI (Delegación de eventos)
            initUIListeners();
            
            // 3. PRIMER RENDER (Catálogo Maestro)
            applyFiltersAndRender();

            // 4. CARGA PROTOCOLOS (Segundo plano)
            getVademecumProtocolos().then(protocols => {
                _allProtocols = protocols.sort((a, b) => a.name.localeCompare(b.name));
                
                // Extraer sistemas únicos de los protocolos para el sidebar
                const sistemas = [...new Set(_allProtocols.map(p => p.system))].filter(Boolean).sort();
                renderSidebarFilters({ sistemas });

                if (_currentView === 'protocols') applyFiltersAndRender();
            }).catch(err => console.error("Error cargando protocolos:", err));

        } catch (error) {
            console.error("Vademecum Initialization Error:", error);
            if (counter) counter.innerText = "Error cargando datos profesional.";
        }
    }

    // --- MOTOR DE HIDRATACIÓN DINÁMICA ---

    function renderAlphabetBar() {
        const container = document.getElementById('alphabet-filter-container');
        if (!container) return;

        // Calcular qué letras tienen elementos reales en los datos (según vista activa)
        const sourceList = _currentView === 'products' ? _allMeds : _allProtocols;
        const activeLetters = new Set(
            sourceList.map(item => {
                const char = item.name.trim().charAt(0).normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                return char;
            })
        );

        let html = `
            <button 
                class="alphabet-letter-btn ${!_selectedLetter ? 'is-active bg-brand text-white border-brand font-black' : 'bg-white text-slate-700 hover:bg-slate-50 border-subtle font-bold'} text-[12px] px-3.5 py-1.5 rounded-xl transition-all border active:scale-95 cursor-pointer shadow-sm" 
                data-letter="all"
            >
                Todos
            </button>
        `;

        ALPHABET.forEach(letter => {
            const hasMeds = activeLetters.has(letter);
            const isSelected = _selectedLetter === letter;
            
            if (hasMeds) {
                html += `
                    <button 
                        class="alphabet-letter-btn ${isSelected ? 'is-active bg-brand text-white border-brand font-black' : 'bg-white text-slate-700 hover:bg-slate-50 border-subtle font-bold'} text-[12px] w-8 h-8 rounded-xl transition-all border active:scale-95 flex items-center justify-center cursor-pointer shadow-sm" 
                        data-letter="${letter}"
                    >
                        ${letter}
                    </button>
                `;
            } else {
                html += `
                    <button 
                        class="text-[12px] w-8 h-8 rounded-xl font-bold border border-slate-100 bg-slate-50/50 text-slate-300 flex items-center justify-center cursor-not-allowed select-none" 
                        disabled
                    >
                        ${letter}
                    </button>
                `;
            }
        });

        container.innerHTML = html;

        // Listeners de clics para letras
        container.querySelectorAll('.alphabet-letter-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const target = e.currentTarget as HTMLElement;
                const letter = target.dataset.letter;
                
                _selectedLetter = letter === 'all' ? null : letter;
                _currentPage = 1;
                
                renderAlphabetBar();
                applyFiltersAndRender();
            });
        });
    }

    function getBaseForm(presentation: string, baseForms: string[]): string {
        const cleanPres = presentation.trim().toLowerCase().replace(/\*$/, '');
        // Ordenar formas base de mayor a menor longitud para evitar coincidencias parciales erróneas
        const sortedBases = [...baseForms].sort((a, b) => b.length - a.length);
        for (const base of sortedBases) {
            const cleanBase = base.toLowerCase().trim();
            if (cleanPres.startsWith(cleanBase) || cleanPres.includes(cleanBase)) {
                return base;
            }
        }
        // Fallback: capitalizar primera palabra
        const firstWord = presentation.split(/[\s:x]/)[0].trim().replace(/\*$/, '');
        return firstWord.charAt(0).toUpperCase() + firstWord.slice(1).toLowerCase();
    }

    function renderSidebarFilters(metadata: any) {
        if (metadata.terapias) {
            const container = document.getElementById('filter-terapia-list');
            if (container) container.innerHTML = metadata.terapias.map((t: string) => createFilterMarkup('terapia', t, 'accent-violet-600')).join('');
        }
        if (metadata.formas) {
            const container = document.getElementById('filter-forma-list');
            if (container) {
                const baseFormsList = _allPosologias.map(p => p.forma_farmaceutica.trim());
                const cleanFormas = [...new Set(metadata.formas.map((f: string) => getBaseForm(f, baseFormsList)))].sort();
                container.innerHTML = cleanFormas.map((f: string) => createFilterMarkup('forma', f, 'accent-orange-500')).join('');
            }
        }
        if (metadata.sistemas) {
            const container = document.getElementById('filter-sistema-list');
            if (container) container.innerHTML = metadata.sistemas.map((s: string) => createFilterMarkup('sistema', s, 'accent-violet-600')).join('');
        }
    }

    function createFilterMarkup(group: string, value: string, accentClass: string) {
        return `
            <label class="sidebar-filter-label group">
                <input 
                    type="checkbox" 
                    class="vademecum-filter sidebar-filter-checkbox ${accentClass}"
                    data-filter-group="${group}"
                    data-filter-value="${value}"
                />
                <span class="group-hover:text-slate-900 transition-colors">${value}</span>
            </label>
        `;
    }

    function applyFiltersAndRender() {
        const activeFilters = _currentView === 'products' ? _filtersProducts : _filtersProtocols;
        const searchTerm = activeFilters.search.toLowerCase();
        
        const source = _currentView === 'products' ? _allMeds : _allProtocols;

        let filtered = source.filter(item => {
            const itemNorm = item.name.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
            const searchNorm = searchTerm.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
            
            let matchesSearch = !searchTerm || itemNorm.includes(searchNorm);
            if (!matchesSearch && _currentView === 'products' && item.activeIngredients) {
                const compNorm = item.activeIngredients.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
                matchesSearch = compNorm.includes(searchNorm);
            }
            
            if (_currentView === 'products') {
                const f = _filtersProducts as any;
                const matchesTerapia = f.terapias.length === 0 || f.terapias.includes(item.category);
                
                const baseFormsList = _allPosologias.map(p => p.forma_farmaceutica.trim());
                const itemFormasRaw = (item.presentations || '').split(';').map((p: string) => p.trim().replace(/\*$/, ''));
                const itemFormasBase = itemFormasRaw.map((p: string) => getBaseForm(p, baseFormsList));
                const matchesForma = f.formas.length === 0 || f.formas.some((selectedForma: string) => itemFormasBase.includes(selectedForma));
                
                const matchesSistema = _filterSistemas.length === 0 || (item.tags?.sistema || []).some((s: string) => _filterSistemas.includes(s));
                
                // Normalizar primera letra del nombre para soportar tildes
                const firstChar = item.name.trim().charAt(0).normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                const matchesLetter = !_selectedLetter || firstChar === _selectedLetter;
                
                return matchesSearch && matchesTerapia && matchesForma && matchesSistema && matchesLetter;
            } else {
                const matchesSistema = _filterSistemas.length === 0 || _filterSistemas.includes(item.system);
                
                // Normalizar primera letra del nombre para soportar tildes
                const firstChar = item.name.trim().charAt(0).normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                const matchesLetter = !_selectedLetter || firstChar === _selectedLetter;
                
                return matchesSearch && matchesSistema && matchesLetter;
            }
        });

        // 🛡️ Prevenir Callejón sin Salida:
        // Si hay una búsqueda de texto activa, pero el listado da 0 resultados,
        // evaluamos si quitando la búsqueda de texto SÍ habría resultados con los filtros actuales de sidebar/abecedario.
        if (filtered.length === 0 && searchTerm) {
            const wouldHaveResults = source.some(item => {
                if (_currentView === 'products') {
                    const f = _filtersProducts as any;
                    const matchesTerapia = f.terapias.length === 0 || f.terapias.includes(item.category);
                    const baseFormsList = _allPosologias.map(p => p.forma_farmaceutica.trim());
                    const itemFormasRaw = (item.presentations || '').split(';').map((p: string) => p.trim().replace(/\*$/, ''));
                    const itemFormasBase = itemFormasRaw.map((p: string) => getBaseForm(p, baseFormsList));
                    const matchesForma = f.formas.length === 0 || f.formas.some((selectedForma: string) => itemFormasBase.includes(selectedForma));
                    const matchesSistema = _filterSistemas.length === 0 || (item.tags?.sistema || []).some((s: string) => _filterSistemas.includes(s));
                    const firstChar = item.name.trim().charAt(0).normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                    const matchesLetter = !_selectedLetter || firstChar === _selectedLetter;
                    return matchesTerapia && matchesForma && matchesSistema && matchesLetter;
                } else {
                    const matchesSistema = _filterSistemas.length === 0 || _filterSistemas.includes(item.system);
                    const firstChar = item.name.trim().charAt(0).normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                    const matchesLetter = !_selectedLetter || firstChar === _selectedLetter;
                    return matchesSistema && matchesLetter;
                }
            });

            if (wouldHaveResults) {
                // Limpiamos la búsqueda de texto para mostrar las tarjetas filtradas por sidebar
                activeFilters.search = '';
                const searchInput = document.getElementById('vademecum-search') as HTMLInputElement;
                if (searchInput) searchInput.value = '';
                
                // Volver a calcular filtrado fresco sin search
                filtered = source.filter(item => {
                    if (_currentView === 'products') {
                        const f = _filtersProducts as any;
                        const matchesTerapia = f.terapias.length === 0 || f.terapias.includes(item.category);
                        const baseFormsList = _allPosologias.map(p => p.forma_farmaceutica.trim());
                        const itemFormasRaw = (item.presentations || '').split(';').map((p: string) => p.trim().replace(/\*$/, ''));
                        const itemFormasBase = itemFormasRaw.map((p: string) => getBaseForm(p, baseFormsList));
                        const matchesForma = f.formas.length === 0 || f.formas.some((selectedForma: string) => itemFormasBase.includes(selectedForma));
                        const matchesSistema = _filterSistemas.length === 0 || (item.tags?.sistema || []).some((s: string) => _filterSistemas.includes(s));
                        const firstChar = item.name.trim().charAt(0).normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                        const matchesLetter = !_selectedLetter || firstChar === _selectedLetter;
                        return matchesTerapia && matchesForma && matchesSistema && matchesLetter;
                    } else {
                        const matchesSistema = _filterSistemas.length === 0 || _filterSistemas.includes(item.system);
                        const firstChar = item.name.trim().charAt(0).normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
                        const matchesLetter = !_selectedLetter || firstChar === _selectedLetter;
                        return matchesSistema && matchesLetter;
                    }
                });
            }
        }

        renderList(filtered);
    }

    function syncFilterUI() {
        const f = (_currentView === 'products' ? _filtersProducts : _filtersProtocols) as any;
        
        // Sincronizar Buscador
        const searchInput = document.getElementById('vademecum-search') as HTMLInputElement;
        if (searchInput) searchInput.value = f.search || '';

        // Sincronizar Checkboxes
        document.querySelectorAll('.vademecum-filter').forEach(checkbox => {
            const cb = checkbox as HTMLInputElement;
            const group = cb.getAttribute('data-filter-group') as string;
            const value = cb.getAttribute('data-filter-value') as string;
            
            if (group === 'sistema') {
                cb.checked = _filterSistemas.includes(value);
            } else {
                const activeList = (f as any)[group + 's'] || []; // terapias, formas
                cb.checked = activeList.includes(value);
            }
        });
    }

    function renderList(items: any[]) {
        const medsContainer = document.getElementById('meds-container');
        const protocolsContainer = document.getElementById('protocols-container');
        const emptyState = document.getElementById('empty-state');
        const counter = document.getElementById('results-counter');
        const nav = document.getElementById('pagination-nav');

        const totalItems = items.length;
        const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
        _currentPage = Math.min(_currentPage, totalPages || 1);

        const start = (_currentPage - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;
        const pageItems = items.slice(start, end);

        // Limpiar y Renderizar
        if (_currentView === 'products' && medsContainer) {
            medsContainer.innerHTML = pageItems.map(item => createMedicalCard(item)).join('');
            medsContainer.classList.remove('hidden');
            if (protocolsContainer) protocolsContainer.classList.add('hidden');
        } else if (protocolsContainer) {
            protocolsContainer.innerHTML = pageItems.map(item => createProtocolCard(item)).join('');
            protocolsContainer.classList.remove('hidden');
            if (medsContainer) medsContainer.classList.add('hidden');
        }

        // Actualizar UI
        if (counter) counter.innerText = `${totalItems} ${_currentView === 'products' ? 'medicamentos' : 'protocolos'} encontrados`;
        if (emptyState) emptyState.classList.toggle('hidden', totalItems > 0);
        if (nav) nav.style.display = totalItems > 0 ? 'flex' : 'none';

        // Mostrar u ocultar el botón global de limpiar filtros de forma condicional
        const globalClearBtn = document.getElementById('global-clear-filters-btn');
        if (globalClearBtn) {
            const hasActiveFilters = 
                (_currentView === 'products' && (
                    _filtersProducts.search || 
                    _filtersProducts.terapias.length > 0 || 
                    _filtersProducts.formas.length > 0
                )) ||
                (_currentView === 'protocols' && (
                    _filtersProtocols.search
                )) ||
                _filterSistemas.length > 0 ||
                _selectedLetter !== null;
            
            if (hasActiveFilters) {
                globalClearBtn.classList.remove('hidden');
                globalClearBtn.classList.add('inline-flex');
            } else {
                globalClearBtn.classList.add('hidden');
                globalClearBtn.classList.remove('inline-flex');
            }
        }

        renderPaginationControls(totalPages);

        // Fase 4: Restaurar clase is-selected visualmente si el ítem seleccionado está en esta página
        const activeSelectionId = _currentView === 'products' ? _selectedMed?.id : _selectedProtocol?.id;
        if (activeSelectionId) {
            const attr = _currentView === 'products' ? 'data-medicine-id' : 'data-protocol-id';
            const selectedCard = document.querySelector(`[${attr}="${activeSelectionId}"] .medical-card`);
            if (selectedCard) selectedCard.classList.add('is-selected');
        }

        // Paso 2: Verificar si estamos en modo fantasma (seleccionado pero oculto)
        checkGhostState();
    }

    function checkGhostState() {
        const activeSelectionId = _currentView === 'products' ? _selectedMed?.id : _selectedProtocol?.id;
        
        // Si no hay nada seleccionado, no hay modo fantasma
        if (!activeSelectionId) {
            window.dispatchEvent(new CustomEvent('vademecum:ghost-mode', { detail: { isGhost: false } }));
            return;
        }

        const attr = _currentView === 'products' ? 'data-medicine-id' : 'data-protocol-id';
        const isVisible = !!document.querySelector(`[${attr}="${activeSelectionId}"]`);
        
        window.dispatchEvent(new CustomEvent('vademecum:ghost-mode', { detail: { isGhost: !isVisible } }));
    }

    function renderPaginationControls(totalPages: number) {
        const ctrl = document.getElementById('pagination-controls');
        const info = document.getElementById('pagination-info');
        if (!ctrl || !info) return;

        info.innerText = `Página ${_currentPage} de ${totalPages}`;
        ctrl.innerHTML = '';

        if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= _currentPage - 1 && i <= _currentPage + 1)) {
                const btn = document.createElement('button');
                btn.className = `px-3 py-1 rounded-md text-sm font-medium transition-all ${_currentPage === i ? 'bg-brand text-white' : 'bg-white text-slate-600 hover:bg-slate-100'}`;
                btn.innerText = i.toString();
                btn.onclick = () => { _currentPage = i; applyFiltersAndRender(); window.scrollTo({top: 0, behavior: 'smooth'}); };
                ctrl.appendChild(btn);
            } else if (i === _currentPage - 2 || i === _currentPage + 2) {
                const dot = document.createElement('span');
                dot.innerText = '...';
                dot.className = 'text-slate-400 px-1';
                ctrl.appendChild(dot);
            }
        }
    }

    function initUIListeners() {
        const searchInput = document.getElementById('vademecum-search') as HTMLInputElement;
        const clearBtn = document.getElementById('clear-filters-btn');
        const sidebar = document.querySelector('aside');

        // Búsqueda Predictiva y Filtrado
        const searchDropdown = document.getElementById('vademecum-search-dropdown');

        const toggleDropdown = (show: boolean) => {
            if (searchDropdown) {
                if (show) searchDropdown.classList.remove('hidden');
                else searchDropdown.classList.add('hidden');
            }
        };

        const updateSearchFocus = (elements: NodeListOf<Element>) => {
            elements.forEach((el, idx) => {
                if (idx === searchFocusIndex) {
                    el.classList.add('is-focused');
                    el.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                } else {
                    el.classList.remove('is-focused');
                }
            });
        };

        const selectFromDropdown = (id: string, type: 'medicine' | 'protocol') => {
            if (type === 'medicine') {
                const medicine = _allMeds.find(m => m.id === id);
                if (medicine) {
                    _selectedMed = medicine;
                    if (searchInput) searchInput.value = medicine.name;
                    _filtersProducts.search = medicine.name;
                    _selectedLetter = null;
                    _currentPage = 1;
                    
                    applyFiltersAndRender();
                    renderAlphabetBar();
                    
                    window.dispatchEvent(new CustomEvent('vademecum:select-item', { 
                        detail: { item: medicine, type: 'medicine' } 
                    }));
                    checkGhostState();
                    
                    setTimeout(() => {
                        const cardEl = document.querySelector(`[data-medicine-id="${id}"]`);
                        if (cardEl) {
                            cardEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            const card = cardEl.querySelector('.medical-card');
                            if (card) {
                                card.classList.add('is-selected');
                                card.classList.add('highlight-row');
                                setTimeout(() => card.classList.remove('highlight-row'), 2000);
                            }
                        }
                    }, 150);
                }
            } else {
                const protocol = _allProtocols.find(p => p.id === id);
                if (protocol) {
                    _selectedProtocol = protocol;
                    if (searchInput) searchInput.value = protocol.name;
                    _filtersProtocols.search = protocol.name;
                    _currentPage = 1;
                    
                    applyFiltersAndRender();
                    
                    window.dispatchEvent(new CustomEvent('vademecum:select-item', { 
                        detail: { item: protocol, type: 'protocol' } 
                    }));
                    checkGhostState();
                    
                    setTimeout(() => {
                        const cardEl = document.querySelector(`[data-protocol-id="${id}"]`);
                        if (cardEl) {
                            cardEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            const card = cardEl.querySelector('.medical-card');
                            if (card) {
                                card.classList.add('is-selected');
                                card.classList.add('highlight-row');
                                setTimeout(() => card.classList.remove('highlight-row'), 2000);
                            }
                        }
                    }, 150);
                }
            }
            toggleDropdown(false);
        };

        const updateSearchDropdown = (items: any[], query: string, forceExpand: boolean | null = null) => {
            if (!searchDropdown) return;

            if (items !== null && query !== null) {
                lastSearchItems = items;
                lastSearchQuery = query;
                if (forceExpand === null) {
                    isSearchExpanded = false;
                    searchFocusIndex = -1;
                }
            } else {
                items = lastSearchItems;
                query = lastSearchQuery;
            }

            if (forceExpand !== null) isSearchExpanded = forceExpand;

            const initialLimit = 6;
            const limit = isSearchExpanded ? 1000 : initialLimit;
            const shown = (items || []).slice(0, limit);

            if (shown.length === 0 || !query) {
                toggleDropdown(false);
                return;
            }

            const escapeHtml = (text: string) => {
                return text
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            };

            let html = `
                <div class="p-2.5 border-b border-slate-100 text-[10px] text-slate-400 font-bold tracking-wider flex justify-between bg-slate-50/80 sticky top-0 z-10 backdrop-blur-sm">
                    <span>RESULTADOS (${items.length})</span>
                    <span class="hidden sm:block">Navega con ↑↓ Enter</span>
                </div>
                <div class="search-results-list">
            `;

            html += shown.map((item, index) => {
                const qNorm = query.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
                const iNorm = item.name.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
                
                let highlightedName = escapeHtml(item.name);
                const matchIdx = iNorm.indexOf(qNorm);
                
                if (matchIdx !== -1 && qNorm.length > 0) {
                    const originalText = item.name.substring(matchIdx, matchIdx + query.length);
                    highlightedName = escapeHtml(item.name.substring(0, matchIdx)) +
                        `<span class="search-highlight">${escapeHtml(originalText)}</span>` +
                        escapeHtml(item.name.substring(matchIdx + query.length));
                }

                // Mostrar categoría o sistema
                const categoryLabel = _currentView === 'products' ? item.linea : item.system;
                const focusClass = (index === searchFocusIndex) ? 'is-focused' : '';

                return `
                    <div class="search-result-item ${focusClass} js-search-item" data-row-id="${item.id}" data-index="${index}">
                        <div class="text-[12px] font-bold text-slate-700 leading-tight">${highlightedName}</div>
                        <div class="text-[10px] text-brand font-medium truncate mt-0.5">${categoryLabel || 'Medicina General'}</div>
                    </div>
                `;
            }).join('');

            html += `</div>`;

            if (items.length > initialLimit) {
                const toggleLabel = isSearchExpanded
                    ? 'Ver menos'
                    : `Ver ${items.length - initialLimit} más...`;
                
                html += `
                    <div class="sticky bottom-0 z-10 p-2.5 text-[11px] text-center text-brand font-bold bg-white cursor-pointer hover:bg-emerald-50 transition-all border-t border-slate-100 js-search-toggle-more">
                        ${toggleLabel}
                    </div>
                `;
            }

            searchDropdown.innerHTML = html;
            toggleDropdown(true);

            // Listeners para clics en los items del dropdown
            searchDropdown.querySelectorAll('.js-search-item').forEach(el => {
                el.addEventListener('click', () => {
                    const id = el.getAttribute('data-row-id');
                    if (id) selectFromDropdown(id, _currentView === 'products' ? 'medicine' : 'protocol');
                });
            });

            const toggleBtn = searchDropdown.querySelector('.js-search-toggle-more');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    updateSearchDropdown(null as any, null as any, !isSearchExpanded);
                });
            }
        };

        searchInput?.addEventListener('input', () => {
            const f = (_currentView === 'products' ? _filtersProducts : _filtersProtocols) as any;
            const rawValue = searchInput.value;
            f.search = sanitizeInput(rawValue);
            _currentPage = 1;
            applyFiltersAndRender();

            const query = rawValue.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
            if (!query) {
                toggleDropdown(false);
                return;
            }

            // Filtrar en memoria para el dropdown predictivo
            if (_currentView === 'products') {
                const matches = _allMeds.filter(m => {
                    const clean = (val: string) => (val || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
                    const searchTerms = `${clean(m.name)} ${clean(m.indications)} ${clean(m.activeIngredients)} ${clean(m.linea)}`;
                    return searchTerms.includes(query);
                });
                updateSearchDropdown(matches, query);
            } else {
                const matches = _allProtocols.filter(p => {
                    const clean = (val: string) => (val || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
                    const searchTerms = `${clean(p.name)} ${clean(p.description)} ${clean(p.complementary)} ${clean(p.oligoelementos)} ${clean(p.topicos)} ${clean(p.emotionalSupport)} ${clean(p.system)}`;
                    return searchTerms.includes(query);
                });
                updateSearchDropdown(matches, query);
            }
        });

        searchInput?.addEventListener('keydown', (e) => {
            if (!searchDropdown || searchDropdown.classList.contains('hidden')) return;

            const itemsEls = searchDropdown.querySelectorAll('.js-search-item');
            if (itemsEls.length === 0) return;

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                searchFocusIndex = (searchFocusIndex + 1) % itemsEls.length;
                updateSearchFocus(itemsEls);
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                searchFocusIndex = (searchFocusIndex - 1 + itemsEls.length) % itemsEls.length;
                updateSearchFocus(itemsEls);
            } else if (e.key === 'Enter') {
                if (searchFocusIndex >= 0) {
                    e.preventDefault();
                    const selectedEl = itemsEls[searchFocusIndex];
                    const id = selectedEl.getAttribute('data-row-id');
                    if (id) selectFromDropdown(id, _currentView === 'products' ? 'medicine' : 'protocol');
                }
            } else if (e.key === 'Escape') {
                toggleDropdown(false);
            }
        });

        // Cerrar dropdown si se hace click fuera
        document.addEventListener('click', (e) => {
            if (searchDropdown && !searchDropdown.classList.contains('hidden')) {
                const target = e.target as HTMLElement;
                if (!target.closest('#vademecum-search') && !target.closest('#vademecum-search-dropdown')) {
                    toggleDropdown(false);
                }
            }
        });

        // Delegación de eventos para filtros dinámicos
        sidebar?.addEventListener('change', (e) => {
            const target = e.target as HTMLInputElement;
            if (target.classList.contains('vademecum-filter')) {
                const groupAttr = target.getAttribute('data-filter-group') as string;
                const value = target.getAttribute('data-filter-value') as string;
                
                if (groupAttr === 'sistema') {
                    // Fase 3: Actualizar filtro compartido
                    if (target.checked) {
                        if (!_filterSistemas.includes(value)) _filterSistemas.push(value);
                    } else {
                        _filterSistemas = _filterSistemas.filter(v => v !== value);
                    }
                } else {
                    // Fase 2: Actualizar filtros por vista
                    const f = (_currentView === 'products' ? _filtersProducts : _filtersProtocols) as any;
                    const group = groupAttr + 's';
                    if (target.checked) {
                        if (!f[group].includes(value)) f[group].push(value);
                    } else {
                        f[group] = f[group].filter((v: string) => v !== value);
                    }
                }

                _currentPage = 1;
                applyFiltersAndRender();
            }
        });

        clearBtn?.addEventListener('click', () => {
            const f = (_currentView === 'products' ? _filtersProducts : _filtersProtocols) as any;
            f.search = '';
            if (f.terapias) f.terapias = [];
            if (f.formas) f.formas = [];
            
            // Fase 3: Limpiar sistemas también
            _filterSistemas = [];
            _selectedLetter = null;

            syncFilterUI();
            renderAlphabetBar();
            _currentPage = 1;
            applyFiltersAndRender();
        });

        // Botón condicional de Quitar Filtros al lado del contador
        const globalClearBtn = document.getElementById('global-clear-filters-btn');
        globalClearBtn?.addEventListener('click', () => {
            _filtersProducts = { search: '', terapias: [], formas: [] };
            _filtersProtocols = { search: '' };
            _filterSistemas = [];
            _selectedLetter = null;
            
            // Limpiar buscador visual
            const searchInput = document.getElementById('vademecum-search') as HTMLInputElement;
            if (searchInput) searchInput.value = '';

            syncFilterUI();
            renderAlphabetBar();
            _currentPage = 1;
            applyFiltersAndRender();
        });

        // Switcher de Vistas
        window.addEventListener('vademecum:view-change', (e: any) => {
            _currentView = e.detail.view;
            _currentPage = 1;
            
            _selectedLetter = null;
            renderAlphabetBar();
            
            // Actualizar Sidebar visibility
            document.querySelectorAll('.sidebar-filter-section').forEach(section => {
                const target = section.getAttribute('data-view-target');
                if (target !== 'both') section.classList.toggle('hidden', target !== _currentView);
            });

            // Fase 1 & 4: Restaurar o limpiar la Columna 3 según la selección guardada de esta vista
            const savedSelection = _currentView === 'products' ? _selectedMed : _selectedProtocol;
            if (savedSelection) {
                window.dispatchEvent(new CustomEvent('vademecum:select-item', { 
                    detail: { item: savedSelection, type: _currentView === 'products' ? 'medicine' : 'protocol' } 
                }));
            } else {
                window.dispatchEvent(new CustomEvent('vademecum:clear-sheet'));
            }

            // Fase 2: Sincronizar UI de filtros con el estado de la nueva vista
            syncFilterUI();
            applyFiltersAndRender();
        });

        // Click en Tarjetas (Delegación de eventos)
        document.getElementById('meds-container')?.addEventListener('click', (e) => {
            const item = (e.target as HTMLElement).closest('[data-medicine-id]');
            if (item) {
                document.querySelectorAll('.medical-card').forEach(c => c.classList.remove('is-selected'));
                const card = item.querySelector('.medical-card');
                if (card) card.classList.add('is-selected');

                const id = item.getAttribute('data-medicine-id');
                const medicine = _allMeds.find(m => m.id === id);
                if (medicine) {
                    _selectedMed = medicine; // Fase 1: guardar selección
                    dispatchEvent(new CustomEvent('vademecum:select-item', { detail: { item: medicine, type: 'medicine' } }));
                    checkGhostState();
                }
            }
        });

        document.getElementById('protocols-container')?.addEventListener('click', (e) => {
            const item = (e.target as HTMLElement).closest('[data-protocol-id]');
            if (item) {
                document.querySelectorAll('.medical-card').forEach(c => c.classList.remove('is-selected'));
                const card = item.querySelector('.medical-card');
                if (card) card.classList.add('is-selected');

                const id = item.getAttribute('data-protocol-id');
                const protocol = _allProtocols.find(p => p.id === id);
                if (protocol) {
                    _selectedProtocol = protocol; // Fase 1: guardar selección
                    dispatchEvent(new CustomEvent('vademecum:select-item', { detail: { item: protocol, type: 'protocol' } }));
                    checkGhostState();
                }
            }
        });

        // MANEJADOR DE SALTO MAESTRO (Solicitud desde detalles)
        window.addEventListener('vademecum:request-jump', (e: any) => {
            const id = e.detail.id;
            const medicine = _allMeds.find(m => m.id === id);
            if (medicine) {
                // Forzar vista de productos si estamos en protocolos
                if (_currentView !== 'products') {
                    _currentView = 'products';
                    applyFiltersAndRender();
                }
                // Disparar selección
                window.dispatchEvent(new CustomEvent('vademecum:select-item', { 
                    detail: { item: medicine, type: 'medicine' } 
                }));
                checkGhostState();
            }
        });

        // MANEJADOR DE BÚSQUEDA POR COMPOSICIÓN (Principios Activos)
        window.addEventListener('vademecum:request-composition-search', (e: any) => {
            let query = e.detail.query || '';
            
            // Limpiar potencias/diluciones comunes para buscar el compuesto base (ej: "Acidum citricum D8" -> "Acidum citricum")
            let cleanQuery = query.replace(/\b(D\d+|CH\d+|\d+CH|\d+D|\d+ch|d\d+|CH|D)\b/gi, '').trim();
            if (cleanQuery.length < 3) cleanQuery = query;

            // Forzar vista de productos si estamos en protocolos
            if (_currentView !== 'products') {
                _currentView = 'products';
                window.dispatchEvent(new CustomEvent('vademecum:view-change', { detail: { view: 'products' } }));
            }

            // Cambiar el buscador central
            if (searchInput) {
                searchInput.value = cleanQuery;
            }
            
            _filtersProducts.search = cleanQuery;
            _selectedLetter = null; // Limpiar filtro A-Z
            _currentPage = 1;

            // Limpiar otros filtros para que no restrinjan
            _filtersProducts.terapias = [];
            _filtersProducts.formas = [];
            _filterSistemas = [];
            
            syncFilterUI();
            renderAlphabetBar();
            applyFiltersAndRender();
        });

        // Escuchar solicitud para abrir modal de posologías
        window.addEventListener('vademecum:request-posologia-modal', () => {
            window.dispatchEvent(new CustomEvent('vademecum:open-posologia-modal', {
                detail: { posologia: _allPosologias }
            }));
        });

        // Escuchar solicitud para abrir modal de principios activos
        window.addEventListener('vademecum:request-principios-modal', async () => {
            if (!_allPrincipios || _allPrincipios.length === 0) {
                try {
                    _allPrincipios = await getVademecumPrincipios();
                } catch (err) {
                    console.error("Error al recargar principios activos en caliente:", err);
                }
            }
            window.dispatchEvent(new CustomEvent('vademecum:open-principios-modal', {
                detail: { principios: _allPrincipios }
            }));
        });
    }
</script>

