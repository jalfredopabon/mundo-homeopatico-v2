                icon: 'test-tube',
                content: '<span class="font-bold text-body">Tropismo principal:</span> Sistema Muscular, Capilares sanguíneos y Tejido Celular.'
            }
        ]
    },
    {
        id: 'ignatia-amara',
        name: 'Ignatia amara',
        potency: 'D12',
        scientificName: 'Strychnos ignatii',
        origin: 'Origen vegetal',
