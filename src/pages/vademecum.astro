---
import BaseLayout from '../layouts/BaseLayout.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
---

<BaseLayout title="Vademécum Clínico | Mundo Homeopático" mostrarZoom={false}>
    
    <!-- Carrito Lateral (Drawer) -->
    <CartDrawer />

    <!-- Modal de Autenticación (Capa sobre todo el Dashboard) -->
    <div id="auth-modal-overlay" class="fixed inset-0 z-[100] bg-slate-900/60 backdrop-blur-sm flex items-center justify-center transition-opacity duration-300">
        
        <!-- Enlace invisible que cubre el fondo para cerrar el modal al hacer clic fuera -->
        <a href="/" class="absolute inset-0 z-0" aria-label="Cerrar y volver al inicio"></a>

        <div id="auth-modal" class="w-full max-w-[440px] mx-4 relative z-10">
            
            <!-- Tarjeta Principal del Modal -->
            <div class="bg-white/95 backdrop-blur-xl rounded-3xl border border-white/50 overflow-hidden relative">
                
                <!-- Botón de Cerrar (X) Superior Derecha (Alineado con el padding de px-8) -->
                <a href="/" class="absolute top-6 right-6 p-2 rounded-full text-slate-700 hover:text-slate-900 hover:bg-slate-100 transition-colors focus:outline-none focus:ring-1 focus:ring-brand z-20" aria-label="Cerrar modal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </a>

                <!-- Encabezado del Modal (Blanco puro Minimalista) -->
                <div class="px-8 pt-10 pb-4 text-left">
                    <h2 class="text-slate-900 text-[26px] font-extrabold tracking-tight mb-2">Acceso</h2>
                </div>

                <!-- Cuerpo del Formulario -->
                <div class="px-8 pb-10">
                    <form id="auth-form" class="space-y-4" novalidate>
                        
                        <!-- Campo NIT / Cédula -->
                        <div class="space-y-1.5">
                            <label for="auth-nit" class="text-[13px] font-bold text-slate-800">
                                Cédula o NIT
                            </label>
                            <div class="relative">
                                <input 
                                    type="text" 
                                    id="auth-nit" 
                                    placeholder="Ej: 1234567890"
                                    autocomplete="username"
                                    class="w-full px-4 py-3 border border-slate-200 rounded-xl text-[15px] text-slate-800 placeholder:text-slate-700 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all"
                                />
                            </div>
                        </div>

                        <!-- Campo Contraseña -->
                        <div class="space-y-1.5">
                            <label for="auth-password" class="text-[13px] font-bold text-slate-800">
                                Contraseña
                            </label>
                            <div class="relative">
                                <input 
                                    type="password" 
                                    id="auth-password"
                                    placeholder="••••••••••"
                                    autocomplete="current-password"
                                    class="w-full px-4 py-3 border border-slate-200 rounded-xl text-[15px] text-slate-800 placeholder:text-slate-700 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all pr-12 tracking-widest font-mono"
                                />
                                <!-- Botón para mostrar/ocultar contraseña -->
                                <button type="button" id="toggle-password" class="absolute right-3 top-1/2 -translate-y-1/2 p-1.5 rounded-lg text-slate-700 hover:text-slate-900 hover:bg-slate-100 transition-all" aria-label="Mostrar contraseña">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" id="icon-eye-open"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" id="icon-eye-closed" class="hidden"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>
                                </button>
                            </div>
                            <!-- Vía de escape (Proximidad) -->
                            <div class="flex justify-end pt-1">
                                <!-- TODO: Reemplazar el número '573000000000' por la línea WhatsApp de Atención al Cliente de la empresa -->
                                <a 
                                    href="https://wa.me/573000000000?text=Hola,%20Mundo%20Homeop%C3%A1tico.%20Soy%20profesional%20m%C3%A9dico%20y%20olvid%C3%A9%20mis%20credenciales%20de%20acceso%20al%20Vadem%C3%A9cum.%20%C2%BFPodr%C3%ADan%20asistirme?" 
                                    target="_blank" 
                                    rel="noopener noreferrer"
                                    class="text-[12px] font-medium text-secondary hover:text-brand hover:underline transition-all cursor-pointer"
                                >
                                    ¿Olvidó su contraseña?
                                </a>
                            </div>
                        </div>

                        <!-- Checkbox "Mantener sesión" -->
                        <div class="flex items-center pt-2 pb-1">
                            <label class="flex items-center gap-2.5 text-[13px] text-secondary cursor-pointer hover:text-slate-800 transition-colors">
                                <input type="checkbox" class="size-4 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                                Mantener sesión iniciada
                            </label>
                        </div>

                        <!-- Mensaje de Error -->
                        <div id="auth-error" class="hidden items-center gap-2.5 px-4 py-3 bg-red-50 border border-red-100 rounded-xl text-red-600 text-[13px] font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
                            <span id="auth-error-text">Credenciales incorrectas</span>
                        </div>

                        <!-- Botón de Ingreso Limpio -->
                        <button 
                            type="submit" 
                            id="auth-submit"
                            class="w-full flex items-center justify-center bg-brand-vibrant hover:bg-brand text-white font-semibold py-3.5 rounded-xl transition-all duration-200 hover:-translate-y-[1px] active:scale-[0.98] focus:ring-2 focus:ring-brand focus:ring-offset-2 text-[15px]"
                        >
                            Ingresar
                        </button>
                        
                    </form>
                </div>
            </div>

        </div>
    </div>

    <!-- Contenedor Principal Dashboard 3 Columnas -->
    <div class="flex flex-col md:flex-row w-full max-w-full mx-auto flex-1 h-[calc(100vh-4rem)] md:h-[calc(100vh-5rem)]">
        
        <!-- Columna Izquierda: Sidebar de Filtros (w-64 = Consistente con Catálogo y Contacto) -->
        <aside class="hidden md:flex flex-col w-64 border-r border-subtle bg-surface-white h-[calc(100vh-4rem)] md:h-[calc(100vh-5rem)] sticky top-16 md:top-20 overflow-y-auto shrink-0">
            <div class="p-6 space-y-7">

                <!-- Buscador de medicamentos -->
                <div class="flex flex-col">
                    <div class="relative group">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-700 group-focus-within:text-brand transition-colors">
                            <path d="M17 17L21 21" />
                            <path d="M19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19C15.4183 19 19 15.4183 19 11Z" />
                        </svg>
                        <input 
                            type="search" 
                            placeholder="Buscar..." 
                            class="w-full pl-9 pr-3 py-2 bg-surface-white border border-subtle rounded-lg text-sm text-body focus:outline-none focus:ring-1 focus:ring-brand focus:border-brand transition-all placeholder:text-slate-700/70"
                        />
                    </div>
                    <div class="mt-1.5 text-[10px] text-slate-700 font-medium pl-9">8 resultados</div>
</div>

                <section class="pl-3">
                    <h4 class="text-[11px] font-bold text-slate-900 mb-3.5 flex items-center gap-2.5">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-slate-900">
                            <path d="M9.06845 2H14.9316C15.8529 2 16.3135 2 16.5997 2.29289C17.1334 2.83907 17.1334 5.16093 16.5997 5.70711C16.3135 6 15.8529 6 14.9316 6H9.06845C8.14715 6 7.6865 6 7.40029 5.70711C6.86657 5.16093 6.86657 2.83907 7.40029 2.29289C7.6865 2 8.14715 2 9.06845 2Z" />
                            <path d="M8 6C8.16493 6.32986 8.24741 6.49481 8.30606 6.6557C8.61211 7.49515 8.52805 8.42732 8.07678 9.19848C7.99029 9.34628 7.87965 9.49381 7.65836 9.78885L7.25493 10.3268C6.80486 10.9269 6.57983 11.2269 6.41674 11.5556C6.252 11.8877 6.13421 12.241 6.06677 12.6055C6 12.9664 6 13.3414 6 14.0915V16C6 18.8284 6 20.2426 6.87868 21.1213C7.75736 22 9.17157 22 12 22C14.8284 22 16.2426 22 17.1213 21.1213C18 20.2426 18 18.8284 18 16V14.0915C18 13.3414 18 12.9664 17.9332 12.6055C17.8658 12.241 17.748 11.8877 17.5833 11.5556C17.4202 11.2269 17.1951 10.9269 16.7451 10.3268L16.3416 9.78885C16.1204 9.49381 16.0097 9.34628 15.9232 9.19848C15.4719 8.42732 15.3879 7.49515 15.6939 6.6557C15.7526 6.49481 15.8351 6.32987 16 6" />
                            <path d="M12 13V18M9.5 15.5L14.5 15.5" />
                        </svg>
                        Tipo de terapia
                    </h4>
                    <div class="space-y-2.5">
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Homeopatía compleja
                        </label>
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Terapia floral
                        </label>
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Oligoelementos
                        </label>
                    </div>
                </section>

                <section class="pl-3">
                    <h4 class="text-[11px] font-bold text-slate-900 mb-3.5 flex items-center gap-2.5">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-slate-900">
                            <path d="M2 12H6L7.5 8L9.5 15L13 6L15.5 18L18 12H22" />
                        </svg>
                        Sistema del cuerpo
                    </h4>
                    <div class="space-y-2.5">
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Digestivo
                        </label>
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Nervioso
                        </label>
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Cardiovascular
                        </label>
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Respiratorio
                        </label>
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Locomotor
                        </label>
                    </div>
                </section>

                <section class="pl-3">
                    <h4 class="text-[11px] font-bold text-slate-900 mb-3.5 flex items-center gap-2.5">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-slate-900">
                            <path d="M11.4497 19.5503L19.5503 11.4497C20.4785 10.5215 21 9.2625 21 7.94975C21 5.21608 18.7839 3 16.0503 3C14.7375 3 13.4785 3.52149 12.5503 4.44975L4.44975 12.5503C3.52149 13.4785 3 14.7375 3 16.0503C3 18.7839 5.21608 21 7.94975 21C9.2625 21 10.5215 20.4785 11.4497 19.5503Z" />
                            <path d="M8.5 8.5L15.5 15.5" />
                        </svg>
                        Forma farmacéutica
                    </h4>
                    <div class="space-y-2.5">
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Gotas
                        </label>
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Tabletas
                        </label>
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Spray
                        </label>
                        <label class="flex items-center gap-2.5 text-[13px] text-slate-700 cursor-pointer hover:text-slate-900 has-[:checked]:text-slate-900 transition-colors">
                            <input type="checkbox" class="size-3.5 rounded border-slate-300 accent-brand text-brand focus:ring-brand/20 cursor-pointer" />
                            Crema
                        </label>
                    </div>
                </section>

            </div>
        </aside>

        <!-- Columna Central: Grilla de Resultados (Scroll independiente) -->
        <div class="flex-1 overflow-y-auto w-full relative flex flex-col bg-surface-muted h-[calc(100vh-4rem)] md:h-[calc(100vh-5rem)] scroll-smooth" id="vademecum-main-scroll">
            <div class="px-8 md:px-16 pt-8 pb-24 flex-1">

                <!-- Encabezado del Vademécum -->
                <div class="flex items-end justify-between mb-8">
                    <div>
                        <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Vademécum clínico</h1>
                        <p class="text-[13px] text-slate-700 mt-1.5">Explore el catálogo de medicamentos homeopáticos de alta dilución.</p>
                    </div>
                    <div class="flex items-center gap-2 px-3 py-1.5 bg-surface-white border border-subtle rounded-lg text-[11px] font-semibold text-slate-700 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" color="currentColor" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700">
                            <path d="M6.5 2H17.5C18.4346 2 18.9019 2 19.25 2.20096C19.478 2.33261 19.6674 2.52197 19.799 2.75C20 3.09808 20 3.56538 20 4.5C20 5.43462 20 5.90192 19.799 6.25C19.6674 6.47803 19.478 6.66739 19.25 6.79904C18.9019 7 18.4346 7 17.5 7H6.5C5.56538 7 5.09808 7 4.75 6.79904C4.52197 6.66739 4.33261 6.47803 4.20096 6.25C4 5.90192 4 5.43462 4 4.5C4 3.56538 4 3.09808 4.20096 2.75C4.33261 2.52197 4.52197 2.33261 4.75 2.20096C5.09808 2 5.56538 2 6.5 2Z" />
                            <path d="M18 16V7H6V16C6 18.8284 6 20.2426 6.87868 21.1213C7.75736 22 9.17157 22 12 22C14.8284 22 16.2426 22 17.1213 21.1213C18 20.2426 18 18.8284 18 16Z" />
                            <path d="M6 11H10C10.9428 11 11.4142 11 11.7071 11.2929C12 11.5858 12 12.0572 12 13V15C12 15.9428 12 16.4142 11.7071 16.7071C11.4142 17 10.9428 17 10 17H6" />
                        </svg>
                        8 medicamentos
                    </div>
                </div>

                <!-- Listado de Tarjetas Clínicas -->
                <div class="space-y-3.5 max-w-3xl">

                    <!-- Card 1: Activa (Seleccionada) -->
                    <div class="bg-surface-white rounded-xl p-6 cursor-pointer border-l-[3px] border-y border-r border-brand border-y-brand/20 border-r-brand/20 transition-all" data-med="nux-vomica">
                        <div class="flex items-baseline gap-2.5 mb-2">
                            <h3 class="text-[16px] font-bold text-brand">Nux vomica</h3>
                            <span class="text-slate-700 text-xs font-medium">D4</span>
                        </div>
                        <p class="text-[13px] text-slate-700 leading-relaxed mb-4">
                            Coadyuvante en el tratamiento de dispepsias, flatulencia, estreñimiento espasmódico e irritabilidad vinculada al estilo de vida sedentario. Especialmente indicado para pacientes con temperamento colérico que sufren agravación matutina y después de las comidas.
                        </p>
                        <div class="flex items-center gap-3 flex-wrap">
                            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-emerald-700 bg-emerald-50 px-2.5 py-1 rounded-md border border-emerald-100">
                                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="none"><circle cx="12" cy="12" r="4"/></svg>
                                Digestivo
                            </span>
                            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-slate-50 px-2.5 py-1 rounded-md border border-slate-100">
                                Nervioso
                            </span>
                            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-slate-50 px-2.5 py-1 rounded-md border border-slate-100">
                                Gotas
                            </span>
                        </div>
                    </div>

                    <!-- Card 2: Inactiva -->
                    <div class="bg-surface-white rounded-xl p-6 cursor-pointer border border-subtle transition-all hover:border-brand/30" data-med="arnica-montana">
                        <div class="flex items-baseline gap-2.5 mb-2">
                             <h3 class="text-[16px] font-bold text-slate-900">Arnica montana</h3>
                            <span class="text-slate-700 text-xs font-medium">D6</span>
                        </div>
                        <p class="text-[13px] text-slate-700 leading-relaxed mb-4">
                            Tratamiento de traumatismos, contusiones y dolores musculares por sobreesfuerzo físico o trauma. Indicado en pre y post operatorio para reducir hematomas y acelerar la recuperación tisular.
                        </p>
                        <div class="flex items-center gap-3 flex-wrap">
                            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-slate-50 px-2.5 py-1 rounded-md border border-slate-100">
                                Locomotor
                            </span>
                            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-slate-50 px-2.5 py-1 rounded-md border border-slate-100">
                                Cardiovascular
                            </span>
                            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-slate-50 px-2.5 py-1 rounded-md border border-slate-100">
                                Gotas
                            </span>
                        </div>
                    </div>

                    <!-- Card 3: Inactiva -->
                    <div class="bg-surface-white rounded-xl p-6 cursor-pointer border border-subtle transition-all hover:border-brand/30" data-med="ignatia-amara">
                        <div class="flex items-baseline gap-2.5 mb-2">
                             <h3 class="text-[16px] font-bold text-slate-900">Ignatia amara</h3>
                             <span class="text-slate-700 text-xs font-medium">D12</span>
                        </div>
                        <p class="text-[13px] text-slate-700 leading-relaxed mb-4">
                            Trastornos emocionales, ansiedad con espasmos, labilidad afectiva y efectos de duelos recientes. Útil en pacientes con tendencia a la somatización de emociones y sensación de nudo en la garganta.
                        </p>
                        <div class="flex items-center gap-3 flex-wrap">
                            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-slate-50 px-2.5 py-1 rounded-md border border-slate-100">
                                Nervioso
                            </span>
                            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-slate-50 px-2.5 py-1 rounded-md border border-slate-100">
                                Gotas
                            </span>
                        </div>
                    </div>

                    <!-- Card 4: Inactiva -->
                    <div class="bg-surface-white rounded-xl p-6 cursor-pointer border border-subtle transition-all hover:border-brand/30" data-med="pulsatilla">
                        <div class="flex items-baseline gap-2.5 mb-2">
                             <h3 class="text-[16px] font-bold text-slate-900">Pulsatilla</h3>
                            <span class="text-slate-700 text-xs font-medium">D6</span>
                        </div>
                        <p class="text-[13px] text-slate-700 leading-relaxed mb-4">
                            Afecciones de mucosas con secreciones blandas, variabilidad de síntomas y timidez. Indicada en rinitis con secreción amarillo-verdosa, otitis media y trastornos digestivos con intolerancia a grasas.
                        </p>
                        <div class="flex items-center gap-3 flex-wrap">
                            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-slate-700 bg-slate-50 px-2.5 py-1 rounded-md border border-slate-100">
                                Respiratorio
                            </span>
