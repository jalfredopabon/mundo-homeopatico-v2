    {
        id: 'belladonna',
        name: 'Belladonna',
        potency: 'D4',
        scientificName: 'Atropa belladonna',
        origin: 'Origen vegetal',
        sections: [
            {
                title: 'Indicaciones clínicas',
                icon: 'list',
                content: 'Inflamaciones agudas, rubor, calor, dolor pulsátil. Frecuente en amigdalitis aguda, otitis derecha, fiebre elevada con sudoración térmica.'
            },
            {
