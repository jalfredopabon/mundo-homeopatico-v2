<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- 1. Sistema de Scroll Reveal ---
        const revealElements = document.querySelectorAll('.reveal');
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, observerOptions);

        revealElements.forEach(el => revealObserver.observe(el));

        // --- 2. Lógica de Autenticación (Temporal) ---
        const TEMP_USER = 'invitado';
        const TEMP_PASS = '1234';

        const overlay = document.getElementById('auth-modal-overlay');
        const form = document.getElementById('auth-form');
        const inputNit = document.getElementById('auth-nit') as HTMLInputElement | null;
        const inputPass = document.getElementById('auth-password') as HTMLInputElement | null;
        const errorBox = document.getElementById('auth-error');
        const errorText = document.getElementById('auth-error-text');
        const toggleBtn = document.getElementById('toggle-password');
        const iconOpen = document.getElementById('icon-eye-open');
        const iconClosed = document.getElementById('icon-eye-closed');

        form?.addEventListener('submit', (e) => {
            e.preventDefault();
            const user = inputNit?.value.trim();
            const pass = inputPass?.value;

            if (user === TEMP_USER && pass === TEMP_PASS) {
                overlay?.classList.add('opacity-0');
                setTimeout(() => overlay?.classList.add('hidden'), 300);
            } else {
                errorBox?.classList.remove('hidden');
                errorBox?.classList.add('flex');
                if (errorText) errorText.textContent = 'Credenciales incorrectas.';
                inputPass?.focus();
            }
        });

        toggleBtn?.addEventListener('click', () => {
            if (!inputPass) return;
            const isPassword = inputPass.type === 'password';
            inputPass.type = isPassword ? 'text' : 'password';
            iconOpen?.classList.toggle('hidden');
            iconClosed?.classList.toggle('hidden');
        });

        // --- 3. Lógica de navegación del Vademécum ---
        const medCards = document.querySelectorAll('[data-med]');
        const fichaNux = document.getElementById('ficha-nux-vomica');
        const fichaArnica = document.getElementById('ficha-arnica-montana');
        const vademecumAside = document.getElementById('vademecum-aside');

        medCards.forEach(card => {
            card.addEventListener('click', () => {
                // Actualizar tarjetas
                medCards.forEach(c => {
                    c.classList.remove('border-brand');
                    c.classList.add('border-subtle');
                    const h3 = c.querySelector('h3');
                    if (h3) { h3.classList.remove('text-brand'); h3.classList.add('text-slate-900'); }
                });
                
                card.classList.add('border-brand');
                const selectedH3 = card.querySelector('h3');
                if (selectedH3) { selectedH3.classList.remove('text-slate-900'); selectedH3.classList.add('text-brand'); }

                // Cambiar contenido
                const medType = card.getAttribute('data-med');
                if (medType === 'arnica-montana') {
                    fichaNux?.classList.add('hidden');
                    fichaArnica?.classList.remove('hidden');
                } else {
                    fichaArnica?.classList.add('hidden');
                    fichaNux?.classList.remove('hidden');
                }

                // Mostrar en móvil
                if (vademecumAside && window.innerWidth < 1024) {
                    vademecumAside.setAttribute('data-mobile-open', 'true');
                    document.body.style.overflow = 'hidden';
                }
            });
        });

        // Cerrar en móvil
        document.querySelectorAll('.close-ficha-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                if (vademecumAside) {
                    vademecumAside.setAttribute('data-mobile-open', 'false');
                    document.body.style.overflow = '';
                }
            });
        });
    });
</script>

