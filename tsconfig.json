{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    // Modo relajado
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "jsxImportSource": "react",
    "target": "ESNext",
    "moduleResolution": "node"
  }
}
